// 고정 크기 배열 [T; N] 스모크 테스트
g_tab: [i32; 4] = [7; 4]

struct Board {
    w: i32
    cells: [i32; 8]
    weights: [f64; 4]
}

fn board_sum(b: &Board) -> i64 {
    s = 0
    i = 0
    while i < 8 {
        s = s + b.cells[i]
        i = i + 1
    }
    return s
}

// 로컬 반복 리터럴 + 인덱스 쓰기/읽기
xs: [i32; 8] = [0; 8]
xs[0] = 10
xs[3] = 32
xs[7] = 1 + 6
print(xs[0])            // 10
print(xs[3])            // 32
print(xs[7])            // 7
print(xs[1])            // 0

// 값 복사 의미론
ys = xs
ys[0] = 999
print(xs[0])            // 10 (복사본 수정이 원본에 영향 없음)
print(ys[0])            // 999

// 글로벌 고정 배열
print(g_tab[2])         // 7
g_tab[2] = 42
print(g_tab[2])         // 42

// 구조체 필드 + 구조체 리터럴 (배열 변수/리터럴 초기화)
b = Board { w: 3, cells: xs, weights: [0.5, 1.5, 2.5, 3.5] }
print(b.cells[3])       // 32
print(b.weights[2])     // 2.5
b.cells[3] = 100
print(b.cells[3])       // 100
print(xs[3])            // 32 (구조체 복사본 수정이 로컬에 영향 없음)
print(board_sum(b))     // 10+0+0+100+0+0+0+7 = 117

// 필드 통째 대입 (리터럴 / 반복 리터럴)
b.weights = [9.0, 8.0, 7.0, 6.0]
print(b.weights[0])     // 9
b.cells = [5; 8]
print(board_sum(b))     // 40

// 필드 → 로컬 값 복사
zs = b.cells
zs[0] = 0
print(b.cells[0])       // 5
print(zs[1])            // 5
