// 리스트 메서드 6종 스모크: find/contains/reverse/take/skip/sort_by
xs = [5, 3, 9, 1]

print(xs.contains(9))      // true
print(xs.contains(7))      // false

f = xs.find(fn(v: i64) -> bool { return v > 4 })
print(f)                   // 5 (첫 매칭)
nf = xs.find(fn(v: i64) -> bool { return v > 100 })
print(nf)                  // 0 (못 찾음)

r = xs.reverse()
print(r[0])                // 1
print(r[3])                // 5

t = xs.take(2)
print(t.len())             // 2
print(t[1])                // 3
tb = xs.take(99)
print(tb.len())            // 4 (len 클램프)

s = xs.skip(2)
print(s.len())             // 2
print(s[0])                // 9

srt = xs.sort_by(fn(a: i64, b: i64) -> i64 { return a - b })
print(srt[0])              // 1
print(srt[1])              // 3
print(srt[2])              // 5
print(srt[3])              // 9
dsc = xs.sort_by(fn(a: i64, b: i64) -> i64 { return b - a })
print(dsc[0])              // 9

names = ["beta", "alpha"]
print(names.contains("alpha"))  // true
print(names.contains("zeta"))   // false

ds = [2.5, 1.5]
print(ds.contains(1.5))    // true
print(ds.contains(9.9))    // false
