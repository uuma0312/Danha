    // memcpy/memset — llvm 인트린식 폴백 심볼 (nostdlib라 libc 없음)
    emit("define i8* @memcpy(i8* %dst, i8* %src, i64 %n) \{")
    emit("entry:")
    emit("  br label %loop")
    emit("loop:")
    emit("  %i = phi i64 [0, %entry], [%next, %cont]")
    emit("  %done = icmp uge i64 %i, %n")
    emit("  br i1 %done, label %out, label %cont")
    emit("cont:")
    emit("  %sp = getelementptr i8, i8* %src, i64 %i")
    emit("  %dp = getelementptr i8, i8* %dst, i64 %i")
    emit("  %ch = load i8, i8* %sp")
    emit("  store i8 %ch, i8* %dp")
    emit("  %next = add i64 %i, 1")
    emit("  br label %loop")
    emit("out:")
    emit("  ret i8* %dst")
    emit("\}")
    emit("")
    emit("define i8* @memset(i8* %dst, i32 %v, i64 %n) \{")
