            if arg_ts[0] == "%DnhList*" {
                emit("  " + r + " = call i64 @dnh_len(%DnhList* " + arg_rs[0] + ")")
            } else if is_arr_ptr(arg_ts[0]) {
                emit("  " + r + " = add i64 0, " + to_string(arr_len_ll(arg_ts[0])))
            } else {
                t = new_reg()
