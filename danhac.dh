    emit("define i8* @malloc(i64 %size) \{")
    emit("entry:")
    emit("  %tot = add i64 %size, 16")
    emit("  %r = call i64 @dnh_sys6(i64 9, i64 0, i64 %tot, i64 3, i64 34, i64 -1, i64 0)")
    emit("  %bad = icmp slt i64 %r, 1")
    emit("  br i1 %bad, label %fail, label %ok")
    emit("fail:")
    emit("  ret i8* null")
    emit("ok:")
    emit("  %base = inttoptr i64 %r to i8*")
    emit("  %szp = bitcast i8* %base to i64*")
    emit("  store i64 %tot, i64* %szp")
    emit("  %usr = getelementptr i8, i8* %base, i64 16")
    emit("  ret i8* %usr")
    emit("\}")
    emit("")
    emit("define void @free(i8* %ptr) \{")
    emit("entry:")
    emit("  %is_null = icmp eq i8* %ptr, null")
    emit("  br i1 %is_null, label %out, label %doit")
    emit("doit:")
    emit("  %base = getelementptr i8, i8* %ptr, i64 -16")
    emit("  %szp = bitcast i8* %base to i64*")
    emit("  %tot = load i64, i64* %szp")
    emit("  %bi = ptrtoint i8* %base to i64")
    emit("  %r = call i64 @dnh_sys3(i64 11, i64 %bi, i64 %tot, i64 0)")
    emit("  br label %out")
    emit("out:")
    emit("  ret void")
    emit("\}")
    emit("")
    emit("define i8* @realloc(i8* %ptr, i64 %size) \{")
    emit("entry:")
    emit("  %is_null = icmp eq i8* %ptr, null")
    emit("  br i1 %is_null, label %fresh, label %grow")
    emit("fresh:")
    emit("  %mem_a = call i8* @malloc(i64 %size)")
    emit("  ret i8* %mem_a")
    emit("grow:")
    emit("  %base = getelementptr i8, i8* %ptr, i64 -16")
    emit("  %szp = bitcast i8* %base to i64*")
    emit("  %old_tot = load i64, i64* %szp")
    emit("  %old_usr = sub i64 %old_tot, 16")
    emit("  %mem_g = call i8* @malloc(i64 %size)")
    emit("  %g_null = icmp eq i8* %mem_g, null")
    emit("  br i1 %g_null, label %gfail, label %copy")
    emit("gfail:")
    emit("  ret i8* null")
    emit("copy:")
    emit("  %small = icmp ult i64 %old_usr, %size")
    emit("  %n = select i1 %small, i64 %old_usr, i64 %size")
    emit("  %cp = call i8* @memcpy(i8* %mem_g, i8* %ptr, i64 %n)")
    emit("  call void @free(i8* %ptr)")
    emit("  ret i8* %mem_g")
    emit("\}")
    emit("")
    emit("define i32 @strlen(i8* %s) \{")
    emit("entry:")
    emit("  br label %loop")
    emit("loop:")
    emit("  %i = phi i32 [0, %entry], [%next, %cont]")
    emit("  %p = getelementptr i8, i8* %s, i32 %i")
    emit("  %ch = load i8, i8* %p")
    emit("  %end = icmp eq i8 %ch, 0")
    emit("  br i1 %end, label %done, label %cont")
    emit("cont:")
    emit("  %next = add i32 %i, 1")
