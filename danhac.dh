    // ── 공용 문자열 유틸 런타임 (libc/direct-os 양쪽 — malloc/strlen만 사용) ──
    emit("define i8* @dnh_str_range(i8* %s, i8* %e) \{")
    emit("entry:")
    emit("  %i = alloca i64")
    emit("  %siv = ptrtoint i8* %s to i64")
    emit("  %eiv = ptrtoint i8* %e to i64")
    emit("  %len = sub i64 %eiv, %siv")
    emit("  %n1 = add i64 %len, 1")
    emit("  %buf = call i8* @malloc(i64 %n1)")
    emit("  store i64 0, i64* %i")
    emit("  br label %cp_loop")
    emit("cp_loop:")
    emit("  %iv = load i64, i64* %i")
    emit("  %cont = icmp slt i64 %iv, %len")
    emit("  br i1 %cont, label %cp_body, label %cp_done")
    emit("cp_body:")
    emit("  %sp = getelementptr i8, i8* %s, i64 %iv")
    emit("  %ch = load i8, i8* %sp")
    emit("  %dp = getelementptr i8, i8* %buf, i64 %iv")
    emit("  store i8 %ch, i8* %dp")
    emit("  %ni = add i64 %iv, 1")
    emit("  store i64 %ni, i64* %i")
    emit("  br label %cp_loop")
    emit("cp_done:")
    emit("  %ep = getelementptr i8, i8* %buf, i64 %len")
    emit("  store i8 0, i8* %ep")
    emit("  ret i8* %buf")
    emit("\}")
    emit("")
    emit("define void @dnh_args_push(%DnhList* %lst, i8* %s, i8* %e) \{")
    emit("entry:")
    emit("  %buf = call i8* @dnh_str_range(i8* %s, i8* %e)")
    emit("  %v = ptrtoint i8* %buf to i64")
    emit("  call void @dnh_push(%DnhList* %lst, i64 %v)")
    emit("  ret void")
    emit("\}")
    emit("")
    emit("define i64 @dnh_str_find(i8* %s, i8* %sub, i64 %from) \{")
    emit("entry:")
    emit("  %i = alloca i64")
    emit("  %j = alloca i64")
    emit("  %sl32 = call i32 @strlen(i8* %s)")
    emit("  %sl = sext i32 %sl32 to i64")
    emit("  %bl32 = call i32 @strlen(i8* %sub)")
    emit("  %bl = sext i32 %bl32 to i64")
    emit("  %lim = sub i64 %sl, %bl")
    emit("  store i64 %from, i64* %i")
    emit("  br label %f_loop")
    emit("f_loop:")
    emit("  %iv = load i64, i64* %i")
    emit("  %cont = icmp sle i64 %iv, %lim")
    emit("  br i1 %cont, label %f_inner_init, label %f_nf")
    emit("f_inner_init:")
    emit("  store i64 0, i64* %j")
    emit("  br label %f_inner")
    emit("f_inner:")
    emit("  %jv = load i64, i64* %j")
    emit("  %jc = icmp slt i64 %jv, %bl")
    emit("  br i1 %jc, label %f_cmp, label %f_found")
    emit("f_cmp:")
    emit("  %iv2 = load i64, i64* %i")
    emit("  %x = add i64 %iv2, %jv")
    emit("  %sp = getelementptr i8, i8* %s, i64 %x")
    emit("  %sc = load i8, i8* %sp")
    emit("  %bp = getelementptr i8, i8* %sub, i64 %jv")
    emit("  %bc = load i8, i8* %bp")
    emit("  %eq = icmp eq i8 %sc, %bc")
    emit("  br i1 %eq, label %f_next_j, label %f_next_i")
    emit("f_next_j:")
    emit("  %jn = add i64 %jv, 1")
    emit("  store i64 %jn, i64* %j")
    emit("  br label %f_inner")
    emit("f_next_i:")
    emit("  %iv3 = load i64, i64* %i")
    emit("  %in = add i64 %iv3, 1")
    emit("  store i64 %in, i64* %i")
    emit("  br label %f_loop")
    emit("f_found:")
    emit("  %r = load i64, i64* %i")
    emit("  ret i64 %r")
    emit("f_nf:")
    emit("  ret i64 -1")
    emit("\}")
    emit("")
    emit("define i8* @dnh_substr(i8* %s, i64 %start, i64 %ln) \{")
    emit("entry:")
    emit("  %sl32 = call i32 @strlen(i8* %s)")
    emit("  %sl = sext i32 %sl32 to i64")
    emit("  %st0 = icmp slt i64 %start, 0")
    emit("  %st1 = select i1 %st0, i64 0, i64 %start")
    emit("  %st2c = icmp sgt i64 %st1, %sl")
    emit("  %st = select i1 %st2c, i64 %sl, i64 %st1")
    emit("  %ln0 = icmp slt i64 %ln, 0")
    emit("  %ln1 = select i1 %ln0, i64 0, i64 %ln")
    emit("  %avail = sub i64 %sl, %st")
    emit("  %ln2c = icmp sgt i64 %ln1, %avail")
    emit("  %lnf = select i1 %ln2c, i64 %avail, i64 %ln1")
    emit("  %sp = getelementptr i8, i8* %s, i64 %st")
    emit("  %ep = getelementptr i8, i8* %sp, i64 %lnf")
    emit("  %r = call i8* @dnh_str_range(i8* %sp, i8* %ep)")
    emit("  ret i8* %r")
    emit("\}")
    emit("")
    emit("define i1 @dnh_str_contains(i8* %s, i8* %sub) \{")
    emit("entry:")
    emit("  %pos = call i64 @dnh_str_find(i8* %s, i8* %sub, i64 0)")
    emit("  %r = icmp sge i64 %pos, 0")
    emit("  ret i1 %r")
    emit("\}")
    emit("")
    emit("define i1 @dnh_ends_with(i8* %s, i8* %suf) \{")
    emit("entry:")
    emit("  %sl32 = call i32 @strlen(i8* %s)")
    emit("  %sl = sext i32 %sl32 to i64")
    emit("  %bl32 = call i32 @strlen(i8* %suf)")
    emit("  %bl = sext i32 %bl32 to i64")
    emit("  %tooLong = icmp sgt i64 %bl, %sl")
    emit("  br i1 %tooLong, label %ew_no, label %ew_cmp")
    emit("ew_cmp:")
    emit("  %off = sub i64 %sl, %bl")
    emit("  %tp = getelementptr i8, i8* %s, i64 %off")
    emit("  %d = call i32 @strcmp(i8* %tp, i8* %suf)")
    emit("  %r = icmp eq i32 %d, 0")
    emit("  ret i1 %r")
    emit("ew_no:")
    emit("  ret i1 0")
    emit("\}")
    emit("")
    emit("define i1 @dnh_starts_with(i8* %s, i8* %pre) \{")
    emit("entry:")
    emit("  %bl32 = call i32 @strlen(i8* %pre)")
    emit("  %bl = sext i32 %bl32 to i64")
    emit("  %sub = call i8* @dnh_substr(i8* %s, i64 0, i64 %bl)")
    emit("  %d = call i32 @strcmp(i8* %sub, i8* %pre)")
    emit("  %r = icmp eq i32 %d, 0")
    emit("  ret i1 %r")
    emit("\}")
    emit("")
    emit("define i8* @dnh_replace(i8* %s, i8* %from, i8* %to) \{")
    emit("entry:")
    emit("  %i = alloca i64")
    emit("  %o = alloca i64")
    emit("  %k = alloca i64")
    emit("  %sl32 = call i32 @strlen(i8* %s)")
    emit("  %sl = sext i32 %sl32 to i64")
    emit("  %fl32 = call i32 @strlen(i8* %from)")
    emit("  %fl = sext i32 %fl32 to i64")
    emit("  %tl32 = call i32 @strlen(i8* %to)")
    emit("  %tl = sext i32 %tl32 to i64")
    emit("  %fz = icmp eq i64 %fl, 0")
    emit("  br i1 %fz, label %rp_dup, label %rp_init")
    emit("rp_dup:")
    emit("  %se = getelementptr i8, i8* %s, i64 %sl")
    emit("  %dup = call i8* @dnh_str_range(i8* %s, i8* %se)")
    emit("  ret i8* %dup")
    emit("rp_init:")
    emit("  %m = mul i64 %sl, %tl")
    emit("  %cap0 = add i64 %m, %sl")
    emit("  %cap = add i64 %cap0, 1")
    emit("  %buf = call i8* @malloc(i64 %cap)")
    emit("  store i64 0, i64* %i")
    emit("  store i64 0, i64* %o")
    emit("  br label %rp_loop")
    emit("rp_loop:")
    emit("  %iv = load i64, i64* %i")
    emit("  %more = icmp slt i64 %iv, %sl")
    emit("  br i1 %more, label %rp_find, label %rp_done")
    emit("rp_find:")
    emit("  %pos = call i64 @dnh_str_find(i8* %s, i8* %from, i64 %iv)")
    emit("  %nf = icmp slt i64 %pos, 0")
    emit("  %stop = select i1 %nf, i64 %sl, i64 %pos")
    emit("  store i64 %iv, i64* %k")
    emit("  br label %rp_copy")
    emit("rp_copy:")
    emit("  %kv = load i64, i64* %k")
    emit("  %kc = icmp slt i64 %kv, %stop")
    emit("  br i1 %kc, label %rp_copy_b, label %rp_after")
    emit("rp_copy_b:")
    emit("  %sp = getelementptr i8, i8* %s, i64 %kv")
    emit("  %ch = load i8, i8* %sp")
    emit("  %ov = load i64, i64* %o")
    emit("  %dp = getelementptr i8, i8* %buf, i64 %ov")
    emit("  store i8 %ch, i8* %dp")
    emit("  %on = add i64 %ov, 1")
    emit("  store i64 %on, i64* %o")
    emit("  %kn = add i64 %kv, 1")
    emit("  store i64 %kn, i64* %k")
    emit("  br label %rp_copy")
    emit("rp_after:")
    emit("  br i1 %nf, label %rp_setend, label %rp_subst")
    emit("rp_setend:")
    emit("  store i64 %sl, i64* %i")
    emit("  br label %rp_loop")
    emit("rp_subst:")
    emit("  store i64 0, i64* %k")
    emit("  br label %rp_tcopy")
    emit("rp_tcopy:")
    emit("  %kv2 = load i64, i64* %k")
    emit("  %kc2 = icmp slt i64 %kv2, %tl")
    emit("  br i1 %kc2, label %rp_tcopy_b, label %rp_advance")
    emit("rp_tcopy_b:")
    emit("  %tp = getelementptr i8, i8* %to, i64 %kv2")
    emit("  %tc = load i8, i8* %tp")
    emit("  %ov2 = load i64, i64* %o")
    emit("  %dp2 = getelementptr i8, i8* %buf, i64 %ov2")
    emit("  store i8 %tc, i8* %dp2")
    emit("  %on2 = add i64 %ov2, 1")
    emit("  store i64 %on2, i64* %o")
    emit("  %kn2 = add i64 %kv2, 1")
    emit("  store i64 %kn2, i64* %k")
    emit("  br label %rp_tcopy")
    emit("rp_advance:")
    emit("  %ni = add i64 %stop, %fl")
    emit("  store i64 %ni, i64* %i")
    emit("  br label %rp_loop")
    emit("rp_done:")
    emit("  %oe = load i64, i64* %o")
    emit("  %ep = getelementptr i8, i8* %buf, i64 %oe")
    emit("  store i8 0, i8* %ep")
    emit("  ret i8* %buf")
    emit("\}")
    emit("")
    emit("define %DnhList* @dnh_split(i8* %s, i8* %sep) \{")
    emit("entry:")
    emit("  %i = alloca i64")
    emit("  %lst = call %DnhList* @dnh_new_list()")
    emit("  %sl32 = call i32 @strlen(i8* %s)")
    emit("  %sl = sext i32 %sl32 to i64")
    emit("  %pl32 = call i32 @strlen(i8* %sep)")
    emit("  %pl = sext i32 %pl32 to i64")
    emit("  %pz = icmp eq i64 %pl, 0")
    emit("  br i1 %pz, label %sp_whole, label %sp_init")
    emit("sp_whole:")
    emit("  %se = getelementptr i8, i8* %s, i64 %sl")
    emit("  call void @dnh_args_push(%DnhList* %lst, i8* %s, i8* %se)")
    emit("  ret %DnhList* %lst")
    emit("sp_init:")
    emit("  store i64 0, i64* %i")
    emit("  br label %sp_loop")
    emit("sp_loop:")
    emit("  %iv = load i64, i64* %i")
    emit("  %pos = call i64 @dnh_str_find(i8* %s, i8* %sep, i64 %iv)")
    emit("  %nf = icmp slt i64 %pos, 0")
    emit("  br i1 %nf, label %sp_last, label %sp_piece")
    emit("sp_piece:")
    emit("  %a = getelementptr i8, i8* %s, i64 %iv")
    emit("  %b = getelementptr i8, i8* %s, i64 %pos")
    emit("  call void @dnh_args_push(%DnhList* %lst, i8* %a, i8* %b)")
    emit("  %ni = add i64 %pos, %pl")
    emit("  store i64 %ni, i64* %i")
    emit("  br label %sp_loop")
    emit("sp_last:")
    emit("  %iv2 = load i64, i64* %i")
    emit("  %a2 = getelementptr i8, i8* %s, i64 %iv2")
    emit("  %b2 = getelementptr i8, i8* %s, i64 %sl")
    emit("  call void @dnh_args_push(%DnhList* %lst, i8* %a2, i8* %b2)")
    emit("  ret %DnhList* %lst")
    emit("\}")
    emit("")
    emit("define i64 @dnh_atoi(i8* %s) \{")
    emit("entry:")
    emit("  %i = alloca i64")
    emit("  %acc = alloca i64")
    emit("  store i64 0, i64* %i")
    emit("  store i64 0, i64* %acc")
    emit("  %c0 = load i8, i8* %s")
    emit("  %neg = icmp eq i8 %c0, 45")
    emit("  br i1 %neg, label %a_neg, label %a_loop")
    emit("a_neg:")
    emit("  store i64 1, i64* %i")
    emit("  br label %a_loop")
    emit("a_loop:")
    emit("  %iv = load i64, i64* %i")
    emit("  %sp = getelementptr i8, i8* %s, i64 %iv")
    emit("  %ch = load i8, i8* %sp")
    emit("  %ge = icmp sge i8 %ch, 48")
    emit("  %le = icmp sle i8 %ch, 57")
    emit("  %dig = and i1 %ge, %le")
    emit("  br i1 %dig, label %a_body, label %a_done")
    emit("a_body:")
    emit("  %d = sext i8 %ch to i64")
    emit("  %d0 = sub i64 %d, 48")
    emit("  %av = load i64, i64* %acc")
    emit("  %m10 = mul i64 %av, 10")
    emit("  %na = add i64 %m10, %d0")
    emit("  store i64 %na, i64* %acc")
    emit("  %niv = add i64 %iv, 1")
    emit("  store i64 %niv, i64* %i")
    emit("  br label %a_loop")
    emit("a_done:")
    emit("  %fin = load i64, i64* %acc")
    emit("  %nv = sub i64 0, %fin")
    emit("  %r = select i1 %neg, i64 %nv, i64 %fin")
    emit("  ret i64 %r")
    emit("\}")
    emit("")
    // ── ECS 엔티티 생명주기 (py _danha_ecs_* 패리티) ──
    // EntityId는 i64에 (gen << 32) | idx 패킹. 저장소는 main 진입 시 dnh_ecs_init이 malloc.
    emit("@__ecs_gens = internal global i32* null")
    emit("@__ecs_alive = internal global i8* null")
    emit("@__ecs_free = internal global i32* null")
    emit("@__ecs_count = internal global i32 0")
    emit("@__ecs_freec = internal global i32 0")
    ovi5 = add_strlit("단아 ECS: 엔티티 용량 초과 (capacity=65536)")
    emit("define internal void @dnh_ecs_init() \{")
    emit("entry:")
    emit("  %g = call i8* @malloc(i64 262144)")
    emit("  %gp = bitcast i8* %g to i32*")
    emit("  store i32* %gp, i32** @__ecs_gens")
    emit("  %a = call i8* @malloc(i64 65536)")
    emit("  store i8* %a, i8** @__ecs_alive")
    emit("  %f = call i8* @malloc(i64 262144)")
    emit("  %fp = bitcast i8* %f to i32*")
    emit("  store i32* %fp, i32** @__ecs_free")
    emit("  ret void")
    emit("\}")
    emit("")
    emit("define internal i64 @dnh_ecs_spawn() \{")
    emit("entry:")
    emit("  %fc = load i32, i32* @__ecs_freec")
    emit("  %hasfree = icmp sgt i32 %fc, 0")
    emit("  br i1 %hasfree, label %reuse, label %fresh")
    emit("reuse:")
    emit("  %fc1 = sub i32 %fc, 1")
    emit("  %fl = load i32*, i32** @__ecs_free")
    emit("  %slot = getelementptr inbounds i32, i32* %fl, i32 %fc1")
    emit("  %ridx = load i32, i32* %slot")
    emit("  store i32 %fc1, i32* @__ecs_freec")
    emit("  %al = load i8*, i8** @__ecs_alive")
    emit("  %as = getelementptr inbounds i8, i8* %al, i32 %ridx")
    emit("  store i8 1, i8* %as")
    emit("  %gl = load i32*, i32** @__ecs_gens")
    emit("  %gs = getelementptr inbounds i32, i32* %gl, i32 %ridx")
    emit("  %rgen = load i32, i32* %gs")
    emit("  br label %done")
    emit("fresh:")
    emit("  %cnt = load i32, i32* @__ecs_count")
    emit("  %ovf = icmp sge i32 %cnt, 65536")
    emit("  br i1 %ovf, label %overflow, label %freshok")
    emit("overflow:")
    emit("  %mp = getelementptr inbounds [" + to_string(g_strlit_szs[ovi5]) + " x i8], [" + to_string(g_strlit_szs[ovi5]) + " x i8]* " + g_strlit_ids[ovi5] + ", i32 0, i32 0")
    emit("  %ig = call i32 @puts(i8* %mp)")
    emit("  call void @dnh_exit(i32 1)")
    emit("  unreachable")
    emit("freshok:")
    emit("  %gl2 = load i32*, i32** @__ecs_gens")
    emit("  %gs2 = getelementptr inbounds i32, i32* %gl2, i32 %cnt")
    emit("  store i32 0, i32* %gs2")
    emit("  %al2 = load i8*, i8** @__ecs_alive")
    emit("  %as2 = getelementptr inbounds i8, i8* %al2, i32 %cnt")
    emit("  store i8 1, i8* %as2")
    emit("  %cnt1 = add i32 %cnt, 1")
    emit("  store i32 %cnt1, i32* @__ecs_count")
    emit("  br label %done")
    emit("done:")
    emit("  %idx = phi i32 [ %ridx, %reuse ], [ %cnt, %freshok ]")
    emit("  %gen = phi i32 [ %rgen, %reuse ], [ 0, %freshok ]")
    emit("  %idx64 = zext i32 %idx to i64")
    emit("  %gen64 = zext i32 %gen to i64")
    emit("  %gsh = shl i64 %gen64, 32")
    emit("  %eid = or i64 %gsh, %idx64")
    emit("  ret i64 %eid")
    emit("\}")
    emit("")
    // 유효성: 0<=idx<count, alive, 세대 일치 (낡은 ID 감지)
    emit("define internal i1 @dnh_ecs_valid(i64 %e) \{")
    emit("entry:")
    emit("  %idx64 = and i64 %e, 4294967295")
    emit("  %idx = trunc i64 %idx64 to i32")
    emit("  %gen64 = lshr i64 %e, 32")
    emit("  %gen = trunc i64 %gen64 to i32")
    emit("  %cnt = load i32, i32* @__ecs_count")
    emit("  %oob = icmp sge i32 %idx, %cnt")
    emit("  br i1 %oob, label %no, label %c1")
    emit("c1:")
    emit("  %al = load i8*, i8** @__ecs_alive")
    emit("  %as = getelementptr inbounds i8, i8* %al, i32 %idx")
    emit("  %av = load i8, i8* %as")
    emit("  %dead = icmp eq i8 %av, 0")
    emit("  br i1 %dead, label %no, label %c2")
    emit("c2:")
    emit("  %gl = load i32*, i32** @__ecs_gens")
    emit("  %gs = getelementptr inbounds i32, i32* %gl, i32 %idx")
    emit("  %gv = load i32, i32* %gs")
    emit("  %geq = icmp eq i32 %gv, %gen")
    emit("  ret i1 %geq")
    emit("no:")
    emit("  ret i1 0")
    emit("\}")
    emit("")
    // destroy 코어: 유효하면 alive=0, gen++, free push 후 true. 컴포넌트 정리는
    // 프로그램별 @dnh_ecs_destroy(컴포넌트 목록 아는 쪽)가 담당.
    emit("define internal i1 @dnh_ecs_destroy_core(i64 %e) \{")
    emit("entry:")
    emit("  %v = call i1 @dnh_ecs_valid(i64 %e)")
    emit("  br i1 %v, label %ok, label %no")
    emit("ok:")
    emit("  %idx64 = and i64 %e, 4294967295")
    emit("  %idx = trunc i64 %idx64 to i32")
    emit("  %al = load i8*, i8** @__ecs_alive")
    emit("  %as = getelementptr inbounds i8, i8* %al, i32 %idx")
    emit("  store i8 0, i8* %as")
    emit("  %gl = load i32*, i32** @__ecs_gens")
    emit("  %gs = getelementptr inbounds i32, i32* %gl, i32 %idx")
    emit("  %gv = load i32, i32* %gs")
    emit("  %g1 = add i32 %gv, 1")
    emit("  store i32 %g1, i32* %gs")
    emit("  %fc = load i32, i32* @__ecs_freec")
    emit("  %fl = load i32*, i32** @__ecs_free")
    emit("  %slot = getelementptr inbounds i32, i32* %fl, i32 %fc")
    emit("  store i32 %idx, i32* %slot")
    emit("  %fc1 = add i32 %fc, 1")
    emit("  store i32 %fc1, i32* @__ecs_freec")
    emit("  ret i1 1")
    emit("no:")
    emit("  ret i1 0")
    emit("\}")
    emit("")
    // (엔티티, 포인터) 병렬 리스트에서 swap-remove. 제거했으면 true.
    emit("define internal i1 @dnh_ecs_swapremove(%DnhList* %el, %DnhList* %pl, i64 %ent) \{")
    emit("entry:")
    emit("  %f = call i64 @dnh_ecs_find(%DnhList* %el, i64 %ent)")
    emit("  %miss = icmp slt i64 %f, 0")
    emit("  br i1 %miss, label %no, label %ok")
    emit("ok:")
    emit("  %n = call i64 @dnh_len(%DnhList* %el)")
    emit("  %last = sub i64 %n, 1")
    emit("  %le = call i64 @dnh_get(%DnhList* %el, i64 %last)")
    emit("  %lp = call i64 @dnh_get(%DnhList* %pl, i64 %last)")
    emit("  call void @dnh_set(%DnhList* %el, i64 %f, i64 %le)")
    emit("  call void @dnh_set(%DnhList* %pl, i64 %f, i64 %lp)")
    emit("  %d1 = call i64 @dnh_pop(%DnhList* %el)")
    emit("  %d2 = call i64 @dnh_pop(%DnhList* %pl)")
    emit("  ret i1 1")
    emit("no:")
    emit("  ret i1 0")
    emit("\}")
    emit("")
    emit("define i64 @dnh_ecs_find(%DnhList* %lst, i64 %ent) \{")
    emit("entry:")
    emit("  %i = alloca i64")
    emit("  store i64 0, i64* %i")
    emit("  br label %ef_loop")
    emit("ef_loop:")
    emit("  %iv = load i64, i64* %i")
    emit("  %n = call i64 @dnh_len(%DnhList* %lst)")
    emit("  %c = icmp slt i64 %iv, %n")
    emit("  br i1 %c, label %ef_body, label %ef_nf")
    emit("ef_body:")
    emit("  %v = call i64 @dnh_get(%DnhList* %lst, i64 %iv)")
    emit("  %eq = icmp eq i64 %v, %ent")
    emit("  br i1 %eq, label %ef_found, label %ef_next")
    emit("ef_next:")
    emit("  %ni = add i64 %iv, 1")
    emit("  store i64 %ni, i64* %i")
    emit("  br label %ef_loop")
    emit("ef_found:")
    emit("  %r = load i64, i64* %i")
    emit("  ret i64 %r")
    emit("ef_nf:")
    emit("  ret i64 -1")
    emit("\}")
    emit("")
    emit("define %DnhArena* @dnh_arena_new(i64 %cap) \{")
    emit("entry:")
    emit("  %raw = call i8* @malloc(i64 24)")
    emit("  %a = bitcast i8* %raw to %DnhArena*")
    emit("  %base = call i8* @malloc(i64 %cap)")
    emit("  %bp = getelementptr inbounds %DnhArena, %DnhArena* %a, i32 0, i32 0")
    emit("  store i8* %base, i8** %bp")
    emit("  %up = getelementptr inbounds %DnhArena, %DnhArena* %a, i32 0, i32 1")
    emit("  store i64 0, i64* %up")
    emit("  %cp = getelementptr inbounds %DnhArena, %DnhArena* %a, i32 0, i32 2")
    emit("  store i64 %cap, i64* %cp")
    emit("  ret %DnhArena* %a")
    emit("\}")
    emit("")
    emit("define i64 @dnh_arena_alloc(%DnhArena* %a, i64 %size) \{")
    emit("entry:")
    emit("  %up = getelementptr inbounds %DnhArena, %DnhArena* %a, i32 0, i32 1")
    emit("  %cp = getelementptr inbounds %DnhArena, %DnhArena* %a, i32 0, i32 2")
    emit("  %u = load i64, i64* %up")
    emit("  %cap = load i64, i64* %cp")
    emit("  %remain = sub i64 %cap, %u")
    emit("  %too_big = icmp ugt i64 %size, %remain")
    emit("  br i1 %too_big, label %overflow, label %ok")
    emit("overflow:")
    emit("  %msg = getelementptr inbounds [42 x i8], [42 x i8]* @.rt_arena_overflow, i32 0, i32 0")
    emit("  call i32 @puts(i8* %msg)")
    emit("  call void @dnh_exit(i32 1)")
    emit("  unreachable")
    emit("ok:")
    emit("  %nu = add i64 %u, %size")
    emit("  store i64 %nu, i64* %up")
    emit("  ret i64 %u")
    emit("\}")
    emit("")
    emit("define i64 @dnh_arena_used(%DnhArena* %a) \{")
    emit("entry:")
    emit("  %up = getelementptr inbounds %DnhArena, %DnhArena* %a, i32 0, i32 1")
    emit("  %u = load i64, i64* %up")
    emit("  ret i64 %u")
    emit("\}")
    emit("")
    emit("define i64 @dnh_arena_cap(%DnhArena* %a) \{")
    emit("entry:")
    emit("  %cp = getelementptr inbounds %DnhArena, %DnhArena* %a, i32 0, i32 2")
    emit("  %c = load i64, i64* %cp")
    emit("  ret i64 %c")
    emit("\}")
    emit("")
    emit("define void @dnh_arena_reset(%DnhArena* %a) \{")
    emit("entry:")
    emit("  %up = getelementptr inbounds %DnhArena, %DnhArena* %a, i32 0, i32 1")
    emit("  store i64 0, i64* %up")
    emit("  ret void")
    emit("\}")
    emit("")
    emit("define void @dnh_arena_destroy(%DnhArena* %a) \{")
    emit("entry:")
    emit("  %bp = getelementptr inbounds %DnhArena, %DnhArena* %a, i32 0, i32 0")
    emit("  %base = load i8*, i8** %bp")
    emit("  call void @free(i8* %base)")
    emit("  %raw = bitcast %DnhArena* %a to i8*")
    emit("  call void @free(i8* %raw)")
    emit("  ret void")
    emit("\}")
    emit("")
    emit("define %DnhEnum* @dnh_enum_new(i64 %tag, i64 %payload) \{")
    emit("entry:")
    emit("  %raw = call i8* @malloc(i64 16)")
    emit("  %e = bitcast i8* %raw to %DnhEnum*")
    emit("  %tp = getelementptr inbounds %DnhEnum, %DnhEnum* %e, i32 0, i32 0")
    emit("  store i64 %tag, i64* %tp")
    emit("  %pp = getelementptr inbounds %DnhEnum, %DnhEnum* %e, i32 0, i32 1")
    emit("  store i64 %payload, i64* %pp")
    emit("  ret %DnhEnum* %e")
    emit("\}")
    emit("")
    // dyn 트레잇 객체: { 데이터 i8*, vtable i8* } 힙 팻 포인터
    emit("define i8* @dnh_dyn_new(i8* %d, i8* %v) \{")
    emit("entry:")
    emit("  %raw = call i8* @malloc(i64 16)")
    emit("  %dp = bitcast i8* %raw to i8**")
    emit("  store i8* %d, i8** %dp")
    emit("  %vp = getelementptr inbounds i8*, i8** %dp, i64 1")
    emit("  store i8* %v, i8** %vp")
    emit("  ret i8* %raw")
    emit("\}")
    emit("")
    // ── StringBuilder 런타임: data는 항상 NUL 종단 유지 (strcpy 기반 복사) ──
    emit("define %DnhSB* @dnh_sb_new() \{")
    emit("entry:")
    emit("  %raw = call i8* @malloc(i64 24)")
    emit("  %sb = bitcast i8* %raw to %DnhSB*")
    emit("  %d = call i8* @malloc(i64 16)")
    emit("  store i8 0, i8* %d")
    emit("  %dp = getelementptr inbounds %DnhSB, %DnhSB* %sb, i32 0, i32 0")
    emit("  store i8* %d, i8** %dp")
    emit("  %lp = getelementptr inbounds %DnhSB, %DnhSB* %sb, i32 0, i32 1")
    emit("  store i64 0, i64* %lp")
    emit("  %cp = getelementptr inbounds %DnhSB, %DnhSB* %sb, i32 0, i32 2")
    emit("  store i64 16, i64* %cp")
    emit("  ret %DnhSB* %sb")
    emit("\}")
    emit("")
    emit("define void @dnh_sb_append(%DnhSB* %sb, i8* %s0) \{")
    emit("entry:")
    emit("  %s = call i8* @dnh_safe_str(i8* %s0)")
    emit("  %sl32 = call i32 @strlen(i8* %s)")
    emit("  %sl = sext i32 %sl32 to i64")
    emit("  %lp = getelementptr inbounds %DnhSB, %DnhSB* %sb, i32 0, i32 1")
    emit("  %len = load i64, i64* %lp")
    emit("  %cp = getelementptr inbounds %DnhSB, %DnhSB* %sb, i32 0, i32 2")
    emit("  %cap = load i64, i64* %cp")
    emit("  %nl = add i64 %len, %sl")
    emit("  %need = add i64 %nl, 1")
    emit("  %dp = getelementptr inbounds %DnhSB, %DnhSB* %sb, i32 0, i32 0")
    emit("  %fits = icmp sle i64 %need, %cap")
    emit("  br i1 %fits, label %copy, label %grow")
    emit("grow:")
    emit("  %c2 = mul i64 %cap, 2")
    emit("  %big = icmp sgt i64 %need, %c2")
    emit("  %nc = select i1 %big, i64 %need, i64 %c2")
    emit("  %od = load i8*, i8** %dp")
    emit("  %nd = call i8* @realloc(i8* %od, i64 %nc)")
    emit("  store i8* %nd, i8** %dp")
    emit("  store i64 %nc, i64* %cp")
    emit("  br label %copy")
    emit("copy:")
    emit("  %data = load i8*, i8** %dp")
    emit("  %dst = getelementptr i8, i8* %data, i64 %len")
    emit("  call i8* @strcpy(i8* %dst, i8* %s)")
    emit("  store i64 %nl, i64* %lp")
    emit("  ret void")
    emit("\}")
    emit("")
    emit("define i8* @dnh_sb_to_str(%DnhSB* %sb) \{")
    emit("entry:")
    emit("  %lp = getelementptr inbounds %DnhSB, %DnhSB* %sb, i32 0, i32 1")
    emit("  %len = load i64, i64* %lp")
    emit("  %n1 = add i64 %len, 1")
    emit("  %buf = call i8* @malloc(i64 %n1)")
    emit("  %dp = getelementptr inbounds %DnhSB, %DnhSB* %sb, i32 0, i32 0")
    emit("  %data = load i8*, i8** %dp")
    emit("  call i8* @strcpy(i8* %buf, i8* %data)")
    emit("  ret i8* %buf")
    emit("\}")
    emit("")
    emit("define i64 @dnh_sb_len(%DnhSB* %sb) \{")
    emit("entry:")
    emit("  %lp = getelementptr inbounds %DnhSB, %DnhSB* %sb, i32 0, i32 1")
    emit("  %len = load i64, i64* %lp")
    emit("  ret i64 %len")
    emit("\}")
    emit("")
    // ── HashMap 런타임: (kkind, kslot, val) 병렬 리스트 + 선형 탐색 (부트스트랩용) ──
    // kkind: 0=정수 키, 1=문자열 키(strcmp 비교). keys()는 삽입 순서 보존 (remove는 시프트 삭제)
    emit("define %DnhHM* @dnh_hm_new() \{")
    emit("entry:")
    emit("  %raw = call i8* @malloc(i64 24)")
    emit("  %m = bitcast i8* %raw to %DnhHM*")
    emit("  %l0 = call %DnhList* @dnh_new_list()")
    emit("  %p0 = getelementptr inbounds %DnhHM, %DnhHM* %m, i32 0, i32 0")
    emit("  store %DnhList* %l0, %DnhList** %p0")
    emit("  %l1 = call %DnhList* @dnh_new_list()")
    emit("  %p1 = getelementptr inbounds %DnhHM, %DnhHM* %m, i32 0, i32 1")
    emit("  store %DnhList* %l1, %DnhList** %p1")
    emit("  %l2 = call %DnhList* @dnh_new_list()")
    emit("  %p2 = getelementptr inbounds %DnhHM, %DnhHM* %m, i32 0, i32 2")
    emit("  store %DnhList* %l2, %DnhList** %p2")
    emit("  ret %DnhHM* %m")
    emit("\}")
    emit("")
    emit("define i64 @dnh_hm_find(%DnhHM* %m, i64 %kk, i64 %ks) \{")
    emit("entry:")
    emit("  %p0 = getelementptr inbounds %DnhHM, %DnhHM* %m, i32 0, i32 0")
    emit("  %kkl = load %DnhList*, %DnhList** %p0")
    emit("  %p1 = getelementptr inbounds %DnhHM, %DnhHM* %m, i32 0, i32 1")
    emit("  %ksl = load %DnhList*, %DnhList** %p1")
    emit("  %n = call i64 @dnh_len(%DnhList* %kkl)")
    emit("  br label %loop")
    emit("loop:")
    emit("  %i = phi i64 [ 0, %entry ], [ %inc, %next ]")
    emit("  %c = icmp slt i64 %i, %n")
    emit("  br i1 %c, label %body, label %nf")
    emit("body:")
    emit("  %ek = call i64 @dnh_get(%DnhList* %kkl, i64 %i)")
    emit("  %samek = icmp eq i64 %ek, %kk")
    emit("  br i1 %samek, label %cmpv, label %next")
    emit("cmpv:")
    emit("  %es = call i64 @dnh_get(%DnhList* %ksl, i64 %i)")
    emit("  %isstr = icmp eq i64 %kk, 1")
    emit("  br i1 %isstr, label %cmps, label %cmpi")
    emit("cmps:")
    emit("  %pa = inttoptr i64 %es to i8*")
    emit("  %pb = inttoptr i64 %ks to i8*")
    emit("  %d = call i32 @strcmp(i8* %pa, i8* %pb)")
    emit("  %eqs = icmp eq i32 %d, 0")
    emit("  br i1 %eqs, label %found, label %next")
    emit("cmpi:")
    emit("  %eqi = icmp eq i64 %es, %ks")
    emit("  br i1 %eqi, label %found, label %next")
    emit("found:")
    emit("  ret i64 %i")
    emit("next:")
    emit("  %inc = add i64 %i, 1")
    emit("  br label %loop")
    emit("nf:")
    emit("  ret i64 -1")
    emit("\}")
    emit("")
    emit("define void @dnh_hm_set(%DnhHM* %m, i64 %kk, i64 %ks, i64 %v) \{")
    emit("entry:")
    emit("  %idx = call i64 @dnh_hm_find(%DnhHM* %m, i64 %kk, i64 %ks)")
    emit("  %p2 = getelementptr inbounds %DnhHM, %DnhHM* %m, i32 0, i32 2")
    emit("  %vl = load %DnhList*, %DnhList** %p2")
    emit("  %found = icmp sge i64 %idx, 0")
    emit("  br i1 %found, label %upd, label %ins")
    emit("upd:")
    emit("  call void @dnh_set(%DnhList* %vl, i64 %idx, i64 %v)")
    emit("  ret void")
    emit("ins:")
    emit("  %p0 = getelementptr inbounds %DnhHM, %DnhHM* %m, i32 0, i32 0")
    emit("  %kkl = load %DnhList*, %DnhList** %p0")
    emit("  call void @dnh_push(%DnhList* %kkl, i64 %kk)")
    emit("  %p1 = getelementptr inbounds %DnhHM, %DnhHM* %m, i32 0, i32 1")
    emit("  %ksl = load %DnhList*, %DnhList** %p1")
    emit("  call void @dnh_push(%DnhList* %ksl, i64 %ks)")
    emit("  call void @dnh_push(%DnhList* %vl, i64 %v)")
    emit("  ret void")
    emit("\}")
    emit("")
    emit("define i64 @dnh_hm_get(%DnhHM* %m, i64 %kk, i64 %ks) \{")
    emit("entry:")
    emit("  %idx = call i64 @dnh_hm_find(%DnhHM* %m, i64 %kk, i64 %ks)")
    emit("  %miss = icmp slt i64 %idx, 0")
    emit("  br i1 %miss, label %no, label %yes")
    emit("no:")
    emit("  ret i64 0")
    emit("yes:")
    emit("  %p2 = getelementptr inbounds %DnhHM, %DnhHM* %m, i32 0, i32 2")
    emit("  %vl = load %DnhList*, %DnhList** %p2")
    emit("  %v = call i64 @dnh_get(%DnhList* %vl, i64 %idx)")
    emit("  ret i64 %v")
    emit("\}")
    emit("")
    emit("define i1 @dnh_hm_has(%DnhHM* %m, i64 %kk, i64 %ks) \{")
    emit("entry:")
    emit("  %idx = call i64 @dnh_hm_find(%DnhHM* %m, i64 %kk, i64 %ks)")
    emit("  %f = icmp sge i64 %idx, 0")
    emit("  ret i1 %f")
    emit("\}")
    emit("")
    emit("define i1 @dnh_hm_remove(%DnhHM* %m, i64 %kk, i64 %ks) \{")
    emit("entry:")
    emit("  %idx = call i64 @dnh_hm_find(%DnhHM* %m, i64 %kk, i64 %ks)")
    emit("  %miss = icmp slt i64 %idx, 0")
    emit("  br i1 %miss, label %no, label %yes")
    emit("no:")
    emit("  ret i1 0")
    emit("yes:")
    emit("  %p0 = getelementptr inbounds %DnhHM, %DnhHM* %m, i32 0, i32 0")
    emit("  %l0 = load %DnhList*, %DnhList** %p0")
    emit("  %p1 = getelementptr inbounds %DnhHM, %DnhHM* %m, i32 0, i32 1")
    emit("  %l1 = load %DnhList*, %DnhList** %p1")
    emit("  %p2 = getelementptr inbounds %DnhHM, %DnhHM* %m, i32 0, i32 2")
    emit("  %l2 = load %DnhList*, %DnhList** %p2")
    emit("  %n = call i64 @dnh_len(%DnhList* %l0)")
    emit("  %last = add i64 %n, -1")
    emit("  br label %sh")
    emit("sh:")
    emit("  %i = phi i64 [ %idx, %yes ], [ %i1v, %shb ]")
    emit("  %c = icmp slt i64 %i, %last")
    emit("  br i1 %c, label %shb, label %fin")
    emit("shb:")
    emit("  %i1v = add i64 %i, 1")
    emit("  %a0 = call i64 @dnh_get(%DnhList* %l0, i64 %i1v)")
    emit("  call void @dnh_set(%DnhList* %l0, i64 %i, i64 %a0)")
    emit("  %a1 = call i64 @dnh_get(%DnhList* %l1, i64 %i1v)")
    emit("  call void @dnh_set(%DnhList* %l1, i64 %i, i64 %a1)")
    emit("  %a2 = call i64 @dnh_get(%DnhList* %l2, i64 %i1v)")
    emit("  call void @dnh_set(%DnhList* %l2, i64 %i, i64 %a2)")
    emit("  br label %sh")
    emit("fin:")
    emit("  %x0 = call i64 @dnh_pop(%DnhList* %l0)")
    emit("  %x1 = call i64 @dnh_pop(%DnhList* %l1)")
    emit("  %x2 = call i64 @dnh_pop(%DnhList* %l2)")
    emit("  ret i1 1")
    emit("\}")
    emit("")
    emit("define i64 @dnh_hm_len(%DnhHM* %m) \{")
    emit("entry:")
    emit("  %p0 = getelementptr inbounds %DnhHM, %DnhHM* %m, i32 0, i32 0")
    emit("  %l0 = load %DnhList*, %DnhList** %p0")
    emit("  %n = call i64 @dnh_len(%DnhList* %l0)")
    emit("  ret i64 %n")
    emit("\}")
    emit("")
    emit("define %DnhList* @dnh_hm_keys(%DnhHM* %m) \{")
    emit("entry:")
    emit("  %p1 = getelementptr inbounds %DnhHM, %DnhHM* %m, i32 0, i32 1")
    emit("  %ksl = load %DnhList*, %DnhList** %p1")
    emit("  %n = call i64 @dnh_len(%DnhList* %ksl)")
    emit("  %out = call %DnhList* @dnh_new_list()")
    emit("  br label %loop")
    emit("loop:")
    emit("  %i = phi i64 [ 0, %entry ], [ %inc, %body ]")
    emit("  %c = icmp slt i64 %i, %n")
    emit("  br i1 %c, label %body, label %done")
    emit("body:")
    emit("  %v = call i64 @dnh_get(%DnhList* %ksl, i64 %i)")
    emit("  call void @dnh_push(%DnhList* %out, i64 %v)")
    emit("  %inc = add i64 %i, 1")
    emit("  br label %loop")
    emit("done:")
    emit("  ret %DnhList* %out")
    emit("\}")
    emit("")
    emit("define %DnhList* @dnh_new_list() \{")
    emit("entry:")
    emit("  %nl_raw = call i8* @malloc(i64 24)")
    emit("  %nl_lst = bitcast i8* %nl_raw to %DnhList*")
    emit("  %nl_lp  = getelementptr inbounds %DnhList, %DnhList* %nl_lst, i32 0, i32 0")
    emit("  store i64 0, i64* %nl_lp")
    emit("  %nl_cp  = getelementptr inbounds %DnhList, %DnhList* %nl_lst, i32 0, i32 1")
    emit("  store i64 4, i64* %nl_cp")
    emit("  %nl_dp  = getelementptr inbounds %DnhList, %DnhList* %nl_lst, i32 0, i32 2")
    emit("  %nl_dr  = call i8* @malloc(i64 32)")
    emit("  %nl_dt  = bitcast i8* %nl_dr to i64*")
    emit("  store i64* %nl_dt, i64** %nl_dp")
    emit("  ret %DnhList* %nl_lst")
    emit("\}")
    emit("")
    emit("define void @dnh_push(%DnhList* %lst, i64 %val) \{")
    emit("entry:")
    emit("  %pu_lp  = getelementptr inbounds %DnhList, %DnhList* %lst, i32 0, i32 0")
    emit("  %pu_len = load i64, i64* %pu_lp")
    emit("  %pu_cp  = getelementptr inbounds %DnhList, %DnhList* %lst, i32 0, i32 1")
    emit("  %pu_cap = load i64, i64* %pu_cp")
    emit("  %pu_ng  = icmp sge i64 %pu_len, %pu_cap")
    emit("  br i1 %pu_ng, label %pu_grow, label %pu_store")
    emit("pu_grow:")
    emit("  %pu_nc  = mul i64 %pu_cap, 2")
    emit("  %pu_dp  = getelementptr inbounds %DnhList, %DnhList* %lst, i32 0, i32 2")
    emit("  %pu_od  = load i64*, i64** %pu_dp")
    emit("  %pu_or  = bitcast i64* %pu_od to i8*")
    emit("  %pu_ns  = mul i64 %pu_nc, 8")
    emit("  %pu_nr  = call i8* @realloc(i8* %pu_or, i64 %pu_ns)")
    emit("  %pu_nd  = bitcast i8* %pu_nr to i64*")
    emit("  store i64* %pu_nd, i64** %pu_dp")
    emit("  store i64 %pu_nc, i64* %pu_cp")
    emit("  br label %pu_store")
    emit("pu_store:")
    emit("  %pu_dp2  = getelementptr inbounds %DnhList, %DnhList* %lst, i32 0, i32 2")
    emit("  %pu_data = load i64*, i64** %pu_dp2")
    emit("  %pu_slot = getelementptr inbounds i64, i64* %pu_data, i64 %pu_len")
    emit("  store i64 %val, i64* %pu_slot")
    emit("  %pu_nl  = add i64 %pu_len, 1")
    emit("  store i64 %pu_nl, i64* %pu_lp")
    emit("  ret void")
    emit("\}")
    emit("")
    emit("define i64 @dnh_len(%DnhList* %lst) \{")
    emit("entry:")
    emit("  %le_lp  = getelementptr inbounds %DnhList, %DnhList* %lst, i32 0, i32 0")
    emit("  %le_len = load i64, i64* %le_lp")
    emit("  ret i64 %le_len")
    emit("\}")
    emit("")
    emit("define i64 @dnh_get(%DnhList* %lst, i64 %idx) \{")
    emit("entry:")
    emit("  %ge_lp  = getelementptr inbounds %DnhList, %DnhList* %lst, i32 0, i32 0")
    emit("  %ge_len = load i64, i64* %ge_lp")
    emit("  %ge_neg = icmp slt i64 %idx, 0")
    emit("  %ge_ovr = icmp sge i64 %idx, %ge_len")
    emit("  %ge_bad = or i1 %ge_neg, %ge_ovr")
    emit("  br i1 %ge_bad, label %ge_oob, label %ge_ok")
    emit("ge_oob:")
    emit("  ret i64 0")
    emit("ge_ok:")
    emit("  %ge_dp   = getelementptr inbounds %DnhList, %DnhList* %lst, i32 0, i32 2")
    emit("  %ge_data = load i64*, i64** %ge_dp")
    emit("  %ge_slot = getelementptr inbounds i64, i64* %ge_data, i64 %idx")
    emit("  %ge_val  = load i64, i64* %ge_slot")
    emit("  ret i64 %ge_val")
    emit("\}")
    emit("")
    emit("define i64 @dnh_u16le(%DnhList* %bs, i64 %off) \{")
    emit("entry:")
    emit("  %b0 = call i64 @dnh_get(%DnhList* %bs, i64 %off)")
    emit("  %o1 = add i64 %off, 1")
    emit("  %b1 = call i64 @dnh_get(%DnhList* %bs, i64 %o1)")
    emit("  %s1 = mul i64 %b1, 256")
    emit("  %v = add i64 %b0, %s1")
    emit("  ret i64 %v")
    emit("\}")
    emit("")
    emit("define i64 @dnh_i16le(%DnhList* %bs, i64 %off) \{")
    emit("entry:")
    emit("  %v = call i64 @dnh_u16le(%DnhList* %bs, i64 %off)")
    emit("  %neg = icmp sge i64 %v, 32768")
    emit("  br i1 %neg, label %i16_neg, label %i16_pos")
    emit("i16_neg:")
    emit("  %sv = sub i64 %v, 65536")
    emit("  ret i64 %sv")
    emit("i16_pos:")
    emit("  ret i64 %v")
    emit("\}")
    emit("")
    emit("define i64 @dnh_u32le(%DnhList* %bs, i64 %off) \{")
    emit("entry:")
    emit("  %b0 = call i64 @dnh_get(%DnhList* %bs, i64 %off)")
    emit("  %o1 = add i64 %off, 1")
    emit("  %b1 = call i64 @dnh_get(%DnhList* %bs, i64 %o1)")
    emit("  %o2 = add i64 %off, 2")
    emit("  %b2 = call i64 @dnh_get(%DnhList* %bs, i64 %o2)")
    emit("  %o3 = add i64 %off, 3")
    emit("  %b3 = call i64 @dnh_get(%DnhList* %bs, i64 %o3)")
    emit("  %s1 = mul i64 %b1, 256")
    emit("  %a1 = add i64 %b0, %s1")
    emit("  %s2 = mul i64 %b2, 65536")
    emit("  %a2 = add i64 %a1, %s2")
    emit("  %s3 = mul i64 %b3, 16777216")
    emit("  %v = add i64 %a2, %s3")
    emit("  ret i64 %v")
    emit("\}")
    emit("")
    emit("define void @dnh_put_u8(%DnhList* %out, i64 %val) \{")
    emit("entry:")
    emit("  %b = and i64 %val, 255")
    emit("  call void @dnh_push(%DnhList* %out, i64 %b)")
    emit("  ret void")
    emit("\}")
    emit("")
    emit("define void @dnh_put_u16le(%DnhList* %out, i64 %val) \{")
    emit("entry:")
    emit("  %b0 = and i64 %val, 255")
    emit("  call void @dnh_push(%DnhList* %out, i64 %b0)")
    emit("  %s1 = sdiv i64 %val, 256")
    emit("  %b1 = and i64 %s1, 255")
    emit("  call void @dnh_push(%DnhList* %out, i64 %b1)")
    emit("  ret void")
    emit("\}")
    emit("")
    emit("define void @dnh_put_u32le(%DnhList* %out, i64 %val) \{")
    emit("entry:")
    emit("  call void @dnh_put_u16le(%DnhList* %out, i64 %val)")
    emit("  %s2 = sdiv i64 %val, 65536")
    emit("  call void @dnh_put_u16le(%DnhList* %out, i64 %s2)")
    emit("  ret void")
    emit("\}")
    emit("")
    emit("define void @dnh_set(%DnhList* %lst, i64 %idx, i64 %val) \{")
    emit("entry:")
    emit("  %se_dp   = getelementptr inbounds %DnhList, %DnhList* %lst, i32 0, i32 2")
    emit("  %se_data = load i64*, i64** %se_dp")
    emit("  %se_slot = getelementptr inbounds i64, i64* %se_data, i64 %idx")
    emit("  store i64 %val, i64* %se_slot")
    emit("  ret void")
    emit("\}")
    emit("")
    emit("define i64 @dnh_pop(%DnhList* %lst) \{")
    emit("entry:")
    emit("  %po_lp   = getelementptr inbounds %DnhList, %DnhList* %lst, i32 0, i32 0")
    emit("  %po_len  = load i64, i64* %po_lp")
    emit("  %po_nl   = sub i64 %po_len, 1")
    emit("  store i64 %po_nl, i64* %po_lp")
    emit("  %po_dp   = getelementptr inbounds %DnhList, %DnhList* %lst, i32 0, i32 2")
    emit("  %po_data = load i64*, i64** %po_dp")
    emit("  %po_slot = getelementptr inbounds i64, i64* %po_data, i64 %po_nl")
    emit("  %po_val  = load i64, i64* %po_slot")
    emit("  ret i64 %po_val")
    emit("\}")
    emit("")
    emit("@.rt_empty = private unnamed_addr constant [1 x i8] zeroinitializer")
    emit("define i8* @dnh_safe_str(i8* %s) \{")
    emit("entry:")
    emit("  %z = icmp eq i8* %s, null")
    emit("  %e = getelementptr inbounds [1 x i8], [1 x i8]* @.rt_empty, i32 0, i32 0")
    emit("  %r = select i1 %z, i8* %e, i8* %s")
    emit("  ret i8* %r")
    emit("\}")
    emit("")
    emit("define i8* @dnh_str_cat(i8* %a0, i8* %b0) \{")
    emit("entry:")
    emit("  %a = call i8* @dnh_safe_str(i8* %a0)")
    emit("  %b = call i8* @dnh_safe_str(i8* %b0)")
    emit("  %sc_la   = call i32 @strlen(i8* %a)")
    emit("  %sc_lb   = call i32 @strlen(i8* %b)")
    emit("  %sc_la64 = sext i32 %sc_la to i64")
    emit("  %sc_lb64 = sext i32 %sc_lb to i64")
    emit("  %sc_tot  = add i64 %sc_la64, %sc_lb64")
    emit("  %sc_sz   = add i64 %sc_tot, 1")
    emit("  %sc_buf  = call i8* @malloc(i64 %sc_sz)")
    emit("  call i8* @strcpy(i8* %sc_buf, i8* %a)")
    emit("  %sc_mid  = getelementptr i8, i8* %sc_buf, i64 %sc_la64")
    emit("  call i8* @strcpy(i8* %sc_mid, i8* %b)")
    emit("  ret i8* %sc_buf")
    emit("\}")
    emit("")
    if g_runtime_direct {
    // direct-os: snprintf 없이 자릿수 루프로 i64 → 문자열
    emit("define i8* @dnh_to_str_int(i64 %v) \{")
    emit("entry:")
    emit("  %buf = call i8* @malloc(i64 32)")
    emit("  %tmp = alloca [32 x i8]")
    emit("  %tmpp = getelementptr inbounds [32 x i8], [32 x i8]* %tmp, i32 0, i32 0")
    emit("  %nv = sub i64 0, %v")
    emit("  %neg = icmp slt i64 %v, 0")
    emit("  %av0 = select i1 %neg, i64 %nv, i64 %v")
    emit("  %n = alloca i64")
    emit("  %cnt = alloca i64")
    emit("  store i64 %av0, i64* %n")
    emit("  store i64 0, i64* %cnt")
    emit("  br label %dig_loop")
    emit("dig_loop:")
    emit("  %nl = load i64, i64* %n")
    emit("  %cl = load i64, i64* %cnt")
    emit("  %d = srem i64 %nl, 10")
    emit("  %dc = add i64 %d, 48")
    emit("  %dc8 = trunc i64 %dc to i8")
    emit("  %dp = getelementptr i8, i8* %tmpp, i64 %cl")
    emit("  store i8 %dc8, i8* %dp")
    emit("  %cl1 = add i64 %cl, 1")
    emit("  store i64 %cl1, i64* %cnt")
    emit("  %nq = sdiv i64 %nl, 10")
    emit("  store i64 %nq, i64* %n")
    emit("  %z = icmp eq i64 %nq, 0")
    emit("  br i1 %z, label %dig_done, label %dig_loop")
    emit("dig_done:")
    emit("  %o = alloca i64")
    emit("  store i64 0, i64* %o")
    emit("  br i1 %neg, label %wsign, label %rev_loop")
    emit("wsign:")
    emit("  store i8 45, i8* %buf")
    emit("  store i64 1, i64* %o")
    emit("  br label %rev_loop")
    emit("rev_loop:")
    emit("  %cl2 = load i64, i64* %cnt")
    emit("  %has = icmp sgt i64 %cl2, 0")
    emit("  br i1 %has, label %rev_body, label %rev_done")
    emit("rev_body:")
    emit("  %cm1 = sub i64 %cl2, 1")
    emit("  store i64 %cm1, i64* %cnt")
    emit("  %sp2 = getelementptr i8, i8* %tmpp, i64 %cm1")
    emit("  %ch2 = load i8, i8* %sp2")
    emit("  %ol = load i64, i64* %o")
    emit("  %dp2 = getelementptr i8, i8* %buf, i64 %ol")
    emit("  store i8 %ch2, i8* %dp2")
    emit("  %ol1 = add i64 %ol, 1")
    emit("  store i64 %ol1, i64* %o")
    emit("  br label %rev_loop")
    emit("rev_done:")
    emit("  %oe = load i64, i64* %o")
    emit("  %ep2 = getelementptr i8, i8* %buf, i64 %oe")
    emit("  store i8 0, i8* %ep2")
    emit("  ret i8* %buf")
    emit("\}")
    emit("")
    // direct runtime: snprintf 없이 소수점 셋째 자리까지 변환한다.
    emit("define i8* @dnh_to_str_float(double %v) \{")
    emit("entry:")
    emit("  %neg = fcmp olt double %v, 0.0")
    emit("  %nv = fsub double 0.0, %v")
    emit("  %av = select i1 %neg, double %nv, double %v")
    emit("  %ip0 = fptosi double %av to i64")
    emit("  %ipf = sitofp i64 %ip0 to double")
    emit("  %fr = fsub double %av, %ipf")
    emit("  %sc = fmul double %fr, 1000.0")
    emit("  %scr = fadd double %sc, 0.5")
    emit("  %fi0 = fptosi double %scr to i64")
    emit("  %carry = icmp sge i64 %fi0, 1000")
    emit("  %ip1 = add i64 %ip0, 1")
    emit("  %ip = select i1 %carry, i64 %ip1, i64 %ip0")
    emit("  %fi = select i1 %carry, i64 0, i64 %fi0")
    emit("  %nip = sub i64 0, %ip")
    emit("  %sip = select i1 %neg, i64 %nip, i64 %ip")
    emit("  %is = call i8* @dnh_to_str_int(i64 %sip)")
    emit("  %nzbuf = call i8* @malloc(i64 3)")
    emit("  store i8 45, i8* %nzbuf")
    emit("  %nzp1 = getelementptr i8, i8* %nzbuf, i64 1")
    emit("  store i8 48, i8* %nzp1")
    emit("  %nzp2 = getelementptr i8, i8* %nzbuf, i64 2")
    emit("  store i8 0, i8* %nzp2")
    emit("  %ipz = icmp eq i64 %ip, 0")
    emit("  %usenegzero = and i1 %neg, %ipz")
    emit("  %is2 = select i1 %usenegzero, i8* %nzbuf, i8* %is")
    emit("  %il32 = call i32 @strlen(i8* %is2)")
    emit("  %il = sext i32 %il32 to i64")
    emit("  %total = add i64 %il, 5")
    emit("  %buf = call i8* @malloc(i64 %total)")
    emit("  call i8* @strcpy(i8* %buf, i8* %is2)")
    emit("  %dotp = getelementptr i8, i8* %buf, i64 %il")
    emit("  store i8 46, i8* %dotp")
    emit("  %h = sdiv i64 %fi, 100")
    emit("  %hr = srem i64 %h, 10")
    emit("  %t0 = sdiv i64 %fi, 10")
    emit("  %tr = srem i64 %t0, 10")
    emit("  %or = srem i64 %fi, 10")
    emit("  %hc64 = add i64 %hr, 48")
    emit("  %tc64 = add i64 %tr, 48")
    emit("  %oc64 = add i64 %or, 48")
    emit("  %hc = trunc i64 %hc64 to i8")
    emit("  %tc = trunc i64 %tc64 to i8")
    emit("  %oc = trunc i64 %oc64 to i8")
    emit("  %p1 = getelementptr i8, i8* %buf, i64 %il")
    emit("  %p2 = getelementptr i8, i8* %p1, i64 1")
    emit("  %p3 = getelementptr i8, i8* %p1, i64 2")
    emit("  %p4 = getelementptr i8, i8* %p1, i64 3")
    emit("  %p5 = getelementptr i8, i8* %p1, i64 4")
    emit("  store i8 %hc, i8* %p2")
    emit("  store i8 %tc, i8* %p3")
    emit("  store i8 %oc, i8* %p4")
    emit("  %oz = icmp eq i64 %or, 0")
    emit("  br i1 %oz, label %trim_o, label %keep_3")
    emit("trim_o:")
    emit("  %tz = icmp eq i64 %tr, 0")
    emit("  br i1 %tz, label %keep_1, label %keep_2")
    emit("keep_1:")
    emit("  store i8 0, i8* %p3")
    emit("  ret i8* %buf")
    emit("keep_2:")
    emit("  store i8 0, i8* %p4")
    emit("  ret i8* %buf")
    emit("keep_3:")
    emit("  store i8 0, i8* %p5")
    emit("  ret i8* %buf")
    emit("\}")
    emit("")
    } else {
    emit("define i8* @dnh_to_str_int(i64 %v) \{")
    emit("entry:")
    emit("  %ts_buf = call i8* @malloc(i64 32)")
    emit("  %ts_fmt = getelementptr inbounds [5 x i8], [5 x i8]* @.rt_fmt_lld, i32 0, i32 0")
    emit("  call i32 (i8*, i64, i8*, ...) @snprintf(i8* %ts_buf, i64 31, i8* %ts_fmt, i64 %v)")
    emit("  ret i8* %ts_buf")
    emit("\}")
    emit("")
    emit("define i8* @dnh_to_str_float(double %v) \{")
    emit("entry:")
    emit("  %i = alloca i64")
    emit("  %tf_buf = call i8* @malloc(i64 32)")
    emit("  %tf_fmt = getelementptr inbounds [3 x i8], [3 x i8]* @.rt_fmt_f, i32 0, i32 0")
    emit("  call i32 (i8*, i64, i8*, ...) @snprintf(i8* %tf_buf, i64 31, i8* %tf_fmt, double %v)")
    emit("  %l32 = call i32 @strlen(i8* %tf_buf)")
    emit("  %l = sext i32 %l32 to i64")
    emit("  %l1 = sub i64 %l, 1")
    emit("  store i64 %l1, i64* %i")
    emit("  br label %st_loop")
    emit("st_loop:")
    emit("  %iv = load i64, i64* %i")
    emit("  %pos = icmp sgt i64 %iv, 0")
    emit("  br i1 %pos, label %st_chk, label %st_done")
    emit("st_chk:")
    emit("  %cp = getelementptr i8, i8* %tf_buf, i64 %iv")
    emit("  %c = load i8, i8* %cp")
    emit("  %is0 = icmp eq i8 %c, 48")
    emit("  br i1 %is0, label %st_prev, label %st_done")
    emit("st_prev:")
    emit("  %im1 = sub i64 %iv, 1")
    emit("  %pp = getelementptr i8, i8* %tf_buf, i64 %im1")
    emit("  %p = load i8, i8* %pp")
    emit("  %isdot = icmp eq i8 %p, 46")
    emit("  br i1 %isdot, label %st_done, label %st_strip")
    emit("st_strip:")
    emit("  store i8 0, i8* %cp")
    emit("  store i64 %im1, i64* %i")
    emit("  br label %st_loop")
    emit("st_done:")
    emit("  ret i8* %tf_buf")
    emit("\}")
    emit("")
    }
    emit("define i8* @dnh_str_idx(i8* %s0, i64 %idx) \{")
    emit("entry:")
    emit("  %s = call i8* @dnh_safe_str(i8* %s0)")
    emit("  %si_buf = call i8* @malloc(i64 2)")
    emit("  %si_ch  = getelementptr i8, i8* %s, i64 %idx")
    emit("  %si_cv  = load i8, i8* %si_ch")
    emit("  store i8 %si_cv, i8* %si_buf")
    emit("  %si_end = getelementptr i8, i8* %si_buf, i64 1")
    emit("  store i8 0, i8* %si_end")
    emit("  ret i8* %si_buf")
    emit("\}")
    emit("")
    emit("define i8* @dnh_chr(i8 %ch) \{")
    emit("entry:")
    emit("  %buf = call i8* @malloc(i64 2)")
    emit("  store i8 %ch, i8* %buf")
    emit("  %end = getelementptr i8, i8* %buf, i64 1")
    emit("  store i8 0, i8* %end")
    emit("  ret i8* %buf")
    emit("\}")
    emit("")
}

fn cg_program(root) {
    if g_debug_codegen { print("cg program begin") }
    emit_rt()
    if g_debug_codegen { print("cg runtime done") }
    emit("")
    ns = g_nch_n[root]
    i = 0
    while i < ns {
        s = g_ch[g_nch_s[root] + i]; k = g_nkind[s]
        if g_debug_codegen { print("cg decl pass " + to_string(i) + " kind " + to_string(k)) }
        if k == NK_STRUCT_DEF { cg_struct_def(s) }
        if k == NK_EXTERN_FN {
            fname = g_nsval[s]; rn = g_nc1[s]; rty = "i64"
            if rn > 0 { rty = ll_ty(g_ntype[rn]) }
            // 중복 extern(모듈 다중 import) — 두 번째부터는 declare/등록 모두 생략
            if find_fn(fname) == -1 {
                np = g_nch_n[s]; pstr = ""
                j = 0
                while j < np {
                    pp = g_ch[g_nch_s[s] + j]
                    if j > 0 { pstr = pstr + ", " }
                    pstr = pstr + ll_ty(g_ntype[pp])
                    push(g_fn_ptys, ll_ty(g_ntype[pp]))
                    j = j + 1
                }
                // 런타임 프리앰블이 이미 declare한 심볼은 재선언 금지 (clang 중복 정의 에러)
                if not rt_predeclared(fname) {
                    emit("declare " + rty + " @" + fname + "(" + pstr + ")"); emit("")
                }
                push(g_fn_names, fname); push(g_fn_rets, rty); push(g_fn_arities, np)
                push(g_fn_ps, len(g_fn_ptys) - np)
            }
        }
        i = i + 1
    }
    // ECS 컴포넌트별 (엔티티, 포인터) 병렬 저장 글로벌
    i = 0
    while i < len(g_comp_names) {
        cn = g_comp_names[i]
        emit("@__ecs_e_" + cn + " = internal global %DnhList* null")
        emit("@__ecs_p_" + cn + " = internal global %DnhList* null")
        i = i + 1
    }
    // destroy: 코어(생명주기) 처리 후 모든 컴포넌트 리스트에서 해당 엔티티 제거.
    // 컴포넌트 목록은 프로그램별이라 여기서 방출 (py destroy의 comp 정리와 동일).
    emit("define internal i1 @dnh_ecs_destroy(i64 %e) \{")
    emit("entry:")
    emit("  %r = call i1 @dnh_ecs_destroy_core(i64 %e)")
    if len(g_comp_names) > 0 {
        emit("  br i1 %r, label %clean, label %done")
        emit("clean:")
        i = 0
        while i < len(g_comp_names) {
            cn = g_comp_names[i]
            emit("  %el" + to_string(i) + " = load %DnhList*, %DnhList** @__ecs_e_" + cn)
            emit("  %pl" + to_string(i) + " = load %DnhList*, %DnhList** @__ecs_p_" + cn)
            emit("  %x" + to_string(i) + " = call i1 @dnh_ecs_swapremove(%DnhList* %el" + to_string(i) + ", %DnhList* %pl" + to_string(i) + ", i64 %e)")
            i = i + 1
        }
        emit("  br label %done")
        emit("done:")
    }
    emit("  ret i1 %r")
    emit("\}")
    emit("")
    // 트레잇별 dyn 팻 포인터 타입 (중복 제거)
    di4 = 0
    while di4 < len(g_trm_trait) {
        tn4 = g_trm_trait[di4]
        dup4 = false
        dj4 = 0
        while dj4 < di4 {
            if g_trm_trait[dj4] == tn4 { dup4 = true }
            dj4 = dj4 + 1
        }
        if not dup4 { emit("%dyn." + tn4 + " = type \{ i8*, i8* \}") }
        di4 = di4 + 1
    }
    if len(g_trm_trait) > 0 { emit("") }
    // fn 시그니처 선등록 패스 — 정의 순서와 무관하게 호출부 호출 타입이 정확해짐
    i = 0
    while i < ns {
        preregister_fn(g_ch[g_nch_s[root] + i])
        i = i + 1
    }
    i = 0
    while i < len(g_impl_fns) { preregister_fn(g_impl_fns[i]); i = i + 1 }
    // vtable 생성 — impl 페어마다 트레잇 메서드 순서대로 함수 포인터 배열
    vi4 = 0
    while vi4 < len(g_impl_traits) {
        vt4 = g_impl_traits[vi4]
        vs4 = g_impl_structs[vi4]
        nm4 = trait_method_count(vt4)
        if nm4 > 0 {
            vstr = ""
            vc4 = 0
            vk4 = 0
            while vk4 < len(g_trm_trait) {
                if g_trm_trait[vk4] == vt4 {
                    mg4 = vs4 + "__" + g_trm_name[vk4]
                    fi4 = find_fn(mg4)
                    if fi4 == -1 {
                        fatal("vtable: " + mg4 + " 시그니처를 찾을 수 없어")
                    }
                    fty4 = g_fn_rets[fi4] + " ("
                    fa4 = 0
                    while fa4 < g_fn_arities[fi4] {
                        if fa4 > 0 { fty4 = fty4 + ", " }
                        fty4 = fty4 + g_fn_ptys[g_fn_ps[fi4] + fa4]
                        fa4 = fa4 + 1
                    }
                    fty4 = fty4 + ")"
                    if vc4 > 0 { vstr = vstr + ", " }
                    vstr = vstr + "i8* bitcast (" + fty4 + "* @" + mg4 + " to i8*)"
                    vc4 = vc4 + 1
                }
                vk4 = vk4 + 1
            }
            emit("@vtable_" + vt4 + "_" + vs4 + " = internal constant [" + to_string(nm4) + " x i8*] [" + vstr + "]")
        }
        vi4 = vi4 + 1
    }
    if len(g_impl_traits) > 0 { emit("") }
    if g_debug_codegen { print("cg global predeclare begin") }
    i = 0
    while i < ns {
        s = g_ch[g_nch_s[root] + i]
        predeclare_global_assign(s)
        i = i + 1
    }
    if g_debug_codegen { print("cg fn pass begin") }
    i = 0
    while i < ns {
        s = g_ch[g_nch_s[root] + i]
        if g_debug_codegen { print("cg fn pass " + to_string(i) + " kind " + to_string(g_nkind[s])) }
        if g_nkind[s] == NK_FN { cg_fn(s) }
        i = i + 1
    }
    i = 0
    while i < len(g_impl_fns) { cg_fn(g_impl_fns[i]); i = i + 1 }
    if g_debug_codegen { print("cg main pass begin") }
    if g_runtime_direct {
        emit("define i32 @main() \{"); emit("entry:")
    } else {
        emit("define i32 @main(i32 %argc, i8** %argv) \{"); emit("entry:")
        emit("  store i32 %argc, i32* @g_dnh_argc")
        emit("  store i8** %argv, i8*** @g_dnh_argv")
    }
    g_cur_fn_ret = "i32"
    // ECS 엔티티 저장소 + 컴포넌트 리스트 초기화 (main 진입 직후)
    emit("  call void @dnh_ecs_init()")
    i = 0
    while i < len(g_comp_names) {
        cn = g_comp_names[i]
        r1 = new_reg()
        emit("  " + r1 + " = call %DnhList* @dnh_new_list()")
        emit("  store %DnhList* " + r1 + ", %DnhList** @__ecs_e_" + cn)
        r2 = new_reg()
        emit("  " + r2 + " = call %DnhList* @dnh_new_list()")
        emit("  store %DnhList* " + r2 + ", %DnhList** @__ecs_p_" + cn)
        i = i + 1
    }
    sv_out: [str] = g_out
    g_out = []
    i = 0
    while i < ns {
        s = g_ch[g_nch_s[root] + i]; k = g_nkind[s]
        if g_debug_codegen { print("cg main pass " + to_string(i) + " kind " + to_string(k) + " line " + to_string(g_nline[s])) }
        if k != NK_FN and k != NK_STRUCT_DEF and k != NK_EXTERN_FN { cg_stmt(s) }
        i = i + 1
    }
    // main 폴스루 defer 방출
    cg_emit_defers()
    while len(g_defer_bodies) > 0 { pop(g_defer_bodies) }
    body_out: [str] = g_out
    g_out = sv_out
    i = 0
    while i < len(g_alloca_buf) { emit(g_alloca_buf[i]); i = i + 1 }
    g_alloca_buf = []
    i = 0
    while i < len(body_out) { emit(body_out[i]); i = i + 1 }
    emit("  ret i32 0"); emit("\}"); emit("")
    // 디퍼드 람다 함수들 플러시 (LLVM IR은 정의 순서 무관)
    i = 0
    while i < len(g_lam_out) { emit(g_lam_out[i]); i = i + 1 }
    // 모노모피제이션된 제네릭 함수들 플러시
    i = 0
    while i < len(g_gen_out) { emit(g_gen_out[i]); i = i + 1 }
    if g_debug_codegen { print("cg program end") }
}

fn build_ir() -> str {
    if g_debug_codegen { print("build_ir begin") }
    out = "; Generated by danhac.dh\n\n"
    i = 0
    while i < len(g_strlits) {
        if g_debug_codegen and i % 100 == 0 { print("build_ir strlit " + to_string(i) + "/" + to_string(len(g_strlits))) }
        s  = g_strlits[i]; nm = g_strlit_ids[i]; sz = g_strlit_szs[i]
        out = out + nm + " = private unnamed_addr constant [" + to_string(sz) + " x i8] c\"" + ll_escape(s) + "\\00\", align 1\n"
        i = i + 1
    }
    if g_debug_codegen { print("build_ir strlits done") }
    out = out + "\n"
    i = 0
    while i < len(g_out) {
        if g_debug_codegen and i % 500 == 0 { print("build_ir out " + to_string(i) + "/" + to_string(len(g_out))) }
        out = out + g_out[i] + "\n"
        i = i + 1
    }
    if g_debug_codegen { print("build_ir end") }
    return out
}

fn is_label_line(s: str) -> bool {
    if len(s) == 0 { return false }
    if s[0] == " " { return false }
    if s[0] == "@" { return false }
    if s[0] == ";" { return false }
    return s[len(s) - 1] == ":"
}

fn label_name(s: str) -> str {
    out = ""
    i = 0
    while i + 1 < len(s) {
        out = out + s[i]
        i = i + 1
    }
    return out
}

// 주의: 누적 버퍼(buf = buf + line) 방식은 아레나(고정 256MB, 무확장)를
// 2차 복사로 고갈시켜 대형 출력에서 힙 손상을 일으킴 — 라인 단위 직접 쓰기 유지.
// (FILE_SHARE_READ 수정으로 라인 단위 append는 AV 간섭에도 안전)
fn write_ir_file(path: str) {
    if g_debug_codegen { print("write_ir begin") }
    file_write(path, "; Generated by danhac.dh\n\n")
    i = 0
    while i < len(g_strlits) {
        if g_debug_codegen and i % 100 == 0 { print("write_ir strlit " + to_string(i) + "/" + to_string(len(g_strlits))) }
        s  = g_strlits[i]; nm = g_strlit_ids[i]; sz = g_strlit_szs[i]
        file_append(path, nm + " = private unnamed_addr constant [" + to_string(sz) + " x i8] c\"" + ll_escape(s) + "\\00\", align 1\n")
        i = i + 1
    }
    file_append(path, "\n")
    i = 0
    prev_was_label = false
    while i < len(g_out) {
        if g_debug_codegen and i % 500 == 0 { print("write_ir out " + to_string(i) + "/" + to_string(len(g_out))) }
        line = g_out[i]
        cur_is_label = is_label_line(line)
        if prev_was_label and cur_is_label {
            file_append(path, "  br label %" + label_name(line) + "\n")
        }
        file_append(path, line + "\n")
        prev_was_label = cur_is_label
        i = i + 1
    }
    if g_debug_codegen { print("write_ir end") }
}

// ─── Native PE/COFF linker foundation ─────────────────────────────────────
fn coff_has_flag(v: i64, flag: i64) -> bool {
    return (v & flag) != 0
}

fn coff_ascii_byte(b: i64) -> str {
    if b == 46 { return "." }
    if b == 48 { return "0" }
    if b == 49 { return "1" }
    if b == 50 { return "2" }
    if b == 51 { return "3" }
    if b == 52 { return "4" }
    if b == 53 { return "5" }
    if b == 54 { return "6" }
    if b == 55 { return "7" }
    if b == 56 { return "8" }
    if b == 57 { return "9" }
    if b == 65 { return "A" }
    if b == 66 { return "B" }
    if b == 67 { return "C" }
    if b == 68 { return "D" }
    if b == 69 { return "E" }
    if b == 70 { return "F" }
    if b == 71 { return "G" }
    if b == 72 { return "H" }
    if b == 73 { return "I" }
    if b == 74 { return "J" }
    if b == 75 { return "K" }
    if b == 76 { return "L" }
    if b == 77 { return "M" }
    if b == 78 { return "N" }
    if b == 79 { return "O" }
    if b == 80 { return "P" }
    if b == 81 { return "Q" }
    if b == 82 { return "R" }
    if b == 83 { return "S" }
    if b == 84 { return "T" }
    if b == 85 { return "U" }
    if b == 86 { return "V" }
    if b == 87 { return "W" }
    if b == 88 { return "X" }
    if b == 89 { return "Y" }
    if b == 90 { return "Z" }
    if b == 95 { return "_" }
    if b == 97 { return "a" }
    if b == 98 { return "b" }
    if b == 99 { return "c" }
    if b == 100 { return "d" }
    if b == 101 { return "e" }
    if b == 102 { return "f" }
    if b == 103 { return "g" }
    if b == 104 { return "h" }
    if b == 105 { return "i" }
    if b == 106 { return "j" }
    if b == 107 { return "k" }
    if b == 108 { return "l" }
    if b == 109 { return "m" }
    if b == 110 { return "n" }
    if b == 111 { return "o" }
    if b == 112 { return "p" }
    if b == 113 { return "q" }
    if b == 114 { return "r" }
    if b == 115 { return "s" }
    if b == 116 { return "t" }
    if b == 117 { return "u" }
    if b == 118 { return "v" }
    if b == 119 { return "w" }
    if b == 120 { return "x" }
    if b == 121 { return "y" }
    if b == 122 { return "z" }
    return "?"
}

fn coff_c_string(off: i64) -> str {
    out = ""
    i: i64 = off
    while i < len(g_coff_bytes) and g_coff_bytes[i] != 0 {
        out = out + coff_ascii_byte(g_coff_bytes[i])
        i = i + 1
    }
    return out
}

fn coff_short_name(off: i64) -> str {
    out = ""
    i: i64 = 0
    while i < 8 and g_coff_bytes[off + i] != 0 {
        out = out + coff_ascii_byte(g_coff_bytes[off + i])
        i = i + 1
    }
    return out
}

fn coff_symbol_name(sym_ptr: i64, sym_count: i64, sym_index: i64) -> str {
    so = sym_ptr + sym_index * 18
    if g_coff_bytes[so] == 0 and g_coff_bytes[so + 1] == 0 and g_coff_bytes[so + 2] == 0 and g_coff_bytes[so + 3] == 0 {
        name_off = u32le(g_coff_bytes, so + 4)
        str_ptr = sym_ptr + sym_count * 18
        return coff_c_string(str_ptr + name_off)
    }
    return coff_short_name(so)
}

fn coff_section_name(sec_off: i64, sym_ptr: i64, sym_count: i64) -> str {
    if g_coff_bytes[sec_off] == 0 and g_coff_bytes[sec_off + 1] == 0 and g_coff_bytes[sec_off + 2] == 0 and g_coff_bytes[sec_off + 3] == 0 {
        name_off = u32le(g_coff_bytes, sec_off + 4)
        str_ptr = sym_ptr + sym_count * 18
        return coff_c_string(str_ptr + name_off)
    }
    return coff_short_name(sec_off)
}

fn coff_import_name(sym: str) -> str {
    if sym == "exit" { return "ExitProcess" }
    return sym
}

fn coff_is_helper_symbol(sym: str) -> bool {
    return sym == "__chkstk" or sym == "___chkstk_ms"
}

fn coff_is_supported_import(sym: str) -> bool {
    imp = coff_import_name(sym)
    return imp == "CloseHandle" or imp == "CreateFileA" or imp == "CreateProcessA" or imp == "CreateThread" or imp == "ExitProcess" or imp == "GetCommandLineA" or imp == "GetExitCodeProcess" or imp == "GetFileAttributesA" or imp == "GetFileSize" or imp == "GetProcessHeap" or imp == "GetStdHandle" or imp == "HeapAlloc" or imp == "HeapFree" or imp == "HeapReAlloc" or imp == "QueryPerformanceCounter" or imp == "QueryPerformanceFrequency" or imp == "ReadFile" or imp == "SetFilePointer" or imp == "WaitForSingleObject" or imp == "WriteFile"
}

fn coff_align(v: i64, a: i64) -> i64 {
    r = v % a
    if r == 0 { return v }
    return v + (a - r)
}

fn coff_normalize_chars(chars: i64) -> i64 {
    out = chars
    if coff_has_flag(out, 4096) { out = out - 4096 }
    if coff_has_flag(out, 1048576) { out = out - 1048576 }
    if coff_has_flag(out, 2097152) { out = out - 2097152 }
    if coff_has_flag(out, 4194304) { out = out - 4194304 }
    if coff_has_flag(out, 8388608) { out = out - 8388608 }
    return out
}

fn coff_find_link_section(name: str, chars: i64) -> i64 {
    i: i64 = 0
    while i < len(g_link_sec_names) {
        if g_link_sec_names[i] == name and g_link_sec_chars[i] == chars { return i }
        i = i + 1
    }
    return -1
}

fn coff_add_link_section(name: str, chars: i64) -> i64 {
    push(g_link_sec_names, name)
    push(g_link_sec_data_lens, 0)
    push(g_link_sec_virtual_sizes, 0)
    push(g_link_sec_chars, chars)
    push(g_link_sec_rvas, 0)
    return len(g_link_sec_names) - 1
}

fn coff_layout_sections() {
    section_count = u16le(g_coff_bytes, 2)
    sym_ptr = u32le(g_coff_bytes, 8)
    sym_count = u32le(g_coff_bytes, 12)
    opt_size = u16le(g_coff_bytes, 16)
    sec_ptr = 20 + opt_size

    g_link_sec_names = []
    g_link_sec_data_lens = []
    g_link_sec_virtual_sizes = []
    g_link_sec_chars = []
    g_link_sec_rvas = []
    g_obj_section_link_indices = []
    g_obj_section_offsets = []

    oi: i64 = 0
    while oi < section_count + 1 {
        push(g_obj_section_link_indices, -1)
        push(g_obj_section_offsets, -1)
        oi = oi + 1
    }

    i: i64 = 0
    while i < section_count {
        off = sec_ptr + i * 40
        name = coff_section_name(off, sym_ptr, sym_count)
        raw_size = u32le(g_coff_bytes, off + 16)
        raw_ptr = u32le(g_coff_bytes, off + 20)
        chars = u32le(g_coff_bytes, off + 36)
        if not coff_has_flag(chars, 2048) {
            norm = coff_normalize_chars(chars)
            li = coff_find_link_section(name, norm)
            if li == -1 { li = coff_add_link_section(name, norm) }
            g_obj_section_link_indices[i + 1] = li
            if not coff_has_flag(chars, 128) and raw_ptr != 0 and raw_size != 0 {
                aligned = coff_align(g_link_sec_data_lens[li], 16)
                g_obj_section_offsets[i + 1] = aligned
                g_link_sec_data_lens[li] = aligned + raw_size
                if g_link_sec_data_lens[li] > g_link_sec_virtual_sizes[li] {
                    g_link_sec_virtual_sizes[li] = g_link_sec_data_lens[li]
                }
            } else {
                start = g_link_sec_virtual_sizes[li]
                g_obj_section_offsets[i + 1] = start
                add_size = raw_size
                if add_size < 1 { add_size = 1 }
                g_link_sec_virtual_sizes[li] = start + add_size
            }
        }
        i = i + 1
    }

    coff_build_thunk_bytes()
    coff_build_import_bytes()
    if len(g_link_thunks) > 0 {
        push(g_link_sec_names, ".dthnk")
        push(g_link_sec_data_lens, len(g_link_thunks))
        push(g_link_sec_virtual_sizes, len(g_link_thunks))
        push(g_link_sec_chars, 1615855648)
        push(g_link_sec_rvas, 0)
    }
    push(g_link_sec_names, ".idata")
    push(g_link_sec_data_lens, len(g_link_idata))
    push(g_link_sec_virtual_sizes, len(g_link_idata))
    push(g_link_sec_chars, 3224371264)
    push(g_link_sec_rvas, 0)

    rva = 4096
    ri: i64 = 0
    while ri < len(g_link_sec_names) {
        g_link_sec_rvas[ri] = rva
        size = g_link_sec_virtual_sizes[ri]
        if g_link_sec_data_lens[ri] > size { size = g_link_sec_data_lens[ri] }
        if size < 1 { size = 1 }
        rva = rva + coff_align(size, 4096)
        ri = ri + 1
    }
}

fn coff_idata_zeroes(n: i64) {
    i: i64 = 0
    while i < n {
        push(g_link_idata, 0)
        i = i + 1
    }
}

fn coff_idata_set_u32le(off: i64, val: i64) {
    g_link_idata[off] = val & 255
    s1 = val / 256
    g_link_idata[off + 1] = s1 & 255
    s2 = val / 65536
    g_link_idata[off + 2] = s2 & 255
    s3 = val / 16777216
    g_link_idata[off + 3] = s3 & 255
}

fn coff_idata_set_u64le(off: i64, val: i64) {
    coff_idata_set_u32le(off, val)
    coff_idata_set_u32le(off + 4, 0)
}

fn coff_thunks_set_u32le(off: i64, val: i64) {
    g_link_thunks[off] = val & 255
    s1 = val / 256
    g_link_thunks[off + 1] = s1 & 255
    s2 = val / 65536
    g_link_thunks[off + 2] = s2 & 255
    s3 = val / 16777216
    g_link_thunks[off + 3] = s3 & 255
}

fn coff_idata_ascii(s: str) {
    i: i64 = 0
    while i < len(s) {
        push(g_link_idata, ord(s[i]))
        i = i + 1
    }
}

fn coff_idata_match_hint_name(off: i64, name: str) -> bool {
    if off + 2 + len(name) >= len(g_link_idata) { return false }
    if g_link_idata[off] != 0 { return false }
    if g_link_idata[off + 1] != 0 { return false }
    i: i64 = 0
    while i < len(name) {
        if g_link_idata[off + 2 + i] != ord(name[i]) { return false }
        i = i + 1
    }
    return g_link_idata[off + 2 + len(name)] == 0
}

fn coff_idata_find_hint_name(name: str) -> i64 {
    off: i64 = 0
    while off < len(g_link_idata) {
        if coff_idata_match_hint_name(off, name) { return off }
        off = off + 1
    }
    return -1
}

fn coff_has_undefined_import(sym_ptr: i64, sym_count: i64, target: str) -> bool {
    si: i64 = 0
    while si < sym_count {
        so = sym_ptr + si * 18
        sec_no = i16le(g_coff_bytes, so + 12)
        aux_count = g_coff_bytes[so + 17]
        if sec_no == 0 {
            nm = coff_import_name(coff_symbol_name(sym_ptr, sym_count, si))
            if nm == target { return true }
        }
        si = si + 1 + aux_count
    }
    return false
}

fn coff_push_import_if_present(sym_ptr: i64, sym_count: i64, name: str) {
    if coff_has_undefined_import(sym_ptr, sym_count, name) {
        push(g_link_imports, name)
    }
}

fn coff_collect_sorted_imports(sym_ptr: i64, sym_count: i64) {
    g_link_imports = []
    coff_push_import_if_present(sym_ptr, sym_count, "CloseHandle")
    coff_push_import_if_present(sym_ptr, sym_count, "CreateFileA")
    coff_push_import_if_present(sym_ptr, sym_count, "CreateProcessA")
    coff_push_import_if_present(sym_ptr, sym_count, "CreateThread")
    coff_push_import_if_present(sym_ptr, sym_count, "ExitProcess")
    coff_push_import_if_present(sym_ptr, sym_count, "GetCommandLineA")
    coff_push_import_if_present(sym_ptr, sym_count, "GetExitCodeProcess")
    coff_push_import_if_present(sym_ptr, sym_count, "GetFileAttributesA")
    coff_push_import_if_present(sym_ptr, sym_count, "GetFileSize")
    coff_push_import_if_present(sym_ptr, sym_count, "GetProcessHeap")
    coff_push_import_if_present(sym_ptr, sym_count, "GetStdHandle")
    coff_push_import_if_present(sym_ptr, sym_count, "HeapAlloc")
    coff_push_import_if_present(sym_ptr, sym_count, "HeapFree")
    coff_push_import_if_present(sym_ptr, sym_count, "HeapReAlloc")
    coff_push_import_if_present(sym_ptr, sym_count, "QueryPerformanceCounter")
    coff_push_import_if_present(sym_ptr, sym_count, "QueryPerformanceFrequency")
    coff_push_import_if_present(sym_ptr, sym_count, "ReadFile")
    coff_push_import_if_present(sym_ptr, sym_count, "SetFilePointer")
    coff_push_import_if_present(sym_ptr, sym_count, "WaitForSingleObject")
    coff_push_import_if_present(sym_ptr, sym_count, "WriteFile")
}

fn coff_build_import_bytes() {
    g_link_idata = []
    n = len(g_link_imports)
    desc_size = 40
    ilt_off = desc_size
    iat_off = ilt_off + (n + 1) * 8
    cursor = iat_off + (n + 1) * 8
    coff_idata_zeroes(cursor)

    i: i64 = 0
    while i < n {
        name = g_link_imports[i]
        aligned = coff_align(cursor, 2)
        coff_idata_zeroes(aligned - len(g_link_idata))
        put_u16le(g_link_idata, 0)
        coff_idata_ascii(name)
        put_u8(g_link_idata, 0)
        cursor = len(g_link_idata)
        i = i + 1
    }

    dll_name_off = cursor
    coff_idata_ascii("KERNEL32.dll")
    put_u8(g_link_idata, 0)

    coff_idata_set_u32le(0, ilt_off)
    coff_idata_set_u32le(12, dll_name_off)
    coff_idata_set_u32le(16, iat_off)
}

fn coff_build_thunk_bytes() {
    g_link_thunks = []
    i: i64 = 0
    while i < len(g_link_imports) {
        put_u8(g_link_thunks, 255)
        put_u8(g_link_thunks, 37)
        put_u32le(g_link_thunks, 0)
        i = i + 1
    }
}

fn coff_finalize_import_bytes(idata_rva: i64, thunks_rva: i64) {
    ilt_off = u32le(g_link_idata, 0)
    dll_name_off = u32le(g_link_idata, 12)
    iat_off = u32le(g_link_idata, 16)

    coff_idata_set_u32le(0, idata_rva + ilt_off)
    coff_idata_set_u32le(12, idata_rva + dll_name_off)
    coff_idata_set_u32le(16, idata_rva + iat_off)

    i: i64 = 0
    while i < len(g_link_imports) {
        name = g_link_imports[i]
        name_off = coff_idata_find_hint_name(name)
        thunk_value = idata_rva + name_off
        coff_idata_set_u64le(ilt_off + i * 8, thunk_value)
        coff_idata_set_u64le(iat_off + i * 8, thunk_value)

        thunk_off = i * 6
        thunk_next = thunks_rva + thunk_off + 6
        iat_rva = idata_rva + iat_off + i * 8
        rel32 = iat_rva - thunk_next
        coff_thunks_set_u32le(thunk_off + 2, rel32)
        i = i + 1
    }
}

fn coff_find_import_index(name: str) -> i64 {
    i: i64 = 0
    while i < len(g_link_imports) {
        if g_link_imports[i] == name { return i }
        i = i + 1
    }
    return -1
}

fn coff_resolve_symbol_rva(sym_ptr: i64, sym_count: i64, sym_index: i64) -> i64 {
    so = sym_ptr + sym_index * 18
    value = u32le(g_coff_bytes, so + 8)
    sec_no = i16le(g_coff_bytes, so + 12)
    name = coff_symbol_name(sym_ptr, sym_count, sym_index)
    if sec_no > 0 {
        li = g_obj_section_link_indices[sec_no]
        if li < 0 { return -1 }
        return g_link_sec_rvas[li] + g_obj_section_offsets[sec_no] + value
    }
    imp = coff_import_name(name)
    ii = coff_find_import_index(imp)
    if ii >= 0 {
        thunks_idx = coff_find_link_section(".dthnk", 1615855648)
        if thunks_idx < 0 { return -1 }
        return g_link_sec_rvas[thunks_idx] + ii * 6
    }
    return -1
}

fn coff_clear_section_bytes() {
    g_sec_text = []
    g_sec_xdata = []
    g_sec_rdata = []
    g_sec_pdata = []
    g_sec_dthnk = []
    g_sec_idata = []
}

fn coff_section_len(li: i64) -> i64 {
    name = g_link_sec_names[li]
    if name == ".text" { return len(g_sec_text) }
    if name == ".xdata" { return len(g_sec_xdata) }
    if name == ".rdata" { return len(g_sec_rdata) }
    if name == ".pdata" { return len(g_sec_pdata) }
    if name == ".dthnk" { return len(g_sec_dthnk) }
    if name == ".idata" { return len(g_sec_idata) }
    return 0
}

fn coff_section_push_byte(li: i64, b: i64) {
    name = g_link_sec_names[li]
    if name == ".text" { push(g_sec_text, b); return }
    if name == ".xdata" { push(g_sec_xdata, b); return }
    if name == ".rdata" { push(g_sec_rdata, b); return }
    if name == ".pdata" { push(g_sec_pdata, b); return }
    if name == ".dthnk" { push(g_sec_dthnk, b); return }
    if name == ".idata" { push(g_sec_idata, b); return }
}

fn coff_section_zeroes(li: i64, n: i64) {
    i: i64 = 0
    while i < n {
        coff_section_push_byte(li, 0)
        i = i + 1
    }
}

fn coff_section_get_byte(li: i64, off: i64) -> i64 {
    name = g_link_sec_names[li]
    if name == ".text" { return g_sec_text[off] }
    if name == ".xdata" { return g_sec_xdata[off] }
    if name == ".rdata" { return g_sec_rdata[off] }
    if name == ".pdata" { return g_sec_pdata[off] }
    if name == ".dthnk" { return g_sec_dthnk[off] }
    if name == ".idata" { return g_sec_idata[off] }
    return 0
}

fn coff_section_set_byte(li: i64, off: i64, b: i64) {
    name = g_link_sec_names[li]
    v = b & 255
    if name == ".text" { g_sec_text[off] = v; return }
    if name == ".xdata" { g_sec_xdata[off] = v; return }
    if name == ".rdata" { g_sec_rdata[off] = v; return }
    if name == ".pdata" { g_sec_pdata[off] = v; return }
    if name == ".dthnk" { g_sec_dthnk[off] = v; return }
    if name == ".idata" { g_sec_idata[off] = v; return }
}

fn coff_section_u32le(li: i64, off: i64) -> i64 {
    b0 = coff_section_get_byte(li, off)
    b1 = coff_section_get_byte(li, off + 1)
    b2 = coff_section_get_byte(li, off + 2)
    b3 = coff_section_get_byte(li, off + 3)
    return b0 + b1 * 256 + b2 * 65536 + b3 * 16777216
}

fn coff_section_i32le(li: i64, off: i64) -> i64 {
    v = coff_section_u32le(li, off)
    if v >= 2147483648 { return v - 4294967296 }
    return v
}

fn coff_section_set_u32le(li: i64, off: i64, val: i64) {
    v = val
    if v < 0 { v = v + 4294967296 }
    coff_section_set_byte(li, off, v & 255)
    s1 = v / 256
    coff_section_set_byte(li, off + 1, s1 & 255)
    s2 = v / 65536
    coff_section_set_byte(li, off + 2, s2 & 255)
    s3 = v / 16777216
    coff_section_set_byte(li, off + 3, s3 & 255)
}

fn coff_build_merged_section_bytes() {
    coff_clear_section_bytes()
    section_count = u16le(g_coff_bytes, 2)
    opt_size = u16le(g_coff_bytes, 16)
    sec_ptr = 20 + opt_size
    i: i64 = 0
    while i < section_count {
        sec_index = i + 1
        li = g_obj_section_link_indices[sec_index]
        if li >= 0 {
            sh = sec_ptr + i * 40
            raw_size = u32le(g_coff_bytes, sh + 16)
            raw_ptr = u32le(g_coff_bytes, sh + 20)
            chars = u32le(g_coff_bytes, sh + 36)
            if not coff_has_flag(chars, 128) and raw_ptr != 0 and raw_size != 0 {
                want = g_obj_section_offsets[sec_index]
                coff_section_zeroes(li, want - coff_section_len(li))
                j: i64 = 0
                while j < raw_size {
                    coff_section_push_byte(li, g_coff_bytes[raw_ptr + j])
                    j = j + 1
                }
            }
        }
        i = i + 1
    }
    dli = coff_find_link_section(".dthnk", 1615855648)
    if dli >= 0 {
        i2: i64 = 0
        while i2 < len(g_link_thunks) { coff_section_push_byte(dli, g_link_thunks[i2]); i2 = i2 + 1 }
    }
    ili = coff_find_link_section(".idata", 3224371264)
    if ili >= 0 {
        i3: i64 = 0
        while i3 < len(g_link_idata) { coff_section_push_byte(ili, g_link_idata[i3]); i3 = i3 + 1 }
    }
}

fn coff_apply_relocations() {
    sym_ptr = u32le(g_coff_bytes, 8)
    sym_count = u32le(g_coff_bytes, 12)
    section_count = u16le(g_coff_bytes, 2)
    opt_size = u16le(g_coff_bytes, 16)
    sec_ptr = 20 + opt_size
    si: i64 = 0
    while si < section_count {
        sec_index = si + 1
        li = g_obj_section_link_indices[sec_index]
        sh = sec_ptr + si * 40
        reloc_ptr = u32le(g_coff_bytes, sh + 24)
        reloc_count = u16le(g_coff_bytes, sh + 32)
        ri: i64 = 0
        while ri < reloc_count {
            ro = reloc_ptr + ri * 10
            rel_off = u32le(g_coff_bytes, ro)
            sym_index = u32le(g_coff_bytes, ro + 4)
            kind = u16le(g_coff_bytes, ro + 8)
            if li >= 0 {
                patch_off = g_obj_section_offsets[sec_index] + rel_off
                place_rva = g_link_sec_rvas[li] + patch_off
                target_rva = coff_resolve_symbol_rva(sym_ptr, sym_count, sym_index)
                if kind == 4 {
                    addend = coff_section_i32le(li, patch_off)
                    value = target_rva + addend - (place_rva + 4)
                    coff_section_set_u32le(li, patch_off, value)
                } else if kind == 3 {
                    addend2 = coff_section_u32le(li, patch_off)
                    coff_section_set_u32le(li, patch_off, target_rva + addend2)
                }
            }
            ri = ri + 1
        }
        si = si + 1
    }
}

fn coff_probe_obj(path: str) {
    bs = file_read_bytes(path)
    g_coff_bytes = bs
    machine = u16le(bs, 0)
    section_count = u16le(bs, 2)
    sym_ptr = u32le(bs, 8)
    sym_count = u32le(bs, 12)
    opt_size = u16le(bs, 16)
    sec_ptr = 20 + opt_size

    reloc_total = 0
    discardable_count = 0
    code_count = 0
    data_count = 0
    bss_count = 0
    i: i64 = 0
    while i < section_count {
        off = sec_ptr + i * 40
        reloc_total = reloc_total + u16le(bs, off + 32)
        chars = u32le(bs, off + 36)
        if coff_has_flag(chars, 2048) { discardable_count = discardable_count + 1 }
        if coff_has_flag(chars, 32) { code_count = code_count + 1 }
        if coff_has_flag(chars, 64) { data_count = data_count + 1 }
        if coff_has_flag(chars, 128) { bss_count = bss_count + 1 }
        i = i + 1
    }

    undefined_count = 0
    si: i64 = 0
    while si < sym_count {
        so = sym_ptr + si * 18
        sec_no = i16le(bs, so + 12)
        aux_count = bs[so + 17]
        if sec_no == 0 { undefined_count = undefined_count + 1 }
        si = si + 1 + aux_count
    }

    print(file_size(path))
    print(len(bs))
    print(machine)
    print(section_count)
    print(sym_ptr)
    print(sym_count)
    print(sec_ptr)
    print(reloc_total)
    print(discardable_count)
    print(code_count)
    print(data_count)
    print(bss_count)
    print(undefined_count)
}

fn coff_probe_imports(path: str) {
    bs = file_read_bytes(path)
    g_coff_bytes = bs
    sym_ptr = u32le(bs, 8)
    sym_count = u32le(bs, 12)

    undefined_count = 0
    helper_count = 0
    supported_import_count = 0
    unsupported_count = 0

    si = 0
    while si < sym_count {
        so = sym_ptr + si * 18
        sec_no = i16le(bs, so + 12)
        aux_count = bs[so + 17]
        if sec_no == 0 {
            nm = coff_symbol_name(sym_ptr, sym_count, si)
            undefined_count = undefined_count + 1
            if coff_is_helper_symbol(nm) {
                helper_count = helper_count + 1
            } else if coff_is_supported_import(nm) {
                supported_import_count = supported_import_count + 1
            } else {
                unsupported_count = unsupported_count + 1
                print("unsupported:" + nm)
            }
            print(nm)
        }
        si = si + 1 + aux_count
    }

    print("undefined=" + to_string(undefined_count))
    print("helpers=" + to_string(helper_count))
    print("supported_imports=" + to_string(supported_import_count))
    print("unsupported=" + to_string(unsupported_count))
}

fn coff_probe_import_bytes(path: str, prefix: str) {
    bs = file_read_bytes(path)
    g_coff_bytes = bs
    sym_ptr = u32le(bs, 8)
    sym_count = u32le(bs, 12)
    coff_collect_sorted_imports(sym_ptr, sym_count)
    coff_build_import_bytes()
    coff_build_thunk_bytes()

    file_write_bytes(prefix + ".idata.bin", g_link_idata)
    file_write_bytes(prefix + ".thunks.bin", g_link_thunks)

    print("imports=" + to_string(len(g_link_imports)))
    print("idata_len=" + to_string(len(g_link_idata)))
    print("thunks_len=" + to_string(len(g_link_thunks)))
}

fn coff_probe_finalized_import_bytes(path: str, prefix: str, idata_rva: i64, thunks_rva: i64) {
    bs = file_read_bytes(path)
    g_coff_bytes = bs
    sym_ptr = u32le(bs, 8)
    sym_count = u32le(bs, 12)
    coff_collect_sorted_imports(sym_ptr, sym_count)
    coff_build_import_bytes()
    coff_build_thunk_bytes()
    coff_finalize_import_bytes(idata_rva, thunks_rva)

    file_write_bytes(prefix + ".idata.final.bin", g_link_idata)
    file_write_bytes(prefix + ".thunks.final.bin", g_link_thunks)

    print("imports=" + to_string(len(g_link_imports)))
    print("idata_len=" + to_string(len(g_link_idata)))
    print("thunks_len=" + to_string(len(g_link_thunks)))
    print("idata_rva=" + to_string(idata_rva))
    print("thunks_rva=" + to_string(thunks_rva))
}

fn coff_probe_layout(path: str) {
    bs = file_read_bytes(path)
    g_coff_bytes = bs
    sym_ptr = u32le(bs, 8)
    sym_count = u32le(bs, 12)
    coff_collect_sorted_imports(sym_ptr, sym_count)
    coff_layout_sections()

    i: i64 = 0
    while i < len(g_link_sec_names) {
        print(to_string(i) + " " + g_link_sec_names[i] + " " + to_string(g_link_sec_data_lens[i]) + " " + to_string(g_link_sec_virtual_sizes[i]) + " " + to_string(g_link_sec_chars[i]) + " " + to_string(g_link_sec_rvas[i]))
        i = i + 1
    }
    print("section_offsets")
    section_count = u16le(bs, 2)
    j: i64 = 1
    while j <= section_count {
        if g_obj_section_offsets[j] != -1 {
            print(to_string(j) + " " + to_string(g_obj_section_offsets[j]))
        }
        j = j + 1
    }
    print("count " + to_string(len(g_link_sec_names)))
}

fn coff_probe_relocs(path: str, limit: i64) {
    bs = file_read_bytes(path)
    g_coff_bytes = bs
    sym_ptr = u32le(bs, 8)
    sym_count = u32le(bs, 12)
    section_count = u16le(bs, 2)
    opt_size = u16le(bs, 16)
    sec_ptr = 20 + opt_size

    coff_collect_sorted_imports(sym_ptr, sym_count)
    coff_layout_sections()

    printed: i64 = 0
    total: i64 = 0
    si: i64 = 0
    while si < section_count {
        sh = sec_ptr + si * 40
        sec_index = si + 1
        reloc_ptr = u32le(bs, sh + 24)
        reloc_count = u16le(bs, sh + 32)
        ri: i64 = 0
        while ri < reloc_count {
            ro = reloc_ptr + ri * 10
            rel_off = u32le(bs, ro)
            sym_index = u32le(bs, ro + 4)
            kind = u16le(bs, ro + 8)
            li = g_obj_section_link_indices[sec_index]
            if li >= 0 {
                patch_off = g_obj_section_offsets[sec_index] + rel_off
                place_rva = g_link_sec_rvas[li] + patch_off
                target_rva = coff_resolve_symbol_rva(sym_ptr, sym_count, sym_index)
                nm = coff_symbol_name(sym_ptr, sym_count, sym_index)
                if printed < limit {
                    print(to_string(total) + " sec=" + to_string(sec_index) + " off=" + to_string(rel_off) + " sym=" + to_string(sym_index) + " name=" + nm + " kind=" + to_string(kind) + " patch=" + to_string(patch_off) + " place=" + to_string(place_rva) + " target=" + to_string(target_rva))
                    printed = printed + 1
                }
                total = total + 1
            }
            ri = ri + 1
        }
        si = si + 1
    }
    print("reloc_count " + to_string(total))
}

fn coff_probe_patched_sections(path: str, prefix: str) {
    bs = file_read_bytes(path)
    g_coff_bytes = bs
    sym_ptr = u32le(bs, 8)
    sym_count = u32le(bs, 12)
    coff_collect_sorted_imports(sym_ptr, sym_count)
    coff_layout_sections()
    dli = coff_find_link_section(".dthnk", 1615855648)
    ili = coff_find_link_section(".idata", 3224371264)
    if dli >= 0 and ili >= 0 {
        coff_finalize_import_bytes(g_link_sec_rvas[ili], g_link_sec_rvas[dli])
    }
    coff_build_merged_section_bytes()
    coff_apply_relocations()

    file_write_bytes(prefix + ".text.bin", g_sec_text)
    file_write_bytes(prefix + ".xdata.bin", g_sec_xdata)
    file_write_bytes(prefix + ".rdata.bin", g_sec_rdata)
    file_write_bytes(prefix + ".pdata.bin", g_sec_pdata)
    file_write_bytes(prefix + ".dthnk.bin", g_sec_dthnk)
    file_write_bytes(prefix + ".idata.bin", g_sec_idata)

    print(".text " + to_string(len(g_sec_text)))
    print(".xdata " + to_string(len(g_sec_xdata)))
    print(".rdata " + to_string(len(g_sec_rdata)))
    print(".pdata " + to_string(len(g_sec_pdata)))
    print(".dthnk " + to_string(len(g_sec_dthnk)))
    print(".idata " + to_string(len(g_sec_idata)))
}

// ─── main ─────────────────────────────────────────────────────────────────
fn compiler_main() {
    args = get_args()
    if len(args) == 0 {
        print("사용법: danha selfhost <input.dh> [--out <name>] [--linker danha|external] [--emit-ir|--emit-obj]")
        print("개발용: danhac_dos.exe --probe-obj <input.obj>")
        return
    }
    if args[0] == "--probe-obj" {
        if len(args) < 2 {
            print("사용법: danhac_dos.exe --probe-obj <input.obj>")
            return
        }
        coff_probe_obj(args[1])
        return
    }
    if args[0] == "--probe-imports" {
        if len(args) < 2 {
            print("사용법: danhac_dos.exe --probe-imports <input.obj>")
            return
        }
        coff_probe_imports(args[1])
        return
    }
    if args[0] == "--probe-import-bytes" {
        if len(args) < 3 {
            print("사용법: danhac_dos.exe --probe-import-bytes <input.obj> <out-prefix>")
            return
        }
        coff_probe_import_bytes(args[1], args[2])
        return
    }
    if args[0] == "--probe-finalized-import-bytes" {
        if len(args) < 5 {
            print("사용법: danhac_dos.exe --probe-finalized-import-bytes <input.obj> <out-prefix> <idata-rva> <thunks-rva>")
            return
        }
        coff_probe_finalized_import_bytes(args[1], args[2], to_int(args[3]), to_int(args[4]))
        return
    }
    if args[0] == "--probe-layout" {
        if len(args) < 2 {
            print("사용법: danhac_dos.exe --probe-layout <input.obj>")
            return
        }
        coff_probe_layout(args[1])
        return
    }
    if args[0] == "--probe-relocs" {
        if len(args) < 2 {
            print("사용법: danhac_dos.exe --probe-relocs <input.obj> [limit]")
            return
        }
        lim = 80
        if len(args) >= 3 { lim = to_int(args[2]) }
        coff_probe_relocs(args[1], lim)
        return
    }
    if args[0] == "--probe-patched-sections" {
        if len(args) < 3 {
            print("사용법: danhac_dos.exe --probe-patched-sections <input.obj> <out-prefix>")
            return
        }
        coff_probe_patched_sections(args[1], args[2])
        return
    }
    in_file = args[0]
    out_name = in_file
    runtime_mode = "libc"
    linker_mode = "auto"
    emit_ir_only = false
    emit_obj_only = false
    dl = len(in_file)
    if dl > 3 and in_file[dl - 3] == "." and in_file[dl - 2] == "d" and in_file[dl - 1] == "h" {
        j = 0; out_name = ""
        while j < dl - 3 { out_name = out_name + in_file[j]; j = j + 1 }
    }
    i = 1
    while i < len(args) {
        if args[i] == "--out" and i + 1 < len(args) { out_name = args[i + 1]; i = i + 2 }
        else if args[i] == "--runtime" and i + 1 < len(args) { runtime_mode = args[i + 1]; i = i + 2 }
        else if args[i] == "--linker" and i + 1 < len(args) { linker_mode = args[i + 1]; i = i + 2 }
        else if args[i] == "--emit-ir" { emit_ir_only = true; i = i + 1 }
        else if args[i] == "--emit-obj" { emit_obj_only = true; i = i + 1 }
        else if args[i] == "--debug-codegen" { g_debug_codegen = true; i = i + 1 }
        else { i = i + 1 }
    }
    if runtime_mode == "direct-os" { g_runtime_direct = true }
    else if runtime_mode == "direct-linux" { g_runtime_direct = true; g_target_linux = true }
    else { g_runtime_direct = false }
    // 모듈 탐색 기준 디렉토리 = 입력 파일 디렉토리 (구분자 포함)
    sd = ""
    cur2 = ""
    di = 0
    while di < len(in_file) {
        c2 = in_file[di]
        cur2 = cur2 + c2
        if c2 == "/" or c2 == "\\" { sd = sd + cur2; cur2 = "" }
        di = di + 1
    }
    g_src_dir = sd
    ll_file = out_name + ".ll"
    src = file_read(in_file)
    print("danhac: 렉싱 " + in_file + " ...")
    lex(src)
    print("danhac: 파싱 ...")
    root = parse_program()
    print("danhac: 코드젠 ...")
    cg_program(root)
    write_ir_file(ll_file)
    print("danhac: IR → " + ll_file)
    meta_file = out_name + ".selfhost.txt"
    target_name = "windows"
    if g_target_linux { target_name = "linux" }
    meta = "compiler=danhac.dh\nsource=" + in_file + "\nruntime=" + runtime_mode + "\ntarget=" + target_name + "\nir=" + ll_file + "\n"
    file_write(meta_file, meta)
    if emit_ir_only {
        print("danhac: 완료(IR만) → " + ll_file)
        return
    }
    exe_file = out_name + ".exe"
    if g_target_linux { exe_file = out_name }
    clang_cmd = "clang"
    local_clang = "C:\\Users\\이현욱\\AppData\\Local\\LLVM\\bin\\clang.exe"
    if file_exists(local_clang) { clang_cmd = "\"" + local_clang + "\"" }
    if linker_mode == "auto" {
        if g_runtime_direct and not g_target_linux and len(g_clink_libs) == 0 { linker_mode = "danha" }
        else { linker_mode = "external" }
    }
    obj_file = out_name + ".obj"
    if linker_mode == "danha" and g_runtime_direct and not g_target_linux and len(g_clink_libs) == 0 {
        cmd = clang_cmd + " -c \"" + ll_file + "\" -o \"" + obj_file + "\" -O2"
        print("danhac: " + cmd)
        ret = os_exec(cmd)
        if ret != 0 {
            print("danhac: clang object 실패 (코드 " + to_string(ret) + ")")
            return
        }
        if emit_obj_only {
            print("danhac: 완료(OBJ만) → " + obj_file)
            return
        }
        link_cmd = "python danha_pe_linker.py \"" + obj_file + "\" \"" + exe_file + "\""
        print("danhac: " + link_cmd)
        ret2 = os_exec(link_cmd)
        if ret2 == 0 { print("danhac: 완료(Danha linker) → " + exe_file) }
        else         { print("danhac: Danha linker 실패 (코드 " + to_string(ret2) + ")") }
    } else {
        cmd = clang_cmd + " \"" + ll_file + "\" -o \"" + exe_file + "\" -O2"
        if g_target_linux {
            // Windows clang + lld로 ELF 크로스 링크 (raw-syscall이라 라이브러리 불필요)
            cmd = cmd + " --target=x86_64-pc-linux-gnu -nostdlib -fuse-ld=lld"
        } else if g_runtime_direct {
            cmd = cmd + " -nostdlib -Wl,/entry:main -lkernel32"
        }
        if len(g_clink_libs) > 0 { cmd = cmd + " -L." }
        li2 = 0
        while li2 < len(g_clink_libs) { cmd = cmd + " -l" + g_clink_libs[li2]; li2 = li2 + 1 }
        print("danhac: " + cmd)
        ret3 = os_exec(cmd)
        if ret3 == 0 { print("danhac: 완료(external linker) → " + exe_file) }
        else         { print("danhac: clang 실패 (코드 " + to_string(ret3) + ")") }
    }
}

compiler_main()
