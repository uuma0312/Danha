    emit("define i64 @dnh_sys6(i64 %nr, i64 %a, i64 %b, i64 %c, i64 %d, i64 %e, i64 %f) \{")
    emit("entry:")
    emit("  %r = call i64 asm sideeffect \"syscall\", \"=\{rax\},\{rax\},\{rdi\},\{rsi\},\{rdx\},\{r10\},\{r8\},\{r9\},~\{rcx\},~\{r11\},~\{memory\}\"(i64 %nr, i64 %a, i64 %b, i64 %c, i64 %d, i64 %e, i64 %f)")
