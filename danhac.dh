        // dot(a, b) — 벡터 내적 (원소곱 + 수평 합)
        if fname_c == "dot" and nargs == 2 {
            if is_vec_ty(arg_ts[0]) and arg_ts[0] == arg_ts[1] {
                vty = arg_ts[0]
                vn2 = vec_ty_n(vty)
                mr = new_reg()
                emit("  " + mr + " = fmul " + vty + " " + arg_rs[0] + ", " + arg_rs[1])
                acc = ""
                vi2 = 0
                while vi2 < vn2 {
                    er2 = new_reg()
                    emit("  " + er2 + " = extractelement " + vty + " " + mr + ", i32 " + to_string(vi2))
                    if vi2 == 0 { acc = er2 }
                    else {
                        na2 = new_reg()
                        emit("  " + na2 + " = fadd double " + acc + ", " + er2)
                        acc = na2
                    }
                    vi2 = vi2 + 1
                }
                g_expr_reg = acc; g_expr_ty = "double"; return
            }
        }
        if fname_c == "length" and nargs == 1 and is_vec_ty(arg0t) {
