        }
        if (fname_c == "mat4_transpose" or fname_c == "mat4_inverse") and nargs == 1 {
            mfn = "dnh_m4_transpose"
            if fname_c == "mat4_inverse" { mfn = "dnh_m4_inverse" }
            if not is_mat_ty(arg_ts[0]) {
                fatal(fname_c + "()는 mat4에만 쓸 수 있어 (줄 " + to_string(g_nline[n]) + ")")
            }
            r = new_reg()
            emit("  " + r + " = call " + m4ty() + " @" + mfn + "(" + m4ty() + " " + arg_rs[0] + ")")
            g_expr_reg = r; g_expr_ty = m4ty(); return
        }
        // 제네릭 함수 호출 — 인자 타입으로 모노모피제이션
        gix = gen_find(fname_c)
        if gix != -1 {
            gnode = g_gen_nodes[gix]
            if nargs != g_nch_n[gnode] {
                fatal("제네릭 " + fname_c + "은(는) 인자 " + to_string(g_nch_n[gnode]) + "개가 필요한데 " + to_string(nargs) + "개가 들어왔어 (줄 " + to_string(g_nline[n]) + ")")
            }
            sv_actn = len(g_tp_act_names)
            mono = fname_c
            gti = g_gen_tp_s[gix]
            gtend = gti + g_gen_tp_n[gix]
            while gti < gtend {
                tpn = g_gen_tps[gti]
                mty = ""
                gai = 0
                while gai < nargs {
                    gp = g_ch[g_nch_s[gnode] + gai]
                    if g_ntype[gp] == tpn { mty = arg_ts[gai]; break }
                    gai = gai + 1
                }
                if mty == "" {
                    fatal("제네릭 " + fname_c + ": 타입 매개변수 '" + tpn + "'를 인자에서 추론할 수 없어 (줄 " + to_string(g_nline[n]) + ")")
                }
                push(g_tp_act_names, tpn)
                push(g_tp_act_tys, mty)
                mono = mono + "__" + ty_sane(mty)
                gti = gti + 1
            }
            if find_fn(mono) == -1 {
                // 별도 버퍼에 인스턴스화 (현재 함수 방출과 분리)
                sv_go: [str] = g_out
                sv_gab: [str] = g_alloca_buf
                g_out = []
                g_alloca_buf = []
                sv_gnm = g_nsval[gnode]
                g_nsval[gnode] = mono
                cg_fn(gnode)
                g_nsval[gnode] = sv_gnm
                ggo = 0
                while ggo < len(g_out) { push(g_gen_out, g_out[ggo]); ggo = ggo + 1 }
                g_out = sv_go
                g_alloca_buf = sv_gab
            }
            while len(g_tp_act_names) > sv_actn { pop(g_tp_act_names); pop(g_tp_act_tys) }
            gfi = find_fn(mono)
            grty = g_fn_rets[gfi]
            gastr = ""
            gai = 0
            while gai < nargs {
                gav = arg_rs[gai]; gat = arg_ts[gai]
                gwant = g_fn_ptys[g_fn_ps[gfi] + gai]
                if gwant != gat { gav = coerce_to(gav, gat, gwant); gat = gwant }
                if gai > 0 { gastr = gastr + ", " }
                gastr = gastr + gat + " " + gav
                gai = gai + 1
            }
            if grty == "void" or grty == "()" {
                emit("  call void @" + mono + "(" + gastr + ")")
                g_expr_reg = ""; g_expr_ty = "void"; return
            }
            r = new_reg()
            emit("  " + r + " = call " + grty + " @" + mono + "(" + gastr + ")")
            g_expr_reg = r; g_expr_ty = grty; return
        }
        ret_ty = "i64"
        fi = find_fn(fname_c)
        if fi != -1 { ret_ty = g_fn_rets[fi] }
        // 람다가 바인딩된 변수 호출: f = fn(...) {...}; f(1, 2)
        if fi == -1 {
            lcvi = find_var(fname_c)
            if lcvi != -1 {
                if g_var_lams[lcvi] >= 0 {
                    clid = g_var_lams[lcvi]
                    castr = ""
                    cai2 = 0
                    while cai2 < nargs {
                        cav = arg_rs[cai2]; cat = arg_ts[cai2]
                        if cai2 < g_lam_nps[clid] {
                            cwant = g_lam_ptys[g_lam_ps[clid] + cai2]
                            if cwant != cat { cav = coerce_to(cav, cat, cwant); cat = cwant }
                        }
                        if cai2 > 0 { castr = castr + ", " }
                        castr = castr + cat + " " + cav
                        cai2 = cai2 + 1
                    }
                    castr = castr + lam_caps_str(clid, nargs)
                    cret2 = g_lam_rets[clid]
                    if cret2 == "void" or cret2 == "()" {
                        emit("  call void @_lam" + to_string(clid) + "(" + castr + ")")
                        g_expr_reg = ""; g_expr_ty = "void"; return
                    }
                    r = new_reg()
                    emit("  " + r + " = call " + cret2 + " @_lam" + to_string(clid) + "(" + castr + ")")
                    g_expr_reg = r; g_expr_ty = cret2; return
                }
            }
        }
        astr = ""
        wb_lists: [str] = []
        wb_tmps: [str] = []
        wb_tys: [str] = []
        i = 0
        while i < nargs {
            av = arg_rs[i]; at = arg_ts[i]
            if fi != -1 and i < g_fn_arities[fi] {
                want = g_fn_ptys[g_fn_ps[fi] + i]
                if want != at and want != "" {
                    if at == "%DnhList*" and (is_arr_val(want) or is_arr_ptr(want)) {
                        want_base = arr_base_ty(want)
                        tmpa = "%__argarr" + to_string(g_reg) + "_v"; g_reg = g_reg + 1
                        emit_alloca("  " + tmpa + " = alloca " + want_base)
                        ety2 = arr_elem_ll(want_base)
                        ai4: i64 = 0
                        an4 = arr_len_ll(want_base)
                        while ai4 < an4 {
                            sv4 = new_reg()
                            emit("  " + sv4 + " = call i64 @dnh_get(%DnhList* " + av + ", i64 " + to_string(ai4) + ")")
                            ev4 = sv4
                            if ety2 == "double" {
                                ev4 = new_reg()
                                emit("  " + ev4 + " = bitcast i64 " + sv4 + " to double")
                            } else if ety2 == "i32" {
                                ev4 = new_reg()
                                emit("  " + ev4 + " = trunc i64 " + sv4 + " to i32")
                            } else if ety2 == "i8*" {
                                ev4 = new_reg()
                                emit("  " + ev4 + " = inttoptr i64 " + sv4 + " to i8*")
                            }
                            gp4 = new_reg()
                            emit("  " + gp4 + " = getelementptr inbounds " + want_base + ", " + want_base + "* " + tmpa + ", i64 0, i64 " + to_string(ai4))
                            emit("  store " + ety2 + " " + ev4 + ", " + ety2 + "* " + gp4)
                            ai4 = ai4 + 1
                        }
                        if is_arr_ptr(want) {
                            push(wb_lists, av); push(wb_tmps, tmpa); push(wb_tys, want_base)
                            av = tmpa; at = want
                        } else {
                            lv4 = new_reg()
                            emit("  " + lv4 + " = load " + want + ", " + want + "* " + tmpa)
                            av = lv4; at = want
                        }
                    } else {
                        av = coerce_to(av, at, want); at = want
                    }
                }
            }
            if i > 0 { astr = astr + ", " }
            astr = astr + at + " " + av
            i = i + 1
        }
        if ret_ty == "void" or ret_ty == "()" {
            emit("  call void @" + fname_c + "(" + astr + ")")
            wi = 0
            while wi < len(wb_lists) {
                wb_list = wb_lists[wi]; wb_tmp = wb_tmps[wi]; wb_ty = wb_tys[wi]
                wb_ety = arr_elem_ll(wb_ty)
                wj: i64 = 0
                wn = arr_len_ll(wb_ty)
                while wj < wn {
                    wgp = new_reg()
                    emit("  " + wgp + " = getelementptr inbounds " + wb_ty + ", " + wb_ty + "* " + wb_tmp + ", i64 0, i64 " + to_string(wj))
                    wlv = new_reg()
                    emit("  " + wlv + " = load " + wb_ety + ", " + wb_ety + "* " + wgp)
                    wslot = val_to_slot(wlv, wb_ety)
                    emit("  call void @dnh_set(%DnhList* " + wb_list + ", i64 " + to_string(wj) + ", i64 " + wslot + ")")
                    wj = wj + 1
                }
                wi = wi + 1
            }
            g_expr_reg = ""; g_expr_ty = "void"
        } else {
            r = new_reg()
            emit("  " + r + " = call " + ret_ty + " @" + fname_c + "(" + astr + ")")
            wi = 0
            while wi < len(wb_lists) {
                wb_list = wb_lists[wi]; wb_tmp = wb_tmps[wi]; wb_ty = wb_tys[wi]
                wb_ety = arr_elem_ll(wb_ty)
                wj: i64 = 0
                wn = arr_len_ll(wb_ty)
                while wj < wn {
                    wgp = new_reg()
                    emit("  " + wgp + " = getelementptr inbounds " + wb_ty + ", " + wb_ty + "* " + wb_tmp + ", i64 0, i64 " + to_string(wj))
                    wlv = new_reg()
                    emit("  " + wlv + " = load " + wb_ety + ", " + wb_ety + "* " + wgp)
                    wslot = val_to_slot(wlv, wb_ety)
                    emit("  call void @dnh_set(%DnhList* " + wb_list + ", i64 " + to_string(wj) + ", i64 " + wslot + ")")
                    wj = wj + 1
                }
                wi = wi + 1
            }
            g_expr_reg = r; g_expr_ty = ret_ty
        }
        return
    }

    // 메서드 호출
    if k == NK_METHOD {
        mname = g_nsval[n]
        eobj = g_nc0[n]
        if g_nkind[eobj] == NK_ID {
            // Arena.new(cap) 빌트인 생성자
            if g_nsval[eobj] == "Arena" and mname == "new" and g_nch_n[n] == 1 {
                cg_expr(g_ch[g_nch_s[n]])
                capv = sext32(g_expr_reg, g_expr_ty)
                r = new_reg()
                emit("  " + r + " = call %DnhArena* @dnh_arena_new(i64 " + capv + ")")
                g_expr_reg = r; g_expr_ty = "%DnhArena*"; return
            }
            // HashMap.new() / HashMap.new(cap) 빌트인 생성자 — 선형 저장이라 cap은 평가만 하고 무시
            if g_nsval[eobj] == "HashMap" and mname == "new" {
                if g_nch_n[n] > 0 { cg_expr(g_ch[g_nch_s[n]]) }
                r = new_reg()
                emit("  " + r + " = call %DnhHM* @dnh_hm_new()")
                g_expr_reg = r; g_expr_ty = "%DnhHM*"; return
            }
            // Enum.Variant(payload) 생성자
            evi = find_variant(g_nsval[eobj], mname)
            if evi != -1 {
                pay = "0"
                if g_nch_n[n] > 0 {
                    cg_expr(g_ch[g_nch_s[n]])
                    pay = val_to_slot(g_expr_reg, g_expr_ty)
                }
                r = new_reg()
                emit("  " + r + " = call %DnhEnum* @dnh_enum_new(i64 " + to_string(g_vrt_tag[evi]) + ", i64 " + pay + ")")
                g_expr_reg = r; g_expr_ty = "%DnhEnum*"; return
            }
            // 모듈 네임스페이스 호출: utils.f(...) (변수가 같은 이름이면 변수 우선)
            if find_var(g_nsval[eobj]) == -1 and mod_has(g_nsval[eobj]) {
                cg_mod_call(n)
                return
            }
        }
        cg_expr(g_nc0[n]); obj_r = g_expr_reg; obj_ty = g_expr_ty
        obj_el = g_expr_elem
        // 트레잇 객체 동적 디스패치: %dyn.T* 메서드 → vtable 간접 호출
        dtn = dyn_of_ty(obj_ty)
        if dtn != "" {
            cg_dyn_method(n, dtn, obj_r, mname)
            return
        }
        // 리스트 메서드 + HOF 콜백
        if obj_ty == "%DnhList*" {
            if mname == "len" and g_nch_n[n] == 0 {
                r = new_reg()
                emit("  " + r + " = call i64 @dnh_len(%DnhList* " + obj_r + ")")
                g_expr_reg = r; g_expr_ty = "i64"; return
            }
            if mname == "push" and g_nch_n[n] == 1 {
                cg_expr(g_ch[g_nch_s[n]])
                hsv = val_to_slot(g_expr_reg, g_expr_ty)
                emit("  call void @dnh_push(%DnhList* " + obj_r + ", i64 " + hsv + ")")
                g_expr_reg = "0"; g_expr_ty = "void"; return
            }
            if mname == "pop" and g_nch_n[n] == 0 {
                r = new_reg()
                emit("  " + r + " = call i64 @dnh_pop(%DnhList* " + obj_r + ")")
                g_expr_reg = r; g_expr_ty = "i64"; return
            }
            hof1 = mname == "map" or mname == "filter" or mname == "count" or mname == "any" or mname == "all" or mname == "for_each"
            if hof1 and g_nch_n[n] == 1 {
                cg_expr(g_ch[g_nch_s[n]])
                hlid = g_expr_lam
                if hlid < 0 {
                    fatal("리스트 " + mname + " 콜백은 람다(fn(...) \{ ... \})가 필요해 (줄 " + to_string(g_nline[n]) + ")")
                }
                cg_list_hof(mname, obj_r, obj_el, hlid)
                return
            }
            if mname == "reduce" and g_nch_n[n] == 2 {
                cg_expr(g_ch[g_nch_s[n]])
                hinit = g_expr_reg; hinit_ty = g_expr_ty
                cg_expr(g_ch[g_nch_s[n] + 1])
                hlid = g_expr_lam
                if hlid < 0 {
                    fatal("reduce 콜백은 람다가 필요해 (줄 " + to_string(g_nline[n]) + ")")
                }
                cg_list_reduce(obj_r, hlid, hinit, hinit_ty)
                return
            }
            if (mname == "find" or mname == "sort_by") and g_nch_n[n] == 1 {
                cg_expr(g_ch[g_nch_s[n]])
                hlid = g_expr_lam
                if hlid < 0 {
                    fatal("리스트 " + mname + " 콜백은 람다(fn(...) \{ ... \})가 필요해 (줄 " + to_string(g_nline[n]) + ")")
                }
                if mname == "find" { cg_list_find(obj_r, obj_el, hlid) }
                else { cg_list_sort_by(obj_r, obj_el, hlid) }
                return
            }
            if mname == "contains" and g_nch_n[n] == 1 {
                cg_expr(g_ch[g_nch_s[n]])
                cg_list_contains(obj_r, obj_el, g_expr_reg, g_expr_ty)
                return
            }
            if mname == "reverse" and g_nch_n[n] == 0 {
                cg_list_reverse(obj_r, obj_el)
                return
            }
            if (mname == "take" or mname == "skip") and g_nch_n[n] == 1 {
                cg_expr(g_ch[g_nch_s[n]])
                tsn = sext32(g_expr_reg, g_expr_ty)
                cg_list_take_skip(mname, obj_r, obj_el, tsn)
                return
            }
        }
        // Result(tagged enum) 메서드 — is_ok/is_err/unwrap_or (py 36a 패리티)
        if obj_ty == "%DnhEnum*" {
            if mname == "is_ok" or mname == "is_err" {
                okv9 = find_variant_any("Ok")
                if okv9 == -1 {
                    fatal("is_ok/is_err: Ok variant가 정의된 enum이 필요해 (줄 " + to_string(g_nline[n]) + ")")
                }
                tp9 = new_reg()
                emit("  " + tp9 + " = getelementptr inbounds %DnhEnum, %DnhEnum* " + obj_r + ", i32 0, i32 0")
                tg9 = new_reg()
                emit("  " + tg9 + " = load i64, i64* " + tp9)
                r = new_reg()
                if mname == "is_ok" {
                    emit("  " + r + " = icmp eq i64 " + tg9 + ", " + to_string(g_vrt_tag[okv9]))
                } else {
                    emit("  " + r + " = icmp ne i64 " + tg9 + ", " + to_string(g_vrt_tag[okv9]))
                }
                g_expr_reg = r; g_expr_ty = "i1"; return
            }
            if mname == "unwrap_or" and g_nch_n[n] == 1 {
                okv9 = find_variant_any("Ok")
                if okv9 == -1 {
                    fatal("unwrap_or: Ok variant가 정의된 enum이 필요해 (줄 " + to_string(g_nline[n]) + ")")
                }
                cg_expr(g_ch[g_nch_s[n]]); udv = g_expr_reg; udt = g_expr_ty
                tp9 = new_reg()
                emit("  " + tp9 + " = getelementptr inbounds %DnhEnum, %DnhEnum* " + obj_r + ", i32 0, i32 0")
                tg9 = new_reg()
                emit("  " + tg9 + " = load i64, i64* " + tp9)
                uok = new_reg()
                emit("  " + uok + " = icmp eq i64 " + tg9 + ", " + to_string(g_vrt_tag[okv9]))
                pp9 = new_reg()
                emit("  " + pp9 + " = getelementptr inbounds %DnhEnum, %DnhEnum* " + obj_r + ", i32 0, i32 1")
                pv9 = new_reg()
                emit("  " + pv9 + " = load i64, i64* " + pp9)
                // payload는 i64 슬롯 — 기본값 타입에 맞춰 디코드 후 select
                if udt == "double" {
                    pd9 = new_reg()
                    emit("  " + pd9 + " = bitcast i64 " + pv9 + " to double")
                    r = new_reg()
                    emit("  " + r + " = select i1 " + uok + ", double " + pd9 + ", double " + udv)
                    g_expr_reg = r; g_expr_ty = "double"; return
                }
                if udt == "i8*" {
                    ps9 = new_reg()
                    emit("  " + ps9 + " = inttoptr i64 " + pv9 + " to i8*")
                    r = new_reg()
                    emit("  " + r + " = select i1 " + uok + ", i8* " + ps9 + ", i8* " + udv)
                    g_expr_reg = r; g_expr_ty = "i8*"; return
                }
                ud64 = sext32(udv, udt)
                r = new_reg()
                emit("  " + r + " = select i1 " + uok + ", i64 " + pv9 + ", i64 " + ud64)
                g_expr_reg = r; g_expr_ty = "i64"; return
            }
        }
        // Arena 인스턴스 메서드
        if obj_ty == "%DnhArena*" {
            if mname == "alloc" and g_nch_n[n] == 1 {
                cg_expr(g_ch[g_nch_s[n]])
                szv = sext32(g_expr_reg, g_expr_ty)
                r = new_reg()
                emit("  " + r + " = call i64 @dnh_arena_alloc(%DnhArena* " + obj_r + ", i64 " + szv + ")")
                g_expr_reg = r; g_expr_ty = "i64"; return
            }
            if mname == "used" {
                r = new_reg()
                emit("  " + r + " = call i64 @dnh_arena_used(%DnhArena* " + obj_r + ")")
                g_expr_reg = r; g_expr_ty = "i64"; return
            }
            if mname == "capacity" {
                r = new_reg()
                emit("  " + r + " = call i64 @dnh_arena_cap(%DnhArena* " + obj_r + ")")
                g_expr_reg = r; g_expr_ty = "i64"; return
            }
            if mname == "reset" {
                emit("  call void @dnh_arena_reset(%DnhArena* " + obj_r + ")")
                g_expr_reg = "0"; g_expr_ty = "void"; return
            }
            if mname == "destroy" {
                emit("  call void @dnh_arena_destroy(%DnhArena* " + obj_r + ")")
                g_expr_reg = "0"; g_expr_ty = "void"; return
            }
        }
        // HashMap 인스턴스 메서드 — 키는 str(kkind 1, strcmp) 또는 정수(kkind 0)
        if obj_ty == "%DnhHM*" {
            if mname == "set" and g_nch_n[n] == 2 {
                cg_expr(g_ch[g_nch_s[n]])
                kr = g_expr_reg; kt = g_expr_ty
                kk = "0"
                if kt == "i8*" { kk = "1" }
                ks = val_to_slot(kr, kt)
                cg_expr(g_ch[g_nch_s[n] + 1])
                vs = val_to_slot(g_expr_reg, g_expr_ty)
                emit("  call void @dnh_hm_set(%DnhHM* " + obj_r + ", i64 " + kk + ", i64 " + ks + ", i64 " + vs + ")")
                g_expr_reg = "0"; g_expr_ty = "void"; return
            }
            hm1 = mname == "get" or mname == "get_i32" or mname == "get_f64" or mname == "get_str" or mname == "get_bool"
            if (hm1 or mname == "has" or mname == "remove") and g_nch_n[n] == 1 {
                cg_expr(g_ch[g_nch_s[n]])
                kr = g_expr_reg; kt = g_expr_ty
                kk = "0"
                if kt == "i8*" { kk = "1" }
                ks = val_to_slot(kr, kt)
                if mname == "has" or mname == "remove" {
                    hmfn = "dnh_hm_has"
                    if mname == "remove" { hmfn = "dnh_hm_remove" }
                    r = new_reg()
                    emit("  " + r + " = call i1 @" + hmfn + "(%DnhHM* " + obj_r + ", i64 " + kk + ", i64 " + ks + ")")
                    g_expr_reg = r; g_expr_ty = "i1"; return
                }
                r = new_reg()
                emit("  " + r + " = call i64 @dnh_hm_get(%DnhHM* " + obj_r + ", i64 " + kk + ", i64 " + ks + ")")
                if mname == "get_str" {
                    hmr = new_reg()
                    emit("  " + hmr + " = inttoptr i64 " + r + " to i8*")
                    g_expr_reg = hmr; g_expr_ty = "i8*"; return
                }
                if mname == "get_f64" {
                    hmr = new_reg()
                    emit("  " + hmr + " = bitcast i64 " + r + " to double")
                    g_expr_reg = hmr; g_expr_ty = "double"; return
                }
                if mname == "get_bool" {
                    hmr = new_reg()
                    emit("  " + hmr + " = icmp ne i64 " + r + ", 0")
                    g_expr_reg = hmr; g_expr_ty = "i1"; return
                }
                g_expr_reg = r; g_expr_ty = "i64"; return
            }
            if mname == "len" and g_nch_n[n] == 0 {
                r = new_reg()
                emit("  " + r + " = call i64 @dnh_hm_len(%DnhHM* " + obj_r + ")")
                g_expr_reg = r; g_expr_ty = "i64"; return
            }
            if mname == "keys" and g_nch_n[n] == 0 {
                r = new_reg()
                emit("  " + r + " = call %DnhList* @dnh_hm_keys(%DnhHM* " + obj_r + ")")
                g_expr_reg = r; g_expr_ty = "%DnhList*"; g_expr_elem = "str"; return
            }
        }
        // StringBuilder 포인터에 대한 메서드는 없음 (빌트인 함수 형태만 지원)
        // struct 메서드 정적 디스패치: obj.m(...) → Struct__m(obj, ...)
        msname = ""
        if len(obj_ty) > 8 {
            if obj_ty[1] == "s" and obj_ty[2] == "t" and obj_ty[3] == "r" {
                si2 = 8
                while si2 < len(obj_ty) and obj_ty[si2] != "*" { msname = msname + obj_ty[si2]; si2 = si2 + 1 }
            }
        }
        if msname != "" {
            fname2 = msname + "__" + mname
            fi2 = find_fn(fname2)
            if fi2 != -1 {
                ret2 = g_fn_rets[fi2]
                astr2 = obj_ty + " " + obj_r
                ai2 = 0
                while ai2 < g_nch_n[n] {
                    cg_expr(g_ch[g_nch_s[n] + ai2])
                    av2 = g_expr_reg; at2 = g_expr_ty
                    if ai2 + 1 < g_fn_arities[fi2] {
                        want2 = g_fn_ptys[g_fn_ps[fi2] + 1 + ai2]
                        if at2 != want2 { av2 = coerce_to(av2, at2, want2); at2 = want2 }
                    }
                    astr2 = astr2 + ", " + at2 + " " + av2
                    ai2 = ai2 + 1
                }
                if ret2 == "void" or ret2 == "()" {
                    emit("  call void @" + fname2 + "(" + astr2 + ")")
                    g_expr_reg = "0"; g_expr_ty = "void"; return
                }
                r = new_reg()
                emit("  " + r + " = call " + ret2 + " @" + fname2 + "(" + astr2 + ")")
                g_expr_reg = r; g_expr_ty = ret2; return
            }
        }
        nargs = g_nch_n[n]
        astr = obj_ty + " " + obj_r
        i = 0
        while i < nargs {
            cg_expr(g_ch[g_nch_s[n] + i])
            astr = astr + ", " + g_expr_ty + " " + g_expr_reg
            i = i + 1
        }
        r = new_reg()
        emit("  " + r + " = call i64 @__dnh_" + mname + "(" + astr + ")")
        g_expr_reg = r; g_expr_ty = "i64"; return
    }

    // 람다(클로저) — @_lamN 함수를 디퍼드 버퍼에 생성하고 함수 포인터를 반환.
    // 자유 변수는 생성 지점에서 값으로 로드해 추가 파라미터로 전달 (stage0과 동일).
    if k == NK_LAMBDA {
        lamid = g_lam_count
        g_lam_count = g_lam_count + 1
        lamname = "@_lam" + to_string(lamid)
        lnp = g_nch_n[n]
        push(g_lam_nps, lnp)
        push(g_lam_ps, len(g_lam_ptys))
        lret = ll_ty(g_ntype[g_nc1[n]])
        push(g_lam_rets, lret)
        lpi = 0
        while lpi < lnp {
            push(g_lam_ptys, ll_ty(g_ntype[g_ch[g_nch_s[n] + lpi]]))
            lpi = lpi + 1
        }
        // 자유 변수 수집
        g_lfv_names = []
        g_lfv_params = []
        lpi = 0
        while lpi < lnp {
            push(g_lfv_params, g_nsval[g_ch[g_nch_s[n] + lpi]])
            lpi = lpi + 1
        }
        lam_free_vars(g_nc0[n])
        // 캡처 값을 생성 지점(현재 버퍼)에서 로드해 등록
        push(g_lam_caps_s, len(g_lam_cap_tys))
        push(g_lam_caps_n, len(g_lfv_names))
        lci = 0
        while lci < len(g_lfv_names) {
            lvi = find_var(g_lfv_names[lci])
            lcty = g_var_tys[lvi]
            lcval = load_val(g_var_regs[lvi], lcty)
            push(g_lam_cap_names, g_lfv_names[lci])
            push(g_lam_cap_tys, lcty)
            push(g_lam_cap_regs, lcval)
            lci = lci + 1
        }
        // 본문은 별도 버퍼에 생성 (현재 함수 본문/alloca 버퍼와 분리)
        sv_lo: [str] = g_out
        sv_lab: [str] = g_alloca_buf
        g_out = []
        g_alloca_buf = []
        sv_lret = g_cur_fn_ret
        sv_lbr = g_loop_br_lbl
        sv_lco = g_loop_co_lbl
        g_cur_fn_ret = lret
        g_loop_br_lbl = ""
        g_loop_co_lbl = ""
        sv_lvlen = len(g_var_names)
        lpstr = ""
        lpi = 0
        while lpi < lnp {
            lpn = g_nsval[g_ch[g_nch_s[n] + lpi]]
            lpt = g_lam_ptys[g_lam_ps[lamid] + lpi]
            if lpi > 0 { lpstr = lpstr + ", " }
            lpstr = lpstr + lpt + " %" + lpn + "_arg"
            lpreg = "%" + lpn + "_v"
            emit_alloca("  " + lpreg + " = alloca " + lpt)
            emit("  store " + lpt + " %" + lpn + "_arg, " + lpt + "* " + lpreg)
            decl_var(lpn, lpreg, lpt)
            lpi = lpi + 1
        }
        lci = 0
        while lci < g_lam_caps_n[lamid] {
            lcn = g_lam_cap_names[g_lam_caps_s[lamid] + lci]
            lct = g_lam_cap_tys[g_lam_caps_s[lamid] + lci]
            if lnp + lci > 0 { lpstr = lpstr + ", " }
            lpstr = lpstr + lct + " %" + lcn + "_cap_arg"
            lcreg = "%" + lcn + "_v"
            emit_alloca("  " + lcreg + " = alloca " + lct)
            emit("  store " + lct + " %" + lcn + "_cap_arg, " + lct + "* " + lcreg)
            decl_var(lcn, lcreg, lct)
            lci = lci + 1
        }
        cg_stmt(g_nc0[n])
        // 조립해서 디퍼드 버퍼로
        lbody: [str] = g_out
        push(g_lam_out, "define " + lret + " " + lamname + "(" + lpstr + ") \{")
        push(g_lam_out, "entry:")
        lli = 0
        while lli < len(g_alloca_buf) { push(g_lam_out, g_alloca_buf[lli]); lli = lli + 1 }
        lli = 0
        while lli < len(lbody) { push(g_lam_out, lbody[lli]); lli = lli + 1 }
        if lret == "void" or lret == "()" { push(g_lam_out, "  ret void") }
        else { push(g_lam_out, "  ret " + lret + " " + ll_zero(lret)) }
        push(g_lam_out, "\}")
        push(g_lam_out, "")
        // 컨텍스트 복원
        g_out = sv_lo
        g_alloca_buf = sv_lab
        g_cur_fn_ret = sv_lret
        g_loop_br_lbl = sv_lbr
        g_loop_co_lbl = sv_lco
        while len(g_var_names) > sv_lvlen {
            pop(g_var_names); pop(g_var_regs); pop(g_var_tys); pop(g_var_elems); pop(g_var_lams)
        }
        g_expr_reg = lamname
        g_expr_ty = lam_ty_str(lamid)
        g_expr_lam = lamid
        return
    }

    // 구조체 인스턴스
    if k == NK_STRUCT_INST {
        sname = g_nsval[n]
        sidx = find_struct(sname)
        r = new_reg()
        emit_alloca("  " + r + " = alloca %struct." + sname)
        if sidx != -1 {
            nf = g_nch_n[n]
            i = 0
            while i < nf {
                fi_node = g_ch[g_nch_s[n] + i]
                fn_s = g_nsval[fi_node]
                fidx = struct_field_idx(sidx, fn_s)
                if fidx != -1 {
                    fty = g_sdef_ftys[g_sdef_fs[sidx] + fidx]
                    // 고정 배열 필드 — 리터럴/통째 복사 경로
                    if is_arr_val(fty) {
                        agep = new_reg()
                        emit("  " + agep + " = getelementptr inbounds %struct." + sname + ", %struct." + sname + "* " + r + ", i32 0, i32 " + to_string(fidx))
                        cg_arr_store(agep, fty, g_nc0[fi_node])
                    } else if union_has(sname) {
                        // union 리터럴 — 오프셋 0 슬롯 bitcast 저장
                        cg_expr(g_nc0[fi_node])
                        ugep = new_reg()
                        emit("  " + ugep + " = getelementptr inbounds %struct." + sname + ", %struct." + sname + "* " + r + ", i32 0, i32 0")
                        fp = ugep
                        if fty != "i64" {
                            fp = new_reg()
                            emit("  " + fp + " = bitcast i64* " + ugep + " to " + fty + "*")
                        }
                        emit("  store " + fty + " " + g_expr_reg + ", " + fty + "* " + fp)
                    } else {
                        cg_expr(g_nc0[fi_node])
                        if g_expr_ty != fty { g_expr_reg = coerce_to(g_expr_reg, g_expr_ty, fty); g_expr_ty = fty }
                        gep = new_reg()
                        emit("  " + gep + " = getelementptr inbounds %struct." + sname + ", %struct." + sname + "* " + r + ", i32 0, i32 " + to_string(fidx))
                        emit("  store " + fty + " " + g_expr_reg + ", " + fty + "* " + gep)
                    }
                }
                i = i + 1
            }
        }
        g_expr_reg = r; g_expr_ty = "%struct." + sname + "*"; return
    }

    g_expr_reg = "0"; g_expr_ty = "i64"
}

// ─── 문 컴파일 ────────────────────────────────────────────────────────────
fn cg_stmt(n) {
    if n < 0 or n >= g_node_count { return }
    k = g_nkind[n]
    if k == NK_NULL { return }

    if k == NK_BLOCK {
        i = 0
        while i < g_nch_n[n] { cg_stmt(g_ch[g_nch_s[n] + i]); i = i + 1 }
        return
    }

    if k == NK_ENUM_DEF { return }

    if k == NK_FOREACH {
        nb = g_nch_n[n]
        if nb == 0 { return }
        b0 = g_ch[g_nch_s[n]]
        c0n = g_ntype[b0]
        idn2 = to_string(g_reg); g_reg = g_reg + 1
        feidx = "%__fe" + idn2 + "_v"
        emit_alloca("  " + feidx + " = alloca i64")
        fe_start = "0"
        if g_parallel_foreach == 1 { fe_start = g_parallel_start_reg }
        emit("  store i64 " + fe_start + ", i64* " + feidx)
        lc = new_lbl(); lb = new_lbl(); le = new_lbl(); lnx = new_lbl()
        // body 안 continue → 인덱스 증가 블록(lnx), break → le
        sv_febr = g_loop_br_lbl; sv_feco = g_loop_co_lbl
        g_loop_br_lbl = le; g_loop_co_lbl = lnx
        emit("  br label %" + lc)
        emit(lc + ":")
        iv = new_reg(); emit("  " + iv + " = load i64, i64* " + feidx)
        el0 = new_reg(); emit("  " + el0 + " = load %DnhList*, %DnhList** @__ecs_e_" + c0n)
        ln0 = new_reg()
        if g_parallel_foreach == 1 { emit("  " + ln0 + " = add i64 0, " + g_parallel_end_reg) }
        else { emit("  " + ln0 + " = call i64 @dnh_len(%DnhList* " + el0 + ")") }
        cc = new_reg(); emit("  " + cc + " = icmp slt i64 " + iv + ", " + ln0)
        emit("  br i1 " + cc + ", label %" + lb + ", label %" + le)
        emit(lb + ":")
        entv = new_reg(); emit("  " + entv + " = call i64 @dnh_get(%DnhList* " + el0 + ", i64 " + iv + ")")
        sv_fe = len(g_var_names)
        p0 = new_reg()
        emit("  " + p0 + " = load %DnhList*, %DnhList** @__ecs_p_" + c0n)
        pl0 = new_reg()
        emit("  " + pl0 + " = call i64 @dnh_get(%DnhList* " + p0 + ", i64 " + iv + ")")
        bp0 = new_reg()
        emit("  " + bp0 + " = inttoptr i64 " + pl0 + " to %struct." + c0n + "*")
        areg0 = "%" + g_nsval[b0] + "_fe" + to_string(b0) + "_v"
        emit_alloca("  " + areg0 + " = alloca %struct." + c0n + "*")
        emit("  store %struct." + c0n + "* " + bp0 + ", %struct." + c0n + "** " + areg0)
        decl_var(g_nsval[b0], areg0, "%struct." + c0n + "*")
        bi3 = 1
        while bi3 < nb {
            bk = g_ch[g_nch_s[n] + bi3]
            ckn = g_ntype[bk]
            ek2 = new_reg(); emit("  " + ek2 + " = load %DnhList*, %DnhList** @__ecs_e_" + ckn)
            fk = new_reg(); emit("  " + fk + " = call i64 @dnh_ecs_find(%DnhList* " + ek2 + ", i64 " + entv + ")")
            hk = new_reg(); emit("  " + hk + " = icmp sge i64 " + fk + ", 0")
            lok2 = new_lbl()
            emit("  br i1 " + hk + ", label %" + lok2 + ", label %" + lnx)
            emit(lok2 + ":")
            pk = new_reg(); emit("  " + pk + " = load %DnhList*, %DnhList** @__ecs_p_" + ckn)
            plk = new_reg(); emit("  " + plk + " = call i64 @dnh_get(%DnhList* " + pk + ", i64 " + fk + ")")
            bpk = new_reg(); emit("  " + bpk + " = inttoptr i64 " + plk + " to %struct." + ckn + "*")
            aregk = "%" + g_nsval[bk] + "_fe" + to_string(bk) + "_v"
            emit_alloca("  " + aregk + " = alloca %struct." + ckn + "*")
            emit("  store %struct." + ckn + "* " + bpk + ", %struct." + ckn + "** " + aregk)
            decl_var(g_nsval[bk], aregk, "%struct." + ckn + "*")
            bi3 = bi3 + 1
        }
        cg_stmt(g_nc0[n])
        while len(g_var_names) > sv_fe {
            pop(g_var_names); pop(g_var_regs); pop(g_var_tys); pop(g_var_elems); pop(g_var_lams)
        }
        emit("  br label %" + lnx)
        emit(lnx + ":")
        iv2 = new_reg(); emit("  " + iv2 + " = load i64, i64* " + feidx)
        ni2 = new_reg(); emit("  " + ni2 + " = add i64 " + iv2 + ", 1")
        emit("  store i64 " + ni2 + ", i64* " + feidx)
        emit("  br label %" + lc)
        emit(le + ":")
        g_loop_br_lbl = sv_febr; g_loop_co_lbl = sv_feco
        return
    }

    if k == NK_MATCH {
        cg_expr(g_nc0[n]); mev = g_expr_reg
        mtp = new_reg()
        emit("  " + mtp + " = getelementptr inbounds %DnhEnum, %DnhEnum* " + mev + ", i32 0, i32 0")
        mtg = new_reg()
        emit("  " + mtg + " = load i64, i64* " + mtp)
        mle = new_lbl()
        na = g_nch_n[n]
        ai = 0
        while ai < na {
            arm = g_ch[g_nch_s[n] + ai]
            avn = g_nsval[arm]
            abn = g_ntype[arm]
            alb = new_lbl(); aln2 = new_lbl()
            if avn == "_" {
                emit("  br i1 1, label %" + alb + ", label %" + aln2)
            } else {
                avi = find_variant_any(avn)
                atag = 0
                if avi != -1 { atag = g_vrt_tag[avi] }
                ac = new_reg()
                emit("  " + ac + " = icmp eq i64 " + mtg + ", " + to_string(atag))
                emit("  br i1 " + ac + ", label %" + alb + ", label %" + aln2)
            }
            emit(alb + ":")
            sv_mv = len(g_var_names)
            if abn != "" and avn != "_" {
                avi2 = find_variant_any(avn)
                apty = ""
                if avi2 != -1 { apty = g_vrt_pty[avi2] }
                app = new_reg()
                emit("  " + app + " = getelementptr inbounds %DnhEnum, %DnhEnum* " + mev + ", i32 0, i32 1")
                apl = new_reg()
                emit("  " + apl + " = load i64, i64* " + app)
                abv = slot_to_ty(apl, apty)
                abty = ll_ty(apty)
                areg = "%" + abn + "_m" + to_string(arm) + "_v"
                emit_alloca("  " + areg + " = alloca " + abty)
                emit("  store " + abty + " " + abv + ", " + abty + "* " + areg)
                decl_var(abn, areg, abty)
            }
            cg_stmt(g_nc0[arm])
            while len(g_var_names) > sv_mv {
                pop(g_var_names); pop(g_var_regs); pop(g_var_tys); pop(g_var_elems); pop(g_var_lams)
            }
            emit("  br label %" + mle)
            emit(aln2 + ":")
            ai = ai + 1
        }
        emit("  br label %" + mle)
        emit(mle + ":")
        return
    }

    if k == NK_ASSIGN {
        name = g_nsval[n]
        // const 재대입 금지 (ival=1인 노드는 const 정의 자신)
        if g_nival[n] == 0 and const_has(name) {
            fatal("'" + name + "'은(는) const라 재대입할 수 없어 (줄 " + to_string(g_nline[n]) + ")")
        }
        // 고정 크기 배열 선언/대입: a: [i32; 8] = [0; 8] / 기존 배열 변수 재대입
        arr_aty = ""
        if ann_fixed_elem(g_ntype[n]) != "" { arr_aty = ll_ty(g_ntype[n]) }
        avi = find_var(name)
        if arr_aty == "" and avi != -1 {
            if is_arr_val(g_var_tys[avi]) { arr_aty = g_var_tys[avi] }
        }
        if arr_aty != "" {
            if avi == -1 {
                areg = "%" + name + "_v"
                emit_alloca("  " + areg + " = alloca " + arr_aty)
                decl_var_e(name, areg, arr_aty, ann_fixed_elem(g_ntype[n]))
                avi = find_var(name)
            }
            cg_arr_store(g_var_regs[avi], arr_aty, g_nc0[n])
            return
        }
        cg_expr(g_nc0[n]); val_r = g_expr_reg; val_ty = g_expr_ty; val_el = g_expr_elem
        // 람다 바인딩은 RHS가 람다 리터럴이거나 람다 변수일 때만 전파
        val_lam = -1
        vlk = g_nkind[g_nc0[n]]
        if vlk == NK_LAMBDA or vlk == NK_ID { val_lam = g_expr_lam }
        vi = find_var(name)
        if vi == -1 {
            // ids2 = b.ids — 우변이 고정 배열이면 새 배열로 값 복사
            if is_arr_ptr(val_ty) {
                cbty = arr_base_ty(val_ty)
                areg2 = "%" + name + "_v"
                emit_alloca("  " + areg2 + " = alloca " + cbty)
                clv = new_reg()
                emit("  " + clv + " = load " + cbty + ", " + cbty + "* " + val_r)
                emit("  store " + cbty + " " + clv + ", " + cbty + "* " + areg2)
                decl_var_e(name, areg2, cbty, val_el)
                return
            }
            el = ann_elem(g_ntype[n])
            if el == "" { el = val_el }
            // s: dyn Trait = ... 어노테이션이면 변수 타입은 트레잇 객체
            nvty = val_ty
            adt = as_dyn_trait(g_ntype[n])
            if adt != "" { nvty = "%dyn." + adt + "*" }
            reg = "%" + name + "_v"
            emit_alloca("  " + reg + " = alloca " + nvty)
            decl_var_e(name, reg, nvty, el)
            vi = find_var(name)
        }
        ty = g_var_tys[vi]
        if ty != val_ty {
            cv = new_reg()
            if val_ty == "i32" and ty == "i64" { emit("  " + cv + " = sext i32 " + val_r + " to i64"); val_r = cv }
            else if val_ty == "i64" and ty == "i32" { emit("  " + cv + " = trunc i64 " + val_r + " to i32"); val_r = cv }
            else if val_ty == "i32" and ty == "double" { emit("  " + cv + " = sitofp i32 " + val_r + " to double"); val_r = cv }
            else if val_ty == "i64" and ty == "double" { emit("  " + cv + " = sitofp i64 " + val_r + " to double"); val_r = cv }
            else if dyn_of_ty(ty) != "" and struct_of_ty(val_ty) != "" {
                // s: dyn T = Circle {...} — 어노테이션 기반 자동 래핑
                g_reg = g_reg - 1
                val_r = dyn_wrap(val_r, val_ty, dyn_of_ty(ty), g_nline[n])
            }
            else if (is_int_ty(val_ty) or is_flt_ty(val_ty)) and (is_int_ty(ty) or is_flt_ty(ty)) {
                // 그 외 숫자 조합 (i8/i16/f32, double→i64 등) 일반 코어션
                g_reg = g_reg - 1
                val_r = coerce_to(val_r, val_ty, ty)
            }
        }
        emit("  store " + ty + " " + val_r + ", " + ty + "* " + g_var_regs[vi])
        g_var_lams[vi] = val_lam
        return
    }

    if k == NK_FASSIGN {
        // v.x = val — 벡터 성분 쓰기 (변수 슬롯 load/insert/store)
        fob = g_nc0[n]
        if g_nkind[fob] == NK_ID {
            fvi2 = find_var(g_nsval[fob])
            if fvi2 != -1 {
                if is_vec_ty(g_var_tys[fvi2]) {
                    vty2 = g_var_tys[fvi2]
                    vidx2 = vec_field_idx(g_nsval[n])
                    if vidx2 < 0 {
                        fatal("벡터에 '" + g_nsval[n] + "' 성분은 없어 (줄 " + to_string(g_nline[n]) + ")")
                    }
                    cg_expr(g_nc1[n]); vv = g_expr_reg; vt2 = g_expr_ty
                    if vt2 != "double" { vv = coerce_to(vv, vt2, "double") }
                    cur2 = load_val(g_var_regs[fvi2], vty2)
                    nr2 = new_reg()
                    emit("  " + nr2 + " = insertelement " + vty2 + " " + cur2 + ", double " + vv + ", i32 " + to_string(vidx2))
                    emit("  store " + vty2 + " " + nr2 + ", " + vty2 + "* " + g_var_regs[fvi2])
                    return
                }
            }
        }
        cg_expr(g_nc0[n]); obj_r = g_expr_reg; obj_ty = g_expr_ty
        fname_s = g_nsval[n]
        sname = ""
        si = 8
        while si < len(obj_ty) and obj_ty[si] != "*" { sname = sname + obj_ty[si]; si = si + 1 }
        sidx = find_struct(sname)
        if sidx != -1 {
            fi = struct_field_idx(sidx, fname_s)
            if fi != -1 {
                fty = g_sdef_ftys[g_sdef_fs[sidx] + fi]
                // 고정 배열 필드 — 리터럴/통째 복사 경로
                if is_arr_val(fty) {
                    gep = new_reg()
                    emit("  " + gep + " = getelementptr inbounds %struct." + sname + ", %struct." + sname + "* " + obj_r + ", i32 0, i32 " + to_string(fi))
                    cg_arr_store(gep, fty, g_nc1[n])
                    return
                }
                cg_expr(g_nc1[n]); val_r = g_expr_reg; val_ty = g_expr_ty
                if val_ty != fty { val_r = coerce_to(val_r, val_ty, fty) }
                // union 필드 쓰기 — 오프셋 0 슬롯 bitcast
                if union_has(sname) {
                    ugep = new_reg()
                    emit("  " + ugep + " = getelementptr inbounds %struct." + sname + ", %struct." + sname + "* " + obj_r + ", i32 0, i32 0")
                    fp = ugep
                    if fty != "i64" {
                        fp = new_reg()
                        emit("  " + fp + " = bitcast i64* " + ugep + " to " + fty + "*")
                    }
                    emit("  store " + fty + " " + val_r + ", " + fty + "* " + fp)
                    return
                }
                gep = new_reg()
                emit("  " + gep + " = getelementptr inbounds %struct." + sname + ", %struct." + sname + "* " + obj_r + ", i32 0, i32 " + to_string(fi))
                emit("  store " + fty + " " + val_r + ", " + fty + "* " + gep)
            }
        }
        return
    }

    if k == NK_IASSIGN {
        cg_expr(g_nc0[n]); arr_r = g_expr_reg; arr_ty = g_expr_ty
        cg_expr(g_nc1[n]); idx_r = sext32(g_expr_reg, g_expr_ty)
        cg_expr(g_nc2[n]); val_r = g_expr_reg; val_ty = g_expr_ty
        if arr_ty == "%DnhList*" {
            sv = val_r
            if val_ty == "i8*" or val_ty == "%DnhList*" or val_ty == "%DnhEnum*" {
                sv = new_reg(); emit("  " + sv + " = ptrtoint " + val_ty + " " + val_r + " to i64")
            } else if val_ty == "double" {
                sv = new_reg(); emit("  " + sv + " = bitcast double " + val_r + " to i64")
            } else if val_ty != "i64" {
                sv = new_reg(); emit("  " + sv + " = sext " + val_ty + " " + val_r + " to i64")
            }
            emit("  call void @dnh_set(%DnhList* " + arr_r + ", i64 " + idx_r + ", i64 " + sv + ")")
        } else if is_arr_ptr(arr_ty) {
            // 고정 크기 배열 원소 쓰기
            bty = arr_base_ty(arr_ty)
            ety = arr_elem_ll(arr_ty)
            if val_ty != ety { val_r = coerce_to(val_r, val_ty, ety) }
            gep = new_reg()
            emit("  " + gep + " = getelementptr inbounds " + bty + ", " + arr_ty + " " + arr_r + ", i64 0, i64 " + idx_r)
            emit("  store " + ety + " " + val_r + ", " + ety + "* " + gep)
        } else {
            gep = new_reg()
            emit("  " + gep + " = getelementptr inbounds " + val_ty + ", " + val_ty + "* " + arr_r + ", i64 " + idx_r)
            emit("  store " + val_ty + " " + val_r + ", " + val_ty + "* " + gep)
        }
        return
    }

    if k == NK_PRINT {
        cg_expr(g_nc0[n]); val_r = g_expr_reg; val_ty = g_expr_ty
        val_el9 = g_expr_elem
        // EntityId — "Entity(idx, gen)" (py fmt_entity 패리티)
        if val_ty == "i64" and val_el9 == "eid" {
            eidx = new_reg()
            emit("  " + eidx + " = and i64 " + val_r + ", 4294967295")
            egen = new_reg()
            emit("  " + egen + " = lshr i64 " + val_r + ", 32")
            eps = istr_cat("", strlit_gep(add_strlit("Entity(")))
            eps = istr_cat(eps, to_str_reg(eidx, "i64"))
            eps = istr_cat(eps, strlit_gep(add_strlit(", ")))
            eps = istr_cat(eps, to_str_reg(egen, "i64"))
            eps = istr_cat(eps, strlit_gep(add_strlit(")")))
            if g_runtime_direct {
                emit("  call void @dnh_os_write_nl(i8* " + eps + ")")
            } else {
                fi = add_strlit("%s\n"); fp = strlit_gep(fi)
                emit("  call i32 (i8*, ...) @printf(i8* " + fp + ", i8* " + eps + ")")
            }
            return
        }
        // 구조체/컴포넌트 — "Name { f1: v1, f2: v2 }" (py 패리티)
        psn = struct_of_ty(val_ty)
        if psn != "" {
            psi = find_struct(psn)
            if psi != -1 and not union_has(psn) {
                pso = istr_cat("", strlit_gep(add_strlit(psn + " \{ ")))
                psb = g_sdef_fs[psi]
                psc = g_sdef_fc[psi]
                pfi = 0
                while pfi < psc {
                    if pfi > 0 { pso = istr_cat(pso, strlit_gep(add_strlit(", "))) }
                    pso = istr_cat(pso, strlit_gep(add_strlit(g_sdef_fnames[psb + pfi] + ": ")))
                    pfty = g_sdef_ftys[psb + pfi]
                    pgep = new_reg()
                    emit("  " + pgep + " = getelementptr inbounds %struct." + psn + ", " + val_ty + " " + val_r + ", i32 0, i32 " + to_string(pfi))
                    if is_arr_val(pfty) or struct_of_ty(pfty) != "" or pfty == "%DnhList*" or pfty == "%DnhHM*" {
                        // 중첩 포인터류는 주소 숫자로 (py도 컴포넌트 스칼라 필드만 의미 있음)
                        ppv = new_reg()
                        emit("  " + ppv + " = ptrtoint " + pfty + "* " + pgep + " to i64")
                        pso = istr_cat(pso, to_str_reg(ppv, "i64"))
                    } else {
                        plv = new_reg()
                        emit("  " + plv + " = load " + pfty + ", " + pfty + "* " + pgep)
                        pso = istr_cat(pso, to_str_reg(plv, pfty))
                    }
                    pfi = pfi + 1
                }
                pso = istr_cat(pso, strlit_gep(add_strlit(" \}")))
                if g_runtime_direct {
                    emit("  call void @dnh_os_write_nl(i8* " + pso + ")")
                } else {
                    fi = add_strlit("%s\n"); fp = strlit_gep(fi)
                    emit("  call i32 (i8*, ...) @printf(i8* " + fp + ", i8* " + pso + ")")
                }
                return
            }
        }
        if g_runtime_direct and val_ty == "i8*" {
            emit("  call void @dnh_os_write_nl(i8* " + val_r + ")")
        } else if g_runtime_direct and val_ty == "i1" {
            lt = new_lbl(); lf = new_lbl(); le = new_lbl()
            ti = add_strlit("true"); tp = strlit_gep(ti)
            xi = add_strlit("false"); xp = strlit_gep(xi)
            emit("  br i1 " + val_r + ", label %" + lt + ", label %" + lf)
            emit(lt + ":"); emit("  call void @dnh_os_write_nl(i8* " + tp + ")"); emit("  br label %" + le)
            emit(lf + ":"); emit("  call void @dnh_os_write_nl(i8* " + xp + ")"); emit("  br label %" + le)
            emit(le + ":")
        } else if g_runtime_direct and (is_vec_ty(val_ty) or is_mat_ty(val_ty)) {
            psr = to_str_reg(val_r, val_ty)
            emit("  call void @dnh_os_write_nl(i8* " + psr + ")")
        } else if g_runtime_direct and val_ty != "double" and val_ty != "float" {
            if val_ty != "i64" {
                cv = new_reg(); emit("  " + cv + " = sext " + val_ty + " " + val_r + " to i64"); val_r = cv
            }
            emit("  call void @dnh_os_print_i64(i64 " + val_r + ")")
        } else if g_runtime_direct {
            // direct-os double/float — dnh_to_str_float 자리표시 + write
            psr = to_str_reg(val_r, val_ty)
            emit("  call void @dnh_os_write_nl(i8* " + psr + ")")
        } else if val_ty == "i8*" {
            sv2 = new_reg()
            emit("  " + sv2 + " = call i8* @dnh_safe_str(i8* " + val_r + ")")
            fi = add_strlit("%s\n"); fp = strlit_gep(fi)
            emit("  call i32 (i8*, ...) @printf(i8* " + fp + ", i8* " + sv2 + ")")
        } else if val_ty == "double" or val_ty == "float" {
            // 평가기와 동일 표기: %f 후 trailing-zero 제거 (보간 경로와 통일)
            psr = to_str_reg(val_r, val_ty)
            fi = add_strlit("%s\n"); fp = strlit_gep(fi)
            emit("  call i32 (i8*, ...) @printf(i8* " + fp + ", i8* " + psr + ")")
        } else if val_ty == "i1" {
            lt = new_lbl(); lf = new_lbl(); le = new_lbl()
            ti = add_strlit("true"); tp = strlit_gep(ti)
            xi = add_strlit("false"); xp = strlit_gep(xi)
            emit("  br i1 " + val_r + ", label %" + lt + ", label %" + lf)
            emit(lt + ":"); emit("  call i32 @puts(i8* " + tp + ")"); emit("  br label %" + le)
            emit(lf + ":"); emit("  call i32 @puts(i8* " + xp + ")"); emit("  br label %" + le)
            emit(le + ":")
        } else if is_vec_ty(val_ty) or is_mat_ty(val_ty) {
            psr = to_str_reg(val_r, val_ty)
            fi = add_strlit("%s\n"); fp = strlit_gep(fi)
            emit("  call i32 (i8*, ...) @printf(i8* " + fp + ", i8* " + psr + ")")
        } else {
            if val_ty != "i64" {
                cv = new_reg(); emit("  " + cv + " = sext " + val_ty + " " + val_r + " to i64"); val_r = cv
            }
            fi = add_strlit("%lld\n"); fp = strlit_gep(fi)
            emit("  call i32 (i8*, ...) @printf(i8* " + fp + ", i64 " + val_r + ")")
        }
        return
    }

    if k == NK_IF {
        cg_expr(g_nc0[n]); cr = g_expr_reg
        lt = new_lbl(); le = new_lbl()
        if g_nc2[n] != -1 {
            lf = new_lbl()
            emit("  br i1 " + cr + ", label %" + lt + ", label %" + lf)
            emit(lt + ":"); cg_stmt(g_nc1[n]); emit("  br label %" + le)
            emit(lf + ":"); cg_stmt(g_nc2[n]); emit("  br label %" + le)
        } else {
            emit("  br i1 " + cr + ", label %" + lt + ", label %" + le)
            emit(lt + ":"); cg_stmt(g_nc1[n]); emit("  br label %" + le)
        }
        emit(le + ":")
        return
    }

    if k == NK_WHILE {
        lc = new_lbl(); lb = new_lbl(); le = new_lbl()
        sb = g_loop_br_lbl; sc = g_loop_co_lbl
        g_loop_br_lbl = le; g_loop_co_lbl = lc
        emit("  br label %" + lc)
        emit(lc + ":"); cg_expr(g_nc0[n]); cr = g_expr_reg
        emit("  br i1 " + cr + ", label %" + lb + ", label %" + le)
        emit(lb + ":"); cg_stmt(g_nc1[n]); emit("  br label %" + lc)
        emit(le + ":")
        g_loop_br_lbl = sb; g_loop_co_lbl = sc
        return
    }

    if k == NK_FOR {
        vname = g_nsval[n]; iter = g_nc0[n]; body = g_nc1[n]
        lc = new_lbl(); lb = new_lbl(); le = new_lbl()
        // continue는 증가 블록(lstp)으로 — 조건(lc)으로 직행하면 증가를 건너뛰어 무한루프
        lstp = new_lbl()
        sb = g_loop_br_lbl; sc = g_loop_co_lbl
        g_loop_br_lbl = le; g_loop_co_lbl = lstp
        if g_nkind[iter] == NK_RANGE {
            cg_expr(g_nc0[iter]); sr = g_expr_reg; ity = g_expr_ty
            cg_expr(g_nc1[iter]); er = g_expr_reg
            vi = find_var(vname)
            if vi == -1 {
                vreg = "%__for" + to_string(g_reg) + "_" + vname + "_v"; g_reg = g_reg + 1
                emit_alloca("  " + vreg + " = alloca " + ity)
                decl_var(vname, vreg, ity); vi = find_var(vname)
            }
            vreg = g_var_regs[vi]
            endreg = new_reg() + "_end"
            emit_alloca("  " + endreg + " = alloca " + ity)
            emit("  store " + ity + " " + sr + ", " + ity + "* " + vreg)
            emit("  store " + ity + " " + er + ", " + ity + "* " + endreg)
            emit("  br label %" + lc)
            emit(lc + ":")
            cv = new_reg(); emit("  " + cv + " = load " + ity + ", " + ity + "* " + vreg)
            ev = new_reg(); emit("  " + ev + " = load " + ity + ", " + ity + "* " + endreg)
            cmp = new_reg(); emit("  " + cmp + " = icmp slt " + ity + " " + cv + ", " + ev)
            emit("  br i1 " + cmp + ", label %" + lb + ", label %" + le)
            emit(lb + ":"); cg_stmt(body)
            emit("  br label %" + lstp)
            emit(lstp + ":")
            cv2 = new_reg(); emit("  " + cv2 + " = load " + ity + ", " + ity + "* " + vreg)
            nv  = new_reg(); emit("  " + nv  + " = add " + ity + " " + cv2 + ", 1")
            emit("  store " + ity + " " + nv + ", " + ity + "* " + vreg)
            emit("  br label %" + lc)
        } else {
            cg_expr(iter); lst_r = g_expr_reg
            lst_ty = g_expr_ty
            lst_el = g_expr_elem
            vi = find_var(vname)
            if is_arr_ptr(lst_ty) {
                bty = arr_base_ty(lst_ty)
                ety = arr_elem_ll(lst_ty)
                if vi == -1 {
                    vreg = "%__for" + to_string(g_reg) + "_" + vname + "_v"; g_reg = g_reg + 1
                    emit_alloca("  " + vreg + " = alloca " + ety)
                    decl_var(vname, vreg, ety); vi = find_var(vname)
                }
                vreg = g_var_regs[vi]
                idn = to_string(g_reg); g_reg = g_reg + 1
                ireg = "%__fi" + idn + "_v"
                emit_alloca("  " + ireg + " = alloca i64")
                emit("  store i64 0, i64* " + ireg)
                emit("  br label %" + lc)
                emit(lc + ":")
                iv = new_reg(); emit("  " + iv + " = load i64, i64* " + ireg)
                cmp2 = new_reg(); emit("  " + cmp2 + " = icmp slt i64 " + iv + ", " + to_string(arr_len_ll(lst_ty)))
                emit("  br i1 " + cmp2 + ", label %" + lb + ", label %" + le)
                emit(lb + ":")
                gepa = new_reg()
                emit("  " + gepa + " = getelementptr inbounds " + bty + ", " + lst_ty + " " + lst_r + ", i64 0, i64 " + iv)
                elemv = new_reg()
                emit("  " + elemv + " = load " + ety + ", " + ety + "* " + gepa)
                emit("  store " + ety + " " + elemv + ", " + ety + "* " + vreg)
                cg_stmt(body)
                emit("  br label %" + lstp)
                emit(lstp + ":")
                iv2 = new_reg(); emit("  " + iv2 + " = load i64, i64* " + ireg)
                nv = new_reg(); emit("  " + nv + " = add i64 " + iv2 + ", 1")
                emit("  store i64 " + nv + ", i64* " + ireg)
                emit("  br label %" + lc)
                emit(le + ":")
                g_loop_br_lbl = sb; g_loop_co_lbl = sc
                return
            }
            if vi == -1 {
                vty = "i64"
                if lst_el == "f64" { vty = "double" }
                else if lst_el == "str" { vty = "i8*" }
                vreg = "%__for" + to_string(g_reg) + "_" + vname + "_v"; g_reg = g_reg + 1
                emit_alloca("  " + vreg + " = alloca " + vty)
                decl_var(vname, vreg, vty); vi = find_var(vname)
            }
            vreg = g_var_regs[vi]
            idn  = to_string(g_reg); g_reg = g_reg + 1
            ireg = "%__fi" + idn + "_v"
            lreg = "%__fl" + idn + "_v"
            emit_alloca("  " + ireg + " = alloca i64")
            emit_alloca("  " + lreg + " = alloca i64")
            emit("  store i64 0, i64* " + ireg)
            ln_r = new_reg()
            emit("  " + ln_r + " = call i64 @dnh_len(%DnhList* " + lst_r + ")")
            emit("  store i64 " + ln_r + ", i64* " + lreg)
            emit("  br label %" + lc)
            emit(lc + ":")
            iv = new_reg(); emit("  " + iv + " = load i64, i64* " + ireg)
            ev = new_reg(); emit("  " + ev + " = load i64, i64* " + lreg)
            cmp2 = new_reg(); emit("  " + cmp2 + " = icmp slt i64 " + iv + ", " + ev)
            emit("  br i1 " + cmp2 + ", label %" + lb + ", label %" + le)
            emit(lb + ":")
            elem = new_reg(); emit("  " + elem + " = call i64 @dnh_get(%DnhList* " + lst_r + ", i64 " + iv + ")")
            if g_var_tys[vi] == "double" {
                de = new_reg()
                emit("  " + de + " = bitcast i64 " + elem + " to double")
                emit("  store double " + de + ", double* " + vreg)
            } else if g_var_tys[vi] == "i8*" {
                pe = new_reg()
                emit("  " + pe + " = inttoptr i64 " + elem + " to i8*")
                emit("  store i8* " + pe + ", i8** " + vreg)
            } else {
                emit("  store i64 " + elem + ", i64* " + vreg)
            }
            cg_stmt(body)
            emit("  br label %" + lstp)
            emit(lstp + ":")
            iv2 = new_reg(); emit("  " + iv2 + " = load i64, i64* " + ireg)
            nv  = new_reg(); emit("  " + nv  + " = add i64 " + iv2 + ", 1")
            emit("  store i64 " + nv + ", i64* " + ireg)
            emit("  br label %" + lc)
        }
        emit(le + ":")
        g_loop_br_lbl = sb; g_loop_co_lbl = sc
        return
    }

    // defer { ... } — 등록만, 실행은 return/함수 끝에서
    if k == NK_DEFER {
        push(g_defer_bodies, g_nc0[n])
        return
    }

    if k == NK_RETURN {
        if g_nc0[n] == -1 {
            cg_emit_defers()
            if g_cur_fn_ret == "void" or g_cur_fn_ret == "()" { emit("  ret void") }
            else { emit("  ret " + g_cur_fn_ret + " " + ll_zero(g_cur_fn_ret)) }
        } else {
            if is_arr_val(g_cur_fn_ret) {
                tmpret = "%__retarr" + to_string(g_reg) + "_v"; g_reg = g_reg + 1
                emit_alloca("  " + tmpret + " = alloca " + g_cur_fn_ret)
                cg_arr_store(tmpret, g_cur_fn_ret, g_nc0[n])
                rv = new_reg()
                emit("  " + rv + " = load " + g_cur_fn_ret + ", " + g_cur_fn_ret + "* " + tmpret)
                rt = g_cur_fn_ret
            } else {
                cg_expr(g_nc0[n])
                rv = g_expr_reg; rt = g_expr_ty
                if rt != g_cur_fn_ret and g_cur_fn_ret != "void" and g_cur_fn_ret != "()" {
                    rv = coerce_to(rv, rt, g_cur_fn_ret)
                    rt = g_cur_fn_ret
                }
            }
            cg_emit_defers()
            emit("  ret " + rt + " " + rv)
        }
        dl = new_lbl(); emit(dl + ":")
        return
    }

    if k == NK_BREAK {
        if g_loop_br_lbl != "" { emit("  br label %" + g_loop_br_lbl); dl = new_lbl(); emit(dl + ":") }
        return
    }
    if k == NK_CONTINUE {
        if g_loop_co_lbl != "" { emit("  br label %" + g_loop_co_lbl); dl = new_lbl(); emit(dl + ":") }
        return
    }

    cg_expr(n)
}

// ─── 함수/구조체 컴파일 ───────────────────────────────────────────────────
fn cg_struct_def(n) {
    sname = g_nsval[n]; nf = g_nch_n[n]
    if g_debug_codegen { print("cg struct " + sname) }
    push(g_sdefs, sname); push(g_sdef_fs, len(g_sdef_fnames)); push(g_sdef_fc, nf)
    fstr = ""
    i = 0
    while i < nf {
        fi = g_ch[g_nch_s[n] + i]
        fn_s = g_nsval[fi]
        fty = ll_ty(g_ntype[fi])
        push(g_sdef_fnames, fn_s); push(g_sdef_ftys, fty)
        if i > 0 { fstr = fstr + ", " }
        fstr = fstr + fty
        i = i + 1
    }
    // union — 모든 필드가 오프셋 0 공유, 8바이트 단일 슬롯 (현재 스칼라 타입은 전부 ≤8B)
    if g_nival[n] == 1 {
        emit("%struct." + sname + " = type \{ i64 \}")
        emit("")
        return
    }
    emit("%struct." + sname + " = type \{ " + fstr + " \}")
    emit("")
    cg_reflection(sname)
}

// 리플렉션 필드 타입 코드 (py와 동일: 0=정수, 1=실수, 2=bool, 3=ptr, -1=기타)
fn refl_ty_code(fty: str) -> i32 {
    if fty == "i32" or fty == "i64" or fty == "i8" or fty == "i16" { return 0 }
    if fty == "double" or fty == "float" { return 1 }
    if fty == "i1" { return 2 }
    if fty == "i8*" { return 3 }
    return 0 - 1
}

// struct마다 5개 리플렉션 메타 함수 방출 (py _emit_reflection_fns와 동일 API)
// _reflect_X_field_count / _field_name(i) / _field_type(i) / _get_f64(s,i) / _set_f64(s,i,v)
fn cg_reflection(sname: str) {
    sidx = find_struct(sname)
    if sidx == -1 { return }
    nf = g_sdef_fc[sidx]
    if nf == 0 { return }
    sp = "%struct." + sname + "*"
    // 1) field_count
    emit("define internal i32 @_reflect_" + sname + "_field_count() \{")
    emit("entry:")
    emit("  ret i32 " + to_string(nf))
    emit("\}")
    push(g_fn_names, "_reflect_" + sname + "_field_count")
    push(g_fn_rets, "i32"); push(g_fn_arities, 0); push(g_fn_ps, len(g_fn_ptys))
    // switch 케이스 문자열 (5개 함수 공용)
    cases = ""
    j = 0
    while j < nf {
        cases = cases + " i32 " + to_string(j) + ", label %c" + to_string(j)
        j = j + 1
    }
    // 2) field_name(i) -> i8*
    emit("define internal i8* @_reflect_" + sname + "_field_name(i32 %i) \{")
    emit("entry:")
    emit("  switch i32 %i, label %dflt [" + cases + " ]")
    j = 0
    while j < nf {
        emit("c" + to_string(j) + ":")
        emit("  ret i8* " + strlit_gep(add_strlit(g_sdef_fnames[g_sdef_fs[sidx] + j])))
        j = j + 1
    }
    emit("dflt:")
    emit("  ret i8* " + strlit_gep(add_strlit("")))
    emit("\}")
    push(g_fn_names, "_reflect_" + sname + "_field_name")
    push(g_fn_rets, "i8*"); push(g_fn_arities, 1); push(g_fn_ps, len(g_fn_ptys))
    push(g_fn_ptys, "i32")
    // 3) field_type(i) -> i32
    emit("define internal i32 @_reflect_" + sname + "_field_type(i32 %i) \{")
    emit("entry:")
    emit("  switch i32 %i, label %dflt [" + cases + " ]")
    j = 0
    while j < nf {
        emit("c" + to_string(j) + ":")
        emit("  ret i32 " + to_string(refl_ty_code(g_sdef_ftys[g_sdef_fs[sidx] + j])))
        j = j + 1
    }
    emit("dflt:")
    emit("  ret i32 -1")
    emit("\}")
    push(g_fn_names, "_reflect_" + sname + "_field_type")
    push(g_fn_rets, "i32"); push(g_fn_arities, 1); push(g_fn_ps, len(g_fn_ptys))
    push(g_fn_ptys, "i32")
    // 4) get_f64(s, i) -> double (숫자 필드만, 그 외 0.0)
    emit("define internal double @_reflect_" + sname + "_get_f64(" + sp + " %s, i32 %i) \{")
    emit("entry:")
    emit("  switch i32 %i, label %dflt [" + cases + " ]")
    j = 0
    while j < nf {
        fty = g_sdef_ftys[g_sdef_fs[sidx] + j]
        js = to_string(j)
        emit("c" + js + ":")
        if is_int_ty(fty) or is_flt_ty(fty) {
            emit("  %p" + js + " = getelementptr inbounds %struct." + sname + ", " + sp + " %s, i32 0, i32 " + js)
            emit("  %v" + js + " = load " + fty + ", " + fty + "* %p" + js)
            if fty == "double" {
                emit("  ret double %v" + js)
            } else if fty == "float" {
                emit("  %d" + js + " = fpext float %v" + js + " to double")
                emit("  ret double %d" + js)
            } else {
                emit("  %d" + js + " = sitofp " + fty + " %v" + js + " to double")
                emit("  ret double %d" + js)
            }
        } else {
            emit("  ret double 0.0")
        }
        j = j + 1
    }
    emit("dflt:")
    emit("  ret double 0.0")
    emit("\}")
    push(g_fn_names, "_reflect_" + sname + "_get_f64")
    push(g_fn_rets, "double"); push(g_fn_arities, 2); push(g_fn_ps, len(g_fn_ptys))
    push(g_fn_ptys, sp); push(g_fn_ptys, "i32")
    // 5) set_f64(s, i, v) (숫자 필드만 갱신)
    emit("define internal void @_reflect_" + sname + "_set_f64(" + sp + " %s, i32 %i, double %v) \{")
    emit("entry:")
    emit("  switch i32 %i, label %dflt [" + cases + " ]")
    j = 0
    while j < nf {
        fty = g_sdef_ftys[g_sdef_fs[sidx] + j]
        js = to_string(j)
        emit("c" + js + ":")
        if is_int_ty(fty) or is_flt_ty(fty) {
            emit("  %p" + js + " = getelementptr inbounds %struct." + sname + ", " + sp + " %s, i32 0, i32 " + js)
            if fty == "double" {
                emit("  store double %v, double* %p" + js)
            } else if fty == "float" {
                emit("  %t" + js + " = fptrunc double %v to float")
                emit("  store float %t" + js + ", float* %p" + js)
            } else {
                emit("  %t" + js + " = fptosi double %v to " + fty)
                emit("  store " + fty + " %t" + js + ", " + fty + "* %p" + js)
            }
            emit("  ret void")
        } else {
            emit("  ret void")
        }
        j = j + 1
    }
    emit("dflt:")
    emit("  ret void")
    emit("\}")
    emit("")
    push(g_fn_names, "_reflect_" + sname + "_set_f64")
    push(g_fn_rets, "void"); push(g_fn_arities, 3); push(g_fn_ps, len(g_fn_ptys))
    push(g_fn_ptys, sp); push(g_fn_ptys, "i32"); push(g_fn_ptys, "double")
    // 6) save_to_path(s, path) -> i32 — ari_save_* 런타임 (py 영속화 헬퍼와 동일, 사용 시 ari 링크 필요)
    emit("define internal i32 @_reflect_" + sname + "_save_to_path(" + sp + " %s, i8* %path) \{")
    emit("entry:")
    emit("  %op = call i32 @ari_save_open(i8* %path)")
    emit("  %ok = icmp ne i32 %op, 0")
    emit("  br i1 %ok, label %wr, label %fail")
    emit("fail:")
    emit("  ret i32 0")
    emit("wr:")
    j = 0
    while j < nf {
        fty = g_sdef_ftys[g_sdef_fs[sidx] + j]
        js = to_string(j)
        npr = strlit_gep(add_strlit(g_sdef_fnames[g_sdef_fs[sidx] + j]))
        if fty == "double" or fty == "float" or is_int_ty(fty) or fty == "i8*" {
            emit("  %sp" + js + " = getelementptr inbounds %struct." + sname + ", " + sp + " %s, i32 0, i32 " + js)
            emit("  %sv" + js + " = load " + fty + ", " + fty + "* %sp" + js)
            if fty == "double" {
                emit("  call void @ari_save_float(i8* " + npr + ", double %sv" + js + ")")
            } else if fty == "float" {
                emit("  %sx" + js + " = fpext float %sv" + js + " to double")
                emit("  call void @ari_save_float(i8* " + npr + ", double %sx" + js + ")")
            } else if fty == "i8*" {
                emit("  call void @ari_save_string(i8* " + npr + ", i8* %sv" + js + ")")
            } else {
                iw = int_width(fty)
                if iw < 32 {
                    emit("  %sx" + js + " = zext " + fty + " %sv" + js + " to i32")
                    emit("  call void @ari_save_int(i8* " + npr + ", i32 %sx" + js + ")")
                } else if iw == 32 {
                    emit("  call void @ari_save_int(i8* " + npr + ", i32 %sv" + js + ")")
                } else {
                    emit("  %sx" + js + " = trunc " + fty + " %sv" + js + " to i32")
                    emit("  call void @ari_save_int(i8* " + npr + ", i32 %sx" + js + ")")
                }
            }
        }
        j = j + 1
    }
    emit("  %cl = call i32 @ari_save_close()")
    emit("  ret i32 1")
    emit("\}")
    push(g_fn_names, "_reflect_" + sname + "_save_to_path")
    push(g_fn_rets, "i32"); push(g_fn_arities, 2); push(g_fn_ps, len(g_fn_ptys))
    push(g_fn_ptys, sp); push(g_fn_ptys, "i8*")
    // 7) load_from_path(s, path) -> i32 — 숫자 필드만 복원 (py와 동일)
    emit("define internal i32 @_reflect_" + sname + "_load_from_path(" + sp + " %s, i8* %path) \{")
    emit("entry:")
    emit("  %op = call i32 @ari_load_open(i8* %path)")
    emit("  %ok = icmp ne i32 %op, 0")
    emit("  br i1 %ok, label %rd, label %fail")
    emit("fail:")
    emit("  ret i32 0")
    emit("rd:")
    j = 0
    while j < nf {
        fty = g_sdef_ftys[g_sdef_fs[sidx] + j]
        js = to_string(j)
        npr = strlit_gep(add_strlit(g_sdef_fnames[g_sdef_fs[sidx] + j]))
        if fty == "double" or fty == "float" or is_int_ty(fty) {
            emit("  %lp" + js + " = getelementptr inbounds %struct." + sname + ", " + sp + " %s, i32 0, i32 " + js)
            emit("  %lc" + js + " = load " + fty + ", " + fty + "* %lp" + js)
            if fty == "double" {
                emit("  %lv" + js + " = call double @ari_load_float(i8* " + npr + ", double %lc" + js + ")")
                emit("  store double %lv" + js + ", double* %lp" + js)
            } else if fty == "float" {
                emit("  %le" + js + " = fpext float %lc" + js + " to double")
                emit("  %lv" + js + " = call double @ari_load_float(i8* " + npr + ", double %le" + js + ")")
                emit("  %lt" + js + " = fptrunc double %lv" + js + " to float")
                emit("  store float %lt" + js + ", float* %lp" + js)
            } else {
                iw = int_width(fty)
                if iw < 32 {
                    emit("  %le" + js + " = zext " + fty + " %lc" + js + " to i32")
                    emit("  %lv" + js + " = call i32 @ari_load_int(i8* " + npr + ", i32 %le" + js + ")")
                    if iw == 1 {
                        emit("  %lt" + js + " = icmp ne i32 %lv" + js + ", 0")
                        emit("  store i1 %lt" + js + ", i1* %lp" + js)
                    } else {
                        emit("  %lt" + js + " = trunc i32 %lv" + js + " to " + fty)
                        emit("  store " + fty + " %lt" + js + ", " + fty + "* %lp" + js)
                    }
                } else if iw == 32 {
                    emit("  %lv" + js + " = call i32 @ari_load_int(i8* " + npr + ", i32 %lc" + js + ")")
                    emit("  store i32 %lv" + js + ", i32* %lp" + js)
                } else {
                    emit("  %le" + js + " = trunc " + fty + " %lc" + js + " to i32")
                    emit("  %lv" + js + " = call i32 @ari_load_int(i8* " + npr + ", i32 %le" + js + ")")
                    emit("  %lt" + js + " = sext i32 %lv" + js + " to " + fty)
                    emit("  store " + fty + " %lt" + js + ", " + fty + "* %lp" + js)
                }
            }
        }
        j = j + 1
    }
    emit("  call void @ari_load_close()")
    emit("  ret i32 1")
    emit("\}")
    emit("")
    push(g_fn_names, "_reflect_" + sname + "_load_from_path")
    push(g_fn_rets, "i32"); push(g_fn_arities, 2); push(g_fn_ps, len(g_fn_ptys))
    push(g_fn_ptys, sp); push(g_fn_ptys, "i8*")
}

// fn 시그니처 선등록 — 전방 참조 호출이 반환/파라미터 타입을 i64로 오추측하는 것 방지
// (ll_ty→find_enum 류의 호출부/정의부 시그니처 불일치는 -O2에서 조용한 미스컴파일이 됨)
fn preregister_fn(n: i32) {
    if g_nkind[n] != NK_FN { return }
    fname = g_nsval[n]
    if find_fn(fname) != -1 { return }
    rn = g_nc1[n]
    rdh = ""
    if rn > 0 { rdh = g_ntype[rn] }
    np = g_nch_n[n]
    push(g_fn_names, fname); push(g_fn_rets, ll_ty(rdh)); push(g_fn_arities, np)
    push(g_fn_ps, len(g_fn_ptys))
    i = 0
    while i < np {
        p = g_ch[g_nch_s[n] + i]
        push(g_fn_ptys, ll_ty(g_ntype[p]))
        i = i + 1
    }
}

fn cg_parallel_fn(n: i32) {
    fname = g_nsval[n]; body = g_nc0[n]; ret_node = g_nc1[n]
    if g_debug_codegen { print("cg parallel fn begin " + fname) }
    ret_dh = ""; if ret_node > 0 { ret_dh = g_ntype[ret_node] }
    ret_ty = ll_ty(ret_dh)
    if ret_ty != "void" and ret_ty != "()" {
        fatal("parallel system '" + fname + "'은(는) void 반환만 지원해")
    }
    foreach_n = -1
    if g_nkind[body] == NK_BLOCK and g_nch_n[body] == 1 {
        cand = g_ch[g_nch_s[body]]
        if g_nkind[cand] == NK_FOREACH { foreach_n = cand }
    }
    if foreach_n == -1 {
        fatal("parallel system '" + fname + "'은(는) 단일 for each 본문만 현재 self-host 병렬화 대상이야")
    }
    if g_nch_n[foreach_n] == 0 {
        fatal("parallel system '" + fname + "'의 for each 바인딩이 비어 있어")
    }
    pivot_b = g_ch[g_nch_s[foreach_n]]
    pivot_c = g_ntype[pivot_b]

    np = g_nch_n[n]
    pnames: [str] = []; ptys: [str] = []
    i = 0
    while i < np {
        p = g_ch[g_nch_s[n] + i]
        push(pnames, g_nsval[p]); push(ptys, ll_ty(g_ntype[p]))
        i = i + 1
    }

    worker = "__dnh_worker_" + fname
    arg_ty = "\{ i64, i64"
    i = 0
    while i < np { arg_ty = arg_ty + ", " + ptys[i]; i = i + 1 }
    arg_ty = arg_ty + " \}"
    arg_ptr_ty = arg_ty + "*"

    // worker thunk body is generated in an isolated buffer so allocas stay at entry.
    sv_out: [str] = g_out
    sv_ab: [str] = g_alloca_buf
    g_out = []
    g_alloca_buf = []
    sv_vlen = len(g_var_names)
    sv_ret = g_cur_fn_ret
    sv_pf = g_parallel_foreach
    sv_ps = g_parallel_start_reg
    sv_pe = g_parallel_end_reg
    g_cur_fn_ret = "i32"

    typed = new_reg()
    emit("  " + typed + " = bitcast i8* %arg to " + arg_ptr_ty)
    sp = new_reg(); emit("  " + sp + " = getelementptr inbounds " + arg_ty + ", " + arg_ptr_ty + " " + typed + ", i32 0, i32 0")
    sr = new_reg(); emit("  " + sr + " = load i64, i64* " + sp)
    ep = new_reg(); emit("  " + ep + " = getelementptr inbounds " + arg_ty + ", " + arg_ptr_ty + " " + typed + ", i32 0, i32 1")
    er = new_reg(); emit("  " + er + " = load i64, i64* " + ep)
    i = 0
    while i < np {
        pp = new_reg()
        emit("  " + pp + " = getelementptr inbounds " + arg_ty + ", " + arg_ptr_ty + " " + typed + ", i32 0, i32 " + to_string(i + 2))
        pv = new_reg()
        emit("  " + pv + " = load " + ptys[i] + ", " + ptys[i] + "* " + pp)
        slot = "%__par_" + pnames[i] + "_" + to_string(g_reg) + "_v"; g_reg = g_reg + 1
        emit_alloca("  " + slot + " = alloca " + ptys[i])
        emit("  store " + ptys[i] + " " + pv + ", " + ptys[i] + "* " + slot)
        decl_var(pnames[i], slot, ptys[i])
        i = i + 1
    }
    g_parallel_foreach = 1
    g_parallel_start_reg = sr
    g_parallel_end_reg = er
    cg_stmt(body)
    g_parallel_foreach = sv_pf
    g_parallel_start_reg = sv_ps
    g_parallel_end_reg = sv_pe
    while len(g_var_names) > sv_vlen {
        pop(g_var_names); pop(g_var_regs); pop(g_var_tys); pop(g_var_elems); pop(g_var_lams)
    }
    g_cur_fn_ret = sv_ret
    worker_body: [str] = g_out
    worker_allocas: [str] = g_alloca_buf
    g_out = sv_out
    g_alloca_buf = sv_ab

    emit("define i32 @" + worker + "(i8* %arg) \{")
    emit("entry:")
    i = 0
    while i < len(worker_allocas) { emit(worker_allocas[i]); i = i + 1 }
    i = 0
    while i < len(worker_body) { emit(worker_body[i]); i = i + 1 }
    emit("  ret i32 0")
    emit("\}")
    emit("")

    pstr = ""
    i = 0
    while i < np {
        if i > 0 { pstr = pstr + ", " }
        pstr = pstr + ptys[i] + " %" + pnames[i] + "_arg"
        i = i + 1
    }
    emit("define void @" + fname + "(" + pstr + ") \{")
    emit("entry:")
    el = new_reg(); emit("  " + el + " = load %DnhList*, %DnhList** @__ecs_e_" + pivot_c)
    cnt = new_reg(); emit("  " + cnt + " = call i64 @dnh_len(%DnhList* " + el + ")")
    half = new_reg(); emit("  " + half + " = sdiv i64 " + cnt + ", 2")
    a1 = new_reg(); emit("  " + a1 + " = call i8* @malloc(i64 " + to_string(16 + np * 8) + ")")
    ta1 = new_reg(); emit("  " + ta1 + " = bitcast i8* " + a1 + " to " + arg_ptr_ty)
    a2 = new_reg(); emit("  " + a2 + " = call i8* @malloc(i64 " + to_string(16 + np * 8) + ")")
    ta2 = new_reg(); emit("  " + ta2 + " = bitcast i8* " + a2 + " to " + arg_ptr_ty)

    s1p = new_reg(); emit("  " + s1p + " = getelementptr inbounds " + arg_ty + ", " + arg_ptr_ty + " " + ta1 + ", i32 0, i32 0")
    emit("  store i64 0, i64* " + s1p)
    e1p = new_reg(); emit("  " + e1p + " = getelementptr inbounds " + arg_ty + ", " + arg_ptr_ty + " " + ta1 + ", i32 0, i32 1")
    emit("  store i64 " + half + ", i64* " + e1p)
    s2p = new_reg(); emit("  " + s2p + " = getelementptr inbounds " + arg_ty + ", " + arg_ptr_ty + " " + ta2 + ", i32 0, i32 0")
    emit("  store i64 " + half + ", i64* " + s2p)
    e2p = new_reg(); emit("  " + e2p + " = getelementptr inbounds " + arg_ty + ", " + arg_ptr_ty + " " + ta2 + ", i32 0, i32 1")
    emit("  store i64 " + cnt + ", i64* " + e2p)
    i = 0
    while i < np {
        p1 = new_reg(); emit("  " + p1 + " = getelementptr inbounds " + arg_ty + ", " + arg_ptr_ty + " " + ta1 + ", i32 0, i32 " + to_string(i + 2))
        emit("  store " + ptys[i] + " %" + pnames[i] + "_arg, " + ptys[i] + "* " + p1)
        p2 = new_reg(); emit("  " + p2 + " = getelementptr inbounds " + arg_ty + ", " + arg_ptr_ty + " " + ta2 + ", i32 0, i32 " + to_string(i + 2))
        emit("  store " + ptys[i] + " %" + pnames[i] + "_arg, " + ptys[i] + "* " + p2)
        i = i + 1
    }
    h1 = new_reg(); emit("  " + h1 + " = call i8* @CreateThread(i8* null, i64 0, i32 (i8*)* @" + worker + ", i8* " + a1 + ", i32 0, i32* null)")
    h2 = new_reg(); emit("  " + h2 + " = call i8* @CreateThread(i8* null, i64 0, i32 (i8*)* @" + worker + ", i8* " + a2 + ", i32 0, i32* null)")
    w1 = new_reg(); emit("  " + w1 + " = call i32 @WaitForSingleObject(i8* " + h1 + ", i32 -1)")
    w2 = new_reg(); emit("  " + w2 + " = call i32 @WaitForSingleObject(i8* " + h2 + ", i32 -1)")
    c1 = new_reg(); emit("  " + c1 + " = call i32 @CloseHandle(i8* " + h1 + ")")
    c2 = new_reg(); emit("  " + c2 + " = call i32 @CloseHandle(i8* " + h2 + ")")
    emit("  call void @free(i8* " + a1 + ")")
    emit("  call void @free(i8* " + a2 + ")")
    emit("  ret void")
    emit("\}")
    emit("")
}

fn cg_fn(n) {
    if g_nival[n] == 1 { cg_parallel_fn(n); return }
    fname = g_nsval[n]; body = g_nc0[n]; ret_node = g_nc1[n]
    if g_debug_codegen { print("cg fn begin " + fname) }
    ret_dh = ""; if ret_node > 0 { ret_dh = g_ntype[ret_node] }
    ret_ty = ll_ty(ret_dh)
    np = g_nch_n[n]
    pnames: [str] = []; ptys: [str] = []; pdhs: [str] = []
    i = 0
    while i < np {
        p = g_ch[g_nch_s[n] + i]
        push(pnames, g_nsval[p]); push(ptys, ll_ty(g_ntype[p]))
        push(pdhs, g_ntype[p])
        i = i + 1
    }
    // 시그니처는 cg_program의 preregister_fn 패스에서 선등록됨 — 중복 등록 방지
    if find_fn(fname) == -1 {
        push(g_fn_names, fname); push(g_fn_rets, ret_ty); push(g_fn_arities, np)
        push(g_fn_ps, len(g_fn_ptys))
        i = 0; while i < np { push(g_fn_ptys, ptys[i]); i = i + 1 }
    }

    pstr = ""
    i = 0
    while i < np {
        if i > 0 { pstr = pstr + ", " }
        pstr = pstr + ptys[i] + " %" + pnames[i] + "_arg"
        i = i + 1
    }
    emit("define " + ret_ty + " @" + fname + "(" + pstr + ") \{")
    emit("entry:")

    // 리스트 대입은 참조 의미론일 수 있으므로 길이 기록 후 절단으로 스코프 복원
    sv_vlen = len(g_var_names); sv_ret = g_cur_fn_ret
    g_cur_fn_ret = ret_ty
    // defer 스코프: 함수별 시작 인덱스 저장
    sv_dbase = g_defer_base
    g_defer_base = len(g_defer_bodies)

    i = 0
    while i < np {
        pr = "%" + pnames[i] + "_v"
        emit("  " + pr + " = alloca " + ptys[i])
        emit("  store " + ptys[i] + " %" + pnames[i] + "_arg, " + ptys[i] + "* " + pr)
        if pdhs[i] == "EntityId" {
            decl_var_e(pnames[i], pr, ptys[i], "eid")
        } else {
            decl_var(pnames[i], pr, ptys[i])
        }
        i = i + 1
    }

    sv_out: [str] = g_out
    g_out = []
    cg_stmt(body)
    // 폴스루 경로의 defer 방출 + 함수 스코프 defer 해제
    cg_emit_defers()
    while len(g_defer_bodies) > g_defer_base { pop(g_defer_bodies) }
    g_defer_base = sv_dbase
    body_out: [str] = g_out
    g_out = sv_out
    i = 0
    while i < len(g_alloca_buf) { emit(g_alloca_buf[i]); i = i + 1 }
    g_alloca_buf = []
    i = 0
    while i < len(body_out) { emit(body_out[i]); i = i + 1 }

    if ret_ty == "void" or ret_ty == "()" { emit("  ret void") }
    else { emit("  ret " + ret_ty + " " + ll_zero(ret_ty)) }
    emit("\}"); emit("")

    while len(g_var_names) > sv_vlen {
        pop(g_var_names); pop(g_var_regs); pop(g_var_tys); pop(g_var_elems); pop(g_var_lams)
    }
    g_cur_fn_ret = sv_ret
    if g_debug_codegen { print("cg fn end " + fname) }
}

fn predeclare_global_assign(n: i32) {
    if g_nkind[n] != NK_ASSIGN { return }
    name = g_nsval[n]
    if find_var(name) != -1 { return }
    // pc_w: HashMap<...> = ... — 주석이 HashMap이면 %DnhHM* 글로벌
    if g_ntype[n] == "HashMap" {
        emit("@" + name + " = internal global %DnhHM* null")
        decl_var_e(name, "@" + name, "%DnhHM*", "")
        return
    }
    // g: [i32; 64] = [0; 64] — 고정 크기 배열 글로벌
    gfel = ann_fixed_elem(g_ntype[n])
    if gfel != "" {
        gaty = ll_ty(g_ntype[n])
        emit("@" + name + " = internal global " + gaty + " zeroinitializer")
        decl_var_e(name, "@" + name, gaty, gfel)
        return
    }
    e = g_nc0[n]
    // ys = xs — 우변이 고정 배열 변수면 같은 배열 타입 글로벌
    if g_nkind[e] == NK_ID {
        rvi = find_var(g_nsval[e])
        if rvi != -1 {
            if is_arr_val(g_var_tys[rvi]) {
                emit("@" + name + " = internal global " + g_var_tys[rvi] + " zeroinitializer")
                decl_var_e(name, "@" + name, g_var_tys[rvi], g_var_elems[rvi])
                return
            }
        }
    }
    // zs = b.cells — 우변이 고정 배열 필드면 같은 배열 타입 글로벌
    if g_nkind[e] == NK_FIELD {
        fobj2 = g_nc0[e]
        if g_nkind[fobj2] == NK_ID {
            // enum bare variant 글로벌: simple → i64 (기본 경로), tagged → %DnhEnum*
            if find_var(g_nsval[fobj2]) == -1 {
                evg = find_variant(g_nsval[fobj2], g_nsval[e])
                if evg != -1 {
                    if not enum_is_simple(g_nsval[fobj2]) {
                        emit("@" + name + " = internal global %DnhEnum* null")
                        decl_var_e(name, "@" + name, "%DnhEnum*", "")
                        return
                    }
                }
            }
            ovi = find_var(g_nsval[fobj2])
            if ovi != -1 {
                oty = g_var_tys[ovi]
                osn = ""
                osi = 8
                while osi < len(oty) and oty[osi] != "*" { osn = osn + oty[osi]; osi = osi + 1 }
                osidx = find_struct(osn)
                if osidx != -1 {
                    ofi = struct_field_idx(osidx, g_nsval[e])
                    if ofi != -1 {
                        ofty = g_sdef_ftys[g_sdef_fs[osidx] + ofi]
                        if is_arr_val(ofty) {
                            emit("@" + name + " = internal global " + ofty + " zeroinitializer")
                            decl_var_e(name, "@" + name, ofty, "")
                            return
                        }
                    }
                }
            }
        }
    }
    ek = g_nkind[e]
    ty = "i64"
    init = "0"
    if ek == NK_FLOAT {
        ty = "double"; init = "0.0"
    } else if ek == NK_BOOL {
        ty = "i1"; init = "0"
    } else if ek == NK_STR or ek == NK_ISTR or ek == NK_NULL {
        ty = "i8*"; init = "null"
    }
    el = ann_elem(g_ntype[n])
    if ek == NK_ARRAY {
        ty = "%DnhList*"; init = "null"
        if el == "" {
            ai = 0
            while ai < g_nch_n[e] {
                ak = g_nkind[g_ch[g_nch_s[e] + ai]]
                if ak == NK_FLOAT { el = "f64" }
                else if ak == NK_STR or ak == NK_ISTR { if el == "" { el = "str" } }
                else if el == "" { el = "i64" }
                ai = ai + 1
            }
        }
    }
    if ek == NK_STRUCT_INST {
        ty = "%struct." + g_nsval[e] + "*"; init = "null"
    }
    // x = expr as T (dyn Trait 포함)
    if ek == NK_AS {
        ty = ll_ty(g_nsval[e])
        init = ll_zero(ty)
    }
    // x = @sin(...) — 수학 내장은 double (정수 abs/min/max는 대입 시 코어션)
    if ek == NK_MATH {
        ty = "double"; init = "0.0"
    }
    // x = comptime { ... } — 평가 결과 타입
    if ek == NK_COMPTIME {
        ct_eval(g_nc0[e])
        if g_ct_ok and g_ct_isf { ty = "double"; init = "0.0" }
    }
    // x = a + ... — 이항 연산의 가장 왼쪽 리프로 타입 추론
    if ek == NK_ADD or ek == NK_SUB or ek == NK_MUL or ek == NK_DIV {
        lm = e
        while g_nkind[lm] == NK_ADD or g_nkind[lm] == NK_SUB or g_nkind[lm] == NK_MUL or g_nkind[lm] == NK_DIV { lm = g_nc0[lm] }
        lmk = g_nkind[lm]
        if ek == NK_ADD {
            if lmk == NK_STR or lmk == NK_ISTR { ty = "i8*"; init = "null" }
        }
        if lmk == NK_FLOAT { ty = "double"; init = "0.0" }
        // 벡터/실수/mat4 변수가 왼쪽 리프면 그 타입을 따른다
        if lmk == NK_ID {
            lvi2 = find_var(g_nsval[lm])
            if lvi2 != -1 {
                if is_vec_ty(g_var_tys[lvi2]) { ty = g_var_tys[lvi2]; init = "zeroinitializer" }
                if g_var_tys[lvi2] == "double" { ty = "double"; init = "0.0" }
                if is_mat_ty(g_var_tys[lvi2]) {
                    ty = m4ty(); init = "zeroinitializer"
                    // m * v → vec4
                    if ek == NK_MUL {
                        rm2 = g_nc1[e]
                        rk2 = g_nkind[rm2]
                        if rk2 == NK_ID {
                            rvi3 = find_var(g_nsval[rm2])
                            if rvi3 != -1 {
                                if is_vec_ty(g_var_tys[rvi3]) { ty = "<4 x double>" }
                            }
                        }
                        if rk2 == NK_CALL {
                            if g_nsval[rm2] == "vec4" or g_nsval[rm2] == "vec3" or g_nsval[rm2] == "vec2" {
                                ty = "<4 x double>"
                            }
                        }
                    }
                }
            }
        }
    }
    // f = fn(...) -> R { ... } — 함수 포인터 타입 (톱레벨 람다는 캡처 없음)
    if ek == NK_LAMBDA {
        lts = ll_ty(g_ntype[g_nc1[e]]) + " ("
        lpi2 = 0
        while lpi2 < g_nch_n[e] {
            if lpi2 > 0 { lts = lts + ", " }
            lts = lts + ll_ty(g_ntype[g_ch[g_nch_s[e] + lpi2]])
            lpi2 = lpi2 + 1
        }
        ty = lts + ")*"
        init = "null"
    }
    if ek == NK_METHOD {
        mobj = g_nc0[e]
        if g_nkind[mobj] == NK_ID {
            if g_nsval[mobj] == "Arena" and g_nsval[e] == "new" {
                ty = "%DnhArena*"; init = "null"
            } else if g_nsval[mobj] == "HashMap" and g_nsval[e] == "new" {
                ty = "%DnhHM*"; init = "null"
            } else if find_variant(g_nsval[mobj], g_nsval[e]) != -1 {
                ty = "%DnhEnum*"; init = "null"
            } else {
                // HashMap 변수에 대한 메서드 반환 타입 (predeclare는 톱레벨을 순서대로 돌므로 변수는 이미 등록됨)
                mvi = find_var(g_nsval[mobj])
                if mvi != -1 {
                    if g_var_tys[mvi] == "%DnhHM*" {
                        mn2 = g_nsval[e]
                        if mn2 == "keys" {
                            ty = "%DnhList*"; init = "null"
                            if el == "" { el = "str" }
                        }
                        if mn2 == "get_str" { ty = "i8*"; init = "null" }
                        if mn2 == "get_f64" { ty = "double"; init = "0.0" }
                        if mn2 == "has" or mn2 == "remove" or mn2 == "get_bool" { ty = "i1"; init = "0" }
                    }
                    // 리스트 메서드/HOF 반환 타입
                    if g_var_tys[mvi] == "%DnhList*" {
                        mn3 = g_nsval[e]
                        if mn3 == "map" or mn3 == "filter" {
                            ty = "%DnhList*"; init = "null"
                            if mn3 == "filter" and el == "" { el = g_var_elems[mvi] }
                            if mn3 == "map" and el == "" and g_nch_n[e] == 1 {
                                mcb = g_ch[g_nch_s[e]]
                                if g_nkind[mcb] == NK_LAMBDA {
                                    mrt = ll_ty(g_ntype[g_nc1[mcb]])
                                    if mrt == "i8*" { el = "str" }
                                    if mrt == "double" { el = "f64" }
                                }
                            }
                        }
                        if mn3 == "len" or mn3 == "count" or mn3 == "pop" { ty = "i64"; init = "0" }
                        if mn3 == "any" or mn3 == "all" or mn3 == "contains" { ty = "i1"; init = "0" }
                        if mn3 == "reverse" or mn3 == "take" or mn3 == "skip" or mn3 == "sort_by" {
                            ty = "%DnhList*"; init = "null"
                            if el == "" { el = g_var_elems[mvi] }
                        }
                        if mn3 == "find" {
                            fel3 = g_var_elems[mvi]
                            if fel3 == "str" { ty = "i8*"; init = "null" }
                            else if fel3 == "f64" { ty = "double"; init = "0.0" }
                            else { ty = "i64"; init = "0" }
                        }
                        if mn3 == "reduce" and g_nch_n[e] == 2 {
                            rcb = g_ch[g_nch_s[e] + 1]
                            if g_nkind[rcb] == NK_LAMBDA and g_nch_n[rcb] > 0 {
                                ty = ll_ty(g_ntype[g_ch[g_nch_s[rcb]]])
                                init = ll_zero(ty)
                            } else {
                                ty = "i64"; init = "0"
                            }
                        }
                    }
                }
            }
        }
    }
    if ek == NK_CALL {
        cn = g_nsval[e]
        if cn == "spawn" and find_fn("spawn") == -1 {
            ty = "i64"; init = "0"
            if el == "" { el = "eid" }
        } else if (cn == "destroy" or cn == "is_alive") and find_fn(cn) == -1 {
            ty = "i1"; init = "0"
        } else if (cn == "has" or cn == "remove") and find_fn(cn) == -1 and g_nch_n[e] == 2 {
            ty = "i1"; init = "0"
        } else if cn == "get" and find_fn("get") == -1 and g_nch_n[e] == 2 {
            // get(e, Comp) — 둘째 인자가 컴포넌트 이름이면 그 struct 포인터
            ga2 = g_ch[g_nch_s[e] + 1]
            if g_nkind[ga2] == NK_ID {
                if comp_has(g_nsval[ga2]) {
                    ty = "%struct." + g_nsval[ga2] + "*"; init = "null"
                }
            }
        } else if cn == "file_read" or cn == "to_string" or cn == "substr" or cn == "replace" or cn == "input" or cn == "chr" {
            ty = "i8*"; init = "null"
        } else if cn == "split" or cn == "get_args" {
            ty = "%DnhList*"; init = "null"
            if el == "" { el = "str" }
        } else if cn == "file_read_bytes" {
            ty = "%DnhList*"; init = "null"
            if el == "" { el = "i64" }
        } else if cn == "clock" or cn == "to_float" {
            ty = "double"; init = "0.0"
        } else if cn == "contains" or cn == "ends_with" or cn == "starts_with" or cn == "file_exists" {
            ty = "i1"; init = "0"
        } else if cn == "file_size" or cn == "u16le" or cn == "i16le" or cn == "u32le" {
            ty = "i64"; init = "0"
        } else if cn == "string_builder" {
            ty = "%DnhSB*"; init = "null"
        } else if cn == "string_builder_to_string" {
            ty = "i8*"; init = "null"
        } else if cn == "vec2" {
            ty = "<2 x double>"; init = "zeroinitializer"
        } else if cn == "vec3" {
            ty = "<3 x double>"; init = "zeroinitializer"
        } else if cn == "vec4" {
            ty = "<4 x double>"; init = "zeroinitializer"
        } else if cn == "dot" {
            ty = "double"; init = "0.0"
        } else if cn == "length" {
            ty = "double"; init = "0.0"
        } else if cn == "normalize" {
            if g_nch_n[e] > 0 {
                na = g_ch[g_nch_s[e]]
                if g_nkind[na] == NK_ID {
                    nvi = find_var(g_nsval[na])
                    if nvi != -1 and is_vec_ty(g_var_tys[nvi]) {
                        ty = g_var_tys[nvi]; init = "zeroinitializer"
                    }
                } else if g_nkind[na] == NK_ADD or g_nkind[na] == NK_SUB or g_nkind[na] == NK_MUL or g_nkind[na] == NK_DIV {
                    nl = g_nc0[na]
                    nr = g_nc1[na]
                    if g_nkind[nl] == NK_ID {
                        nlvi = find_var(g_nsval[nl])
                        if nlvi != -1 and is_vec_ty(g_var_tys[nlvi]) {
                            ty = g_var_tys[nlvi]; init = "zeroinitializer"
                        }
                    }
                    if ty == "i64" and g_nkind[nr] == NK_ID {
                        nrvi = find_var(g_nsval[nr])
                        if nrvi != -1 and is_vec_ty(g_var_tys[nrvi]) {
                            ty = g_var_tys[nrvi]; init = "zeroinitializer"
                        }
                    }
                }
            }
        } else if cn == "cross" {
            ty = "<3 x double>"; init = "zeroinitializer"
        } else if cn == "mat4_identity" or cn == "mat4_translate" or cn == "mat4_scale" or cn == "mat4_rotate_x" or cn == "mat4_rotate_y" or cn == "mat4_rotate_z" or cn == "mat4_transpose" or cn == "mat4_inverse" {
            ty = m4ty(); init = "zeroinitializer"
        } else {
            // 사용자 정의 fn 반환 타입 (preregister 패스가 먼저 돌아 시그니처가 있음)
            pfi = find_fn(cn)
            if pfi != -1 {
                ty = g_fn_rets[pfi]
                init = ll_zero(ty)
                if is_arr_val(ty) { init = "zeroinitializer" }
                if ty == "void" or ty == "()" { ty = "i64"; init = "0" }
            }
        }
    }
    emit("@" + name + " = internal global " + ty + " " + init)
    decl_var_e(name, "@" + name, ty, el)
}

fn emit_direct_os_rt() {
    // MSVC 링커는 double 사용 시 CRT 심볼 _fltused를 요구 — 직접 정의
    emit("@_fltused = global i32 0")
    emit("@.rt_nl = private unnamed_addr constant [2 x i8] c\"\\0A\\00\", align 1")
    emit("@.rt_i64_buf = internal global [32 x i8] zeroinitializer, align 1")
    emit("@_danha_os_write_count = internal global i32 0")
    emit("")
    emit("declare i8* @GetProcessHeap()")
    emit("declare i8* @HeapAlloc(i8*, i32, i64)")
    emit("declare i8* @HeapReAlloc(i8*, i32, i8*, i64)")
    emit("declare i32 @HeapFree(i8*, i32, i8*)")
    emit("declare i8* @GetStdHandle(i32)")
    emit("declare i32 @WriteFile(i8*, i8*, i32, i32*, i8*)")
    emit("declare void @ExitProcess(i32)")
    emit("")
    emit("define i8* @malloc(i64 %size) \{")
    emit("entry:")
    emit("  %heap = call i8* @GetProcessHeap()")
    emit("  %mem = call i8* @HeapAlloc(i8* %heap, i32 8, i64 %size)")
    emit("  ret i8* %mem")
    emit("\}")
    emit("")
    emit("define i8* @realloc(i8* %ptr, i64 %size) \{")
    emit("entry:")
    emit("  %is_null = icmp eq i8* %ptr, null")
    emit("  br i1 %is_null, label %alloc, label %grow")
    emit("alloc:")
    emit("  %heap_a = call i8* @GetProcessHeap()")
    emit("  %mem_a = call i8* @HeapAlloc(i8* %heap_a, i32 8, i64 %size)")
    emit("  ret i8* %mem_a")
    emit("grow:")
    emit("  %heap_g = call i8* @GetProcessHeap()")
    emit("  %mem_g = call i8* @HeapReAlloc(i8* %heap_g, i32 8, i8* %ptr, i64 %size)")
    emit("  ret i8* %mem_g")
    emit("\}")
    emit("")
    emit("define void @free(i8* %ptr) \{")
    emit("entry:")
    emit("  %heap = call i8* @GetProcessHeap()")
    emit("  call i32 @HeapFree(i8* %heap, i32 0, i8* %ptr)")
    emit("  ret void")
    emit("\}")
    emit("")
    emit("define i32 @strlen(i8* %s) \{")
    emit("entry:")
    emit("  br label %loop")
    emit("loop:")
    emit("  %i = phi i32 [0, %entry], [%next, %cont]")
    emit("  %p = getelementptr i8, i8* %s, i32 %i")
    emit("  %ch = load i8, i8* %p")
    emit("  %end = icmp eq i8 %ch, 0")
    emit("  br i1 %end, label %done, label %cont")
    emit("cont:")
    emit("  %next = add i32 %i, 1")
    emit("  br label %loop")
    emit("done:")
    emit("  ret i32 %i")
    emit("\}")
    emit("")
    emit("define i8* @strcpy(i8* %dst, i8* %src) \{")
    emit("entry:")
    emit("  br label %loop")
    emit("loop:")
    emit("  %i = phi i32 [0, %entry], [%next, %cont]")
    emit("  %sp = getelementptr i8, i8* %src, i32 %i")
    emit("  %dp = getelementptr i8, i8* %dst, i32 %i")
    emit("  %ch = load i8, i8* %sp")
    emit("  store i8 %ch, i8* %dp")
    emit("  %end = icmp eq i8 %ch, 0")
    emit("  br i1 %end, label %done, label %cont")
    emit("cont:")
    emit("  %next = add i32 %i, 1")
    emit("  br label %loop")
    emit("done:")
    emit("  ret i8* %dst")
    emit("\}")
    emit("")
    emit("define i32 @strcmp(i8* %a, i8* %b) \{")
    emit("entry:")
    emit("  br label %loop")
    emit("loop:")
    emit("  %i = phi i32 [0, %entry], [%next, %cont]")
    emit("  %ap = getelementptr i8, i8* %a, i32 %i")
    emit("  %bp = getelementptr i8, i8* %b, i32 %i")
    emit("  %ac8 = load i8, i8* %ap")
    emit("  %bc8 = load i8, i8* %bp")
    emit("  %ac = zext i8 %ac8 to i32")
    emit("  %bc = zext i8 %bc8 to i32")
    emit("  %diff = sub i32 %ac, %bc")
    emit("  %neq = icmp ne i32 %diff, 0")
    emit("  %end = icmp eq i8 %ac8, 0")
    emit("  %stop = or i1 %neq, %end")
    emit("  br i1 %stop, label %done, label %cont")
    emit("cont:")
    emit("  %next = add i32 %i, 1")
    emit("  br label %loop")
    emit("done:")
    emit("  ret i32 %diff")
    emit("\}")
    emit("")
    emit("define void @dnh_os_write(i8* %s, i32 %len) \{")
    emit("entry:")
    emit("  %out = call i8* @GetStdHandle(i32 -11)")
    emit("  call i32 @WriteFile(i8* %out, i8* %s, i32 %len, i32* @_danha_os_write_count, i8* null)")
    emit("  ret void")
    emit("\}")
    emit("")
    emit("define void @dnh_os_write_nl(i8* %s) \{")
    emit("entry:")
    emit("  %len = call i32 @strlen(i8* %s)")
    emit("  call void @dnh_os_write(i8* %s, i32 %len)")
    emit("  %nl = getelementptr inbounds [2 x i8], [2 x i8]* @.rt_nl, i32 0, i32 0")
    emit("  call void @dnh_os_write(i8* %nl, i32 1)")
    emit("  ret void")
    emit("\}")
    emit("")
    emit("define i32 @puts(i8* %s) \{")
    emit("entry:")
    emit("  call void @dnh_os_write_nl(i8* %s)")
    emit("  ret i32 0")
    emit("\}")
    emit("")
    emit("define void @dnh_os_print_i64(i64 %v) \{")
    emit("entry:")
    emit("  %is_zero = icmp eq i64 %v, 0")
    emit("  br i1 %is_zero, label %zero, label %prep")
    emit("zero:")
    emit("  %zbuf = getelementptr inbounds [32 x i8], [32 x i8]* @.rt_i64_buf, i32 0, i32 0")
    emit("  store i8 48, i8* %zbuf")
    emit("  call void @dnh_os_write(i8* %zbuf, i32 1)")
    emit("  %znl = getelementptr inbounds [2 x i8], [2 x i8]* @.rt_nl, i32 0, i32 0")
    emit("  call void @dnh_os_write(i8* %znl, i32 1)")
    emit("  ret void")
    emit("prep:")
    emit("  %neg = icmp slt i64 %v, 0")
    emit("  %absn = sub i64 0, %v")
    emit("  %n0 = select i1 %neg, i64 %absn, i64 %v")
    emit("  %endp = getelementptr inbounds [32 x i8], [32 x i8]* @.rt_i64_buf, i32 0, i32 31")
    emit("  br label %loop")
    emit("loop:")
    emit("  %n = phi i64 [%n0, %prep], [%n2, %loop]")
    emit("  %p = phi i8* [%endp, %prep], [%p2, %loop]")
    emit("  %len = phi i32 [0, %prep], [%len2, %loop]")
    emit("  %rem = srem i64 %n, 10")
    emit("  %d64 = add i64 %rem, 48")
    emit("  %d8 = trunc i64 %d64 to i8")
    emit("  %p2 = getelementptr i8, i8* %p, i64 -1")
    emit("  store i8 %d8, i8* %p2")
    emit("  %n2 = sdiv i64 %n, 10")
    emit("  %len2 = add i32 %len, 1")
    emit("  %more = icmp ne i64 %n2, 0")
    emit("  br i1 %more, label %loop, label %digits_done")
    emit("digits_done:")
    emit("  br i1 %neg, label %add_minus, label %write")
    emit("add_minus:")
    emit("  %mp = getelementptr i8, i8* %p2, i64 -1")
    emit("  store i8 45, i8* %mp")
    emit("  %mlen = add i32 %len2, 1")
    emit("  br label %write")
    emit("write:")
    emit("  %wp = phi i8* [%p2, %digits_done], [%mp, %add_minus]")
    emit("  %wl = phi i32 [%len2, %digits_done], [%mlen, %add_minus]")
    emit("  call void @dnh_os_write(i8* %wp, i32 %wl)")
    emit("  %nl = getelementptr inbounds [2 x i8], [2 x i8]* @.rt_nl, i32 0, i32 0")
    emit("  call void @dnh_os_write(i8* %nl, i32 1)")
    emit("  ret void")
    emit("\}")
    emit("")
    emit("define i32 @printf(i8* %fmt, ...) \{")
    emit("entry:")
    emit("  ret i32 0")
    emit("\}")
    emit("")
    emit("define i32 @snprintf(i8* %buf, i64 %size, i8* %fmt, ...) \{")
    emit("entry:")
    emit("  store i8 0, i8* %buf")
    emit("  ret i32 0")
    emit("\}")
    emit("")
    emit("define void @dnh_exit(i32 %code) \{")
    emit("entry:")
    emit("  call void @ExitProcess(i32 %code)")
    emit("  ret void")
    emit("\}")
    emit("declare i8* @CreateFileA(i8*, i32, i32, i8*, i32, i32, i8*)")
    emit("declare i32 @ReadFile(i8*, i8*, i32, i32*, i8*)")
    emit("declare i32 @GetFileSize(i8*, i32*)")
    emit("declare i32 @CloseHandle(i8*)")
    emit("declare i32 @SetFilePointer(i8*, i32, i32*, i32)")
    emit("declare i32 @GetFileAttributesA(i8*)")
    emit("declare i8* @GetCommandLineA()")
    emit("declare i32 @CreateProcessA(i8*, i8*, i8*, i8*, i32, i32, i8*, i8*, i8*, i8*)")
    emit("declare i8* @CreateThread(i8*, i64, i32 (i8*)*, i8*, i32, i32*)")
    emit("declare i32 @WaitForSingleObject(i8*, i32)")
    emit("declare i32 @GetExitCodeProcess(i8*, i32*)")
    emit("declare void @llvm.memset.p0i8.i64(i8*, i8, i64, i1)")
    emit("")
    emit("define i8* @dnh_file_read(i8* %path) \{")
    emit("entry:")
    emit("  %rd = alloca i32")
    emit("  %h = call i8* @CreateFileA(i8* %path, i32 -2147483648, i32 1, i8* null, i32 3, i32 128, i8* null)")
    emit("  %hi = ptrtoint i8* %h to i64")
    emit("  %bad = icmp eq i64 %hi, -1")
    emit("  br i1 %bad, label %fr_fail, label %fr_ok")
    emit("fr_fail:")
    emit("  %e = call i8* @malloc(i64 1)")
    emit("  store i8 0, i8* %e")
    emit("  ret i8* %e")
    emit("fr_ok:")
    emit("  %sz = call i32 @GetFileSize(i8* %h, i32* null)")
    emit("  %sz64 = zext i32 %sz to i64")
    emit("  %n1 = add i64 %sz64, 1")
    emit("  %buf = call i8* @malloc(i64 %n1)")
    emit("  %r = call i32 @ReadFile(i8* %h, i8* %buf, i32 %sz, i32* %rd, i8* null)")
    emit("  %rdv = load i32, i32* %rd")
    emit("  %rd64 = zext i32 %rdv to i64")
    emit("  %endp = getelementptr i8, i8* %buf, i64 %rd64")
    emit("  store i8 0, i8* %endp")
    emit("  %c = call i32 @CloseHandle(i8* %h)")
    emit("  ret i8* %buf")
    emit("\}")
    emit("")
    emit("define i64 @dnh_file_size(i8* %path) \{")
    emit("entry:")
    emit("  %h = call i8* @CreateFileA(i8* %path, i32 -2147483648, i32 1, i8* null, i32 3, i32 128, i8* null)")
    emit("  %hi = ptrtoint i8* %h to i64")
    emit("  %bad = icmp eq i64 %hi, -1")
    emit("  br i1 %bad, label %fs_fail, label %fs_ok")
    emit("fs_fail:")
    emit("  ret i64 -1")
    emit("fs_ok:")
    emit("  %sz = call i32 @GetFileSize(i8* %h, i32* null)")
    emit("  %c = call i32 @CloseHandle(i8* %h)")
    emit("  %sz64 = zext i32 %sz to i64")
    emit("  ret i64 %sz64")
    emit("\}")
    emit("")
    emit("define %DnhList* @dnh_file_read_bytes(i8* %path) \{")
    emit("entry:")
    emit("  %rd = alloca i32")
    emit("  %lst = call %DnhList* @dnh_new_list()")
    emit("  %h = call i8* @CreateFileA(i8* %path, i32 -2147483648, i32 1, i8* null, i32 3, i32 128, i8* null)")
    emit("  %hi = ptrtoint i8* %h to i64")
    emit("  %bad = icmp eq i64 %hi, -1")
    emit("  br i1 %bad, label %frb_done, label %frb_ok")
    emit("frb_ok:")
    emit("  %sz = call i32 @GetFileSize(i8* %h, i32* null)")
    emit("  %sz64 = zext i32 %sz to i64")
    emit("  %buf = call i8* @malloc(i64 %sz64)")
    emit("  %r = call i32 @ReadFile(i8* %h, i8* %buf, i32 %sz, i32* %rd, i8* null)")
    emit("  %rdv = load i32, i32* %rd")
    emit("  %rd64 = zext i32 %rdv to i64")
    emit("  br label %frb_loop")
    emit("frb_loop:")
    emit("  %i = phi i64 [0, %frb_ok], [%ni, %frb_loop_body]")
    emit("  %more = icmp slt i64 %i, %rd64")
    emit("  br i1 %more, label %frb_loop_body, label %frb_close")
    emit("frb_loop_body:")
    emit("  %bp = getelementptr i8, i8* %buf, i64 %i")
    emit("  %bv = load i8, i8* %bp")
    emit("  %b64 = zext i8 %bv to i64")
    emit("  call void @dnh_push(%DnhList* %lst, i64 %b64)")
    emit("  %ni = add i64 %i, 1")
    emit("  br label %frb_loop")
    emit("frb_close:")
    emit("  %c = call i32 @CloseHandle(i8* %h)")
    emit("  br label %frb_done")
    emit("frb_done:")
    emit("  ret %DnhList* %lst")
    emit("\}")
    emit("")
    emit("define void @dnh_file_write(i8* %path, i8* %text) \{")
    emit("entry:")
    emit("  %wr = alloca i32")
    emit("  %h = call i8* @CreateFileA(i8* %path, i32 1073741824, i32 1, i8* null, i32 2, i32 128, i8* null)")
    emit("  %hi = ptrtoint i8* %h to i64")
    emit("  %bad = icmp eq i64 %hi, -1")
    emit("  br i1 %bad, label %fw_done, label %fw_ok")
    emit("fw_ok:")
    emit("  %l = call i32 @strlen(i8* %text)")
    emit("  %w = call i32 @WriteFile(i8* %h, i8* %text, i32 %l, i32* %wr, i8* null)")
    emit("  %c = call i32 @CloseHandle(i8* %h)")
    emit("  br label %fw_done")
    emit("fw_done:")
    emit("  ret void")
    emit("\}")
    emit("")
    emit("define void @dnh_file_write_bytes(i8* %path, %DnhList* %lst) \{")
    emit("entry:")
    emit("  %wr = alloca i32")
    emit("  %h = call i8* @CreateFileA(i8* %path, i32 1073741824, i32 1, i8* null, i32 2, i32 128, i8* null)")
    emit("  %hi = ptrtoint i8* %h to i64")
    emit("  %bad = icmp eq i64 %hi, -1")
    emit("  br i1 %bad, label %fwb_done, label %fwb_ok")
    emit("fwb_ok:")
    emit("  %n = call i64 @dnh_len(%DnhList* %lst)")
    emit("  %buf = call i8* @malloc(i64 %n)")
    emit("  br label %fwb_loop")
    emit("fwb_loop:")
    emit("  %i = phi i64 [0, %fwb_ok], [%ni, %fwb_loop_body]")
    emit("  %more = icmp slt i64 %i, %n")
    emit("  br i1 %more, label %fwb_loop_body, label %fwb_write")
    emit("fwb_loop_body:")
    emit("  %v = call i64 @dnh_get(%DnhList* %lst, i64 %i)")
    emit("  %b = trunc i64 %v to i8")
    emit("  %bp = getelementptr i8, i8* %buf, i64 %i")
    emit("  store i8 %b, i8* %bp")
    emit("  %ni = add i64 %i, 1")
    emit("  br label %fwb_loop")
    emit("fwb_write:")
    emit("  %n32 = trunc i64 %n to i32")
    emit("  %w = call i32 @WriteFile(i8* %h, i8* %buf, i32 %n32, i32* %wr, i8* null)")
    emit("  %c = call i32 @CloseHandle(i8* %h)")
    emit("  br label %fwb_done")
    emit("fwb_done:")
    emit("  ret void")
    emit("\}")
    emit("")
    emit("define void @dnh_file_append(i8* %path, i8* %text) \{")
    emit("entry:")
    emit("  %wr = alloca i32")
    emit("  %h = call i8* @CreateFileA(i8* %path, i32 1073741824, i32 1, i8* null, i32 4, i32 128, i8* null)")
    emit("  %hi = ptrtoint i8* %h to i64")
    emit("  %bad = icmp eq i64 %hi, -1")
    emit("  br i1 %bad, label %fa_done, label %fa_ok")
    emit("fa_ok:")
