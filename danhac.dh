            t2 = new_reg(); t3 = new_reg(); cy = new_reg()
            emit("  " + t2 + " = fmul double " + az + ", " + bx)
            emit("  " + t3 + " = fmul double " + ax + ", " + bz)
            emit("  " + cy + " = fsub double " + t2 + ", " + t3)
            t4 = new_reg(); t5 = new_reg(); cz = new_reg()
