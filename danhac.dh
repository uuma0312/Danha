// danhac.dh — Danha 셀프 호스팅 컴파일러 (부트스트랩 단계)
// 사용법: danha selfhost <input.dh> [--out <name>] [--linker danha|external] [--emit-ir|--emit-obj]
// 개발용: danhac_dos.exe --probe-obj <input.obj>
// 출력:  <name>.ll  →  clang -c <name>.ll → Danha PE linker 또는 외부 clang 링크

// ─── 토큰 종류 상수 ────────────────────────────────────────────────────────
TK_EOF      = 0
TK_NUM      = 1
TK_FNUM     = 2
TK_STR      = 3
TK_ISTR     = 4
TK_ID       = 5
TK_DOC      = 6
TK_NL       = 7

TK_PRINT    = 10
TK_IF       = 11
TK_ELSE     = 12
TK_WHILE    = 13
TK_FOR      = 14
TK_IN       = 15
TK_FN       = 16
TK_RETURN   = 17
TK_AND      = 18
TK_OR       = 19
TK_NOT      = 20
TK_STRUCT   = 21
TK_COMPONENT = 22
TK_SYSTEM   = 23
TK_PARALLEL = 24
TK_TRAIT    = 25
TK_IMPL     = 26
TK_SELF_KW  = 27
TK_TRUE     = 28
TK_FALSE    = 29
TK_NULL     = 30
TK_DYN      = 31
TK_MUT      = 32
TK_CONST    = 33
TK_ENUM     = 34
TK_BREAK    = 35
TK_CONTINUE = 36
TK_EXTERN   = 37
TK_MATCH    = 38
TK_IMPORT   = 39
TK_FROM     = 40
TK_AS       = 41
TK_DEFER    = 42
TK_COMPTIME = 43
TK_UNSAFE   = 44
TK_MACRO    = 45
TK_EXPORT   = 46
TK_UNION    = 47

TK_PLUS     = 60
TK_MINUS    = 61
TK_STAR     = 62
TK_SLASH    = 63
TK_PERCENT  = 64
TK_AMP      = 65
TK_PIPE     = 66
TK_CARET    = 67
TK_TILDE    = 68
TK_LSHIFT   = 69
TK_RSHIFT   = 70
TK_EQ       = 71
TK_EQEQ     = 72
TK_NEQ      = 73
TK_LT       = 74
TK_GT       = 75
TK_LTE      = 76
TK_GTE      = 77
TK_FAT_ARROW = 78
TK_ARROW    = 79
TK_LPAREN   = 80
TK_RPAREN   = 81
TK_LBRACE   = 82
TK_RBRACE   = 83
TK_LBRACK   = 84
TK_RBRACK   = 85
TK_COMMA    = 86
TK_COLON    = 87
TK_DOT      = 88
TK_DOTDOT   = 89
TK_ELLIPSIS = 90
TK_AT       = 91
TK_BANG     = 92
TK_SEMICOLON = 93
TK_QUESTION = 94

// ─── 토큰 저장소 (SoA) ────────────────────────────────────────────────────
g_toks_kind: [i32] = []
g_toks_sval: [str] = []
g_toks_ival: [i64] = []
g_toks_fval: [f64] = []
g_toks_line: [i32] = []

g_runtime_direct: bool = false
g_target_linux: bool = false
g_debug_codegen: bool = false
g_coff_bytes: [i64] = []
g_link_imports: [str] = []
g_link_idata: [i64] = []
g_link_thunks: [i64] = []
g_link_sec_names: [str] = []
g_link_sec_data_lens: [i64] = []
g_link_sec_virtual_sizes: [i64] = []
g_link_sec_chars: [i64] = []
g_link_sec_rvas: [i64] = []
g_obj_section_link_indices: [i64] = []
g_obj_section_offsets: [i64] = []
g_sec_text: [i64] = []
g_sec_xdata: [i64] = []
g_sec_rdata: [i64] = []
g_sec_pdata: [i64] = []
g_sec_dthnk: [i64] = []
g_sec_idata: [i64] = []

// ─── 렉서 헬퍼 ────────────────────────────────────────────────────────────
fn is_digit(c: str) -> bool {
    return c == "0" or c == "1" or c == "2" or c == "3" or c == "4" or c == "5" or c == "6" or c == "7" or c == "8" or c == "9"
}

fn is_hex_char(c: str) -> bool {
    return c == "0" or c == "1" or c == "2" or c == "3" or c == "4" or c == "5" or c == "6" or c == "7" or c == "8" or c == "9" or c == "a" or c == "b" or c == "c" or c == "d" or c == "e" or c == "f" or c == "A" or c == "B" or c == "C" or c == "D" or c == "E" or c == "F" or c == "_"
}

fn is_alpha(c: str) -> bool {
    return (c >= "a" and c <= "z") or (c >= "A" and c <= "Z") or c == "_"
}

fn is_alnum(c: str) -> bool {
    return is_alpha(c) or is_digit(c)
}

fn char_digit_val(c: str) -> i64 {
    if c == "0" { return 0 }
    if c == "1" { return 1 }
    if c == "2" { return 2 }
    if c == "3" { return 3 }
    if c == "4" { return 4 }
    if c == "5" { return 5 }
    if c == "6" { return 6 }
    if c == "7" { return 7 }
    if c == "8" { return 8 }
    return 9
}

fn hex_digit_val(c: str) -> i64 {
    if c == "0" { return 0 }
    if c == "1" { return 1 }
    if c == "2" { return 2 }
    if c == "3" { return 3 }
    if c == "4" { return 4 }
    if c == "5" { return 5 }
    if c == "6" { return 6 }
    if c == "7" { return 7 }
    if c == "8" { return 8 }
    if c == "9" { return 9 }
    if c == "a" or c == "A" { return 10 }
    if c == "b" or c == "B" { return 11 }
    if c == "c" or c == "C" { return 12 }
    if c == "d" or c == "D" { return 13 }
    if c == "e" or c == "E" { return 14 }
    return 15
}

fn parse_int(s: str) -> i64 {
    result = 0
    i = 0
    while i < len(s) {
        result = result * 10 + char_digit_val(s[i])
        i = i + 1
    }
    return result
}

fn parse_hex(s: str) -> i64 {
    result = 0
    i = 0
    while i < len(s) {
        result = result * 16 + hex_digit_val(s[i])
        i = i + 1
    }
    return result
}

fn parse_float(s: str) -> f64 {
    dot_pos = -1
    i = 0
    while i < len(s) {
        if s[i] == "." { dot_pos = i }
        i = i + 1
    }
    int_part = 0
    i = 0
    while i < dot_pos {
        int_part = int_part * 10 + char_digit_val(s[i])
        i = i + 1
    }
    frac_part = 0.0
    scale = 0.1
    i = dot_pos + 1
    while i < len(s) {
        frac_part = frac_part + (char_digit_val(s[i]) as f64) * scale
        scale = scale * 0.1
        i = i + 1
    }
    return (int_part as f64) + frac_part
}

fn kw_kind(name: str) -> i32 {
    if name == "print"    { return TK_PRINT }
    if name == "if"       { return TK_IF }
    if name == "else"     { return TK_ELSE }
    if name == "while"    { return TK_WHILE }
    if name == "for"      { return TK_FOR }
    if name == "in"       { return TK_IN }
    if name == "fn"       { return TK_FN }
    if name == "return"   { return TK_RETURN }
    if name == "and"      { return TK_AND }
    if name == "or"       { return TK_OR }
    if name == "not"      { return TK_NOT }
    if name == "struct"   { return TK_STRUCT }
    if name == "true"     { return TK_TRUE }
    if name == "false"    { return TK_FALSE }
    if name == "null"     { return TK_NULL }
    if name == "break"    { return TK_BREAK }
    if name == "continue" { return TK_CONTINUE }
    if name == "extern"   { return TK_EXTERN }
    if name == "as"       { return TK_AS }
    if name == "enum"     { return TK_ENUM }
    if name == "match"    { return TK_MATCH }
    if name == "trait"    { return TK_TRAIT }
    if name == "impl"     { return TK_IMPL }
    return TK_ID
}

fn tok_push(kind: i32, sval: str, ival: i64, fval: f64, line: i32) {
    push(g_toks_kind, kind)
    push(g_toks_sval, sval)
    push(g_toks_ival, ival)
    push(g_toks_fval, fval)
    push(g_toks_line, line)
}

// ─── 렉서 본체 ────────────────────────────────────────────────────────────
fn lex(src: str) {
    n = len(src)
    i = 0
    line = 1

    while i < n {
        c = src[i]

        if c == " " or c == "\t" {
            i = i + 1
            continue
        }

        if c == "#" {
            while i < n and src[i] != "\n" {
                i = i + 1
            }
            continue
        }

        if c == "/" and i + 1 < n and src[i + 1] == "/" {
            if i + 2 < n and src[i + 2] == "/" {
                i = i + 3
                doc_str = ""
                while i < n and src[i] != "\n" {
                    doc_str = doc_str + src[i]
                    i = i + 1
                }
                tok_push(TK_DOC, doc_str, 0, 0.0, line)
            } else {
                while i < n and src[i] != "\n" {
                    i = i + 1
                }
            }
            continue
        }

        if c == "\n" {
            tok_push(TK_NL, "\n", 0, 0.0, line)
            line = line + 1
            i = i + 1
            continue
        }

        if is_digit(c) {
            start_line = line
            if c == "0" and i + 1 < n and (src[i + 1] == "x" or src[i + 1] == "X") {
                i = i + 2
                hex_str = ""
                while i < n and is_hex_char(src[i]) {
                    if src[i] != "_" {
                        hex_str = hex_str + src[i]
                    }
                    i = i + 1
                }
                tok_push(TK_NUM, hex_str, parse_hex(hex_str), 0.0, start_line)
                continue
            }
            num_str = ""
            while i < n and is_digit(src[i]) {
                num_str = num_str + src[i]
                i = i + 1
            }
            if i < n and src[i] == "." and i + 1 < n and is_digit(src[i + 1]) {
                num_str = num_str + "."
                i = i + 1
                while i < n and is_digit(src[i]) {
                    num_str = num_str + src[i]
                    i = i + 1
                }
                parsed_f = parse_float(num_str)
                tok_push(TK_FNUM, num_str, 0, parsed_f, start_line)
            } else {
                parsed_i = parse_int(num_str)
                tok_push(TK_NUM, num_str, parsed_i, 0.0, start_line)
            }
            continue
        }

        if is_alpha(c) {
            start_line = line
            name = ""
            while i < n and is_alnum(src[i]) {
                name = name + src[i]
                i = i + 1
            }
            kind = kw_kind(name)
            tok_push(kind, name, 0, 0.0, start_line)
            continue
        }

        if c == "\"" {
            start_line = line
            i = i + 1
            str_val = ""
            has_interp = false
            idepth = 0
            while i < n {
                if idepth == 0 and src[i] == "\"" { break }
                if src[i] == "\\" and i + 1 < n {
                    esc = src[i + 1]
                    if esc == "n"  { str_val = str_val + "\n" }
                    else if esc == "t"  { str_val = str_val + "\t" }
                    else if esc == "\\" { str_val = str_val + "\\" }
                    else if esc == "\"" { str_val = str_val + "\"" }
                    else if esc == "\{"  { str_val = str_val + "\{" }
                    else if esc == "\}"  { str_val = str_val + "\}" }
                    else               { str_val = str_val + esc }
                    i = i + 2
                } else if src[i] == "\{" {
                    has_interp = true
                    idepth = idepth + 1
                    str_val = str_val + "\{"
                    i = i + 1
                } else if src[i] == "\}" {
                    if idepth > 0 { idepth = idepth - 1 }
                    str_val = str_val + "\}"
                    i = i + 1
                } else {
                    str_val = str_val + src[i]
                    i = i + 1
                }
            }
            if i < n { i = i + 1 }
            if has_interp {
                tok_push(TK_ISTR, str_val, 0, 0.0, start_line)
            } else {
                tok_push(TK_STR, str_val, 0, 0.0, start_line)
            }
            continue
        }

        if c == "+" { tok_push(TK_PLUS,    "+",  0, 0.0, line); i = i + 1; continue }
        if c == "*" { tok_push(TK_STAR,    "*",  0, 0.0, line); i = i + 1; continue }
        if c == "%" { tok_push(TK_PERCENT, "%",  0, 0.0, line); i = i + 1; continue }
        if c == "&" { tok_push(TK_AMP,     "&",  0, 0.0, line); i = i + 1; continue }
        if c == "|" { tok_push(TK_PIPE,    "|",  0, 0.0, line); i = i + 1; continue }
        if c == "^" { tok_push(TK_CARET,   "^",  0, 0.0, line); i = i + 1; continue }
        if c == "~" { tok_push(TK_TILDE,   "~",  0, 0.0, line); i = i + 1; continue }
        if c == "?" { tok_push(TK_QUESTION,"?",  0, 0.0, line); i = i + 1; continue }
        if c == "@" { tok_push(TK_AT,      "@",  0, 0.0, line); i = i + 1; continue }
        if c == ";" { tok_push(TK_SEMICOLON,";", 0, 0.0, line); i = i + 1; continue }
        if c == "(" { tok_push(TK_LPAREN,  "(",  0, 0.0, line); i = i + 1; continue }
        if c == ")" { tok_push(TK_RPAREN,  ")",  0, 0.0, line); i = i + 1; continue }
        if c == "\{" { tok_push(TK_LBRACE,  "\{",  0, 0.0, line); i = i + 1; continue }
        if c == "\}" { tok_push(TK_RBRACE,  "\}",  0, 0.0, line); i = i + 1; continue }
        if c == "[" { tok_push(TK_LBRACK,  "[",  0, 0.0, line); i = i + 1; continue }
        if c == "]" { tok_push(TK_RBRACK,  "]",  0, 0.0, line); i = i + 1; continue }
        if c == "," { tok_push(TK_COMMA,   ",",  0, 0.0, line); i = i + 1; continue }
        if c == ":" { tok_push(TK_COLON,   ":",  0, 0.0, line); i = i + 1; continue }

        if c == "-" {
            if i + 1 < n and src[i + 1] == ">" {
                tok_push(TK_ARROW, "->", 0, 0.0, line); i = i + 2
            } else {
                tok_push(TK_MINUS, "-",  0, 0.0, line); i = i + 1
            }
            continue
        }
        if c == "/" {
            tok_push(TK_SLASH, "/", 0, 0.0, line); i = i + 1; continue
        }
        if c == "!" {
            if i + 1 < n and src[i + 1] == "=" {
                tok_push(TK_NEQ,  "!=", 0, 0.0, line); i = i + 2
            } else {
                tok_push(TK_BANG, "!",  0, 0.0, line); i = i + 1
            }
            continue
        }
        if c == "=" {
            if i + 1 < n and src[i + 1] == "=" {
                tok_push(TK_EQEQ,     "==", 0, 0.0, line); i = i + 2
            } else if i + 1 < n and src[i + 1] == ">" {
                tok_push(TK_FAT_ARROW,"=>", 0, 0.0, line); i = i + 2
            } else {
                tok_push(TK_EQ,       "=",  0, 0.0, line); i = i + 1
            }
            continue
        }
        if c == "<" {
            if i + 1 < n and src[i + 1] == "<" {
                tok_push(TK_LSHIFT, "<<", 0, 0.0, line); i = i + 2
            } else if i + 1 < n and src[i + 1] == "=" {
                tok_push(TK_LTE,    "<=", 0, 0.0, line); i = i + 2
            } else {
                tok_push(TK_LT,     "<",  0, 0.0, line); i = i + 1
            }
            continue
        }
        if c == ">" {
            if i + 1 < n and src[i + 1] == ">" {
                tok_push(TK_RSHIFT, ">>", 0, 0.0, line); i = i + 2
            } else if i + 1 < n and src[i + 1] == "=" {
                tok_push(TK_GTE,    ">=", 0, 0.0, line); i = i + 2
            } else {
                tok_push(TK_GT,     ">",  0, 0.0, line); i = i + 1
            }
            continue
        }
        if c == "." {
            if i + 2 < n and src[i + 1] == "." and src[i + 2] == "." {
                tok_push(TK_ELLIPSIS, "...", 0, 0.0, line); i = i + 3
            } else if i + 1 < n and src[i + 1] == "." {
                tok_push(TK_DOTDOT,   "..",  0, 0.0, line); i = i + 2
            } else {
                tok_push(TK_DOT,      ".",   0, 0.0, line); i = i + 1
            }
            continue
        }

        i = i + 1
    }

    tok_push(TK_EOF, "", 0, 0.0, line)
}

// ─── 노드 종류 상수 ────────────────────────────────────────────────────────
NK_INT        = 1
NK_FLOAT      = 2
NK_STR        = 3
