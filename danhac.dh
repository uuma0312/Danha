                cv = new_reg(); emit("  " + cv + " = ptrtoint " + rt + " " + rv + " to i64"); rv = cv
            } else if rt == "double" {
                cv = new_reg(); emit("  " + cv + " = bitcast double " + rv + " to i64"); rv = cv
            } else if rt == "float" {
                cv = new_reg(); cv2 = new_reg()
                emit("  " + cv + " = bitcast float " + rv + " to i32")
                emit("  " + cv2 + " = zext i32 " + cv + " to i64")
                rv = cv2
            } else if rt != "i64" {
                cv = new_reg(); emit("  " + cv + " = sext " + rt + " " + rv + " to i64"); rv = cv
            }
            emit("  call void @dnh_push(%DnhList* " + lv + ", i64 " + rv + ")")
            g_expr_reg = "0"; g_expr_ty = "void"; return
        }
        if fname_c == "len" and nargs == 1 {
