// ─── AST 저장소 (SoA) ─────────────────────────────────────────────────────
g_nkind: [i32] = []
g_nsval: [str] = []
g_ntype: [str] = []
g_nival: [i64] = []
g_nfval: [f64] = []
g_nc0: [i32] = []
g_nc1: [i32] = []
g_nc2: [i32] = []
g_nline: [i32] = []
g_ch: [i32] = []
g_nch_s: [i32] = []
g_nch_n: [i32] = []
g_node_count = 0

// ─── 파서 위치 ────────────────────────────────────────────────────────────
g_pos = 0
g_allow_struct_lit = 1

// ─── 노드/파서 헬퍼 ───────────────────────────────────────────────────────
fn node_new(kind: i32, sval: str, ival: i64, fval: f64, c0: i32, c1: i32, c2: i32, ln: i32) -> i32 {
    idx = g_node_count
    push(g_nkind, kind)
    push(g_nsval,  sval)
    push(g_ntype,  "")
    push(g_nival,  ival)
    push(g_nfval,  fval)
    push(g_nc0,    c0)
    push(g_nc1,    c1)
    push(g_nc2,    c2)
    push(g_nline,  ln)
    push(g_nch_s,  len(g_ch))
    push(g_nch_n,  0)
    g_node_count = g_node_count + 1
    return idx
}

fn node_add_ch(n: i32, child: i32) {
    if g_nch_n[n] == 0 { g_nch_s[n] = len(g_ch) }
    push(g_ch, child)
    g_nch_n[n] = g_nch_n[n] + 1
}

fn ctok()  -> i32  { return g_toks_kind[g_pos] }
fn csval() -> str  { return g_toks_sval[g_pos] }
fn cival() -> i64  { return g_toks_ival[g_pos] }
fn cfval() -> f64  { return g_toks_fval[g_pos] }
fn cline() -> i32  { return g_toks_line[g_pos] }

fn adv() { g_pos = g_pos + 1 }

fn skip_nls() {
    while ctok() == TK_NL or ctok() == TK_SEMICOLON { adv() }
}

fn fatal(msg: str) {
    print(msg)
    exit(1)
}

fn eat(kind: i32) {
    if ctok() != kind {
        fatal("파서 오류: 예상 토큰 " + to_string(kind) + " 실제 " + to_string(ctok()) + " (줄 " + to_string(cline()) + ")")
    }
    adv()
}

fn parse_type_str() -> str {
    if ctok() == TK_AMP {
        adv()
        had_mut = false
        if ctok() == TK_MUT { adv(); had_mut = true }
        else if ctok() == TK_ID and csval() == "mut" { adv(); had_mut = true }
        inner = parse_type_str()
        if had_mut { return "&mut " + inner }
        return "&" + inner
    }
    if ctok() == TK_LBRACK {
        adv()
        if ctok() == TK_RBRACK { adv(); return "[]" }
        elem = parse_type_str()
        if ctok() == TK_SEMICOLON {
            adv()
            sz = to_string(cival())
            adv()
            eat(TK_RBRACK)
            return "[" + elem + ";" + sz + "]"
        }
        eat(TK_RBRACK)
        return "[" + elem + "]"
    }
    if ctok() == TK_LPAREN { adv(); eat(TK_RPAREN); return "()" }
    if ctok() == TK_ID and csval() == "dyn" {
        adv()
        dtn = csval(); adv()
        return "dyn " + dtn
    }
    if ctok() == TK_ID or (ctok() >= TK_PRINT and ctok() <= TK_UNION) {
        ty = csval(); adv()
        // HashMap<str, f64> 같은 꺾쇠 제네릭 주석 — 파라미터는 소거 (HM은 i64 슬롯 저장)
        if ctok() == TK_LT {
            adv()
            gdep = 1
            while gdep > 0 and ctok() != TK_EOF {
                if ctok() == TK_LT { gdep = gdep + 1 }
                if ctok() == TK_GT { gdep = gdep - 1 }
                adv()
            }
        }
        return ty
    }
    return "?"
}

fn try_type_ann() -> str {
    if ctok() == TK_COLON { adv(); return parse_type_str() }
    return ""
}

// @sin(x) 같은 수학 내장 함수 이름 (danha_parser.py의 _MATH_UNARY/_MATH_BINARY와 동일)
fn math_unary_has(name: str) -> bool {
    if name == "sin" or name == "cos" or name == "tan" or name == "sqrt" { return true }
    if name == "abs" or name == "floor" or name == "ceil" or name == "round" { return true }
    if name == "log" or name == "exp" { return true }
    return false
}

fn math_binary_has(name: str) -> bool {
    if name == "pow" or name == "atan2" or name == "hypot" { return true }
    if name == "min" or name == "max" { return true }
    return false
}

// ─── 식 파서 ──────────────────────────────────────────────────────────────
fn parse_atom() -> i32 {
    ln = cline()
    if ctok() == TK_NUM    { v = cival(); adv(); return node_new(NK_INT,   "", v, 0.0, -1, -1, -1, ln) }
    if ctok() == TK_FNUM   { fs = csval(); fv = cfval(); adv(); return node_new(NK_FLOAT, fs, 0, fv, -1, -1, -1, ln) }
    if ctok() == TK_STR    { s = csval(); adv(); return node_new(NK_STR,   s,  0, 0.0, -1, -1, -1, ln) }
    if ctok() == TK_ISTR   { s = csval(); adv(); return node_new(NK_ISTR,  s,  0, 0.0, -1, -1, -1, ln) }
    if ctok() == TK_TRUE   { adv(); return node_new(NK_BOOL, "", 1, 0.0, -1, -1, -1, ln) }
    if ctok() == TK_FALSE  { adv(); return node_new(NK_BOOL, "", 0, 0.0, -1, -1, -1, ln) }
    if ctok() == TK_NULL   { adv(); return node_new(NK_NULL, "", 0, 0.0, -1, -1, -1, ln) }
    if ctok() == TK_FN     { return parse_lambda() }

    if ctok() == TK_LBRACK {
        adv()
        nd = node_new(NK_ARRAY, "", 0, 0.0, -1, -1, -1, ln)
        skip_nls()
        if ctok() != TK_RBRACK {
            // g_ch는 노드별 자식이 연속이어야 함 — 모두 파싱한 뒤 한 번에 붙인다
            cargs: [i32] = []
            push(cargs, parse_or())
            // [v; N] — 반복 배열 리터럴 (고정 크기 배열 초기화 전용, ival=N)
            if ctok() == TK_SEMICOLON {
                adv()
                rcnt = cival(); adv()
                eat(TK_RBRACK)
                g_nival[nd] = rcnt
                node_add_ch(nd, cargs[0])
                return nd
            }
            while ctok() == TK_COMMA {
                adv(); skip_nls()
                if ctok() == TK_RBRACK { break }
                push(cargs, parse_or())
            }
            cai = 0
            while cai < len(cargs) { node_add_ch(nd, cargs[cai]); cai = cai + 1 }
        }
        eat(TK_RBRACK)
        return nd
    }

    if ctok() == TK_LPAREN {
        adv(); e = parse_or(); eat(TK_RPAREN); return e
    }

    // @sin(x), @pow(x, y) — 수학 내장 함수 (식 위치)
    if ctok() == TK_AT {
        adv()
        mname = csval(); eat(TK_ID)
        if not math_unary_has(mname) and not math_binary_has(mname) {
            fatal("danhac 서브셋 미지원 인트린식: '@" + mname + "' (줄 " + to_string(ln) + ") — danha.py compile을 사용해줘")
        }
        eat(TK_LPAREN)
        nd = node_new(NK_MATH, mname, 0, 0.0, -1, -1, -1, ln)
        skip_nls()
        if ctok() != TK_RPAREN {
            margs: [i32] = []
            push(margs, parse_or())
            while ctok() == TK_COMMA {
                adv(); skip_nls()
                if ctok() == TK_RPAREN { break }
                push(margs, parse_or())
            }
            mai = 0
            while mai < len(margs) { node_add_ch(nd, margs[mai]); mai = mai + 1 }
        }
        eat(TK_RPAREN)
        wantn = 1
        if math_binary_has(mname) { wantn = 2 }
        if g_nch_n[nd] != wantn {
            fatal("@" + mname + "은(는) 인자 " + to_string(wantn) + "개가 필요해 (줄 " + to_string(ln) + ")")
        }
        return nd
    }

    // comptime { ... } — 컴파일 타임 블록 평가
    if ctok() == TK_ID and csval() == "comptime" {
        adv()
        skip_nls()
        cte = parse_block()
        return node_new(NK_COMPTIME, "", 0, 0.0, cte, -1, -1, ln)
    }

    if ctok() == TK_ID {
        name = csval(); adv()
        // name!(args) — 매크로 호출 (인라인 확장)
        if ctok() == TK_BANG {
            adv(); eat(TK_LPAREN)
            nd = node_new(NK_MACRO_CALL, name, 0, 0.0, -1, -1, -1, ln)
            skip_nls()
            if ctok() != TK_RPAREN {
                mcargs: [i32] = []
                push(mcargs, parse_or())
                while ctok() == TK_COMMA {
                    adv(); skip_nls()
                    if ctok() == TK_RPAREN { break }
                    push(mcargs, parse_or())
                }
                mcai = 0
                while mcai < len(mcargs) { node_add_ch(nd, mcargs[mcai]); mcai = mcai + 1 }
            }
            skip_nls(); eat(TK_RPAREN)
            return nd
        }
        if ctok() == TK_LPAREN {
            adv()
            nd = node_new(NK_CALL, name, 0, 0.0, -1, -1, -1, ln)
            skip_nls()
            if ctok() != TK_RPAREN {
                cargs: [i32] = []
                push(cargs, parse_or())
                while ctok() == TK_COMMA {
                    adv(); skip_nls()
                    if ctok() == TK_RPAREN { break }
                    push(cargs, parse_or())
                }
                cai = 0
                while cai < len(cargs) { node_add_ch(nd, cargs[cai]); cai = cai + 1 }
            }
            skip_nls(); eat(TK_RPAREN)
            return nd
        }
        if ctok() == TK_LBRACE and g_allow_struct_lit == 1 {
            adv()
            nd = node_new(NK_STRUCT_INST, name, 0, 0.0, -1, -1, -1, ln)
            skip_nls()
            finits: [i32] = []
            while ctok() != TK_RBRACE and ctok() != TK_EOF {
                fln = cline()
                fname = csval(); eat(TK_ID); eat(TK_COLON)
                fval_node = parse_or()
                fi = node_new(NK_FIELD_INIT, fname, 0, 0.0, fval_node, -1, -1, fln)
                push(finits, fi)
                if ctok() == TK_COMMA { adv() }
                skip_nls()
            }
            fai = 0
            while fai < len(finits) { node_add_ch(nd, finits[fai]); fai = fai + 1 }
            eat(TK_RBRACE)
            return nd
        }
        return node_new(NK_ID, name, 0, 0.0, -1, -1, -1, ln)
    }

    print("파서 오류: 예상치 못한 토큰 " + to_string(ctok()) + " 줄 " + to_string(ln))
    adv()
    return node_new(NK_NULL, "", 0, 0.0, -1, -1, -1, ln)
}

fn parse_postfix(e) -> i32 {
    while true {
        ln = cline()
        if ctok() == TK_DOT {
            adv()
            fname = csval(); eat(TK_ID)
            if ctok() == TK_LPAREN {
                adv()
                nd = node_new(NK_METHOD, fname, 0, 0.0, e, -1, -1, ln)
                skip_nls()
                if ctok() != TK_RPAREN {
                    margs: [i32] = []
                    push(margs, parse_or())
                    while ctok() == TK_COMMA {
                        adv(); skip_nls()
                        if ctok() == TK_RPAREN { break }
                        push(margs, parse_or())
                    }
                    mai = 0
                    while mai < len(margs) { node_add_ch(nd, margs[mai]); mai = mai + 1 }
                }
                eat(TK_RPAREN)
                e = nd
            } else {
                e = node_new(NK_FIELD, fname, 0, 0.0, e, -1, -1, ln)
            }
            continue
        }
        if ctok() == TK_LBRACK {
            adv(); idx = parse_or(); eat(TK_RBRACK)
            e = node_new(NK_INDEX, "", 0, 0.0, e, idx, -1, ln)
            continue
        }
        if ctok() == TK_AS {
            adv(); ty = parse_type_str()
            e = node_new(NK_AS, ty, 0, 0.0, e, -1, -1, ln)
            continue
        }
        if ctok() == TK_QUESTION {
            adv()
            e = node_new(NK_TRY, "", 0, 0.0, e, -1, -1, ln)
            continue
        }
        break
    }
    return e
}

fn parse_unary() -> i32 {
    ln = cline()
    if ctok() == TK_MINUS  { adv(); return node_new(NK_NEG,    "", 0, 0.0, parse_unary(), -1, -1, ln) }
    if ctok() == TK_TILDE  { adv(); return node_new(NK_BITNOT, "", 0, 0.0, parse_unary(), -1, -1, ln) }
    if ctok() == TK_AMP    {
        adv()
        if ctok() == TK_MUT { adv() }
        else if ctok() == TK_ID and csval() == "mut" { adv() }
        return node_new(NK_REF,    "", 0, 0.0, parse_unary(), -1, -1, ln)
    }
    if ctok() == TK_STAR   { adv(); return node_new(NK_DEREF,  "", 0, 0.0, parse_unary(), -1, -1, ln) }
    return parse_postfix(parse_atom())
}

fn parse_mul() -> i32 {
    e = parse_unary()
    while ctok() == TK_STAR or ctok() == TK_SLASH or ctok() == TK_PERCENT {
        ln = cline(); op = ctok(); adv(); r = parse_unary()
        if op == TK_STAR    { e = node_new(NK_MUL, "", 0, 0.0, e, r, -1, ln) }
        else if op == TK_SLASH   { e = node_new(NK_DIV, "", 0, 0.0, e, r, -1, ln) }
        else                { e = node_new(NK_MOD, "", 0, 0.0, e, r, -1, ln) }
    }
    return e
}

fn parse_add() -> i32 {
    e = parse_mul()
    while ctok() == TK_PLUS or ctok() == TK_MINUS {
        ln = cline(); op = ctok(); adv(); r = parse_mul()
        if op == TK_PLUS { e = node_new(NK_ADD, "", 0, 0.0, e, r, -1, ln) }
        else              { e = node_new(NK_SUB, "", 0, 0.0, e, r, -1, ln) }
    }
    return e
}

fn parse_shift() -> i32 {
    e = parse_add()
    while ctok() == TK_LSHIFT or ctok() == TK_RSHIFT {
        ln = cline(); op = ctok(); adv(); r = parse_add()
        if op == TK_LSHIFT { e = node_new(NK_LSHIFT, "", 0, 0.0, e, r, -1, ln) }
        else               { e = node_new(NK_RSHIFT, "", 0, 0.0, e, r, -1, ln) }
    }
    return e
}

fn parse_bitwise() -> i32 {
    e = parse_shift()
    while ctok() == TK_AMP or ctok() == TK_PIPE or ctok() == TK_CARET {
        ln = cline(); op = ctok(); adv(); r = parse_shift()
        if op == TK_AMP   { e = node_new(NK_BITAND, "", 0, 0.0, e, r, -1, ln) }
        else if op == TK_PIPE  { e = node_new(NK_BITOR,  "", 0, 0.0, e, r, -1, ln) }
        else              { e = node_new(NK_BITXOR, "", 0, 0.0, e, r, -1, ln) }
    }
    return e
}

fn parse_cmp() -> i32 {
    e = parse_bitwise()
    while ctok() == TK_LT or ctok() == TK_GT or ctok() == TK_LTE or ctok() == TK_GTE {
        ln = cline(); op = ctok(); adv(); r = parse_bitwise()
        if op == TK_LT  { e = node_new(NK_LT,  "", 0, 0.0, e, r, -1, ln) }
        else if op == TK_GT  { e = node_new(NK_GT,  "", 0, 0.0, e, r, -1, ln) }
        else if op == TK_LTE { e = node_new(NK_LTE, "", 0, 0.0, e, r, -1, ln) }
        else              { e = node_new(NK_GTE, "", 0, 0.0, e, r, -1, ln) }
    }
    return e
}

fn parse_eq() -> i32 {
    e = parse_cmp()
    while ctok() == TK_EQEQ or ctok() == TK_NEQ {
        ln = cline(); op = ctok(); adv(); r = parse_cmp()
        if op == TK_EQEQ { e = node_new(NK_EQ,  "", 0, 0.0, e, r, -1, ln) }
        else              { e = node_new(NK_NEQ, "", 0, 0.0, e, r, -1, ln) }
    }
    return e
}

fn parse_not() -> i32 {
    ln = cline()
    if ctok() == TK_NOT { adv(); return node_new(NK_NOT, "", 0, 0.0, parse_not(), -1, -1, ln) }
    return parse_eq()
}

fn parse_and() -> i32 {
    e = parse_not()
    while ctok() == TK_AND { ln = cline(); adv(); r = parse_not(); e = node_new(NK_AND, "", 0, 0.0, e, r, -1, ln) }
    return e
}

fn parse_or() -> i32 {
    e = parse_and()
    while ctok() == TK_OR { ln = cline(); adv(); r = parse_and(); e = node_new(NK_OR, "", 0, 0.0, e, r, -1, ln) }
    return e
}

// ─── 문 파서 ──────────────────────────────────────────────────────────────
fn impl_done_has(s: str) -> bool {
    i = 0
    while i < len(g_impl_done) {
        if g_impl_done[i] == s { return true }
        i = i + 1
    }
    return false
}

// trait/impl 공용 메서드 파서 — 이름을 owner__name으로 맹글링하고 self를 첫 파라미터로 주입
fn parse_method_def(owner: str) -> i32 {
    ln = cline(); eat(TK_FN)
    mdname = csval(); eat(TK_ID); eat(TK_LPAREN)
    nd = node_new(NK_FN, owner + "__" + mdname, 0, 0.0, -1, -1, -1, ln)
    g_ntype[nd] = mdname
    skip_nls()
    params: [i32] = []
    sp = node_new(NK_PARAM, "self", 0, 0.0, -1, -1, -1, ln)
    g_ntype[sp] = owner
    push(params, sp)
    while ctok() != TK_RPAREN and ctok() != TK_EOF {
        pln = cline(); pname = csval(); eat(TK_ID)
        if pname == "self" {
            if ctok() == TK_COMMA { adv() }
            skip_nls()
            continue
        }
        pty = try_type_ann()
        p = node_new(NK_PARAM, pname, 0, 0.0, -1, -1, -1, pln)
        g_ntype[p] = pty
        push(params, p)
        if ctok() == TK_COMMA { adv() }
        skip_nls()
    }
    eat(TK_RPAREN)
    ret_ty = ""
    if ctok() == TK_ARROW { adv(); ret_ty = parse_type_str() }
    rtn = node_new(NK_PARAM, "", 0, 0.0, -1, -1, -1, ln)
    g_ntype[rtn] = ret_ty
    g_nc1[nd] = rtn
    skip_nls()
    body = parse_block()
    g_nc0[nd] = body
    i = 0
    while i < len(params) { node_add_ch(nd, params[i]); i = i + 1 }
    return nd
}

// trait Name { fn m(self...) { 디폴트 } ... } — 메서드 템플릿 등록
fn parse_trait() -> i32 {
    ln = cline(); eat(TK_TRAIT)
    tname = csval(); eat(TK_ID)
    eat(TK_LBRACE); skip_nls()
    while ctok() == TK_FN {
        f = parse_method_def(tname)
        push(g_trm_trait, tname)
        push(g_trm_name, g_ntype[f])
        push(g_trm_fn, f)
        skip_nls()
    }
    eat(TK_RBRACE)
    return node_new(NK_NULL, "", 0, 0.0, -1, -1, -1, ln)
}

// impl Trait for Struct { ... } — 오버라이드 등록 + 빠진 메서드는 트레잇 디폴트로 인스턴스화
fn parse_impl() -> i32 {
    ln = cline(); eat(TK_IMPL)
    tname = csval(); eat(TK_ID)
    sname = tname
    trait_impl = 0
    if ctok() == TK_FOR {
        adv()
        sname = csval(); eat(TK_ID)
        trait_impl = 1
        // dyn 디스패치용 (트레잇, 스트럭트) 페어 — vtable 생성에 사용
        push(g_impl_traits, tname)
        push(g_impl_structs, sname)
    }
    eat(TK_LBRACE); skip_nls()
    while ctok() == TK_FN {
        f = parse_method_def(sname)
        push(g_impl_fns, f)
        push(g_impl_done, g_nsval[f])
        skip_nls()
    }
    eat(TK_RBRACE)
    i = 0
    while trait_impl == 1 and i < len(g_trm_trait) {
        if g_trm_trait[i] == tname {
            mangled = sname + "__" + g_trm_name[i]
            if not impl_done_has(mangled) {
                tf = g_trm_fn[i]
                nf = node_new(NK_FN, mangled, 0, 0.0, g_nc0[tf], g_nc1[tf], -1, ln)
                j = 0
                while j < g_nch_n[tf] {
                    tp2 = g_ch[g_nch_s[tf] + j]
                    np2 = node_new(NK_PARAM, g_nsval[tp2], 0, 0.0, -1, -1, -1, ln)
                    if j == 0 { g_ntype[np2] = sname } else { g_ntype[np2] = g_ntype[tp2] }
                    node_add_ch(nf, np2)
                    j = j + 1
                }
                push(g_impl_fns, nf)
                push(g_impl_done, mangled)
            }
        }
        i = i + 1
    }
    return node_new(NK_NULL, "", 0, 0.0, -1, -1, -1, ln)
}

// enum Name { Variant(Type)? ... } — 파스 시점에 레지스트리 등록
fn parse_enum_def() -> i32 {
    ln = cline(); eat(TK_ENUM)
    ename = csval(); eat(TK_ID)
    // enum Option[T] — 제네릭 enum은 타입 소거 (payload는 i64 슬롯)
    etps: [str] = []
    if ctok() == TK_LBRACK {
        adv()
        while ctok() != TK_RBRACK and ctok() != TK_EOF {
            push(etps, csval()); eat(TK_ID)
            if ctok() == TK_COMMA { adv() }
        }
        eat(TK_RBRACK)
    }
    eat(TK_LBRACE); skip_nls()
    push(g_enum_names, ename)
    // simple enum 판정: 모든 variant가 payload 없음 + 비제네릭 → variant가 i64 상수 (py 의미론)
    has_pay = false
    vidx = 0
    while ctok() != TK_RBRACE and ctok() != TK_EOF {
        vname = csval(); eat(TK_ID)
        vpty = ""
        if ctok() == TK_LPAREN {
            adv()
            vpty = parse_type_str()
            eat(TK_RPAREN)
            has_pay = true
        }
        // payload가 타입 매개변수면 소거 — i64 슬롯으로 취급
        eti = 0
        while eti < len(etps) {
            if vpty == etps[eti] { vpty = "" }
            eti = eti + 1
        }
        push(g_vrt_names, vname); push(g_vrt_owner, ename)
        push(g_vrt_tag, vidx); push(g_vrt_pty, vpty)
        vidx = vidx + 1
        if ctok() == TK_COMMA { adv() }
        skip_nls()
    }
    eat(TK_RBRACE)
    sflag = 1
    if has_pay { sflag = 0 }
    if len(etps) > 0 { sflag = 0 }
    push(g_enum_simple, sflag)
    return node_new(NK_ENUM_DEF, ename, 0, 0.0, -1, -1, -1, ln)
}

// match subj { Variant(bind) => { ... }  _ => { ... } }
fn parse_match() -> i32 {
    ln = cline(); eat(TK_MATCH)
    // subj 뒤의 {는 match 블록 — struct 리터럴로 오파싱 방지
    g_allow_struct_lit = 0; subj = parse_or(); g_allow_struct_lit = 1
    eat(TK_LBRACE); skip_nls()
    nd = node_new(NK_MATCH, "", 0, 0.0, subj, -1, -1, ln)
    arms: [i32] = []
    while ctok() != TK_RBRACE and ctok() != TK_EOF {
        aln = cline()
        avn = csval(); eat(TK_ID)
        abn = ""
        if ctok() == TK_LPAREN {
            adv()
            abn = csval(); eat(TK_ID)
            eat(TK_RPAREN)
        }
        eat(TK_FAT_ARROW)
        skip_nls()
        abody = parse_block()
        arm = node_new(NK_ARM, avn, 0, 0.0, abody, -1, -1, aln)
        g_ntype[arm] = abn
        push(arms, arm)
        skip_nls()
    }
    ai = 0
    while ai < len(arms) { node_add_ch(nd, arms[ai]); ai = ai + 1 }
    eat(TK_RBRACE)
    return nd
}

fn parse_block() -> i32 {
    ln = cline(); eat(TK_LBRACE); skip_nls()
    g_block_depth = g_block_depth + 1
    stmts: [i32] = []
    while ctok() != TK_RBRACE and ctok() != TK_EOF {
        s = parse_stmt()
        push(stmts, s)
        skip_nls()
    }
    g_block_depth = g_block_depth - 1
    eat(TK_RBRACE)
    nd = node_new(NK_BLOCK, "", 0, 0.0, -1, -1, -1, ln)
    i = 0
    while i < len(stmts) { node_add_ch(nd, stmts[i]); i = i + 1 }
    return nd
}

fn parse_fn_def() -> i32 {
    ln = cline(); eat(TK_FN)
    name = csval(); eat(TK_ID)
    // fn name[T, U](...) — 제네릭 타입 매개변수
    tps: [str] = []
    if ctok() == TK_LBRACK {
        adv()
        while ctok() != TK_RBRACK and ctok() != TK_EOF {
            push(tps, csval()); eat(TK_ID)
            if ctok() == TK_COMMA { adv() }
        }
        eat(TK_RBRACK)
    }
    eat(TK_LPAREN)
    nd = node_new(NK_FN, name, 0, 0.0, -1, -1, -1, ln)
    skip_nls()
    params: [i32] = []
    while ctok() != TK_RPAREN and ctok() != TK_EOF {
        pln = cline(); pname = csval(); eat(TK_ID)
        pty = try_type_ann()
        p = node_new(NK_PARAM, pname, 0, 0.0, -1, -1, -1, pln)
        g_ntype[p] = pty
        push(params, p)
        if ctok() == TK_COMMA { adv() }
        skip_nls()
    }
    eat(TK_RPAREN)
    ret_ty = ""
    if ctok() == TK_ARROW { adv(); ret_ty = parse_type_str() }
    rtn = node_new(NK_PARAM, "", 0, 0.0, -1, -1, -1, ln)
    g_ntype[rtn] = ret_ty
    g_nc1[nd] = rtn
    skip_nls()
    body = parse_block()
    g_nc0[nd] = body
    i = 0
    while i < len(params) { node_add_ch(nd, params[i]); i = i + 1 }
    // 제네릭이면 등록만 하고 일반 컴파일 패스에서는 제외
    if len(tps) > 0 {
        if gen_find(name) != -1 {
            fatal("제네릭 함수 '" + name + "'은(는) 이미 정의됐어 (줄 " + to_string(ln) + ")")
        }
        push(g_gen_names, name)
        push(g_gen_nodes, nd)
        push(g_gen_tp_s, len(g_gen_tps))
        push(g_gen_tp_n, len(tps))
        ti = 0
        while ti < len(tps) { push(g_gen_tps, tps[ti]); ti = ti + 1 }
        return node_new(NK_NULL, "", 0, 0.0, -1, -1, -1, ln)
    }
    return nd
}

// fn(a: i64) -> i64 { ... } — 람다 식 (parse_fn_def와 같은 형태, 이름 없음)
fn parse_lambda() -> i32 {
    ln = cline(); eat(TK_FN); eat(TK_LPAREN)
    nd = node_new(NK_LAMBDA, "", 0, 0.0, -1, -1, -1, ln)
    skip_nls()
    params: [i32] = []
    while ctok() != TK_RPAREN and ctok() != TK_EOF {
        pln = cline(); pname = csval(); eat(TK_ID)
        pty = try_type_ann()
        p = node_new(NK_PARAM, pname, 0, 0.0, -1, -1, -1, pln)
        g_ntype[p] = pty
        push(params, p)
        if ctok() == TK_COMMA { adv() }
        skip_nls()
    }
    eat(TK_RPAREN)
    ret_ty = ""
    if ctok() == TK_ARROW { adv(); ret_ty = parse_type_str() }
    rtn = node_new(NK_PARAM, "", 0, 0.0, -1, -1, -1, ln)
    g_ntype[rtn] = ret_ty
    g_nc1[nd] = rtn
    skip_nls()
    body = parse_block()
    g_nc0[nd] = body
    i = 0
    while i < len(params) { node_add_ch(nd, params[i]); i = i + 1 }
    return nd
}

// union Name { fields } — 모든 필드가 오프셋 0 공유 (NK_STRUCT_DEF ival=1)
fn parse_union_def() -> i32 {
    ln = cline(); adv()
    name = csval(); eat(TK_ID); eat(TK_LBRACE); skip_nls()
    nd = node_new(NK_STRUCT_DEF, name, 1, 0.0, -1, -1, -1, ln)
    while ctok() != TK_RBRACE and ctok() != TK_EOF {
        fln = cline(); fname = csval(); eat(TK_ID)
        fty = try_type_ann()
        fi = node_new(NK_FIELD_DEF, fname, 0, 0.0, -1, -1, -1, fln)
        g_ntype[fi] = fty
        node_add_ch(nd, fi)
        if ctok() == TK_COMMA { adv() }
        skip_nls()
    }
    eat(TK_RBRACE)
    push(g_union_names, name)
    return nd
}

fn parse_struct_def() -> i32 {
    ln = cline(); eat(TK_STRUCT)
    name = csval(); eat(TK_ID); eat(TK_LBRACE); skip_nls()
    nd = node_new(NK_STRUCT_DEF, name, 0, 0.0, -1, -1, -1, ln)
    while ctok() != TK_RBRACE and ctok() != TK_EOF {
        fln = cline(); fname = csval(); eat(TK_ID)
        fty = try_type_ann()
        fi = node_new(NK_FIELD_DEF, fname, 0, 0.0, -1, -1, -1, fln)
        g_ntype[fi] = fty
        node_add_ch(nd, fi)
        if ctok() == TK_COMMA { adv() }
        skip_nls()
    }
    eat(TK_RBRACE)
    return nd
}

// @clink("lib")로 수집한 링크 라이브러리 이름들 (중복 제거)
g_clink_libs: [str] = []
// @clink extern 블록에서 첫 fn 이후의 추가 extern fn 노드들 — parse_program이 드레인
g_pending_externs: [i32] = []

// ─── 모듈 시스템 (병합 방식) ──────────────────────────────────────────────
// 모듈 톱레벨 정의를 프리픽스 없이 프로그램에 그대로 합치고,
// mod.f(...) / mod.CONST 는 네임스페이스 레지스트리로 일반 이름에 매핑한다.
g_mod_names: [str] = []      // import된 네임스페이스 (점 경로의 마지막 성분)
g_mod_loaded: [str] = []     // 로드 완료된 모듈 전체 이름 (중복 import 방지)
g_mod_loading: [str] = []    // 로딩 중인 모듈 (순환 import 감지)
g_pending_stmts: [i32] = []  // 모듈에서 파싱된 톱레벨 문 — parse_program이 드레인
g_src_dir = ""               // 입력 파일 디렉토리 (모듈 탐색 기준)
g_block_depth = 0            // 블록 깊이 — import는 톱레벨에서만 허용

// 제네릭 fn 레지스트리 (파스 시점 등록) — 호출 인자 타입으로 모노모피제이션
g_gen_names: [str] = []
g_gen_nodes: [i32] = []
g_gen_tp_s: [i32] = []
g_gen_tp_n: [i32] = []
g_gen_tps: [str] = []
// 인스턴스화 중 활성 타입 치환 (ll_ty가 참조)
g_tp_act_names: [str] = []
g_tp_act_tys: [str] = []
// 인스턴스화된 함수 정의 출력 — cg_program 끝에 플러시
g_gen_out: [str] = []

fn gen_find(name: str) -> i32 {
    i = 0
    while i < len(g_gen_names) {
        if g_gen_names[i] == name { return i }
        i = i + 1
    }
    return -1
}

fn tp_act_find(name: str) -> i32 {
    i = len(g_tp_act_names) - 1
    while i >= 0 {
        if g_tp_act_names[i] == name { return i }
        i = i - 1
    }
    return -1
}

// LLVM 타입 → 모노 이름용 토큰 (max__i64, max__f64 등)
fn ty_sane(t: str) -> str {
    if t == "i64" { return "i64" }
    if t == "i32" { return "i32" }
    if t == "double" { return "f64" }
    if t == "float" { return "f32" }
    if t == "i1" { return "bool" }
    if t == "i8*" { return "str" }
    s = ""
    i = 0
    while i < len(t) {
        if is_alnum(t[i]) { s = s + t[i] }
        i = i + 1
    }
    return s
}

// macro 레지스트리 (파스 시점 등록) — 호출 시 본문 인라인 컴파일
g_macro_names: [str] = []
g_macro_nodes: [i32] = []
g_macro_variadic: [i32] = []

fn macro_find(name: str) -> i32 {
    i = 0
    while i < len(g_macro_names) {
        if g_macro_names[i] == name { return i }
        i = i + 1
    }
    return -1
}

// 파스 타임 숫자 const 값 (comptime 상수식 평가용)
g_cc_names: [str] = []
g_cc_ivals: [i64] = []
g_cc_fvals: [f64] = []
g_cc_isf: [i32] = []     // 1이면 실수

fn cc_find(name: str) -> i32 {
    i = 0
    while i < len(g_cc_names) {
        if g_cc_names[i] == name { return i }
        i = i + 1
    }
    return -1
}

// ─── comptime 상수식 평가기 (숫자 산술 서브셋) ────────────────────────────
g_ct_ok = false
g_ct_isf = false
g_ct_i: i64 = 0
g_ct_f: f64 = 0.0
g_ct_names: [str] = []
g_ct_ivals: [i64] = []
g_ct_fvals: [f64] = []
g_ct_isfs: [i32] = []

fn ct_local_find(name: str) -> i32 {
    i = len(g_ct_names) - 1
    while i >= 0 {
        if g_ct_names[i] == name { return i }
        i = i - 1
    }
    return -1
}

fn ct_local_set(name: str) {
    ci = ct_local_find(name)
    if ci == -1 {
        push(g_ct_names, name)
        push(g_ct_ivals, g_ct_i)
        push(g_ct_fvals, g_ct_f)
        if g_ct_isf { push(g_ct_isfs, 1) } else { push(g_ct_isfs, 0) }
        return
    }
    g_ct_ivals[ci] = g_ct_i
    g_ct_fvals[ci] = g_ct_f
    if g_ct_isf { g_ct_isfs[ci] = 1 } else { g_ct_isfs[ci] = 0 }
}

fn ct_load_local(ci: i32) {
    g_ct_ok = true
    if g_ct_isfs[ci] == 1 { g_ct_isf = true; g_ct_f = g_ct_fvals[ci] }
    else { g_ct_isf = false; g_ct_i = g_ct_ivals[ci] }
}

fn ct_truth() -> bool {
    if not g_ct_ok { return false }
    if g_ct_isf { return g_ct_f != 0.0 }
    return g_ct_i != 0
}

fn ct_pop_to(n: i32) {
    while len(g_ct_names) > n {
        pop(g_ct_names); pop(g_ct_ivals); pop(g_ct_fvals); pop(g_ct_isfs)
    }
}

fn ct_eval(n: i32) {
    g_ct_ok = false
    if n < 0 { return }
    k = g_nkind[n]
    if k == NK_INT   { g_ct_ok = true; g_ct_isf = false; g_ct_i = g_nival[n]; return }
    if k == NK_FLOAT { g_ct_ok = true; g_ct_isf = true;  g_ct_f = g_nfval[n]; return }
    if k == NK_BOOL  { g_ct_ok = true; g_ct_isf = false; g_ct_i = g_nival[n]; return }
    if k == NK_COMPTIME { ct_eval(g_nc0[n]); return }
    // simple enum bare variant: Phase.Chase → 태그 상수 (const INITIAL = State.Idle 등)
    if k == NK_FIELD {
        cfo = g_nc0[n]
        if g_nkind[cfo] == NK_ID {
            cev = find_variant(g_nsval[cfo], g_nsval[n])
            if cev != -1 {
                if enum_is_simple(g_nsval[cfo]) {
                    g_ct_ok = true; g_ct_isf = false; g_ct_i = g_vrt_tag[cev]
                    return
                }
            }
        }
        return
    }
    if k == NK_ID {
        lci = ct_local_find(g_nsval[n])
        if lci != -1 { ct_load_local(lci); return }
        ci = cc_find(g_nsval[n])
        if ci == -1 { return }
        g_ct_ok = true
        if g_cc_isf[ci] == 1 { g_ct_isf = true; g_ct_f = g_cc_fvals[ci] }
        else { g_ct_isf = false; g_ct_i = g_cc_ivals[ci] }
        return
    }
    if k == NK_BLOCK {
        sv = len(g_ct_names)
        g_ct_ok = true; g_ct_isf = false; g_ct_i = 0
        bi = 0
        while bi < g_nch_n[n] {
            ct_eval(g_ch[g_nch_s[n] + bi])
            if not g_ct_ok { ct_pop_to(sv); return }
            bi = bi + 1
        }
        ct_pop_to(sv)
        return
    }
    if k == NK_ASSIGN {
        ct_eval(g_nc0[n])
        if not g_ct_ok { return }
        ct_local_set(g_nsval[n])
        return
    }
    if k == NK_IF {
        ct_eval(g_nc0[n])
        if not g_ct_ok { return }
        if ct_truth() { ct_eval(g_nc1[n]); return }
        if g_nc2[n] != -1 { ct_eval(g_nc2[n]); return }
        g_ct_ok = true; g_ct_isf = false; g_ct_i = 0
        return
    }
    if k == NK_WHILE {
        guard = 0
        g_ct_ok = true; g_ct_isf = false; g_ct_i = 0
        while true {
            ct_eval(g_nc0[n])
            if not g_ct_ok { return }
            if not ct_truth() { g_ct_ok = true; return }
            ct_eval(g_nc1[n])
            if not g_ct_ok { return }
            guard = guard + 1
            if guard > 100000 { g_ct_ok = false; return }
        }
    }
    if k == NK_FOR {
        iter = g_nc0[n]
        if g_nkind[iter] != NK_RANGE { return }
        ct_eval(g_nc0[iter])
        if not g_ct_ok or g_ct_isf { return }
        startv = g_ct_i
        ct_eval(g_nc1[iter])
        if not g_ct_ok or g_ct_isf { return }
        endv = g_ct_i
        sv = len(g_ct_names)
        cur = startv
        g_ct_ok = true; g_ct_isf = false; g_ct_i = 0
        while cur < endv {
            g_ct_isf = false; g_ct_i = cur; g_ct_f = 0.0
            ct_local_set(g_nsval[n])
            ct_eval(g_nc1[n])
            if not g_ct_ok { ct_pop_to(sv); return }
            cur = cur + 1
        }
        ct_pop_to(sv)
        g_ct_ok = true
        return
    }
    if k == NK_NEG {
        ct_eval(g_nc0[n])
        if not g_ct_ok { return }
        if g_ct_isf { g_ct_f = 0.0 - g_ct_f } else { g_ct_i = 0 - g_ct_i }
        return
    }
    if k == NK_NOT {
        ct_eval(g_nc0[n])
        if not g_ct_ok { return }
        tv = 0
        if not ct_truth() { tv = 1 }
        g_ct_ok = true; g_ct_isf = false; g_ct_i = tv
        return
    }
    if k == NK_AND or k == NK_OR {
        ct_eval(g_nc0[n])
        if not g_ct_ok { return }
        lt = ct_truth()
        if k == NK_AND and not lt { g_ct_ok = true; g_ct_isf = false; g_ct_i = 0; return }
        if k == NK_OR and lt { g_ct_ok = true; g_ct_isf = false; g_ct_i = 1; return }
        ct_eval(g_nc1[n])
        if not g_ct_ok { return }
        rt = ct_truth()
        g_ct_ok = true; g_ct_isf = false
        if rt { g_ct_i = 1 } else { g_ct_i = 0 }
        return
    }
    if k == NK_ADD or k == NK_SUB or k == NK_MUL or k == NK_DIV or k == NK_MOD {
        ct_eval(g_nc0[n])
        if not g_ct_ok { return }
        lf = g_ct_isf; li = g_ct_i; lv = g_ct_f
        ct_eval(g_nc1[n])
        if not g_ct_ok { return }
        rf = g_ct_isf; ri = g_ct_i; rv = g_ct_f
        if lf or rf {
            a = lv; b = rv
            if not lf { a = li as f64 }
            if not rf { b = ri as f64 }
            if k == NK_MOD { g_ct_ok = false; return }
            if k == NK_DIV and b == 0.0 { g_ct_ok = false; return }
            g_ct_ok = true; g_ct_isf = true
            if k == NK_ADD { g_ct_f = a + b }
            if k == NK_SUB { g_ct_f = a - b }
            if k == NK_MUL { g_ct_f = a * b }
            if k == NK_DIV { g_ct_f = a / b }
            return
        }
        if (k == NK_DIV or k == NK_MOD) and ri == 0 { g_ct_ok = false; return }
        g_ct_ok = true; g_ct_isf = false
        if k == NK_ADD { g_ct_i = li + ri }
        if k == NK_SUB { g_ct_i = li - ri }
        if k == NK_MUL { g_ct_i = li * ri }
        if k == NK_DIV { g_ct_i = li / ri }
        if k == NK_MOD { g_ct_i = li % ri }
        return
    }
    if k == NK_EQ or k == NK_NEQ or k == NK_LT or k == NK_GT or k == NK_LTE or k == NK_GTE {
        ct_eval(g_nc0[n])
        if not g_ct_ok { return }
        lf = g_ct_isf; li = g_ct_i; lv = g_ct_f
        ct_eval(g_nc1[n])
        if not g_ct_ok { return }
        rf = g_ct_isf; ri = g_ct_i; rv = g_ct_f
        out = false
        if lf or rf {
            a = lv; b = rv
            if not lf { a = li as f64 }
            if not rf { b = ri as f64 }
            if k == NK_EQ { out = a == b }
            if k == NK_NEQ { out = a != b }
            if k == NK_LT { out = a < b }
            if k == NK_GT { out = a > b }
            if k == NK_LTE { out = a <= b }
            if k == NK_GTE { out = a >= b }
        } else {
            if k == NK_EQ { out = li == ri }
            if k == NK_NEQ { out = li != ri }
            if k == NK_LT { out = li < ri }
            if k == NK_GT { out = li > ri }
            if k == NK_LTE { out = li <= ri }
            if k == NK_GTE { out = li >= ri }
        }
        g_ct_ok = true; g_ct_isf = false
        if out { g_ct_i = 1 } else { g_ct_i = 0 }
        return
    }
}

// union 이름 레지스트리 (파스 시점 등록) — 필드 접근 시 bitcast 경로 판별
g_union_names: [str] = []

fn union_has(name: str) -> bool {
    i = 0
    while i < len(g_union_names) {
        if g_union_names[i] == name { return true }
        i = i + 1
    }
    return false
}

// defer 스택 — 현재 함수에 등록된 defer 본문 노드들 (LIFO 실행)
g_defer_bodies: [i32] = []
g_defer_base = 0      // 현재 함수 스코프의 defer 시작 인덱스
g_in_defer = false    // defer 본문 컴파일 중 (중첩 defer/return 가드)

// const 이름 레지스트리 (파스 시점 등록) — 재대입 금지 검사용
g_const_names: [str] = []

fn const_has(name: str) -> bool {
    i = 0
    while i < len(g_const_names) {
        if g_const_names[i] == name { return true }
        i = i + 1
    }
    return false
}

fn mod_has(name: str) -> bool {
    mi = 0
    while mi < len(g_mod_names) {
        if g_mod_names[mi] == name { return true }
        mi = mi + 1
    }
    return false
}

fn mod_register(name: str) {
    if not mod_has(name) { push(g_mod_names, name) }
}

fn mod_loaded_has(name: str) -> bool {
    mi = 0
    while mi < len(g_mod_loaded) {
        if g_mod_loaded[mi] == name { return true }
        mi = mi + 1
    }
    return false
}

fn mod_loading_has(name: str) -> bool {
    mi = 0
    while mi < len(g_mod_loading) {
        if g_mod_loading[mi] == name { return true }
        mi = mi + 1
    }
    return false
}

// "physics.collision" → "physics/collision.dh"
fn mod_rel_path(mname: str) -> str {
    out = ""
    i = 0
    while i < len(mname) {
        if mname[i] == "." { out = out + "/" }
        else { out = out + mname[i] }
        i = i + 1
    }
    return out + ".dh"
}

// 모듈 파일을 렉싱해 토큰을 뒤에 덧붙이고, 그 지점부터 톱레벨 문을 파싱해
// g_pending_stmts로 모은다 (parse_program이 드레인). 토큰은 append-only라
// 파서 위치(g_pos)만 저장/복원하면 재진입 안전.
fn import_module(mname: str, iln: i32) {
    if mod_loaded_has(mname) { return }
    if mod_loading_has(mname) {
        fatal("순환 임포트를 감지했어: '" + mname + "' (줄 " + to_string(iln) + ")")
    }
    rel = mod_rel_path(mname)
    path = g_src_dir + rel
    if not file_exists(path) { path = rel }
    if not file_exists(path) {
        fatal("모듈 '" + mname + "'을 찾을 수 없어: " + g_src_dir + rel + " (줄 " + to_string(iln) + ")")
    }
    push(g_mod_loading, mname)
    msrc = file_read(path)
    tstart = len(g_toks_kind)
    lex(msrc)
    sv_pos = g_pos
    g_pos = tstart
    skip_nls()
    while ctok() != TK_EOF {
        ms = parse_stmt()
        push(g_pending_stmts, ms)
        skip_nls()
    }
    g_pos = sv_pos
    pop(g_mod_loading)
    push(g_mod_loaded, mname)
}

fn clink_add(libn2: str) {
    ci3 = 0
    while ci3 < len(g_clink_libs) {
        if g_clink_libs[ci3] == libn2 { return }
        ci3 = ci3 + 1
    }
    push(g_clink_libs, libn2)
}

fn parse_extern_fn() -> i32 {
    eat(TK_EXTERN)
    return parse_extern_fn_decl()
}

// 커서가 TK_FN에 있다고 가정 — extern fn 본체 파싱 (@clink 블록 형식과 공유)
fn parse_extern_fn_decl() -> i32 {
    ln = cline(); eat(TK_FN)
    name = csval(); eat(TK_ID); eat(TK_LPAREN)
    nd = node_new(NK_EXTERN_FN, name, 0, 0.0, -1, -1, -1, ln)
    skip_nls()
    while ctok() != TK_RPAREN and ctok() != TK_EOF {
        if ctok() == TK_ELLIPSIS { adv(); break }
        pln = cline(); pname = csval()
        if ctok() == TK_ID { adv() } else { adv() }
        pty = try_type_ann()
        p = node_new(NK_PARAM, pname, 0, 0.0, -1, -1, -1, pln)
        g_ntype[p] = pty
        node_add_ch(nd, p)
        if ctok() == TK_COMMA { adv() }
        skip_nls()
    }
    eat(TK_RPAREN)
    ret_ty = ""
    if ctok() == TK_ARROW { adv(); ret_ty = parse_type_str() }
    rtn = node_new(NK_PARAM, "", 0, 0.0, -1, -1, -1, ln)
    g_ntype[rtn] = ret_ty
    g_nc1[nd] = rtn
    return nd
}

fn parse_if() -> i32 {
    ln = cline(); eat(TK_IF)
    g_allow_struct_lit = 0; cond = parse_or(); g_allow_struct_lit = 1
    skip_nls(); then_b = parse_block()
    else_b = -1
    saved = g_pos; skip_nls()
    if ctok() == TK_ELSE {
        adv(); skip_nls()
        if ctok() == TK_IF { else_b = parse_if() }
        else                { else_b = parse_block() }
    } else {
        g_pos = saved
    }
    return node_new(NK_IF, "", 0, 0.0, cond, then_b, else_b, ln)
}

fn parse_while() -> i32 {
    ln = cline(); eat(TK_WHILE)
    g_allow_struct_lit = 0; cond = parse_or(); g_allow_struct_lit = 1
    skip_nls(); body = parse_block()
    return node_new(NK_WHILE, "", 0, 0.0, cond, body, -1, ln)
}

fn comp_has(cn: str) -> bool {
    i = 0
    while i < len(g_comp_names) {
        if g_comp_names[i] == cn { return true }
        i = i + 1
    }
    return false
}

// component Name { fields } — struct 정의 + 컴포넌트 등록
// foreach 본문이 바인딩 이름의 필드에 대입하는지 (p.x = ... → p는 쓰기)
fn fe_body_writes(nn: i32, bname: str) -> bool {
    if nn < 0 or nn >= g_node_count { return false }
    if g_nkind[nn] == NK_FASSIGN {
        fwo = g_nc0[nn]
        if fwo >= 0 {
            if g_nkind[fwo] == NK_ID and g_nsval[fwo] == bname { return true }
        }
    }
    if fe_body_writes(g_nc0[nn], bname) { return true }
    if fe_body_writes(g_nc1[nn], bname) { return true }
    if fe_body_writes(g_nc2[nn], bname) { return true }
    fwi = 0
    while fwi < g_nch_n[nn] {
        if fe_body_writes(g_ch[g_nch_s[nn] + fwi], bname) { return true }
        fwi = fwi + 1
    }
    return false
}

fn parse_component_def() -> i32 {
    ln = cline(); adv()
    name = csval(); eat(TK_ID); eat(TK_LBRACE); skip_nls()
    nd = node_new(NK_STRUCT_DEF, name, 0, 0.0, -1, -1, -1, ln)
    while ctok() != TK_RBRACE and ctok() != TK_EOF {
        fln = cline(); fname = csval(); eat(TK_ID)
        fty = try_type_ann()
        // 무타입 컴포넌트 필드는 f64 기본 (py 7.15f 의미론)
        if fty == "" { fty = "f64" }
        fi = node_new(NK_FIELD_DEF, fname, 0, 0.0, -1, -1, -1, fln)
        g_ntype[fi] = fty
        node_add_ch(nd, fi)
        if ctok() == TK_COMMA { adv() }
        skip_nls()
    }
    eat(TK_RBRACE)
    push(g_comp_names, name)
    return nd
}

// system name(params) { body } — 일반 fn + 시스템 등록 (schedule이 선언 순서로 실행)
fn parse_system_def() -> i32 {
    ln = cline(); adv()
    name = csval(); eat(TK_ID); eat(TK_LPAREN)
    nd = node_new(NK_FN, name, 0, 0.0, -1, -1, -1, ln)
    if g_parse_parallel_system == 1 { g_nival[nd] = 1; g_parse_parallel_system = 0 }
    skip_nls()
    params: [i32] = []
    while ctok() != TK_RPAREN and ctok() != TK_EOF {
        pln = cline(); pname = csval(); eat(TK_ID)
        pty = try_type_ann()
        p = node_new(NK_PARAM, pname, 0, 0.0, -1, -1, -1, pln)
        g_ntype[p] = pty
        push(params, p)
        if ctok() == TK_COMMA { adv() }
        skip_nls()
    }
    eat(TK_RPAREN)
    ret_ty = ""
    if ctok() == TK_ARROW { adv(); ret_ty = parse_type_str() }
    if ret_ty == "" { ret_ty = "()" }
    rtn = node_new(NK_PARAM, "", 0, 0.0, -1, -1, -1, ln)
    g_ntype[rtn] = ret_ty
    g_nc1[nd] = rtn
    skip_nls()
    body = parse_block()
    g_nc0[nd] = body
    i = 0
    while i < len(params) { node_add_ch(nd, params[i]); i = i + 1 }
    push(g_sys_names, name)
    // 컴포넌트 읽기/쓰기 접근 수집 — schedule() 토포 정렬용
    sys_collect_access(name, body)
    return nd
}

fn parse_for() -> i32 {
    ln = cline(); eat(TK_FOR)
    // for each (p: &mut Position, v: &Velocity) { ... }
    if ctok() == TK_ID and csval() == "each" {
        adv(); eat(TK_LPAREN)
        nd = node_new(NK_FOREACH, "", 0, 0.0, -1, -1, -1, ln)
        skip_nls()
        binds: [i32] = []
        bamps: [i32] = []
        while ctok() != TK_RPAREN and ctok() != TK_EOF {
            bln = cline()
            bname = csval(); eat(TK_ID)
            bty = try_type_ann()
            // "&mut Pos" / "&Pos" / "Pos" → 컴포넌트 이름 + 쓰기 플래그
            wr = 0
            hamp = 0
            cn = bty
            if len(cn) > 0 {
                if cn[0] == "&" {
                    hamp = 1
                    tmp = ""
                    bi = 1
                    while bi < len(cn) { tmp = tmp + cn[bi]; bi = bi + 1 }
                    cn = tmp
                }
            }
            if len(cn) > 4 {
                if cn[0] == "m" and cn[1] == "u" and cn[2] == "t" and cn[3] == " " {
                    wr = 1
                    tmp = ""
                    bi = 4
                    while bi < len(cn) { tmp = tmp + cn[bi]; bi = bi + 1 }
                    cn = tmp
                }
            }
            bp = node_new(NK_PARAM, bname, wr, 0.0, -1, -1, -1, bln)
            g_ntype[bp] = cn
            push(binds, bp)
            push(bamps, hamp)
            if ctok() == TK_COMMA { adv() }
            skip_nls()
        }
        eat(TK_RPAREN)
        skip_nls()
        febody = parse_block()
        g_nc0[nd] = febody
        bi = 0
        while bi < len(binds) {
            // & 명시가 없는 바인딩은 본문의 필드 대입으로 쓰기 추론 (py 7.14 의미론)
            if g_nival[binds[bi]] == 0 and bamps[bi] == 0 {
                if fe_body_writes(febody, g_nsval[binds[bi]]) { g_nival[binds[bi]] = 1 }
            }
            node_add_ch(nd, binds[bi])
            bi = bi + 1
        }
        return nd
    }
    vname = csval(); eat(TK_ID); eat(TK_IN)
    g_allow_struct_lit = 0; iter = parse_or(); g_allow_struct_lit = 1
    if ctok() == TK_DOTDOT {
        g_allow_struct_lit = 0; rln = cline(); adv(); end_e = parse_or(); g_allow_struct_lit = 1
        iter = node_new(NK_RANGE, "", 0, 0.0, iter, end_e, -1, rln)
    }
    skip_nls(); body = parse_block()
    return node_new(NK_FOR, vname, 0, 0.0, iter, body, -1, ln)
}

fn parse_stmt() -> i32 {
    skip_nls()
    ln = cline()
    // 부트스트랩 서브셋 밖의 문법은 조용히 깨진 IR을 만들지 말고 명확히 거부
    if ctok() == TK_ID {
        kw = csval()
        // const NAME [: ty] = expr — 대입과 동일 경로, ival=1로 const 정의 표시
        if kw == "const" {
            adv()
            cname = csval(); eat(TK_ID)
            cann = ""
            if ctok() == TK_COLON { adv(); cann = parse_type_str() }
            eat(TK_EQ)
            cval = parse_or()
            if const_has(cname) {
                fatal("const '" + cname + "'은(는) 이미 선언된 이름이야 (줄 " + to_string(ln) + ")")
            }
            push(g_const_names, cname)
            // 숫자 상수식이면 값을 기록 — comptime 블록에서 참조 가능
            ct_eval(cval)
            if g_ct_ok {
                push(g_cc_names, cname)
                if g_ct_isf {
                    push(g_cc_ivals, 0); push(g_cc_fvals, g_ct_f); push(g_cc_isf, 1)
                } else {
                    push(g_cc_ivals, g_ct_i); push(g_cc_fvals, 0.0); push(g_cc_isf, 0)
                }
            }
            can = node_new(NK_ASSIGN, cname, 1, 0.0, cval, -1, -1, ln)
            g_ntype[can] = cann
            return can
        }
        if kw == "import" {
            if g_block_depth > 0 { fatal("import는 톱레벨에서만 지원해 (줄 " + to_string(ln) + ")") }
            adv()
            mfull = csval(); eat(TK_ID)
            mlast = mfull
            while ctok() == TK_DOT {
                adv()
                mlast = csval(); eat(TK_ID)
                mfull = mfull + "." + mlast
            }
            // import x.y as z — 네임스페이스 별칭
            if ctok() == TK_AS {
                adv()
                mlast = csval(); eat(TK_ID)
            }
            import_module(mfull, ln)
            mod_register(mlast)
            return node_new(NK_NULL, "", 0, 0.0, -1, -1, -1, ln)
        }
        if kw == "from" {
            if g_block_depth > 0 { fatal("from import는 톱레벨에서만 지원해 (줄 " + to_string(ln) + ")") }
            adv()
            mfull = csval(); eat(TK_ID)
            mlast = mfull
            while ctok() == TK_DOT {
                adv()
                mlast = csval(); eat(TK_ID)
                mfull = mfull + "." + mlast
            }
            if ctok() == TK_ID and csval() == "import" { adv() }
            else { fatal("from 다음에는 import가 필요해 (줄 " + to_string(ln) + ")") }
            // 병합 방식이라 가져온 이름은 그대로 쓸 수 있음 — 목록은 소비만 한다
            if ctok() == TK_STAR { adv() }
            else {
                eat(TK_ID)
                while ctok() == TK_COMMA { adv(); eat(TK_ID) }
            }
            import_module(mfull, ln)
            return node_new(NK_NULL, "", 0, 0.0, -1, -1, -1, ln)
        }
        if kw == "component" { return parse_component_def() }
        if kw == "system"    { return parse_system_def() }
        if kw == "union"     { return parse_union_def() }
        // parallel system — 순차 컴파일 (의미론 동일, 병렬화는 미지원)
        if kw == "parallel" {
            adv()
            if ctok() == TK_ID and csval() == "system" {
                g_parse_parallel_system = 1
                return parse_system_def()
            }
            fatal("'parallel' 다음에는 system이 와야 해 (줄 " + to_string(ln) + ")")
        }
        // unsafe { ... } / unsafe fn — 본문 그대로 컴파일 (안전 검사 자체가 없음)
        if kw == "unsafe" {
            adv()
            skip_nls()
            if ctok() == TK_FN { return parse_fn_def() }
            return parse_block()
        }
        // export fn — 함수는 이미 external linkage라 일반 fn과 동일
        if kw == "export" {
            adv()
            skip_nls()
            if ctok() == TK_FN { return parse_fn_def() }
            fatal("'export' 다음에는 fn이 와야 해 (줄 " + to_string(ln) + ")")
        }
        // defer { ... } — 함수 종료(return/끝) 시 LIFO 실행
        if kw == "defer" {
            adv()
            skip_nls()
            dbody = parse_block()
            return node_new(NK_DEFER, "", 0, 0.0, dbody, -1, -1, ln)
        }
        // macro name(params) { body } — 호출 지점 인라인 컴파일 (py와 동일 방식)
        if kw == "macro" {
            adv()
            mcname = csval(); eat(TK_ID)
            if ctok() == TK_BANG { adv() }
            eat(TK_LPAREN)
            mcnode = node_new(NK_FN, mcname, 0, 0.0, -1, -1, -1, ln)
            skip_nls()
            mcparams: [i32] = []
            mcvar = 0
            while ctok() != TK_RPAREN and ctok() != TK_EOF {
                mpln = cline(); mpname = csval(); eat(TK_ID)
                if ctok() == TK_ELLIPSIS {
                    adv()
                    mcvar = 1
                }
                mpty = try_type_ann()
                mp = node_new(NK_PARAM, mpname, 0, 0.0, -1, -1, -1, mpln)
                g_ntype[mp] = mpty
                push(mcparams, mp)
                if ctok() == TK_COMMA { adv() }
                skip_nls()
                if mcvar == 1 and ctok() != TK_RPAREN {
                    fatal("가변 인자 매크로 파라미터는 마지막에만 올 수 있어 (줄 " + to_string(ln) + ")")
                }
            }
            eat(TK_RPAREN)
            skip_nls()
            mcbody = parse_block()
            g_nc0[mcnode] = mcbody
            mci = 0
            while mci < len(mcparams) { node_add_ch(mcnode, mcparams[mci]); mci = mci + 1 }
            if macro_find(mcname) != -1 {
                fatal("매크로 '" + mcname + "'은(는) 이미 정의됐어 (줄 " + to_string(ln) + ")")
            }
            push(g_macro_names, mcname)
            push(g_macro_nodes, mcnode)
            push(g_macro_variadic, mcvar)
            return node_new(NK_NULL, "", 0, 0.0, -1, -1, -1, ln)
        }
    }
    // @clink("lib") extern fn ... / extern { fn ... } — 링크 라이브러리 어노테이션
    if ctok() == TK_AT {
        adv()
        aname = csval(); eat(TK_ID)
        if aname != "clink" {
            fatal("danhac 서브셋 미지원 어노테이션: '@" + aname + "' (줄 " + to_string(ln) + ") — danha.py compile을 사용해줘")
        }
        eat(TK_LPAREN)
        libn = csval(); eat(TK_STR)
        eat(TK_RPAREN)
        clink_add(libn)
        skip_nls()
        if ctok() != TK_EXTERN {
            fatal("@clink 다음에는 extern 선언이 필요해 (줄 " + to_string(ln) + ")")
        }
        eat(TK_EXTERN)
        skip_nls()
        if ctok() == TK_FN { return parse_extern_fn_decl() }
        eat(TK_LBRACE)
        skip_nls()
        fst = -1
        while ctok() == TK_FN {
            xn = parse_extern_fn_decl()
            if fst == -1 { fst = xn } else { push(g_pending_externs, xn) }
            skip_nls()
        }
        eat(TK_RBRACE)
        if fst == -1 {
            fatal("@clink extern 블록이 비어 있어 (줄 " + to_string(ln) + ")")
        }
        return fst
    }
    if ctok() == TK_ENUM     { return parse_enum_def() }
    if ctok() == TK_MATCH    { return parse_match() }
    if ctok() == TK_TRAIT    { return parse_trait() }
    if ctok() == TK_IMPL     { return parse_impl() }
    if ctok() == TK_FN       { return parse_fn_def() }
    if ctok() == TK_STRUCT   { return parse_struct_def() }
    if ctok() == TK_EXTERN   { return parse_extern_fn() }
    if ctok() == TK_IF       { return parse_if() }
    if ctok() == TK_WHILE    { return parse_while() }
    if ctok() == TK_FOR      { return parse_for() }
    if ctok() == TK_BREAK    { adv(); return node_new(NK_BREAK,    "", 0, 0.0, -1, -1, -1, ln) }
    if ctok() == TK_CONTINUE { adv(); return node_new(NK_CONTINUE, "", 0, 0.0, -1, -1, -1, ln) }
    if ctok() == TK_RETURN {
        adv()
        if ctok() == TK_NL or ctok() == TK_RBRACE or ctok() == TK_EOF {
            return node_new(NK_RETURN, "", 0, 0.0, -1, -1, -1, ln)
        }
        val = parse_or()
        return node_new(NK_RETURN, "", 0, 0.0, val, -1, -1, ln)
    }
    if ctok() == TK_PRINT {
        adv(); eat(TK_LPAREN)
        val = parse_or(); eat(TK_RPAREN)
        return node_new(NK_PRINT, "", 0, 0.0, val, -1, -1, ln)
    }
    // 무시 토큰
    if ctok() == TK_IMPORT or ctok() == TK_FROM or ctok() == TK_EXPORT or ctok() == TK_COMPTIME or ctok() == TK_MACRO {
        while ctok() != TK_NL and ctok() != TK_EOF { adv() }
        return node_new(NK_NULL, "", 0, 0.0, -1, -1, -1, ln)
    }
    // 식 또는 대입
    expr = parse_or()
    ann = ""
    if ctok() == TK_COLON { adv(); ann = parse_type_str() }
    if ctok() == TK_EQ {
        adv(); val = parse_or()
        k = g_nkind[expr]
        if k == NK_ID    { an = node_new(NK_ASSIGN, g_nsval[expr], 0, 0.0, val, -1, -1, ln); g_ntype[an] = ann; return an }
        if k == NK_FIELD { return node_new(NK_FASSIGN, g_nsval[expr], 0, 0.0, g_nc0[expr], val, -1, ln) }
        if k == NK_INDEX { return node_new(NK_IASSIGN, "", 0, 0.0, g_nc0[expr], g_nc1[expr], val, ln) }
    }
    return expr
}

fn parse_program() -> i32 {
    stmts: [i32] = []
    skip_nls()
    while ctok() != TK_EOF {
        push(stmts, parse_stmt())
        // import된 모듈의 톱레벨 문들을 드레인
        pm = 0
        while pm < len(g_pending_stmts) { push(stmts, g_pending_stmts[pm]); pm = pm + 1 }
        if len(g_pending_stmts) > 0 { g_pending_stmts = [] }
        // @clink extern 블록의 나머지 fn들을 톱레벨로 드레인
        pe = 0
        while pe < len(g_pending_externs) { push(stmts, g_pending_externs[pe]); pe = pe + 1 }
        if len(g_pending_externs) > 0 { g_pending_externs = [] }
        skip_nls()
    }
    nd = node_new(NK_BLOCK, "", 0, 0.0, -1, -1, -1, 1)
    i = 0
    while i < len(stmts) { node_add_ch(nd, stmts[i]); i = i + 1 }
    return nd
}

// ─── 코드젠 전역 변수 ─────────────────────────────────────────────────────
g_out: [str] = []
g_alloca_buf: [str] = []
g_reg        = 0
g_lbl        = 0
g_strlits: [str] = []
g_strlit_ids: [str] = []
g_strlit_szs: [i32] = []

g_var_names: [str] = []
g_var_regs: [str] = []
g_var_tys: [str] = []
g_var_elems: [str] = []
g_parallel_foreach = 0
g_parallel_start_reg = ""
g_parallel_end_reg = ""

g_sdefs: [str] = []
g_sdef_fnames: [str] = []
g_sdef_ftys: [str] = []
g_sdef_fs: [i32] = []
g_sdef_fc: [i32] = []

// ECS 레지스트리 (파스 시점 등록)
g_comp_names: [str] = []
g_sys_names: [str] = []
g_parse_parallel_system = 0
// 시스템별 컴포넌트 접근 (sys, comp, write?) — schedule() 토포 정렬용
g_sa_sys: [str] = []
g_sa_comp: [str] = []
g_sa_w: [i32] = []

// 시스템의 comp 접근 종류: 0=없음, 1=읽기, 2=쓰기 (쓰기가 우선)
fn sys_access(sysname: str, comp: str) -> i32 {
    r = 0
    i = 0
    while i < len(g_sa_sys) {
        if g_sa_sys[i] == sysname and g_sa_comp[i] == comp {
            if g_sa_w[i] == 1 { return 2 }
            r = 1
        }
        i = i + 1
    }
    return r
}

// system 본문에서 for each 바인딩의 컴포넌트 접근 수집
fn sys_collect_access(sysname: str, nn: i32) {
    if nn < 0 or nn >= g_node_count { return }
    if g_nkind[nn] == NK_FOREACH {
        bi = 0
        while bi < g_nch_n[nn] {
            bp = g_ch[g_nch_s[nn] + bi]
            push(g_sa_sys, sysname)
            push(g_sa_comp, g_ntype[bp])
            wv = 0
            if g_nival[bp] == 1 { wv = 1 }
            push(g_sa_w, wv)
            bi = bi + 1
        }
        sys_collect_access(sysname, g_nc0[nn])
        return
    }
    sys_collect_access(sysname, g_nc0[nn])
    sys_collect_access(sysname, g_nc1[nn])
    sys_collect_access(sysname, g_nc2[nn])
    wi = 0
    while wi < g_nch_n[nn] { sys_collect_access(sysname, g_ch[g_nch_s[nn] + wi]); wi = wi + 1 }
}

// trait/impl 레지스트리 (파스 시점 등록)
g_trm_trait: [str] = []
g_trm_name: [str] = []
g_trm_fn: [i32] = []
g_impl_fns: [i32] = []
g_impl_done: [str] = []
// dyn 디스패치용 (트레잇, 스트럭트) impl 페어 — vtable 생성
g_impl_traits: [str] = []
g_impl_structs: [str] = []

// 람다(클로저) 레지스트리 — id는 cg 순서
g_lam_count = 0
g_lam_rets: [str] = []       // LLVM 반환 타입
g_lam_nps: [i32] = []        // 파라미터 수 (캡처 제외)
g_lam_ps: [i32] = []         // g_lam_ptys 시작 인덱스
g_lam_ptys: [str] = []       // 파라미터 LLVM 타입 (평탄)
g_lam_caps_s: [i32] = []     // 캡처 시작 인덱스
g_lam_caps_n: [i32] = []     // 캡처 수
g_lam_cap_names: [str] = []  // 캡처 변수 이름 (평탄)
g_lam_cap_tys: [str] = []    // 캡처 LLVM 타입 (평탄)
g_lam_cap_regs: [str] = []   // 생성 지점에서 로드한 값 레지스터 (평탄)
g_lam_out: [str] = []        // 람다 define들 — cg_program 끝에 플러시
g_var_lams: [i32] = []       // g_var_names 평행: 변수에 바인딩된 람다 id (-1 없음)
g_expr_lam = -1              // 직전 cg_expr 결과의 람다 id
// 자유 변수 수집 임시 버퍼
g_lfv_names: [str] = []
g_lfv_params: [str] = []

// tagged enum 레지스트리 (파스 시점 등록)
g_enum_names: [str] = []
// g_enum_names와 평행 — 1이면 simple enum (payload 없는 비제네릭, variant가 i64 상수)
g_enum_simple: [i32] = []
g_vrt_names: [str] = []
g_vrt_owner: [str] = []
g_vrt_tag: [i32] = []
g_vrt_pty: [str] = []

g_fn_names: [str] = []
g_fn_rets: [str] = []
g_fn_arities: [i32] = []
g_fn_ptys: [str] = []
g_fn_ps: [i32] = []

g_cur_fn_ret  = ""
g_loop_br_lbl = ""
g_loop_co_lbl = ""
g_expr_reg    = ""
g_expr_ty     = ""
g_expr_elem   = ""

// ─── 코드젠 헬퍼 ──────────────────────────────────────────────────────────
fn emit(s: str) { push(g_out, s) }

// 로컬 변수 alloca는 entry 블록으로 호이스트 (dominance 보장)
fn emit_alloca(s: str) { push(g_alloca_buf, s) }

fn new_reg() -> str {
    r = "%r" + to_string(g_reg)
    g_reg = g_reg + 1
    return r
}

fn new_lbl() -> str {
    l = "lbl" + to_string(g_lbl)
    g_lbl = g_lbl + 1
    return l
}

fn sext32(r: str, ty: str) -> str {
    if ty == "i32" {
        x = new_reg()
        emit("  " + x + " = sext i32 " + r + " to i64")
        return x
    }
    return r
}

fn hex2(n: i32) -> str {
    d = "0123456789ABCDEF"
    return d[n / 16] + d[n % 16]
}

// 런타임 프리앰블(emit_rt)이 항상 declare하는 외부 심볼 — 사용자 extern과 중복 방출 금지
fn rt_predeclared(name2: str) -> bool {
    if name2 == "sin" or name2 == "cos" or name2 == "tan" { return true }
    if name2 == "log" or name2 == "exp" or name2 == "pow" { return true }
    if name2 == "atan2" or name2 == "hypot" { return true }
    if name2 == "ari_save_open" or name2 == "ari_save_int" or name2 == "ari_save_float" { return true }
    if name2 == "ari_save_string" or name2 == "ari_save_close" { return true }
    if name2 == "ari_load_open" or name2 == "ari_load_int" or name2 == "ari_load_float" { return true }
    if name2 == "ari_load_close" { return true }
    if name2 == "malloc" or name2 == "realloc" or name2 == "free" { return true }
    if name2 == "puts" or name2 == "printf" or name2 == "strcmp" { return true }
    return false
}

// ECS 런타임 abort: 메시지 출력 후 exit(1) (py printf+exit 패리티, puts가 \n 추가)
fn cg_ecs_die(msg: str) {
    mi6 = add_strlit(msg)
    mp6 = strlit_gep(mi6)
    emit("  call i32 @puts(i8* " + mp6 + ")")
    emit("  call void @dnh_exit(i32 1)")
    emit("  unreachable")
}

// 엔티티 유효성 검사 — 죽었거나 낡은 ID면 메시지 찍고 abort
fn cg_ecs_check_alive(ent: str, msg: str) {
    v6 = new_reg()
    emit("  " + v6 + " = call i1 @dnh_ecs_valid(i64 " + ent + ")")
    lo6 = new_lbl(); lb6 = new_lbl()
    emit("  br i1 " + v6 + ", label %" + lo6 + ", label %" + lb6)
    emit(lb6 + ":")
    cg_ecs_die(msg)
    emit(lo6 + ":")
}

fn utf8_byte_len(s: str) -> i32 {
    n = 0; i = 0
    while i < len(s) {
        cp = ord(s[i])
        if cp < 128   { n = n + 1 }
        else if cp < 256   { n = n + 1 }
        else if cp < 2048  { n = n + 2 }
        else if cp < 65536 { n = n + 3 }
        else          { n = n + 4 }
        i = i + 1
    }
    return n
}

fn is_int_ty(t: str) -> bool {
    return t == "i1" or t == "i8" or t == "i16" or t == "i32" or t == "i64"
}

fn is_flt_ty(t: str) -> bool {
    return t == "float" or t == "double"
}

fn int_width(t: str) -> i32 {
    if t == "i1"  { return 1 }
    if t == "i8"  { return 8 }
    if t == "i16" { return 16 }
    if t == "i32" { return 32 }
    if t == "i64" { return 64 }
    return 64
}

fn ll_zero(ty: str) -> str {
    if ty == "double" or ty == "float" { return "0.0" }
    if ty == "i1"                       { return "0" }
    if ty == "i8"                       { return "0" }
    if ty == "i32"                      { return "0" }
    if ty == "i64"                      { return "0" }
    if ty == "void" or ty == "()"       { return "" }
    if len(ty) > 0 {
        if ty[0] == "[" or ty[0] == "<" { return "zeroinitializer" }
    }
    return "null"
}

fn ll_ty(dh_ty: str) -> str {
    // &T / &mut T — struct는 이미 포인터라 내부 타입과 동일
    if len(dh_ty) > 0 {
        if dh_ty[0] == "&" {
            inner = ""
            ri = 1
            while ri < len(dh_ty) { inner = inner + dh_ty[ri]; ri = ri + 1 }
            // "mut " 접두 제거
            if len(inner) > 4 {
                if inner[0] == "m" and inner[1] == "u" and inner[2] == "t" and inner[3] == " " {
                    im = ""
                    ri = 4
                    while ri < len(inner) { im = im + inner[ri]; ri = ri + 1 }
                    inner = im
                }
            }
            if ann_fixed_elem(inner) != "" { return ll_ty(inner) + "*" }
            return ll_ty(inner)
        }
    }
    // 활성 제네릭 타입 매개변수 치환 (인스턴스화 중)
    tpa = tp_act_find(dh_ty)
    if tpa != -1 { return g_tp_act_tys[tpa] }
    // [i32;8] — 고정 크기 배열
    fae = ann_fixed_elem(dh_ty)
    if fae != "" {
        return "[" + ann_fixed_size(dh_ty) + " x " + ll_ty(fae) + "]"
    }
    if dh_ty == "vec2" { return "<2 x double>" }
    if dh_ty == "vec3" { return "<3 x double>" }
    if dh_ty == "vec4" { return "<4 x double>" }
    if dh_ty == "i8"   { return "i8" }
    if dh_ty == "i16"  { return "i16" }
    if dh_ty == "i32"  { return "i32" }
    if dh_ty == "i64"  { return "i64" }
    if dh_ty == "u8"   { return "i8" }
    if dh_ty == "u16"  { return "i16" }
    if dh_ty == "u32"  { return "i32" }
    if dh_ty == "u64"  { return "i64" }
    if dh_ty == "f32"  { return "float" }
    if dh_ty == "f64"  { return "double" }
    if dh_ty == "bool" { return "i1" }
    if dh_ty == "str"  { return "i8*" }
    if dh_ty == "ptr"  { return "i8*" }
    if dh_ty == "EntityId" { return "i64" }
    if dh_ty == "HashMap" { return "%DnhHM*" }
    if dh_ty == "()"   { return "void" }
    if dh_ty == ""     { return "i64" }
    dtr3 = as_dyn_trait(dh_ty)
    if dtr3 != "" { return "%dyn." + dtr3 + "*" }
    if find_enum(dh_ty) != -1 { return "%DnhEnum*" }
    return "%struct." + dh_ty + "*"
}

fn ll_escape(s: str) -> str {
    result = ""
    i = 0
    while i < len(s) {
        c = s[i]
        cp = ord(c)
        if c == "\n"      { result = result + "\\0A" }
        else if c == "\t" { result = result + "\\09" }
        else if c == "\\" { result = result + "\\5C" }
        else if c == "\"" { result = result + "\\22" }
        else if cp < 128  { result = result + c }
        else if cp < 256 {
            // 컴파일된 런타임은 바이트 단위 — UTF-8 바이트를 그대로 통과
            result = result + "\\" + hex2(cp)
        }
        else if cp < 2048 {
            b1 = 192 + (cp / 64); b2 = 128 + (cp % 64)
            result = result + "\\" + hex2(b1) + "\\" + hex2(b2)
        } else if cp < 65536 {
            b1 = 224 + (cp / 4096); b2 = 128 + ((cp / 64) % 64); b3 = 128 + (cp % 64)
            result = result + "\\" + hex2(b1) + "\\" + hex2(b2) + "\\" + hex2(b3)
        } else {
            b1 = 240 + (cp / 262144); b2 = 128 + ((cp / 4096) % 64)
            b3 = 128 + ((cp / 64) % 64); b4 = 128 + (cp % 64)
            result = result + "\\" + hex2(b1) + "\\" + hex2(b2) + "\\" + hex2(b3) + "\\" + hex2(b4)
        }
        i = i + 1
    }
    return result
}

fn add_strlit(s: str) -> i32 {
    i = 0
    while i < len(g_strlits) {
        if g_strlits[i] == s { return i }
        i = i + 1
    }
    idx = len(g_strlits)
    push(g_strlits,    s)
    push(g_strlit_ids, "@.s" + to_string(idx))
    push(g_strlit_szs, utf8_byte_len(s) + 1)
    return idx
}

fn strlit_gep(idx: i32) -> str {
    sz   = g_strlit_szs[idx]
    name = g_strlit_ids[idx]
    r    = new_reg()
    emit("  " + r + " = getelementptr inbounds [" + to_string(sz) + " x i8], [" + to_string(sz) + " x i8]* " + name + ", i32 0, i32 0")
    return r
}

fn find_var(name: str) -> i32 {
    i = len(g_var_names) - 1
    while i >= 0 {
        if g_var_names[i] == name { return i }
        i = i - 1
    }
    return -1
}

fn decl_var(name: str, reg: str, ty: str) {
    push(g_var_names, name)
    push(g_var_regs,  reg)
    push(g_var_tys,   ty)
    push(g_var_elems, "")
    push(g_var_lams,  -1)
}

fn decl_var_e(name: str, reg: str, ty: str, elem: str) {
    decl_var(name, reg, ty)
    g_var_elems[len(g_var_elems) - 1] = elem
}

// "[str]" → "str", 리스트 타입 주석이 아니면 ""
fn ann_elem(ann: str) -> str {
    if len(ann) < 3 { return "" }
    if ann[0] != "[" { return "" }
    e = ""
    i = 1
    while i < len(ann) - 1 {
        if ann[i] == ";" { return "" }
        e = e + ann[i]
        i = i + 1
    }
    return e
}

// ─── 고정 크기 배열 헬퍼 ──────────────────────────────────────────────────
// "[i32;8]" → "i32", 고정 크기 배열 주석이 아니면 ""
fn ann_fixed_elem(ann: str) -> str {
    if len(ann) < 5 { return "" }
    if ann[0] != "[" { return "" }
    e = ""
    i = 1
    while i < len(ann) {
        if ann[i] == ";" { return e }
        e = e + ann[i]
        i = i + 1
    }
    return ""
}

// "[i32;8]" → "8"
fn ann_fixed_size(ann: str) -> str {
    s = ""
    seen = false
    i = 0
    while i < len(ann) {
        c = ann[i]
        if c == "]" { return s }
        if seen { s = s + c }
        if c == ";" { seen = true }
        i = i + 1
    }
    return s
}

// LLVM 배열 값 타입 "[8 x i32]" 판별 (mat4 "[4 x <4 x double>]"는 제외 — 값 의미론)
fn is_arr_val(t: str) -> bool {
    if len(t) < 2 { return false }
    if t[0] != "[" { return false }
    if index_of(t, "<") != -1 { return false }
    return t[len(t) - 1] == "]"
}

// LLVM 배열 포인터 타입 "[8 x i32]*" 판별
fn is_arr_ptr(t: str) -> bool {
    if len(t) < 3 { return false }
    if t[0] != "[" { return false }
    if index_of(t, "<") != -1 { return false }
    return t[len(t) - 1] == "*"
}

// mat4 LLVM 타입 (열-우선: 4컬럼 × <4 x double>)
fn m4ty() -> str { return "[4 x <4 x double>]" }

fn is_mat_ty(t: str) -> bool {
    if len(t) < 7 { return false }
    if t[0] != "[" { return false }
    return index_of(t, "<") != -1
}

// "[8 x i32]*"/"[8 x i32]" → "[8 x i32]"
fn arr_base_ty(t: str) -> str {
    if is_arr_ptr(t) {
        b = ""
        i = 0
        while i < len(t) - 1 { b = b + t[i]; i = i + 1 }
        return b
    }
    return t
}

// "[8 x i32]"(또는 포인터) → 8
fn arr_len_ll(t: str) -> i64 {
    b = arr_base_ty(t)
    if len(b) < 4 { return 0 }
    if b[0] != "[" { return 0 }
    s = ""
    i = 1
    while i < len(b) {
        if b[i] == " " { break }
        s = s + b[i]
        i = i + 1
    }
    if s == "" { return 0 }
    return parse_int(s)
}

// "<3 x double>" 벡터 타입 판별
fn is_vec_ty(t: str) -> bool {
    if len(t) < 2 { return false }
    return t[0] == "<"
}

// "<N x double>" → N
fn vec_ty_n(t: str) -> i64 {
    s = ""
    i = 1
    while i < len(t) {
        if t[i] == " " { break }
        s = s + t[i]
        i = i + 1
    }
    return parse_int(s)
}

// 벡터 성분 이름 → 인덱스 (x/y/z/w)
fn vec_field_idx(f: str) -> i64 {
    if f == "x" { return 0 }
    if f == "y" { return 1 }
    if f == "z" { return 2 }
    if f == "w" { return 3 }
    return 0 - 1
}

// "[8 x i32]"(또는 포인터) → "i32"
fn arr_elem_ll(t: str) -> str {
    b = arr_base_ty(t)
    xpos = -1
    i = 0
    while i < len(b) {
        if b[i] == "x" { xpos = i; break }
        i = i + 1
    }
    if xpos == -1 { return "i64" }
    e = ""
    i = xpos + 2
    while i < len(b) - 1 { e = e + b[i]; i = i + 1 }
    return e
}

fn find_enum(name: str) -> i32 {
    i = 0
    while i < len(g_enum_names) {
        if g_enum_names[i] == name { return i }
        i = i + 1
    }
    return -1
}

fn enum_is_simple(name: str) -> bool {
    ei9 = find_enum(name)
    if ei9 == -1 { return false }
    return g_enum_simple[ei9] == 1
}

fn find_variant(ename: str, vname: str) -> i32 {
    i = 0
    while i < len(g_vrt_names) {
        if g_vrt_owner[i] == ename and g_vrt_names[i] == vname { return i }
        i = i + 1
    }
    return -1
}

fn find_variant_any(vname: str) -> i32 {
    i = 0
    while i < len(g_vrt_names) {
        if g_vrt_names[i] == vname { return i }
        i = i + 1
    }
    return -1
}

// 값을 i64 슬롯으로 인코딩 (리스트/enum payload 공용 규약)
// 포인터류(%struct.X*, %dyn.T* 포함)는 전부 ptrtoint
fn val_to_slot(vr: str, vt: str) -> str {
    if vt == "i64" { return vr }
    if vt == "float" {
        cf1 = new_reg(); cf2 = new_reg()
        emit("  " + cf1 + " = bitcast float " + vr + " to i32")
        emit("  " + cf2 + " = zext i32 " + cf1 + " to i64")
        return cf2
    }
    cv = new_reg()
    isp = false
    if len(vt) > 0 {
        if vt[len(vt) - 1] == "*" { isp = true }
    }
    if isp {
        emit("  " + cv + " = ptrtoint " + vt + " " + vr + " to i64")
    } else if vt == "double" {
        emit("  " + cv + " = bitcast double " + vr + " to i64")
    } else {
        emit("  " + cv + " = sext " + vt + " " + vr + " to i64")
    }
    return cv
}

// i64 슬롯을 dh 타입으로 디코딩
fn slot_to_ty(vr: str, dhty: str) -> str {
    lty = ll_ty(dhty)
    if lty == "i64" { return vr }
    cv = new_reg()
    if lty == "i8*" or lty == "%DnhList*" or lty == "%DnhEnum*" {
        emit("  " + cv + " = inttoptr i64 " + vr + " to " + lty)
    } else if lty == "double" {
        emit("  " + cv + " = bitcast i64 " + vr + " to double")
    } else {
        emit("  " + cv + " = trunc i64 " + vr + " to " + lty)
    }
    return cv
}

fn find_struct(name: str) -> i32 {
    i = 0
    while i < len(g_sdefs) {
        if g_sdefs[i] == name { return i }
        i = i + 1
    }
    return -1
}

fn struct_field_idx(sidx: i32, fname: str) -> i32 {
    base = g_sdef_fs[sidx]
    cnt  = g_sdef_fc[sidx]
    i = 0
    while i < cnt {
        if g_sdef_fnames[base + i] == fname { return i }
        i = i + 1
    }
    return -1
}

fn find_fn(name: str) -> i32 {
    i = 0
    while i < len(g_fn_names) {
        if g_fn_names[i] == name { return i }
        i = i + 1
    }
    return -1
}

fn load_val(reg: str, ty: str) -> str {
    r = new_reg()
    emit("  " + r + " = load " + ty + ", " + ty + "* " + reg)
    return r
}

fn coerce_to(reg: str, from_ty: str, to_ty: str) -> str {
    if from_ty == to_ty { return reg }
    r = new_reg()
    if is_int_ty(from_ty) and is_int_ty(to_ty) {
        fw = int_width(from_ty); tw = int_width(to_ty)
        if tw > fw      { emit("  " + r + " = sext " + from_ty + " " + reg + " to " + to_ty) }
        else if tw < fw { emit("  " + r + " = trunc " + from_ty + " " + reg + " to " + to_ty) }
        else            { return reg }
        return r
    }
    if is_int_ty(from_ty) and is_flt_ty(to_ty) {
        emit("  " + r + " = sitofp " + from_ty + " " + reg + " to " + to_ty)
        return r
    }
    if is_flt_ty(from_ty) and is_int_ty(to_ty) {
        emit("  " + r + " = fptosi " + from_ty + " " + reg + " to " + to_ty)
        return r
    }
    if is_flt_ty(from_ty) and is_flt_ty(to_ty) {
        if to_ty == "double" { emit("  " + r + " = fpext " + from_ty + " " + reg + " to double") }
        else                  { emit("  " + r + " = fptrunc " + from_ty + " " + reg + " to float") }
        return r
    }
    if from_ty == "i8*" and is_int_ty(to_ty) {
        emit("  " + r + " = ptrtoint i8* " + reg + " to " + to_ty)
        return r
    }
    if is_int_ty(from_ty) and to_ty == "i8*" {
        emit("  " + r + " = inttoptr " + from_ty + " " + reg + " to i8*")
        return r
    }
    // %struct.X* → %dyn.T* 자동 코어션 (트레잇 객체 래핑)
    ctd = dyn_of_ty(to_ty)
    if ctd != "" and struct_of_ty(from_ty) != "" {
        g_reg = g_reg - 1
        return dyn_wrap(reg, from_ty, ctd, 0)
    }
    emit("  " + r + " = bitcast " + from_ty + " " + reg + " to " + to_ty)
    return r
}

// 현재 함수 스코프의 defer 본문들을 LIFO로 방출 (스택은 유지 — 다중 return 대응)
fn cg_emit_defers() {
    if g_in_defer { return }
    g_in_defer = true
    di = len(g_defer_bodies) - 1
    while di >= g_defer_base {
        cg_stmt(g_defer_bodies[di])
        di = di - 1
    }
    g_in_defer = false
}

// 고정 크기 배열 dst(aty* 포인터)에 RHS 노드를 채운다.
// [v; N] 반복 리터럴 / [a, b, c] 리터럴 / 배열 식(통째 복사) 모두 처리.
fn cg_arr_store(dst: str, aty: str, vn: i32) {
    ety = arr_elem_ll(aty)
    if g_nkind[vn] == NK_ARRAY {
        if g_nival[vn] > 0 {
            // [v; N] — 값 한 번 평가 후 카운터 루프로 채움
            cg_expr(g_ch[g_nch_s[vn]]); ev = g_expr_reg; et = g_expr_ty
            if et != ety { ev = coerce_to(ev, et, ety) }
            idxs = "%__ar" + to_string(g_reg) + "_v"; g_reg = g_reg + 1
            emit_alloca("  " + idxs + " = alloca i64")
            emit("  store i64 0, i64* " + idxs)
            lc = new_lbl(); lb = new_lbl(); le = new_lbl()
            emit("  br label %" + lc)
            emit(lc + ":")
            iv = new_reg(); emit("  " + iv + " = load i64, i64* " + idxs)
            cc = new_reg(); emit("  " + cc + " = icmp slt i64 " + iv + ", " + to_string(g_nival[vn]))
            emit("  br i1 " + cc + ", label %" + lb + ", label %" + le)
            emit(lb + ":")
            gp = new_reg()
            emit("  " + gp + " = getelementptr inbounds " + aty + ", " + aty + "* " + dst + ", i64 0, i64 " + iv)
            emit("  store " + ety + " " + ev + ", " + ety + "* " + gp)
            nx = new_reg(); emit("  " + nx + " = add i64 " + iv + ", 1")
            emit("  store i64 " + nx + ", i64* " + idxs)
            emit("  br label %" + lc)
            emit(le + ":")
            return
        }
        // [a, b, c] — 원소별 저장
        i = 0
        while i < g_nch_n[vn] {
            cg_expr(g_ch[g_nch_s[vn] + i]); ev = g_expr_reg; et = g_expr_ty
            if et != ety { ev = coerce_to(ev, et, ety) }
            gp = new_reg()
            emit("  " + gp + " = getelementptr inbounds " + aty + ", " + aty + "* " + dst + ", i64 0, i64 " + to_string(i))
            emit("  store " + ety + " " + ev + ", " + ety + "* " + gp)
            i = i + 1
        }
        return
    }
    // 배열 식 — 포인터에서 통째로 로드/스토어 (값 복사)
    cg_expr(vn); sv = g_expr_reg; st = g_expr_ty
    if is_arr_ptr(st) {
        lv = new_reg()
        emit("  " + lv + " = load " + aty + ", " + aty + "* " + sv)
        emit("  store " + aty + " " + lv + ", " + aty + "* " + dst)
        return
    }
    if is_arr_val(st) {
        if st != aty { fatal("고정 배열 타입이 맞지 않아 (줄 " + to_string(g_nline[vn]) + ")") }
        emit("  store " + aty + " " + sv + ", " + aty + "* " + dst)
        return
    }
    fatal("고정 배열 대입의 우변이 배열이 아니야 (줄 " + to_string(g_nline[vn]) + ")")
}

// ─── 식 컴파일 ────────────────────────────────────────────────────────────
// ISTR 보간 헬퍼 — a가 ""이면 b 그대로, 아니면 dnh_str_cat 체인
fn istr_cat(a: str, b: str) -> str {
    if a == "" { return b }
    r = new_reg()
    emit("  " + r + " = call i8* @dnh_str_cat(i8* " + a + ", i8* " + b + ")")
    return r
}

// 레지스터 값을 타입에 따라 i8* 문자열로 변환
fn to_str_reg(vr: str, vt: str) -> str {
    if vt == "i8*" { return vr }
    if is_vec_ty(vt) {
        n = vec_ty_n(vt)
        out = strlit_gep(add_strlit("vec" + to_string(n) + "("))
        i: i64 = 0
        while i < n {
            if i > 0 { out = istr_cat(out, strlit_gep(add_strlit(", "))) }
            ev = new_reg()
            emit("  " + ev + " = extractelement " + vt + " " + vr + ", i32 " + to_string(i))
            sr = new_reg()
            emit("  " + sr + " = call i8* @dnh_to_str_float(double " + ev + ")")
            out = istr_cat(out, sr)
            i = i + 1
        }
        out = istr_cat(out, strlit_gep(add_strlit(")")))
        return out
    }
    if is_mat_ty(vt) {
        outm = ""
        row: i64 = 0
        while row < 4 {
            row_s = strlit_gep(add_strlit("| "))
            col: i64 = 0
            while col < 4 {
                cv = new_reg()
                emit("  " + cv + " = extractvalue " + vt + " " + vr + ", " + to_string(col))
                evm = new_reg()
                emit("  " + evm + " = extractelement <4 x double> " + cv + ", i32 " + to_string(row))
                fsm = new_reg()
                emit("  " + fsm + " = call i8* @dnh_to_str_float(double " + evm + ")")
                row_s = istr_cat(row_s, fsm)
                if col < 3 { row_s = istr_cat(row_s, strlit_gep(add_strlit(" "))) }
                col = col + 1
            }
            row_s = istr_cat(row_s, strlit_gep(add_strlit(" |")))
            if row > 0 { outm = istr_cat(outm, strlit_gep(add_strlit("\n"))) }
            outm = istr_cat(outm, row_s)
            row = row + 1
        }
        return outm
    }
    if vt == "float" {
        dv = new_reg()
        emit("  " + dv + " = fpext float " + vr + " to double")
        sr = new_reg()
        emit("  " + sr + " = call i8* @dnh_to_str_float(double " + dv + ")")
        return sr
    }
    if vt == "double" {
        sr = new_reg()
        emit("  " + sr + " = call i8* @dnh_to_str_float(double " + vr + ")")
        return sr
    }
    if vt == "i1" {
        ti = add_strlit("true"); tp = strlit_gep(ti)
        xi = add_strlit("false"); xp = strlit_gep(xi)
        sr = new_reg()
        emit("  " + sr + " = select i1 " + vr + ", i8* " + tp + ", i8* " + xp)
        return sr
    }
    v64 = vr
    if vt != "i64" {
        v64 = new_reg()
        emit("  " + v64 + " = sext " + vt + " " + vr + " to i64")
    }
    sr = new_reg()
    emit("  " + sr + " = call i8* @dnh_to_str_int(i64 " + v64 + ")")
    return sr
}

// 보간 스니펫을 재렉싱+파싱해 임의 식으로 컴파일.
// 파싱은 전체 완료 후 코드젠 단계라 토큰 상태를 덮어써도 안전.
fn cg_interp_expr(isrc: str) {
    g_toks_kind = []
    g_toks_sval = []
    g_toks_ival = []
    g_toks_fval = []
    g_toks_line = []
    g_pos = 0
    lex(isrc)
    e = parse_or()
    cg_expr(e)
}

// "안녕 \{name\}!" → strlit("안녕 ") ++ to_str(식) ++ strlit("!")
// 중괄호 안은 임의 식 지원 (단, 식 내부 문자열에 \} 는 미지원)
fn cg_istr(s: str) {
    res = ""
    cur = ""
    si = 0
    sn = len(s)
    while si < sn {
        c = s[si]
        if c == "\{" {
            j = si + 1
            nm = ""
            while j < sn and s[j] != "\}" { nm = nm + s[j]; j = j + 1 }
            if j >= sn or nm == "" {
                cur = cur + c
                si = si + 1
            } else {
                if cur != "" { res = istr_cat(res, strlit_gep(add_strlit(cur))); cur = "" }
                cg_interp_expr(nm)
                res = istr_cat(res, to_str_reg(g_expr_reg, g_expr_ty))
                si = j + 1
            }
        } else {
            cur = cur + c
            si = si + 1
        }
    }
    if cur != "" or res == "" { res = istr_cat(res, strlit_gep(add_strlit(cur))) }
    g_expr_reg = res
    g_expr_ty = "i8*"
}

// ─── dyn 트레잇 객체 헬퍼 ─────────────────────────────────────────────────
// "dyn Trait" 표기에서 트레잇 이름 추출 (아니면 "")
fn as_dyn_trait(t: str) -> str {
    if len(t) < 5 { return "" }
    if t[0] != "d" { return "" }
    if t[1] != "y" { return "" }
    if t[2] != "n" { return "" }
    if t[3] != " " { return "" }
    out = ""
    i = 4
    while i < len(t) { out = out + t[i]; i = i + 1 }
    return out
}

// "%dyn.T*" → "T" (아니면 "")
fn dyn_of_ty(t: str) -> str {
    if len(t) < 7 { return "" }
    if t[1] != "d" { return "" }
    if t[2] != "y" { return "" }
    if t[3] != "n" { return "" }
    if t[4] != "." { return "" }
    out = ""
    i = 5
    while i < len(t) and t[i] != "*" { out = out + t[i]; i = i + 1 }
    return out
}

// "%struct.X*" → "X" (아니면 "")
fn struct_of_ty(t: str) -> str {
    if len(t) < 10 { return "" }
    if t[1] != "s" { return "" }
    if t[2] != "t" { return "" }
    if t[3] != "r" { return "" }
    out = ""
    i = 8
    while i < len(t) and t[i] != "*" { out = out + t[i]; i = i + 1 }
    return out
}

fn trait_method_count(tname: str) -> i32 {
    c = 0
    i = 0
    while i < len(g_trm_trait) {
        if g_trm_trait[i] == tname { c = c + 1 }
        i = i + 1
    }
    return c
}

// %struct.S* 값을 %dyn.T* 트레잇 객체로 감싼다 (데이터 포인터 + vtable)
fn dyn_wrap(sr: str, sty: str, tname: str, wln: i32) -> str {
    sname = struct_of_ty(sty)
    if sname == "" {
        fatal("as dyn " + tname + ": struct 값이 필요해 (줄 " + to_string(wln) + ")")
    }
    found = false
    i = 0
    while i < len(g_impl_traits) {
        if g_impl_traits[i] == tname and g_impl_structs[i] == sname { found = true }
        i = i + 1
    }
    if not found {
        fatal("impl " + tname + " for " + sname + "이 없어 (줄 " + to_string(wln) + ")")
    }
    nm = trait_method_count(tname)
    dp = new_reg()
    emit("  " + dp + " = bitcast " + sty + " " + sr + " to i8*")
    vp = new_reg()
    emit("  " + vp + " = bitcast [" + to_string(nm) + " x i8*]* @vtable_" + tname + "_" + sname + " to i8*")
    op = new_reg()
    emit("  " + op + " = call i8* @dnh_dyn_new(i8* " + dp + ", i8* " + vp + ")")
    r = new_reg()
    emit("  " + r + " = bitcast i8* " + op + " to %dyn." + tname + "*")
    return r
}

// ─── 람다(클로저) 헬퍼 ────────────────────────────────────────────────────
fn lfv_param_has(name: str) -> bool {
    i = 0
    while i < len(g_lfv_params) {
        if g_lfv_params[i] == name { return true }
        i = i + 1
    }
    return false
}

fn lfv_has(name: str) -> bool {
    i = 0
    while i < len(g_lfv_names) {
        if g_lfv_names[i] == name { return true }
        i = i + 1
    }
    return false
}

// 현재 스코프의 % 로컬만 캡처 후보 (@글로벌은 람다 본문에서 직접 접근 가능)
fn lam_fv_add(name: str) {
    if lfv_param_has(name) { return }
    if lfv_has(name) { return }
    vi = find_var(name)
    if vi == -1 { return }
    reg = g_var_regs[vi]
    if len(reg) == 0 { return }
    if reg[0] != "%" { return }
    push(g_lfv_names, name)
}

// 람다 본문에서 자유 변수 수집 — NK_ID 참조와 NK_ASSIGN 대상 모두 후보
fn lam_free_vars(nn: i32) {
    if nn < 0 or nn >= g_node_count { return }
    wk = g_nkind[nn]
    if wk == NK_ID {
        lam_fv_add(g_nsval[nn])
        return
    }
    if wk == NK_ASSIGN { lam_fv_add(g_nsval[nn]) }
    if wk == NK_LAMBDA {
        // 중첩 람다: 내부 파라미터를 가린 채 본문 탐색
        svp = len(g_lfv_params)
        wi = 0
        while wi < g_nch_n[nn] {
            push(g_lfv_params, g_nsval[g_ch[g_nch_s[nn] + wi]])
            wi = wi + 1
        }
        lam_free_vars(g_nc0[nn])
        while len(g_lfv_params) > svp { pop(g_lfv_params) }
        return
    }
    lam_free_vars(g_nc0[nn])
    lam_free_vars(g_nc1[nn])
    lam_free_vars(g_nc2[nn])
    wi = 0
    while wi < g_nch_n[nn] { lam_free_vars(g_ch[g_nch_s[nn] + wi]); wi = wi + 1 }
}

// 캡처 인자 문자열 ", ty reg, ..." (argc는 앞에 오는 일반 인자 수)
fn lam_caps_str(lamid: i32, argc: i32) -> str {
    s = ""
    i = 0
    while i < g_lam_caps_n[lamid] {
        if argc + i > 0 { s = s + ", " }
        s = s + g_lam_cap_tys[g_lam_caps_s[lamid] + i] + " " + g_lam_cap_regs[g_lam_caps_s[lamid] + i]
        i = i + 1
    }
    return s
}

// 람다 값의 LLVM 함수 포인터 타입 문자열 (캡처 파라미터 포함)
fn lam_ty_str(lamid: i32) -> str {
    s = g_lam_rets[lamid] + " ("
    i = 0
    while i < g_lam_nps[lamid] {
        if i > 0 { s = s + ", " }
        s = s + g_lam_ptys[g_lam_ps[lamid] + i]
        i = i + 1
    }
    j = 0
    while j < g_lam_caps_n[lamid] {
        if g_lam_nps[lamid] > 0 or j > 0 { s = s + ", " }
        s = s + g_lam_cap_tys[g_lam_caps_s[lamid] + j]
        j = j + 1
    }
    return s + ")*"
}

// i64 슬롯 → 임의 LLVM 타입 디코드 (람다 파라미터 타입 기준)
fn slot_to_ll(sv: str, lty: str) -> str {
    if lty == "i64" { return sv }
    if lty == "double" {
        r = new_reg()
        emit("  " + r + " = bitcast i64 " + sv + " to double")
        return r
    }
    if lty == "float" {
        t32 = new_reg(); r = new_reg()
        emit("  " + t32 + " = trunc i64 " + sv + " to i32")
        emit("  " + r + " = bitcast i32 " + t32 + " to float")
        return r
    }
    r = new_reg()
    if len(lty) > 0 {
        if lty[len(lty) - 1] == "*" {
            emit("  " + r + " = inttoptr i64 " + sv + " to " + lty)
            return r
        }
    }
    emit("  " + r + " = trunc i64 " + sv + " to " + lty)
    return r
}

// 콜백 반환값을 i1 술어로 (i1이 아니면 != 0)
fn cb_pred(cr: str, cret: str) -> str {
    if cret == "i1" { return cr }
    p = new_reg()
    emit("  " + p + " = icmp ne " + cret + " " + cr + ", 0")
    return p
}

fn cg_truth_reg(v: str, ty: str) -> str {
    if ty == "i1" { return v }
    r = new_reg()
    if ty == "double" or ty == "float" {
        emit("  " + r + " = fcmp une " + ty + " " + v + ", 0.0")
    } else if len(ty) > 0 and ty[len(ty) - 1] == "*" {
        emit("  " + r + " = icmp ne " + ty + " " + v + ", null")
    } else {
        emit("  " + r + " = icmp ne " + ty + " " + v + ", 0")
    }
    return r
}

// 리스트 HOF: map/filter/count/any/all/for_each (콜백 1개)
fn cg_list_hof(mname: str, lst: str, src_el: str, lamid: i32) {
    lnr = new_reg()
    emit("  " + lnr + " = call i64 @dnh_len(%DnhList* " + lst + ")")
    hid = to_string(g_reg); g_reg = g_reg + 1
    idxr = "%__hof" + hid + "_i"
    emit_alloca("  " + idxr + " = alloca i64")
    emit("  store i64 0, i64* " + idxr)
    res = ""
    accr = ""
    if mname == "map" or mname == "filter" {
        res = new_reg()
        emit("  " + res + " = call %DnhList* @dnh_new_list()")
    }
    if mname == "count" {
        accr = "%__hof" + hid + "_c"
        emit_alloca("  " + accr + " = alloca i64")
        emit("  store i64 0, i64* " + accr)
    }
    if mname == "any" or mname == "all" {
        accr = "%__hof" + hid + "_b"
        emit_alloca("  " + accr + " = alloca i1")
        if mname == "any" { emit("  store i1 0, i1* " + accr) }
        else { emit("  store i1 1, i1* " + accr) }
    }
    lc = new_lbl(); lb = new_lbl(); le = new_lbl()
    emit("  br label %" + lc)
    emit(lc + ":")
    iv = new_reg(); emit("  " + iv + " = load i64, i64* " + idxr)
    cc = new_reg(); emit("  " + cc + " = icmp slt i64 " + iv + ", " + lnr)
    emit("  br i1 " + cc + ", label %" + lb + ", label %" + le)
    emit(lb + ":")
    sv = new_reg(); emit("  " + sv + " = call i64 @dnh_get(%DnhList* " + lst + ", i64 " + iv + ")")
    pt0 = "i64"
    if g_lam_nps[lamid] > 0 { pt0 = g_lam_ptys[g_lam_ps[lamid]] }
    ev = slot_to_ll(sv, pt0)
    castr = pt0 + " " + ev + lam_caps_str(lamid, 1)
    cret = g_lam_rets[lamid]
    cr = ""
    if cret == "void" or cret == "()" {
        emit("  call void @_lam" + to_string(lamid) + "(" + castr + ")")
        cret = "i64"; cr = "0"
    } else {
        cr = new_reg()
        emit("  " + cr + " = call " + cret + " @_lam" + to_string(lamid) + "(" + castr + ")")
    }
    linc = new_lbl()
    if mname == "map" {
        msv = val_to_slot(cr, cret)
        emit("  call void @dnh_push(%DnhList* " + res + ", i64 " + msv + ")")
        emit("  br label %" + linc)
    }
    if mname == "filter" {
        pr = cb_pred(cr, cret)
        lpush = new_lbl()
        emit("  br i1 " + pr + ", label %" + lpush + ", label %" + linc)
        emit(lpush + ":")
        emit("  call void @dnh_push(%DnhList* " + res + ", i64 " + sv + ")")
        emit("  br label %" + linc)
    }
    if mname == "count" {
        pr = cb_pred(cr, cret)
        cnt = new_reg(); emit("  " + cnt + " = load i64, i64* " + accr)
        pz = new_reg(); emit("  " + pz + " = zext i1 " + pr + " to i64")
        cnt2 = new_reg(); emit("  " + cnt2 + " = add i64 " + cnt + ", " + pz)
        emit("  store i64 " + cnt2 + ", i64* " + accr)
        emit("  br label %" + linc)
    }
    if mname == "any" {
        pr = cb_pred(cr, cret)
        lset = new_lbl()
        emit("  br i1 " + pr + ", label %" + lset + ", label %" + linc)
        emit(lset + ":")
        emit("  store i1 1, i1* " + accr)
        emit("  br label %" + le)
    }
    if mname == "all" {
        pr = cb_pred(cr, cret)
        lset = new_lbl()
        emit("  br i1 " + pr + ", label %" + linc + ", label %" + lset)
        emit(lset + ":")
        emit("  store i1 0, i1* " + accr)
        emit("  br label %" + le)
    }
    if mname == "for_each" {
        emit("  br label %" + linc)
    }
    emit(linc + ":")
    iv2 = new_reg(); emit("  " + iv2 + " = load i64, i64* " + idxr)
    ni = new_reg(); emit("  " + ni + " = add i64 " + iv2 + ", 1")
    emit("  store i64 " + ni + ", i64* " + idxr)
    emit("  br label %" + lc)
    emit(le + ":")
    g_expr_lam = -1
    if mname == "map" {
        g_expr_reg = res; g_expr_ty = "%DnhList*"
        g_expr_elem = ""
        if cret == "i8*" { g_expr_elem = "str" }
        if cret == "double" { g_expr_elem = "f64" }
        return
    }
    if mname == "filter" {
        g_expr_reg = res; g_expr_ty = "%DnhList*"; g_expr_elem = src_el
        return
    }
    if mname == "count" {
        r = new_reg(); emit("  " + r + " = load i64, i64* " + accr)
        g_expr_reg = r; g_expr_ty = "i64"; return
    }
    if mname == "any" or mname == "all" {
        r = new_reg(); emit("  " + r + " = load i1, i1* " + accr)
        g_expr_reg = r; g_expr_ty = "i1"; return
    }
    g_expr_reg = "0"; g_expr_ty = "void"
}

// 리스트 reduce(init, cb): acc 타입은 콜백 첫 파라미터를 따른다
fn cg_list_reduce(lst: str, lamid: i32, init: str, init_ty: str) {
    aty = "i64"
    if g_lam_nps[lamid] > 0 { aty = g_lam_ptys[g_lam_ps[lamid]] }
    ety = "i64"
    if g_lam_nps[lamid] > 1 { ety = g_lam_ptys[g_lam_ps[lamid] + 1] }
    iv0 = init
    if init_ty != aty { iv0 = coerce_to(init, init_ty, aty) }
    hid = to_string(g_reg); g_reg = g_reg + 1
    accr = "%__red" + hid + "_a"
    idxr = "%__red" + hid + "_i"
    emit_alloca("  " + accr + " = alloca " + aty)
    emit_alloca("  " + idxr + " = alloca i64")
    emit("  store " + aty + " " + iv0 + ", " + aty + "* " + accr)
    emit("  store i64 0, i64* " + idxr)
    lnr = new_reg()
    emit("  " + lnr + " = call i64 @dnh_len(%DnhList* " + lst + ")")
    lc = new_lbl(); lb = new_lbl(); le = new_lbl()
    emit("  br label %" + lc)
    emit(lc + ":")
    iv = new_reg(); emit("  " + iv + " = load i64, i64* " + idxr)
    cc = new_reg(); emit("  " + cc + " = icmp slt i64 " + iv + ", " + lnr)
    emit("  br i1 " + cc + ", label %" + lb + ", label %" + le)
    emit(lb + ":")
    av = new_reg(); emit("  " + av + " = load " + aty + ", " + aty + "* " + accr)
    sv = new_reg(); emit("  " + sv + " = call i64 @dnh_get(%DnhList* " + lst + ", i64 " + iv + ")")
    ev = slot_to_ll(sv, ety)
    castr = aty + " " + av + ", " + ety + " " + ev + lam_caps_str(lamid, 2)
    cret = g_lam_rets[lamid]
    cr = new_reg()
    emit("  " + cr + " = call " + cret + " @_lam" + to_string(lamid) + "(" + castr + ")")
    crv = cr
    if cret != aty { crv = coerce_to(cr, cret, aty) }
    emit("  store " + aty + " " + crv + ", " + aty + "* " + accr)
    iv2 = new_reg(); emit("  " + iv2 + " = load i64, i64* " + idxr)
    ni = new_reg(); emit("  " + ni + " = add i64 " + iv2 + ", 1")
    emit("  store i64 " + ni + ", i64* " + idxr)
    emit("  br label %" + lc)
    emit(le + ":")
    r = new_reg(); emit("  " + r + " = load " + aty + ", " + aty + "* " + accr)
    g_expr_reg = r; g_expr_ty = aty
    g_expr_lam = -1
}

// 스칼라 → 벡터 splat (insertelement 체인)
fn vec_splat(sr: str, sty: str, vty: str) -> str {
    sv = sr
    if sty != "double" { sv = coerce_to(sr, sty, "double") }
    vn = vec_ty_n(vty)
    cur = "undef"
    i = 0
    while i < vn {
        nr = new_reg()
        emit("  " + nr + " = insertelement " + vty + " " + cur + ", double " + sv + ", i32 " + to_string(i))
        cur = nr
        i = i + 1
    }
    return cur
}

// i64 슬롯 → 원소 dh 타입(elem 메타) 기준 디코드 — 인덱싱 결과와 동일 규약
fn list_slot_decode(sv: str, el: str) {
    if el == "str" {
        p = new_reg()
        emit("  " + p + " = inttoptr i64 " + sv + " to i8*")
        g_expr_reg = p; g_expr_ty = "i8*"; return
    }
    if el == "f64" {
        d = new_reg()
        emit("  " + d + " = bitcast i64 " + sv + " to double")
        g_expr_reg = d; g_expr_ty = "double"; return
    }
    g_expr_reg = sv; g_expr_ty = "i64"
}

// arr.find(cb) — 첫 매칭 원소 또는 0 (py _dynarr_find와 동일)
fn cg_list_find(lst: str, src_el: str, lamid: i32) {
    hid = to_string(g_reg); g_reg = g_reg + 1
    resr = "%__find" + hid + "_r"
    idxr = "%__find" + hid + "_i"
    emit_alloca("  " + resr + " = alloca i64")
    emit_alloca("  " + idxr + " = alloca i64")
    emit("  store i64 0, i64* " + resr)
    emit("  store i64 0, i64* " + idxr)
    lnr = new_reg()
    emit("  " + lnr + " = call i64 @dnh_len(%DnhList* " + lst + ")")
    lc = new_lbl(); lb = new_lbl(); lfound = new_lbl(); linc = new_lbl(); le = new_lbl()
    emit("  br label %" + lc)
    emit(lc + ":")
    iv = new_reg(); emit("  " + iv + " = load i64, i64* " + idxr)
    cc = new_reg(); emit("  " + cc + " = icmp slt i64 " + iv + ", " + lnr)
    emit("  br i1 " + cc + ", label %" + lb + ", label %" + le)
    emit(lb + ":")
    sv = new_reg(); emit("  " + sv + " = call i64 @dnh_get(%DnhList* " + lst + ", i64 " + iv + ")")
    pt0 = "i64"
    if g_lam_nps[lamid] > 0 { pt0 = g_lam_ptys[g_lam_ps[lamid]] }
    ev = slot_to_ll(sv, pt0)
    cret = g_lam_rets[lamid]
    cr = new_reg()
    emit("  " + cr + " = call " + cret + " @_lam" + to_string(lamid) + "(" + pt0 + " " + ev + lam_caps_str(lamid, 1) + ")")
    pr = cb_pred(cr, cret)
    emit("  br i1 " + pr + ", label %" + lfound + ", label %" + linc)
    emit(lfound + ":")
    emit("  store i64 " + sv + ", i64* " + resr)
    emit("  br label %" + le)
    emit(linc + ":")
    ni = new_reg(); emit("  " + ni + " = add i64 " + iv + ", 1")
    emit("  store i64 " + ni + ", i64* " + idxr)
    emit("  br label %" + lc)
    emit(le + ":")
    rv = new_reg(); emit("  " + rv + " = load i64, i64* " + resr)
    g_expr_lam = -1
    list_slot_decode(rv, src_el)
}

// arr.contains(v) — eq 비교 (int: 슬롯 icmp, f64: fcmp oeq, str: strcmp)
fn cg_list_contains(lst: str, src_el: str, tgt_r: str, tgt_ty: str) {
    hid = to_string(g_reg); g_reg = g_reg + 1
    resr = "%__cont" + hid + "_r"
    idxr = "%__cont" + hid + "_i"
    emit_alloca("  " + resr + " = alloca i1")
    emit_alloca("  " + idxr + " = alloca i64")
    emit("  store i1 0, i1* " + resr)
    emit("  store i64 0, i64* " + idxr)
    lnr = new_reg()
    emit("  " + lnr + " = call i64 @dnh_len(%DnhList* " + lst + ")")
    lc = new_lbl(); lb = new_lbl(); lfound = new_lbl(); linc = new_lbl(); le = new_lbl()
    emit("  br label %" + lc)
    emit(lc + ":")
    iv = new_reg(); emit("  " + iv + " = load i64, i64* " + idxr)
    cc = new_reg(); emit("  " + cc + " = icmp slt i64 " + iv + ", " + lnr)
    emit("  br i1 " + cc + ", label %" + lb + ", label %" + le)
    emit(lb + ":")
    sv = new_reg(); emit("  " + sv + " = call i64 @dnh_get(%DnhList* " + lst + ", i64 " + iv + ")")
    eq = new_reg()
    if src_el == "str" or tgt_ty == "i8*" {
        sp = new_reg()
        emit("  " + sp + " = inttoptr i64 " + sv + " to i8*")
        sc = new_reg()
        emit("  " + sc + " = call i32 @strcmp(i8* " + sp + ", i8* " + tgt_r + ")")
        emit("  " + eq + " = icmp eq i32 " + sc + ", 0")
    } else if src_el == "f64" or tgt_ty == "double" {
        dv = new_reg()
        emit("  " + dv + " = bitcast i64 " + sv + " to double")
        tv = tgt_r
        if tgt_ty != "double" { tv = coerce_to(tgt_r, tgt_ty, "double") }
        emit("  " + eq + " = fcmp oeq double " + dv + ", " + tv)
    } else {
        tv = tgt_r
        if tgt_ty != "i64" { tv = coerce_to(tgt_r, tgt_ty, "i64") }
        emit("  " + eq + " = icmp eq i64 " + sv + ", " + tv)
    }
    emit("  br i1 " + eq + ", label %" + lfound + ", label %" + linc)
    emit(lfound + ":")
    emit("  store i1 1, i1* " + resr)
    emit("  br label %" + le)
    emit(linc + ":")
    ni = new_reg(); emit("  " + ni + " = add i64 " + iv + ", 1")
    emit("  store i64 " + ni + ", i64* " + idxr)
    emit("  br label %" + lc)
    emit(le + ":")
    rv = new_reg(); emit("  " + rv + " = load i1, i1* " + resr)
    g_expr_reg = rv; g_expr_ty = "i1"; g_expr_lam = -1
}

// arr.reverse() — 새 리스트 (역순)
fn cg_list_reverse(lst: str, src_el: str) {
    res = new_reg()
    emit("  " + res + " = call %DnhList* @dnh_new_list()")
    hid = to_string(g_reg); g_reg = g_reg + 1
    idxr = "%__rev" + hid + "_i"
    emit_alloca("  " + idxr + " = alloca i64")
    lnr = new_reg()
    emit("  " + lnr + " = call i64 @dnh_len(%DnhList* " + lst + ")")
    st = new_reg()
    emit("  " + st + " = sub i64 " + lnr + ", 1")
    emit("  store i64 " + st + ", i64* " + idxr)
    lc = new_lbl(); lb = new_lbl(); le = new_lbl()
    emit("  br label %" + lc)
    emit(lc + ":")
    iv = new_reg(); emit("  " + iv + " = load i64, i64* " + idxr)
    cc = new_reg(); emit("  " + cc + " = icmp sge i64 " + iv + ", 0")
    emit("  br i1 " + cc + ", label %" + lb + ", label %" + le)
    emit(lb + ":")
    sv = new_reg(); emit("  " + sv + " = call i64 @dnh_get(%DnhList* " + lst + ", i64 " + iv + ")")
    emit("  call void @dnh_push(%DnhList* " + res + ", i64 " + sv + ")")
    ni = new_reg(); emit("  " + ni + " = sub i64 " + iv + ", 1")
    emit("  store i64 " + ni + ", i64* " + idxr)
    emit("  br label %" + lc)
    emit(le + ":")
    g_expr_reg = res; g_expr_ty = "%DnhList*"; g_expr_elem = src_el; g_expr_lam = -1
}

// arr.take(n) / arr.skip(n) — 새 리스트
fn cg_list_take_skip(mname: str, lst: str, src_el: str, nv: str) {
    res = new_reg()
    emit("  " + res + " = call %DnhList* @dnh_new_list()")
    hid = to_string(g_reg); g_reg = g_reg + 1
    idxr = "%__ts" + hid + "_i"
    emit_alloca("  " + idxr + " = alloca i64")
    lnr = new_reg()
    emit("  " + lnr + " = call i64 @dnh_len(%DnhList* " + lst + ")")
    endv = lnr
    if mname == "take" {
        emit("  store i64 0, i64* " + idxr)
        // end = min(n, len)
        c0 = new_reg(); emit("  " + c0 + " = icmp slt i64 " + nv + ", " + lnr)
        m0 = new_reg(); emit("  " + m0 + " = select i1 " + c0 + ", i64 " + nv + ", i64 " + lnr)
        endv = m0
    } else {
        emit("  store i64 " + nv + ", i64* " + idxr)
    }
    lc = new_lbl(); lb = new_lbl(); le = new_lbl()
    emit("  br label %" + lc)
    emit(lc + ":")
    iv = new_reg(); emit("  " + iv + " = load i64, i64* " + idxr)
    cc = new_reg(); emit("  " + cc + " = icmp slt i64 " + iv + ", " + endv)
    emit("  br i1 " + cc + ", label %" + lb + ", label %" + le)
    emit(lb + ":")
    sv = new_reg(); emit("  " + sv + " = call i64 @dnh_get(%DnhList* " + lst + ", i64 " + iv + ")")
    emit("  call void @dnh_push(%DnhList* " + res + ", i64 " + sv + ")")
    ni = new_reg(); emit("  " + ni + " = add i64 " + iv + ", 1")
    emit("  store i64 " + ni + ", i64* " + idxr)
    emit("  br label %" + lc)
    emit(le + ":")
    g_expr_reg = res; g_expr_ty = "%DnhList*"; g_expr_elem = src_el; g_expr_lam = -1
}

// arr.sort_by(cb) — 새 리스트 (삽입 정렬, cmp(a,b) > 0 이면 시프트)
fn cg_list_sort_by(lst: str, src_el: str, lamid: i32) {
    res = new_reg()
    emit("  " + res + " = call %DnhList* @dnh_new_list()")
    hid = to_string(g_reg); g_reg = g_reg + 1
    cir = "%__srt" + hid + "_c"
    oir = "%__srt" + hid + "_o"
    jir = "%__srt" + hid + "_j"
    emit_alloca("  " + cir + " = alloca i64")
    emit_alloca("  " + oir + " = alloca i64")
    emit_alloca("  " + jir + " = alloca i64")
    lnr = new_reg()
    emit("  " + lnr + " = call i64 @dnh_len(%DnhList* " + lst + ")")
    // 원본 복사
    emit("  store i64 0, i64* " + cir)
    cc0 = new_lbl(); cb0 = new_lbl(); ce0 = new_lbl()
    emit("  br label %" + cc0)
    emit(cc0 + ":")
    civ = new_reg(); emit("  " + civ + " = load i64, i64* " + cir)
    ccc = new_reg(); emit("  " + ccc + " = icmp slt i64 " + civ + ", " + lnr)
    emit("  br i1 " + ccc + ", label %" + cb0 + ", label %" + ce0)
    emit(cb0 + ":")
    csv = new_reg(); emit("  " + csv + " = call i64 @dnh_get(%DnhList* " + lst + ", i64 " + civ + ")")
    emit("  call void @dnh_push(%DnhList* " + res + ", i64 " + csv + ")")
    cni = new_reg(); emit("  " + cni + " = add i64 " + civ + ", 1")
    emit("  store i64 " + cni + ", i64* " + cir)
    emit("  br label %" + cc0)
    emit(ce0 + ":")
    // 삽입 정렬
    pt0 = "i64"; pt1 = "i64"
    if g_lam_nps[lamid] > 0 { pt0 = g_lam_ptys[g_lam_ps[lamid]] }
    if g_lam_nps[lamid] > 1 { pt1 = g_lam_ptys[g_lam_ps[lamid] + 1] }
    cret = g_lam_rets[lamid]
    emit("  store i64 1, i64* " + oir)
    oc = new_lbl(); ob = new_lbl(); ic = new_lbl(); ichk = new_lbl(); ib = new_lbl(); ie = new_lbl(); oe = new_lbl()
    emit("  br label %" + oc)
    emit(oc + ":")
    oiv = new_reg(); emit("  " + oiv + " = load i64, i64* " + oir)
    occ = new_reg(); emit("  " + occ + " = icmp slt i64 " + oiv + ", " + lnr)
    emit("  br i1 " + occ + ", label %" + ob + ", label %" + oe)
    emit(ob + ":")
    keyv = new_reg(); emit("  " + keyv + " = call i64 @dnh_get(%DnhList* " + res + ", i64 " + oiv + ")")
    j0 = new_reg(); emit("  " + j0 + " = sub i64 " + oiv + ", 1")
    emit("  store i64 " + j0 + ", i64* " + jir)
    emit("  br label %" + ic)
    emit(ic + ":")
    jv = new_reg(); emit("  " + jv + " = load i64, i64* " + jir)
    jge = new_reg(); emit("  " + jge + " = icmp sge i64 " + jv + ", 0")
    emit("  br i1 " + jge + ", label %" + ichk + ", label %" + ie)
    emit(ichk + ":")
    ajv = new_reg(); emit("  " + ajv + " = call i64 @dnh_get(%DnhList* " + res + ", i64 " + jv + ")")
    a0 = slot_to_ll(ajv, pt0)
    a1 = slot_to_ll(keyv, pt1)
    cr = new_reg()
    emit("  " + cr + " = call " + cret + " @_lam" + to_string(lamid) + "(" + pt0 + " " + a0 + ", " + pt1 + " " + a1 + lam_caps_str(lamid, 2) + ")")
    shp = new_reg()
    if cret == "double" or cret == "float" {
        emit("  " + shp + " = fcmp ogt " + cret + " " + cr + ", 0.0")
    } else {
        emit("  " + shp + " = icmp sgt " + cret + " " + cr + ", 0")
    }
    emit("  br i1 " + shp + ", label %" + ib + ", label %" + ie)
    emit(ib + ":")
    j1 = new_reg(); emit("  " + j1 + " = add i64 " + jv + ", 1")
    emit("  call void @dnh_set(%DnhList* " + res + ", i64 " + j1 + ", i64 " + ajv + ")")
    j2 = new_reg(); emit("  " + j2 + " = sub i64 " + jv + ", 1")
    emit("  store i64 " + j2 + ", i64* " + jir)
    emit("  br label %" + ic)
    emit(ie + ":")
    jv2 = new_reg(); emit("  " + jv2 + " = load i64, i64* " + jir)
    insi = new_reg(); emit("  " + insi + " = add i64 " + jv2 + ", 1")
    emit("  call void @dnh_set(%DnhList* " + res + ", i64 " + insi + ", i64 " + keyv + ")")
    oni = new_reg(); emit("  " + oni + " = add i64 " + oiv + ", 1")
    emit("  store i64 " + oni + ", i64* " + oir)
    emit("  br label %" + oc)
    emit(oe + ":")
    g_expr_reg = res; g_expr_ty = "%DnhList*"; g_expr_elem = src_el; g_expr_lam = -1
}

// 트레잇 객체 메서드 호출: vtable 간접 호출 (self는 i8* 데이터 포인터)
fn cg_dyn_method(n: i32, tname: str, obj_r: str, mname: str) {
    midx = -1
    tmpl = -1
    cnt = 0
    i = 0
    while i < len(g_trm_trait) {
        if g_trm_trait[i] == tname {
            if g_trm_name[i] == mname { midx = cnt; tmpl = g_trm_fn[i] }
            cnt = cnt + 1
        }
        i = i + 1
    }
    if midx == -1 {
        fatal("트레잇 " + tname + "에 메서드 " + mname + "가 없어 (줄 " + to_string(g_nline[n]) + ")")
    }
    rn = g_nc1[tmpl]
    rdh = ""
    if rn > 0 { rdh = g_ntype[rn] }
    mret = ll_ty(rdh)
    fty = mret + " (i8*"
    pi = 1
    while pi < g_nch_n[tmpl] {
        fty = fty + ", " + ll_ty(g_ntype[g_ch[g_nch_s[tmpl] + pi]])
        pi = pi + 1
    }
    fty = fty + ")"
    dpp = new_reg()
    emit("  " + dpp + " = getelementptr inbounds %dyn." + tname + ", %dyn." + tname + "* " + obj_r + ", i32 0, i32 0")
    dpv = new_reg()
    emit("  " + dpv + " = load i8*, i8** " + dpp)
    vpp = new_reg()
    emit("  " + vpp + " = getelementptr inbounds %dyn." + tname + ", %dyn." + tname + "* " + obj_r + ", i32 0, i32 1")
    vpv = new_reg()
    emit("  " + vpv + " = load i8*, i8** " + vpp)
    nm = trait_method_count(tname)
    vta = new_reg()
    emit("  " + vta + " = bitcast i8* " + vpv + " to [" + to_string(nm) + " x i8*]*")
    fpp = new_reg()
    emit("  " + fpp + " = getelementptr inbounds [" + to_string(nm) + " x i8*], [" + to_string(nm) + " x i8*]* " + vta + ", i32 0, i32 " + to_string(midx))
    fp8 = new_reg()
    emit("  " + fp8 + " = load i8*, i8** " + fpp)
    fp = new_reg()
    emit("  " + fp + " = bitcast i8* " + fp8 + " to " + fty + "*")
    astr = "i8* " + dpv
    ai = 0
    while ai < g_nch_n[n] {
        cg_expr(g_ch[g_nch_s[n] + ai])
        av = g_expr_reg; at = g_expr_ty
        if ai + 1 < g_nch_n[tmpl] {
            want = ll_ty(g_ntype[g_ch[g_nch_s[tmpl] + 1 + ai]])
            if at != want { av = coerce_to(av, at, want); at = want }
        }
        astr = astr + ", " + at + " " + av
        ai = ai + 1
    }
    g_expr_lam = -1
    if mret == "void" or mret == "()" {
        emit("  call void " + fp + "(" + astr + ")")
        g_expr_reg = "0"; g_expr_ty = "void"
        return
    }
    r = new_reg()
    emit("  " + r + " = call " + mret + " " + fp + "(" + astr + ")")
    g_expr_reg = r; g_expr_ty = mret
}

// 모듈 네임스페이스 호출: utils.f(...) → @f(...) (정의는 병합돼 있음)
fn cg_mod_call(n: i32) {
    fname = g_nsval[n]
    nargs = g_nch_n[n]
    arg_rs: [str] = []
    arg_ts: [str] = []
    i = 0
    while i < nargs {
        cg_expr(g_ch[g_nch_s[n] + i])
        push(arg_rs, g_expr_reg); push(arg_ts, g_expr_ty)
        i = i + 1
    }
    ret_ty = "i64"
    fi = find_fn(fname)
    if fi != -1 { ret_ty = g_fn_rets[fi] }
    astr = ""
    i = 0
    while i < nargs {
        av = arg_rs[i]; at = arg_ts[i]
        if fi != -1 and i < g_fn_arities[fi] {
            want = g_fn_ptys[g_fn_ps[fi] + i]
            if want != at and want != "" {
                av = coerce_to(av, at, want); at = want
            }
        }
        if i > 0 { astr = astr + ", " }
        astr = astr + at + " " + av
        i = i + 1
    }
    g_expr_lam = -1
    if ret_ty == "void" or ret_ty == "()" {
        emit("  call void @" + fname + "(" + astr + ")")
        g_expr_reg = ""; g_expr_ty = "void"
        return
    }
    r = new_reg()
    emit("  " + r + " = call " + ret_ty + " @" + fname + "(" + astr + ")")
    g_expr_reg = r; g_expr_ty = ret_ty
}

fn cg_expr(n) {
    g_expr_elem = ""
    g_expr_lam = -1
    if n < 0 or n >= g_node_count {
        g_expr_reg = "0"; g_expr_ty = "i64"; return
    }
    k = g_nkind[n]

    if k == NK_INT {
        g_expr_reg = to_string(g_nival[n]); g_expr_ty = "i64"; return
    }
    if k == NK_FLOAT {
        if g_nsval[n] != "" { g_expr_reg = g_nsval[n] }
        else { g_expr_reg = to_string(g_nfval[n]) }
        g_expr_ty = "double"; return
    }
    if k == NK_BOOL {
        if g_nival[n] == 1 { g_expr_reg = "1" } else { g_expr_reg = "0" }
        g_expr_ty = "i1"; return
    }
    if k == NK_NULL {
        g_expr_reg = "null"; g_expr_ty = "i8*"; return
    }
    if k == NK_STR {
        idx = add_strlit(g_nsval[n])
        g_expr_reg = strlit_gep(idx); g_expr_ty = "i8*"; return
    }
    if k == NK_ISTR {
        cg_istr(g_nsval[n])
        return
    }
    // expr? — Err이면 현재 함수에서 즉시 반환, Ok면 payload 언랩
    if k == NK_TRY {
        cg_expr(g_nc0[n]); ev = g_expr_reg
        okv = find_variant_any("Ok")
        errv = find_variant_any("Err")
        if okv == -1 or errv == -1 {
            fatal("? 연산자: Ok/Err variant가 정의된 enum이 필요해 (줄 " + to_string(g_nline[n]) + ")")
        }
        tp = new_reg()
        emit("  " + tp + " = getelementptr inbounds %DnhEnum, %DnhEnum* " + ev + ", i32 0, i32 0")
        tg = new_reg()
        emit("  " + tg + " = load i64, i64* " + tp)
        lerr = new_lbl(); lok = new_lbl()
        c2 = new_reg()
        emit("  " + c2 + " = icmp eq i64 " + tg + ", " + to_string(g_vrt_tag[errv]))
        emit("  br i1 " + c2 + ", label %" + lerr + ", label %" + lok)
        emit(lerr + ":")
        emit("  ret " + g_cur_fn_ret + " " + ev)
        emit(lok + ":")
        pp = new_reg()
        emit("  " + pp + " = getelementptr inbounds %DnhEnum, %DnhEnum* " + ev + ", i32 0, i32 1")
        pl = new_reg()
        emit("  " + pl + " = load i64, i64* " + pp)
        opty = g_vrt_pty[okv]
        g_expr_reg = slot_to_ty(pl, opty)
        g_expr_ty = ll_ty(opty)
        return
    }
    // comptime { expr } — 상수식 평가 후 리터럴로 임베드
    if k == NK_COMPTIME {
        ct_eval(g_nc0[n])
        if not g_ct_ok {
            fatal("comptime 서브셋: 숫자 상수식(리터럴/const/산술)만 지원해 (줄 " + to_string(g_nline[n]) + ") — danha.py compile을 사용해줘")
        }
        if g_ct_isf { g_expr_reg = to_string(g_ct_f); g_expr_ty = "double" }
        else { g_expr_reg = to_string(g_ct_i); g_expr_ty = "i64" }
        return
    }

    // name!(args) — 매크로 인라인 확장: 인자를 로컬로 바인딩하고 본문을 현재 위치에 컴파일
    if k == NK_MACRO_CALL {
        mci2 = macro_find(g_nsval[n])
        if mci2 == -1 {
            fatal("정의되지 않은 매크로야: " + g_nsval[n] + "! (줄 " + to_string(g_nline[n]) + ")")
        }
        mnode = g_macro_nodes[mci2]
        mvar = g_macro_variadic[mci2]
        mfixed = g_nch_n[mnode]
        if mvar == 1 { mfixed = mfixed - 1 }
        if (mvar == 0 and g_nch_n[n] != g_nch_n[mnode]) or (mvar == 1 and g_nch_n[n] < mfixed) {
            fatal("매크로 '" + g_nsval[n] + "!'은(는) 인자 " + to_string(g_nch_n[mnode]) + "개가 필요한데 " + to_string(g_nch_n[n]) + "개가 들어왔어 (줄 " + to_string(g_nline[n]) + ")")
        }
        sv_mvlen = len(g_var_names)
        mi2 = 0
        while mi2 < mfixed {
            cg_expr(g_ch[g_nch_s[n] + mi2]); mav = g_expr_reg; mat = g_expr_ty
            mp2 = g_ch[g_nch_s[mnode] + mi2]
            mpreg = "%__mac" + to_string(g_reg) + "_v"; g_reg = g_reg + 1
            emit_alloca("  " + mpreg + " = alloca " + mat)
            emit("  store " + mat + " " + mav + ", " + mat + "* " + mpreg)
            decl_var(g_nsval[mp2], mpreg, mat)
            mi2 = mi2 + 1
        }
        if mvar == 1 {
            restn = g_nch_n[n] - mfixed
            elem_ty = "i64"
            vals_r: [str] = []
            vals_t: [str] = []
            ri = 0
            while ri < restn {
                cg_expr(g_ch[g_nch_s[n] + mfixed + ri])
                if ri == 0 { elem_ty = g_expr_ty }
                push(vals_r, g_expr_reg)
                push(vals_t, g_expr_ty)
                ri = ri + 1
            }
            arr_ty = "[" + to_string(restn) + " x " + elem_ty + "]"
            arr_reg = "%__mac" + to_string(g_reg) + "_rest"; g_reg = g_reg + 1
            emit_alloca("  " + arr_reg + " = alloca " + arr_ty)
            ri = 0
            while ri < restn {
                vr = vals_r[ri]; vt = vals_t[ri]
                if vt != elem_ty { vr = coerce_to(vr, vt, elem_ty) }
                gep = new_reg()
                emit("  " + gep + " = getelementptr inbounds " + arr_ty + ", " + arr_ty + "* " + arr_reg + ", i64 0, i64 " + to_string(ri))
                emit("  store " + elem_ty + " " + vr + ", " + elem_ty + "* " + gep)
                ri = ri + 1
            }
            vparam = g_ch[g_nch_s[mnode] + mfixed]
            decl_var(g_nsval[vparam], arr_reg, arr_ty)
        }
        mbody = g_nc0[mnode]
        g_expr_reg = "0"; g_expr_ty = "i64"
        mi2 = 0
        while mi2 < g_nch_n[mbody] {
            cg_stmt(g_ch[g_nch_s[mbody] + mi2])
            mi2 = mi2 + 1
        }
        while len(g_var_names) > sv_mvlen {
            pop(g_var_names); pop(g_var_regs); pop(g_var_tys); pop(g_var_elems); pop(g_var_lams)
        }
        g_expr_lam = -1
        return
    }

    // @sin(x) 등 수학 내장 함수 — 정수 abs/min/max는 select, 나머지는 double 호출
    if k == NK_MATH {
        mn = g_nsval[n]
        cg_expr(g_ch[g_nch_s[n]]); a0r = g_expr_reg; a0t = g_expr_ty
        a1r = ""; a1t = ""
        if g_nch_n[n] == 2 {
            cg_expr(g_ch[g_nch_s[n] + 1]); a1r = g_expr_reg; a1t = g_expr_ty
        }
        if mn == "abs" and is_int_ty(a0t) {
            av = sext32(a0r, a0t)
            ng = new_reg(); emit("  " + ng + " = sub i64 0, " + av)
            ac = new_reg(); emit("  " + ac + " = icmp slt i64 " + av + ", 0")
            r = new_reg(); emit("  " + r + " = select i1 " + ac + ", i64 " + ng + ", i64 " + av)
            g_expr_reg = r; g_expr_ty = "i64"; return
        }
        if (mn == "min" or mn == "max") and is_int_ty(a0t) and is_int_ty(a1t) {
            ml = sext32(a0r, a0t); mr = sext32(a1r, a1t)
            cmpo = "slt"; if mn == "max" { cmpo = "sgt" }
            mc = new_reg(); emit("  " + mc + " = icmp " + cmpo + " i64 " + ml + ", " + mr)
            r = new_reg(); emit("  " + r + " = select i1 " + mc + ", i64 " + ml + ", i64 " + mr)
            g_expr_reg = r; g_expr_ty = "i64"; return
        }
        // 실수 경로 — 인자 double 코어션
        if a0t != "double" {
            d0 = new_reg()
            if a0t == "float" { emit("  " + d0 + " = fpext float " + a0r + " to double") }
            else { emit("  " + d0 + " = sitofp " + a0t + " " + a0r + " to double") }
            a0r = d0
        }
        if g_nch_n[n] == 2 and a1t != "double" {
            d1 = new_reg()
            if a1t == "float" { emit("  " + d1 + " = fpext float " + a1r + " to double") }
            else { emit("  " + d1 + " = sitofp " + a1t + " " + a1r + " to double") }
            a1r = d1
        }
        if mn == "min" or mn == "max" {
            fo = "olt"; if mn == "max" { fo = "ogt" }
            fc = new_reg(); emit("  " + fc + " = fcmp " + fo + " double " + a0r + ", " + a1r)
            r = new_reg(); emit("  " + r + " = select i1 " + fc + ", double " + a0r + ", double " + a1r)
            g_expr_reg = r; g_expr_ty = "double"; return
        }
        callee = mn
        if mn == "sqrt"  { callee = "llvm.sqrt.f64" }
        if mn == "abs"   { callee = "llvm.fabs.f64" }
        if mn == "floor" { callee = "llvm.floor.f64" }
        if mn == "ceil"  { callee = "llvm.ceil.f64" }
        if mn == "round" { callee = "llvm.round.f64" }
        r = new_reg()
        if g_nch_n[n] == 2 {
            emit("  " + r + " = call double @" + callee + "(double " + a0r + ", double " + a1r + ")")
        } else {
            emit("  " + r + " = call double @" + callee + "(double " + a0r + ")")
        }
        g_expr_reg = r; g_expr_ty = "double"; return
    }

    if k == NK_ID {
        name = g_nsval[n]
        vi = find_var(name)
        if vi == -1 { g_expr_reg = "0"; g_expr_ty = "i64"; return }
        // 고정 배열 변수 — 값 로드 대신 슬롯 포인터 (인덱싱/통째 복사용)
        if is_arr_val(g_var_tys[vi]) {
            g_expr_reg = g_var_regs[vi]
            g_expr_ty = g_var_tys[vi] + "*"
            g_expr_elem = g_var_elems[vi]
            g_expr_lam = -1
            return
        }
        g_expr_reg = load_val(g_var_regs[vi], g_var_tys[vi])
        g_expr_ty  = g_var_tys[vi]
        g_expr_elem = g_var_elems[vi]
        g_expr_lam = g_var_lams[vi]
        return
    }

    // 이항 산술
    if k == NK_ADD or k == NK_SUB or k == NK_MUL or k == NK_DIV or k == NK_MOD {
        cg_expr(g_nc0[n]); lr = g_expr_reg; lty = g_expr_ty
        cg_expr(g_nc1[n]); rr = g_expr_reg; rty = g_expr_ty
        if lty == "i32" and rty == "i64" { lr = sext32(lr, lty); lty = "i64" }
        if lty == "i64" and rty == "i32" { rr = sext32(rr, rty) }
        // double vs int 산술 — int 쪽을 승격 (py Q3 의미론; h.hp - 1 같은 f64필드-정수리터럴)
        if (lty == "double" or lty == "float") and is_int_ty(rty) {
            rr = coerce_to(rr, rty, lty); rty = lty
        }
        if (rty == "double" or rty == "float") and is_int_ty(lty) {
            lr = coerce_to(lr, lty, rty); lty = rty
        }
        // mat4 곱: m*m / m*v
        if is_mat_ty(lty) or is_mat_ty(rty) {
            if k != NK_MUL {
                fatal("mat4는 * 연산만 지원해 (줄 " + to_string(g_nline[n]) + ")")
            }
            if is_mat_ty(lty) and is_vec_ty(rty) {
                r = new_reg()
                emit("  " + r + " = call <4 x double> @dnh_m4_vec(" + m4ty() + " " + lr + ", <4 x double> " + rr + ")")
                g_expr_reg = r; g_expr_ty = "<4 x double>"; return
            }
            if is_mat_ty(lty) and is_mat_ty(rty) {
                r = new_reg()
                emit("  " + r + " = call " + m4ty() + " @dnh_m4_mul(" + m4ty() + " " + lr + ", " + m4ty() + " " + rr + ")")
                g_expr_reg = r; g_expr_ty = m4ty(); return
            }
            fatal("mat4 곱의 피연산자 조합이 잘못됐어 (mat4*mat4 또는 mat4*vec4) (줄 " + to_string(g_nline[n]) + ")")
        }
        // 벡터 산술 — 원소별 연산, 스칼라는 splat
        if is_vec_ty(lty) or is_vec_ty(rty) {
            if k == NK_MOD { fatal("벡터에 %는 쓸 수 없어 (줄 " + to_string(g_nline[n]) + ")") }
            vvty = lty
            if not is_vec_ty(vvty) { vvty = rty }
            if not is_vec_ty(lty) { lr = vec_splat(lr, lty, vvty) }
            if not is_vec_ty(rty) { rr = vec_splat(rr, rty, vvty) }
            r = new_reg()
            if k == NK_ADD { emit("  " + r + " = fadd reassoc nsz contract " + vvty + " " + lr + ", " + rr) }
            else if k == NK_SUB { emit("  " + r + " = fsub reassoc nsz contract " + vvty + " " + lr + ", " + rr) }
            else if k == NK_MUL { emit("  " + r + " = fmul reassoc nsz contract " + vvty + " " + lr + ", " + rr) }
            else { emit("  " + r + " = fdiv reassoc nsz contract arcp " + vvty + " " + lr + ", " + rr) }
            g_expr_reg = r; g_expr_ty = vvty; return
        }
        r = new_reg()
        flt = lty == "double" or lty == "float"
        if k == NK_ADD {
            if lty == "i8*" {
                emit("  " + r + " = call i8* @dnh_str_cat(i8* " + lr + ", i8* " + rr + ")")
                g_expr_reg = r; g_expr_ty = "i8*"; return
            }
            if flt { emit("  " + r + " = fadd reassoc nsz contract " + lty + " " + lr + ", " + rr) }
            else    { emit("  " + r + " = add  " + lty + " " + lr + ", " + rr) }
        } else if k == NK_SUB {
            if flt { emit("  " + r + " = fsub reassoc nsz contract " + lty + " " + lr + ", " + rr) }
            else    { emit("  " + r + " = sub  " + lty + " " + lr + ", " + rr) }
        } else if k == NK_MUL {
            if flt { emit("  " + r + " = fmul reassoc nsz contract " + lty + " " + lr + ", " + rr) }
            else    { emit("  " + r + " = mul  " + lty + " " + lr + ", " + rr) }
        } else if k == NK_DIV {
            if flt { emit("  " + r + " = fdiv reassoc nsz contract arcp " + lty + " " + lr + ", " + rr) }
            else    { emit("  " + r + " = sdiv " + lty + " " + lr + ", " + rr) }
        } else {
            emit("  " + r + " = srem " + lty + " " + lr + ", " + rr)
        }
        g_expr_reg = r; g_expr_ty = lty; return
    }

    // 비교
    if k == NK_EQ or k == NK_NEQ or k == NK_LT or k == NK_GT or k == NK_LTE or k == NK_GTE {
        cg_expr(g_nc0[n]); lr = g_expr_reg; lty = g_expr_ty
        cg_expr(g_nc1[n]); rr = g_expr_reg; rty = g_expr_ty
        if lty == "i32" and rty == "i64" { lr = sext32(lr, lty); lty = "i64" }
        if lty == "i64" and rty == "i32" { rr = sext32(rr, rty) }
        // double vs int 비교 — int 쪽을 승격 (py Q3 의미론)
        if (lty == "double" or lty == "float") and is_int_ty(rty) {
            rr = coerce_to(rr, rty, lty); rty = lty
        }
        if (rty == "double" or rty == "float") and is_int_ty(lty) {
            lr = coerce_to(lr, lty, rty); lty = rty
        }
        r = new_reg()
        flt = lty == "double" or lty == "float"
        if flt {
            if k == NK_EQ  { emit("  " + r + " = fcmp oeq " + lty + " " + lr + ", " + rr) }
            else if k == NK_NEQ { emit("  " + r + " = fcmp one " + lty + " " + lr + ", " + rr) }
            else if k == NK_LT  { emit("  " + r + " = fcmp olt " + lty + " " + lr + ", " + rr) }
            else if k == NK_GT  { emit("  " + r + " = fcmp ogt " + lty + " " + lr + ", " + rr) }
            else if k == NK_LTE { emit("  " + r + " = fcmp ole " + lty + " " + lr + ", " + rr) }
            else                { emit("  " + r + " = fcmp oge " + lty + " " + lr + ", " + rr) }
        } else if lty == "i8*" {
            sl2 = new_reg(); sr2 = new_reg()
            emit("  " + sl2 + " = call i8* @dnh_safe_str(i8* " + lr + ")")
            emit("  " + sr2 + " = call i8* @dnh_safe_str(i8* " + rr + ")")
            cmp = new_reg()
            emit("  " + cmp + " = call i32 @strcmp(i8* " + sl2 + ", i8* " + sr2 + ")")
            if k == NK_EQ  { emit("  " + r + " = icmp eq  i32 " + cmp + ", 0") }
            else if k == NK_NEQ { emit("  " + r + " = icmp ne  i32 " + cmp + ", 0") }
            else if k == NK_LT  { emit("  " + r + " = icmp slt i32 " + cmp + ", 0") }
            else if k == NK_GT  { emit("  " + r + " = icmp sgt i32 " + cmp + ", 0") }
            else if k == NK_LTE { emit("  " + r + " = icmp sle i32 " + cmp + ", 0") }
            else                { emit("  " + r + " = icmp sge i32 " + cmp + ", 0") }
        } else {
            if k == NK_EQ  { emit("  " + r + " = icmp eq  " + lty + " " + lr + ", " + rr) }
            else if k == NK_NEQ { emit("  " + r + " = icmp ne  " + lty + " " + lr + ", " + rr) }
            else if k == NK_LT  { emit("  " + r + " = icmp slt " + lty + " " + lr + ", " + rr) }
            else if k == NK_GT  { emit("  " + r + " = icmp sgt " + lty + " " + lr + ", " + rr) }
            else if k == NK_LTE { emit("  " + r + " = icmp sle " + lty + " " + lr + ", " + rr) }
            else                { emit("  " + r + " = icmp sge " + lty + " " + lr + ", " + rr) }
        }
        g_expr_reg = r; g_expr_ty = "i1"; return
    }

    // 논리
    if k == NK_AND {
        slot = "%__bool" + to_string(g_reg) + "_v"; g_reg = g_reg + 1
        emit_alloca("  " + slot + " = alloca i1")
        lrhs = new_lbl(); lfalse = new_lbl(); lend = new_lbl()
        cg_expr(g_nc0[n]); lr = cg_truth_reg(g_expr_reg, g_expr_ty)
        emit("  br i1 " + lr + ", label %" + lrhs + ", label %" + lfalse)
        emit(lfalse + ":")
        emit("  store i1 0, i1* " + slot)
        emit("  br label %" + lend)
        emit(lrhs + ":")
        cg_expr(g_nc1[n]); rr = cg_truth_reg(g_expr_reg, g_expr_ty)
        emit("  store i1 " + rr + ", i1* " + slot)
        emit("  br label %" + lend)
        emit(lend + ":")
        r = new_reg()
        emit("  " + r + " = load i1, i1* " + slot)
        g_expr_reg = r; g_expr_ty = "i1"; return
    }
    if k == NK_OR {
        slot = "%__bool" + to_string(g_reg) + "_v"; g_reg = g_reg + 1
        emit_alloca("  " + slot + " = alloca i1")
        ltrue = new_lbl(); lrhs = new_lbl(); lend = new_lbl()
        cg_expr(g_nc0[n]); lr = cg_truth_reg(g_expr_reg, g_expr_ty)
        emit("  br i1 " + lr + ", label %" + ltrue + ", label %" + lrhs)
        emit(ltrue + ":")
        emit("  store i1 1, i1* " + slot)
        emit("  br label %" + lend)
        emit(lrhs + ":")
        cg_expr(g_nc1[n]); rr = cg_truth_reg(g_expr_reg, g_expr_ty)
        emit("  store i1 " + rr + ", i1* " + slot)
        emit("  br label %" + lend)
        emit(lend + ":")
        r = new_reg()
        emit("  " + r + " = load i1, i1* " + slot)
        g_expr_reg = r; g_expr_ty = "i1"; return
    }
    if k == NK_NOT {
        cg_expr(g_nc0[n]); br = cg_truth_reg(g_expr_reg, g_expr_ty); r = new_reg()
        emit("  " + r + " = xor i1 " + br + ", 1")
        g_expr_reg = r; g_expr_ty = "i1"; return
    }
    if k == NK_NEG {
        cg_expr(g_nc0[n]); lr = g_expr_reg; lty = g_expr_ty
        r = new_reg()
        if is_vec_ty(lty) {
            emit("  " + r + " = fneg " + lty + " " + lr)
        } else if lty == "double" or lty == "float" {
            emit("  " + r + " = fneg " + lty + " " + lr)
        } else {
            emit("  " + r + " = sub " + lty + " 0, " + lr)
        }
        g_expr_reg = r; g_expr_ty = lty; return
    }

    // 비트 연산
    if k == NK_BITAND or k == NK_BITOR or k == NK_BITXOR or k == NK_BITNOT or k == NK_LSHIFT or k == NK_RSHIFT {
        cg_expr(g_nc0[n]); lr = g_expr_reg; lty = g_expr_ty
        r = new_reg()
        if k == NK_BITNOT {
            emit("  " + r + " = xor " + lty + " " + lr + ", -1")
        } else {
            cg_expr(g_nc1[n]); rr = g_expr_reg
            if k == NK_BITAND { emit("  " + r + " = and  " + lty + " " + lr + ", " + rr) }
            else if k == NK_BITOR  { emit("  " + r + " = or   " + lty + " " + lr + ", " + rr) }
            else if k == NK_BITXOR { emit("  " + r + " = xor  " + lty + " " + lr + ", " + rr) }
            else if k == NK_LSHIFT { emit("  " + r + " = shl  " + lty + " " + lr + ", " + rr) }
            else                   { emit("  " + r + " = lshr " + lty + " " + lr + ", " + rr) }
        }
        g_expr_reg = r; g_expr_ty = lty; return
    }

    // 캐스트
    if k == NK_AS {
        cg_expr(g_nc0[n]); sr = g_expr_reg; sty = g_expr_ty
        // c as dyn Trait — 트레잇 객체 생성
        dtr = as_dyn_trait(g_nsval[n])
        if dtr != "" {
            g_expr_reg = dyn_wrap(sr, sty, dtr, g_nline[n])
            g_expr_ty = "%dyn." + dtr + "*"
            return
        }
        dty = ll_ty(g_nsval[n])
        if sty == dty { g_expr_reg = sr; g_expr_ty = dty; return }
        // bool → 정수는 zext (sext면 true가 -1이 됨)
        if sty == "i1" and is_int_ty(dty) {
            r = new_reg()
            emit("  " + r + " = zext i1 " + sr + " to " + dty)
            g_expr_reg = r; g_expr_ty = dty; return
        }
        // 정수/실수 캐스트는 coerce_to로 일반화 (i8/i16/f32 포함)
        if (is_int_ty(sty) or is_flt_ty(sty)) and (is_int_ty(dty) or is_flt_ty(dty)) {
            g_expr_reg = coerce_to(sr, sty, dty); g_expr_ty = dty; return
        }
        r = new_reg()
        emit("  " + r + " = bitcast " + sty + " " + sr + " to " + dty)
        g_expr_reg = r; g_expr_ty = dty; return
    }

    // 필드 접근
    if k == NK_FIELD {
        fname_s = g_nsval[n]
        // 모듈 상수 접근: config.SPEED → 병합된 글로벌 SPEED
        fobj = g_nc0[n]
        if g_nkind[fobj] == NK_ID {
            // enum bare variant 접근: Phase.Chase (괄호 없음)
            // simple enum → i64 태그 상수 (py 의미론), tagged enum → payload 0 enum 객체
            if find_var(g_nsval[fobj]) == -1 {
                evb = find_variant(g_nsval[fobj], fname_s)
                if evb != -1 {
                    if enum_is_simple(g_nsval[fobj]) {
                        g_expr_reg = to_string(g_vrt_tag[evb]); g_expr_ty = "i64"; return
                    }
                    r = new_reg()
                    emit("  " + r + " = call %DnhEnum* @dnh_enum_new(i64 " + to_string(g_vrt_tag[evb]) + ", i64 0)")
                    g_expr_reg = r; g_expr_ty = "%DnhEnum*"; return
                }
            }
            if find_var(g_nsval[fobj]) == -1 and mod_has(g_nsval[fobj]) {
                mfvi = find_var(fname_s)
                if mfvi != -1 {
                    g_expr_reg = load_val(g_var_regs[mfvi], g_var_tys[mfvi])
                    g_expr_ty = g_var_tys[mfvi]
                    g_expr_elem = g_var_elems[mfvi]
                    g_expr_lam = g_var_lams[mfvi]
                    return
                }
                g_expr_reg = "0"; g_expr_ty = "i64"; return
            }
        }
        cg_expr(g_nc0[n]); obj_r = g_expr_reg; obj_ty = g_expr_ty
        // 벡터 성분 읽기: v.x → extractelement
        if is_vec_ty(obj_ty) {
            vfi = vec_field_idx(fname_s)
            if vfi < 0 {
                fatal("벡터에 '" + fname_s + "' 성분은 없어 (줄 " + to_string(g_nline[n]) + ")")
            }
            r = new_reg()
            emit("  " + r + " = extractelement " + obj_ty + " " + obj_r + ", i32 " + to_string(vfi))
            g_expr_reg = r; g_expr_ty = "double"; return
        }
        sname = ""
        si = 8
        while si < len(obj_ty) and obj_ty[si] != "*" { sname = sname + obj_ty[si]; si = si + 1 }
        sidx = find_struct(sname)
        if sidx == -1 { g_expr_reg = "0"; g_expr_ty = "i64"; return }
        fi = struct_field_idx(sidx, fname_s)
        if fi == -1  { g_expr_reg = "0"; g_expr_ty = "i64"; return }
        fty = g_sdef_ftys[g_sdef_fs[sidx] + fi]
        // union 필드 읽기 — 오프셋 0 슬롯을 필드 타입으로 bitcast해 로드
        if union_has(sname) {
            ugep = new_reg()
            emit("  " + ugep + " = getelementptr inbounds %struct." + sname + ", %struct." + sname + "* " + obj_r + ", i32 0, i32 0")
            fp = ugep
            if fty != "i64" {
                fp = new_reg()
                emit("  " + fp + " = bitcast i64* " + ugep + " to " + fty + "*")
            }
            r = new_reg()
            emit("  " + r + " = load " + fty + ", " + fty + "* " + fp)
            g_expr_reg = r; g_expr_ty = fty; return
        }
        gep = new_reg()
        emit("  " + gep + " = getelementptr inbounds %struct." + sname + ", %struct." + sname + "* " + obj_r + ", i32 0, i32 " + to_string(fi))
        // 고정 배열 필드 — 값 로드 대신 필드 포인터
        if is_arr_val(fty) {
            g_expr_reg = gep; g_expr_ty = fty + "*"; return
        }
        r = new_reg()
        emit("  " + r + " = load " + fty + ", " + fty + "* " + gep)
        g_expr_reg = r; g_expr_ty = fty; return
    }

    // 인덱스
    if k == NK_INDEX {
        e0 = g_nc0[n]
        elem = ""
        if g_nkind[e0] == NK_ID {
            evi = find_var(g_nsval[e0])
            if evi != -1 { elem = g_var_elems[evi] }
        }
        cg_expr(e0); arr_r = g_expr_reg; arr_ty = g_expr_ty
        cg_expr(g_nc1[n]); idx_r = sext32(g_expr_reg, g_expr_ty)
        r = new_reg()
        if arr_ty == "%DnhList*" {
            emit("  " + r + " = call i64 @dnh_get(%DnhList* " + arr_r + ", i64 " + idx_r + ")")
            if elem == "str" {
                p = new_reg()
                emit("  " + p + " = inttoptr i64 " + r + " to i8*")
                g_expr_reg = p; g_expr_ty = "i8*"
            } else if elem == "f64" {
                d = new_reg()
                emit("  " + d + " = bitcast i64 " + r + " to double")
                g_expr_reg = d; g_expr_ty = "double"
            } else if as_dyn_trait(elem) != "" {
                // [dyn Trait] 원소 디코드
                del = as_dyn_trait(elem)
                p2 = new_reg()
                emit("  " + p2 + " = inttoptr i64 " + r + " to %dyn." + del + "*")
                g_expr_reg = p2; g_expr_ty = "%dyn." + del + "*"
            } else {
                g_expr_reg = r; g_expr_ty = "i64"
            }
        } else if arr_ty == "i8*" {
            emit("  " + r + " = call i8* @dnh_str_idx(i8* " + arr_r + ", i64 " + idx_r + ")")
            g_expr_reg = r; g_expr_ty = "i8*"
        } else if is_arr_ptr(arr_ty) {
            // 고정 크기 배열 인덱싱
            bty = arr_base_ty(arr_ty)
            ety = arr_elem_ll(arr_ty)
            gep = r; r = new_reg()
            emit("  " + gep + " = getelementptr inbounds " + bty + ", " + arr_ty + " " + arr_r + ", i64 0, i64 " + idx_r)
            emit("  " + r + " = load " + ety + ", " + ety + "* " + gep)
            g_expr_reg = r; g_expr_ty = ety
        } else {
            gep = r; r = new_reg()
            emit("  " + gep + " = getelementptr inbounds i64, i64* " + arr_r + ", i64 " + idx_r)
            emit("  " + r + " = load i64, i64* " + gep)
            g_expr_reg = r; g_expr_ty = "i64"
        }
        return
    }

    // 참조/역참조
    if k == NK_REF or k == NK_DEREF { cg_expr(g_nc0[n]); return }

    // 배열 리터럴 → dnh_new_list + dnh_push
    if k == NK_ARRAY {
        if g_nival[n] > 0 {
            fatal("[값; N] 반복 리터럴은 고정 크기 배열 주석이 있는 자리에서만 쓸 수 있어 (줄 " + to_string(g_nline[n]) + ")")
        }
        r = new_reg()
        emit("  " + r + " = call %DnhList* @dnh_new_list()")
        nc = g_nch_n[n]
        list_el = ""
        i = 0
        while i < nc {
            ck = g_nkind[g_ch[g_nch_s[n] + i]]
            if ck == NK_FLOAT { list_el = "f64" }
            else if ck == NK_STR or ck == NK_ISTR { if list_el == "" { list_el = "str" } }
            else if list_el == "" { list_el = "i64" }
            i = i + 1
        }
        i = 0
        while i < nc {
            cg_expr(g_ch[g_nch_s[n] + i]); ev = g_expr_reg; ety = g_expr_ty
            if list_el == "f64" and ety != "double" and ety != "float" {
                ev = coerce_to(ev, ety, "double")
                ety = "double"
            }
            ev = val_to_slot(ev, ety)
            emit("  call void @dnh_push(%DnhList* " + r + ", i64 " + ev + ")")
            i = i + 1
        }
        g_expr_reg = r; g_expr_ty = "%DnhList*"; g_expr_elem = list_el; return
    }

    // 함수 호출
    if k == NK_CALL {
        fname_c = g_nsval[n]
        nargs = g_nch_n[n]
        if fname_c == "tok_push" and nargs == 5 {
            cg_expr(g_ch[g_nch_s[n] + 0]); a0 = g_expr_reg; t0 = g_expr_ty
            cg_expr(g_ch[g_nch_s[n] + 1]); a1 = g_expr_reg; t1 = g_expr_ty
            cg_expr(g_ch[g_nch_s[n] + 2]); a2 = g_expr_reg; t2 = g_expr_ty
            cg_expr(g_ch[g_nch_s[n] + 3]); a3 = g_expr_reg; t3 = g_expr_ty
            cg_expr(g_ch[g_nch_s[n] + 4]); a4 = g_expr_reg; t4 = g_expr_ty
            if t0 != "i32" { a0 = coerce_to(a0, t0, "i32") }
            if t2 != "i64" { a2 = coerce_to(a2, t2, "i64") }
            if t3 != "double" { a3 = coerce_to(a3, t3, "double") }
            if t4 != "i32" { a4 = coerce_to(a4, t4, "i32") }
            r = new_reg()
            emit("  " + r + " = call i64 @tok_push(i32 " + a0 + ", i8* " + a1 + ", i64 " + a2 + ", double " + a3 + ", i32 " + a4 + ")")
            g_expr_reg = r; g_expr_ty = "i64"; return
        }
        // ── ECS has/remove/get(e, Comp) — 둘째 인자가 컴포넌트 '타입 이름'이라
        //    일반 인자 평가 전에 가로채야 함 (NK_ID 평가가 미정의 변수로 죽음)
        if nargs == 2 and find_fn(fname_c) == -1 {
            if fname_c == "has" or fname_c == "remove" or fname_c == "get" {
                a1n = g_ch[g_nch_s[n] + 1]
                if g_nkind[a1n] == NK_ID {
                    hcn = g_nsval[a1n]
                    if comp_has(hcn) and find_var(hcn) == -1 {
                        cg_expr(g_ch[g_nch_s[n]])
                        hent = sext32(g_expr_reg, g_expr_ty)
                        hel = new_reg()
                        emit("  " + hel + " = load %DnhList*, %DnhList** @__ecs_e_" + hcn)
                        if fname_c == "has" {
                            // 죽은/낡은 엔티티 → false (abort 아님, py 동일)
                            hv = new_reg()
                            emit("  " + hv + " = call i1 @dnh_ecs_valid(i64 " + hent + ")")
                            hf = new_reg()
                            emit("  " + hf + " = call i64 @dnh_ecs_find(%DnhList* " + hel + ", i64 " + hent + ")")
                            hok = new_reg()
                            emit("  " + hok + " = icmp sge i64 " + hf + ", 0")
                            hr = new_reg()
                            emit("  " + hr + " = and i1 " + hv + ", " + hok)
                            g_expr_reg = hr; g_expr_ty = "i1"; return
                        }
                        if fname_c == "remove" {
                            cg_ecs_check_alive(hent, "단아 ECS: remove에 죽은 엔티티 (component " + hcn + ")")
                            hpl = new_reg()
                            emit("  " + hpl + " = load %DnhList*, %DnhList** @__ecs_p_" + hcn)
                            hr = new_reg()
                            emit("  " + hr + " = call i1 @dnh_ecs_swapremove(%DnhList* " + hel + ", %DnhList* " + hpl + ", i64 " + hent + ")")
                            g_expr_reg = hr; g_expr_ty = "i1"; return
                        }
                        // get — 죽은 엔티티/없는 컴포넌트는 abort, 있으면 '사본' 반환 (py 동일)
                        cg_ecs_check_alive(hent, "단아 ECS: get에 죽은 엔티티 (component " + hcn + ")")
                        hf = new_reg()
                        emit("  " + hf + " = call i64 @dnh_ecs_find(%DnhList* " + hel + ", i64 " + hent + ")")
                        hmiss = new_reg()
                        emit("  " + hmiss + " = icmp slt i64 " + hf + ", 0")
                        lgm = new_lbl(); lgo = new_lbl()
                        emit("  br i1 " + hmiss + ", label %" + lgm + ", label %" + lgo)
                        emit(lgm + ":")
                        cg_ecs_die("단아 ECS: get에 없는 컴포넌트 " + hcn)
                        emit(lgo + ":")
                        hpl = new_reg()
                        emit("  " + hpl + " = load %DnhList*, %DnhList** @__ecs_p_" + hcn)
                        hpv = new_reg()
                        emit("  " + hpv + " = call i64 @dnh_get(%DnhList* " + hpl + ", i64 " + hf + ")")
                        hsrc = new_reg()
                        emit("  " + hsrc + " = inttoptr i64 " + hpv + " to %struct." + hcn + "*")
                        htmp = "%__ecsget" + to_string(g_reg) + "_v"; g_reg = g_reg + 1
                        emit_alloca("  " + htmp + " = alloca %struct." + hcn)
                        hval = new_reg()
                        emit("  " + hval + " = load %struct." + hcn + ", %struct." + hcn + "* " + hsrc)
                        emit("  store %struct." + hcn + " " + hval + ", %struct." + hcn + "* " + htmp)
                        g_expr_reg = htmp; g_expr_ty = "%struct." + hcn + "*"; return
                    }
                }
            }
        }
        arg_rs: [str] = []
        arg_ts: [str] = []
        i = 0
        while i < nargs {
            cg_expr(g_ch[g_nch_s[n] + i])
            push(arg_rs, g_expr_reg); push(arg_ts, g_expr_ty)
            i = i + 1
        }
        // 조건식에서 arg_ts[0]을 직접 인덱싱하면 0-인자 호출에서 빈 리스트 OOB —
        // and 단락평가에 기대지 않도록 안전한 사본을 미리 뽑는다 (prev 부트스트랩 호환)
        arg0t = ""
        if nargs > 0 { arg0t = arg_ts[0] }
        arg1t = ""
        if nargs > 1 { arg1t = arg_ts[1] }
        // ── 빌트인 함수
        if fname_c == "arena_reset" and nargs == 0 {
            g_expr_reg = "0"; g_expr_ty = "i64"; return
        }
        if fname_c == "get_args" and nargs == 0 {
            r = new_reg()
            emit("  " + r + " = call %DnhList* @dnh_get_args()")
            g_expr_reg = r; g_expr_ty = "%DnhList*"; g_expr_elem = "str"; return
        }
        if fname_c == "exit" and nargs == 1 {
            v32 = arg_rs[0]
            if arg_ts[0] != "i32" {
                v32 = new_reg()
                emit("  " + v32 + " = trunc " + arg_ts[0] + " " + arg_rs[0] + " to i32")
            }
            emit("  call void @dnh_exit(i32 " + v32 + ")")
            g_expr_reg = "0"; g_expr_ty = "void"; return
        }
        if fname_c == "ord" and nargs == 1 {
            b = new_reg(); r = new_reg()
            emit("  " + b + " = load i8, i8* " + arg_rs[0])
            emit("  " + r + " = zext i8 " + b + " to i32")
            g_expr_reg = r; g_expr_ty = "i32"; return
        }
        if fname_c == "chr" and nargs == 1 {
            v8 = arg_rs[0]
            if arg_ts[0] != "i8" {
                v8 = new_reg()
                emit("  " + v8 + " = trunc " + arg_ts[0] + " " + arg_rs[0] + " to i8")
            }
            r = new_reg()
            emit("  " + r + " = call i8* @dnh_chr(i8 " + v8 + ")")
            g_expr_reg = r; g_expr_ty = "i8*"; return
        }
        if fname_c == "spawn" and nargs == 0 and find_fn("spawn") == -1 {
            r0 = new_reg()
            emit("  " + r0 + " = call i64 @dnh_ecs_spawn()")
            g_expr_reg = r0; g_expr_ty = "i64"; g_expr_elem = "eid"; return
        }
        if fname_c == "destroy" and nargs == 1 and find_fn("destroy") == -1 {
            de64 = sext32(arg_rs[0], arg_ts[0])
            r = new_reg()
            emit("  " + r + " = call i1 @dnh_ecs_destroy(i64 " + de64 + ")")
            g_expr_reg = r; g_expr_ty = "i1"; return
        }
        if fname_c == "is_alive" and nargs == 1 and find_fn("is_alive") == -1 {
            ia64 = sext32(arg_rs[0], arg_ts[0])
            r = new_reg()
            emit("  " + r + " = call i1 @dnh_ecs_valid(i64 " + ia64 + ")")
            g_expr_reg = r; g_expr_ty = "i1"; return
        }
        if fname_c == "add" and nargs == 2 {
            // add(ent, Comp{...}) — 두 번째 인자가 등록된 컴포넌트 struct일 때만
            ecn = ""
            ct = arg_ts[1]
            if len(ct) > 8 {
                if ct[1] == "s" and ct[2] == "t" and ct[3] == "r" {
                    ci = 8
                    while ci < len(ct) and ct[ci] != "*" { ecn = ecn + ct[ci]; ci = ci + 1 }
                }
            }
            if comp_has(ecn) {
                ent64 = sext32(arg_rs[0], arg_ts[0])
                // 죽은 엔티티에 add → abort (py 동일)
                cg_ecs_check_alive(ent64, "단아 ECS: add에 죽은 엔티티 (component " + ecn + ")")
                le = new_reg()
                emit("  " + le + " = load %DnhList*, %DnhList** @__ecs_e_" + ecn)
                lp = new_reg()
                emit("  " + lp + " = load %DnhList*, %DnhList** @__ecs_p_" + ecn)
                // 이미 있으면 제자리 덮어쓰기 (py add overwrite 의미론)
                af = new_reg()
                emit("  " + af + " = call i64 @dnh_ecs_find(%DnhList* " + le + ", i64 " + ent64 + ")")
                aex = new_reg()
                emit("  " + aex + " = icmp sge i64 " + af + ", 0")
                low2 = new_lbl(); lfr2 = new_lbl(); ldn2 = new_lbl()
                emit("  br i1 " + aex + ", label %" + low2 + ", label %" + lfr2)
                emit(low2 + ":")
                apv = new_reg()
                emit("  " + apv + " = call i64 @dnh_get(%DnhList* " + lp + ", i64 " + af + ")")
                adst = new_reg()
                emit("  " + adst + " = inttoptr i64 " + apv + " to " + ct)
                abty = ""
                aci = 0
                while aci < len(ct) - 1 { abty = abty + ct[aci]; aci = aci + 1 }
                asv = new_reg()
                emit("  " + asv + " = load " + abty + ", " + ct + " " + arg_rs[1])
                emit("  store " + abty + " " + asv + ", " + ct + " " + adst)
                emit("  br label %" + ldn2)
                emit(lfr2 + ":")
                emit("  call void @dnh_push(%DnhList* " + le + ", i64 " + ent64 + ")")
                pv = new_reg()
                emit("  " + pv + " = ptrtoint " + ct + " " + arg_rs[1] + " to i64")
                emit("  call void @dnh_push(%DnhList* " + lp + ", i64 " + pv + ")")
                emit("  br label %" + ldn2)
                emit(ldn2 + ":")
                g_expr_reg = "0"; g_expr_ty = "void"; return
            }
        }
        if fname_c == "schedule" and nargs == 1 {
            nsys = len(g_sys_names)
            // writer/writer 충돌 검사 (py _schedule_systems_topo와 동일 규칙)
            si3 = 0
            while si3 < nsys {
                sj3 = si3 + 1
                while sj3 < nsys {
                    ci3 = 0
                    while ci3 < len(g_comp_names) {
                        cn3 = g_comp_names[ci3]
                        if sys_access(g_sys_names[si3], cn3) == 2 and sys_access(g_sys_names[sj3], cn3) == 2 {
                            fatal("system '" + g_sys_names[si3] + "'와(과) '" + g_sys_names[sj3] + "'이(가) 컴포넌트 " + cn3 + "에 모두 쓰려고 해 (줄 " + to_string(g_nline[n]) + ")")
                        }
                        ci3 = ci3 + 1
                    }
                    sj3 = sj3 + 1
                }
                si3 = si3 + 1
            }
            // 간선: A가 쓰고 B가 읽으면 A→B (상호 참조면 생략) — indegree 계산
            indeg: [i32] = []
            si3 = 0
            while si3 < nsys { push(indeg, 0); si3 = si3 + 1 }
            edge_a: [i32] = []
            edge_b: [i32] = []
            si3 = 0
            while si3 < nsys {
                sj3 = 0
                while sj3 < nsys {
                    if si3 != sj3 {
                        awb = false
                        bwa = false
                        ci3 = 0
                        while ci3 < len(g_comp_names) {
                            cn3 = g_comp_names[ci3]
                            if sys_access(g_sys_names[si3], cn3) == 2 and sys_access(g_sys_names[sj3], cn3) == 1 { awb = true }
                            if sys_access(g_sys_names[sj3], cn3) == 2 and sys_access(g_sys_names[si3], cn3) == 1 { bwa = true }
                            ci3 = ci3 + 1
                        }
                        if awb and not bwa {
                            push(edge_a, si3); push(edge_b, sj3)
                            indeg[sj3] = indeg[sj3] + 1
                        }
                    }
                    sj3 = sj3 + 1
                }
                si3 = si3 + 1
            }
            // Kahn — 동순위는 선언 순서
            order: [i32] = []
            done: [i32] = []
            si3 = 0
            while si3 < nsys { push(done, 0); si3 = si3 + 1 }
            cnt3 = 0
            while cnt3 < nsys {
                pick = -1
                si3 = 0
                while si3 < nsys {
                    if done[si3] == 0 and indeg[si3] == 0 and pick == -1 { pick = si3 }
                    si3 = si3 + 1
                }
                if pick == -1 {
                    // 순환 — 남은 것들은 선언 순서로
                    si3 = 0
                    while si3 < nsys {
                        if done[si3] == 0 { push(order, si3); done[si3] = 1 }
                        si3 = si3 + 1
                    }
                    cnt3 = nsys
                } else {
                    push(order, pick); done[pick] = 1
                    ei3 = 0
                    while ei3 < len(edge_a) {
                        if edge_a[ei3] == pick { indeg[edge_b[ei3]] = indeg[edge_b[ei3]] - 1 }
                        ei3 = ei3 + 1
                    }
                    cnt3 = cnt3 + 1
                }
            }
            // 정렬된 순서로 호출 방출
            oi3 = 0
            while oi3 < len(order) {
                sn3 = g_sys_names[order[oi3]]
                sfi = find_fn(sn3)
                if sfi != -1 {
                    sav = arg_rs[0]; sat = arg_ts[0]
                    if g_fn_arities[sfi] > 0 {
                        swant = g_fn_ptys[g_fn_ps[sfi]]
                        if sat != swant { sav = coerce_to(sav, sat, swant); sat = swant }
                    }
                    sret = g_fn_rets[sfi]
                    if sret == "void" or sret == "()" {
                        emit("  call void @" + sn3 + "(" + sat + " " + sav + ")")
                    } else {
                        sr3 = new_reg()
                        emit("  " + sr3 + " = call " + sret + " @" + sn3 + "(" + sat + " " + sav + ")")
                    }
                }
                oi3 = oi3 + 1
            }
            g_expr_reg = "0"; g_expr_ty = "void"; return
        }
        if fname_c == "sqrt" and nargs == 1 {
            a0 = arg_rs[0]
            if arg_ts[0] != "double" {
                d0 = new_reg()
                emit("  " + d0 + " = sitofp " + arg_ts[0] + " " + a0 + " to double")
                a0 = d0
            }
            r = new_reg()
            emit("  " + r + " = call double @llvm.sqrt.f64(double " + a0 + ")")
            g_expr_reg = r; g_expr_ty = "double"; return
        }
        if fname_c == "clock" and nargs == 0 {
            r = new_reg()
            emit("  " + r + " = call double @dnh_clock()")
            g_expr_reg = r; g_expr_ty = "double"; return
        }
        if fname_c == "string_builder" and nargs == 0 {
            r = new_reg()
