NK_LTE        = 16
NK_GTE        = 17
NK_AND        = 18
NK_OR         = 19
NK_NOT        = 20
NK_NEG        = 21
NK_BITAND     = 22
NK_BITOR      = 23
NK_BITXOR     = 24
NK_BITNOT     = 25
NK_LSHIFT     = 26
NK_RSHIFT     = 27
NK_ASSIGN     = 28
