        // vec2/vec3/vec4 생성자 — insertelement 체인
        if (fname_c == "vec2" and nargs == 2) or (fname_c == "vec3" and nargs == 3) or (fname_c == "vec4" and nargs == 4) {
            vn2 = nargs
            vty = "<" + to_string(vn2) + " x double>"
            cur = "undef"
            vi2 = 0
            while vi2 < vn2 {
                ev2 = arg_rs[vi2]
                if arg_ts[vi2] != "double" { ev2 = coerce_to(ev2, arg_ts[vi2], "double") }
                nr2 = new_reg()
                emit("  " + nr2 + " = insertelement " + vty + " " + cur + ", double " + ev2 + ", i32 " + to_string(vi2))
                cur = nr2
                vi2 = vi2 + 1
            }
            g_expr_reg = cur; g_expr_ty = vty; return
