    emit("")
    emit("define i32 @strcmp(i8* %a, i8* %b) \{")
    emit("entry:")
    emit("  br label %loop")
    emit("loop:")
    emit("  %i = phi i32 [0, %entry], [%next, %cont]")
    emit("  %ap = getelementptr i8, i8* %a, i32 %i")
    emit("  %bp = getelementptr i8, i8* %b, i32 %i")
    emit("  %ac8 = load i8, i8* %ap")
    emit("  %bc8 = load i8, i8* %bp")
    emit("  %ac = zext i8 %ac8 to i32")
    emit("  %bc = zext i8 %bc8 to i32")
    emit("  %diff = sub i32 %ac, %bc")
    emit("  %neq = icmp ne i32 %diff, 0")
    emit("  %end = icmp eq i8 %ac8, 0")
    emit("  %stop = or i1 %neq, %end")
    emit("  br i1 %stop, label %done, label %cont")
    emit("cont:")
    emit("  %next = add i32 %i, 1")
    emit("  br label %loop")
    emit("done:")
    emit("  ret i32 %diff")
    emit("\}")
