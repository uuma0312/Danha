    emit("  %more = icmp ne i64 %n2, 0")
    emit("  br i1 %more, label %loop, label %digits_done")
    emit("digits_done:")
    emit("  br i1 %neg, label %add_minus, label %write")
    emit("add_minus:")
    emit("  %mp = getelementptr i8, i8* %p2, i64 -1")
    emit("  store i8 45, i8* %mp")
    emit("  %mlen = add i32 %len2, 1")
    emit("  br label %write")
    emit("write:")
    emit("  %wp = phi i8* [%p2, %digits_done], [%mp, %add_minus]")
    emit("  %wl = phi i32 [%len2, %digits_done], [%mlen, %add_minus]")
    emit("  call void @dnh_os_write(i8* %wp, i32 %wl)")
    emit("  %nl = getelementptr inbounds [2 x i8], [2 x i8]* @.rt_nl, i32 0, i32 0")
    emit("  call void @dnh_os_write(i8* %nl, i32 1)")
    emit("  ret void")
    emit("\}")
