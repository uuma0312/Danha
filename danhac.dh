            emit("  " + t5 + " = fmul double " + ay + ", " + bx)
            emit("  " + cz + " = fsub double " + t4 + ", " + t5)
            cr0 = new_reg(); cr1 = new_reg(); cr2 = new_reg()
            emit("  " + cr0 + " = insertelement <3 x double> undef, double " + cx + ", i32 0")
            emit("  " + cr1 + " = insertelement <3 x double> " + cr0 + ", double " + cy + ", i32 1")
