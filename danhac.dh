    emit("define void @dnh_os_print_i64(i64 %v) \{")
    emit("entry:")
    emit("  %is_zero = icmp eq i64 %v, 0")
    emit("  br i1 %is_zero, label %zero, label %prep")
    emit("zero:")
    emit("  %zbuf = getelementptr inbounds [32 x i8], [32 x i8]* @.rt_i64_buf, i32 0, i32 0")
    emit("  store i8 48, i8* %zbuf")
    emit("  call void @dnh_os_write(i8* %zbuf, i32 1)")
    emit("  %znl = getelementptr inbounds [2 x i8], [2 x i8]* @.rt_nl, i32 0, i32 0")
    emit("  call void @dnh_os_write(i8* %znl, i32 1)")
    emit("  ret void")
    emit("prep:")
    emit("  %neg = icmp slt i64 %v, 0")
    emit("  %absn = sub i64 0, %v")
    emit("  %n0 = select i1 %neg, i64 %absn, i64 %v")
    emit("  %endp = getelementptr inbounds [32 x i8], [32 x i8]* @.rt_i64_buf, i32 0, i32 31")
    emit("  br label %loop")
    emit("loop:")
    emit("  %n = phi i64 [%n0, %prep], [%n2, %loop]")
    emit("  %p = phi i8* [%endp, %prep], [%p2, %loop]")
    emit("  %len = phi i32 [0, %prep], [%len2, %loop]")
    emit("  %rem = srem i64 %n, 10")
    emit("  %d64 = add i64 %rem, 48")
    emit("  %d8 = trunc i64 %d64 to i8")
    emit("  %p2 = getelementptr i8, i8* %p, i64 -1")
    emit("  store i8 %d8, i8* %p2")
    emit("  %n2 = sdiv i64 %n, 10")
