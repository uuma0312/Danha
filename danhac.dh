    emit("  %missing = icmp eq i32 %a, -1")
    emit("  %ok = xor i1 %missing, 1")
    emit("  ret i1 %ok")
    emit("\}")
    emit("")
    emit("define i64 @dnh_os_exec(i8* %cmd) \{")
    emit("entry:")
    emit("  %si = alloca [104 x i8]")
    emit("  %pi = alloca [24 x i8]")
    emit("  %ec = alloca i32")
    emit("  %sip = getelementptr inbounds [104 x i8], [104 x i8]* %si, i32 0, i32 0")
    emit("  %pip = getelementptr inbounds [24 x i8], [24 x i8]* %pi, i32 0, i32 0")
    emit("  call void @llvm.memset.p0i8.i64(i8* %sip, i8 0, i64 104, i1 false)")
    emit("  call void @llvm.memset.p0i8.i64(i8* %pip, i8 0, i64 24, i1 false)")
    emit("  %cbp = bitcast i8* %sip to i32*")
    emit("  store i32 104, i32* %cbp")
    emit("  %ok = call i32 @CreateProcessA(i8* null, i8* %cmd, i8* null, i8* null, i32 1, i32 0, i8* null, i8* null, i8* %sip, i8* %pip)")
    emit("  %fail = icmp eq i32 %ok, 0")
    emit("  br i1 %fail, label %ox_fail, label %ox_ok")
    emit("ox_fail:")
    emit("  ret i64 -1")
    emit("ox_ok:")
    emit("  %hpp = bitcast i8* %pip to i8**")
    emit("  %hp = load i8*, i8** %hpp")
    emit("  %htraw = getelementptr i8, i8* %pip, i64 8")
    emit("  %htp = bitcast i8* %htraw to i8**")
    emit("  %ht = load i8*, i8** %htp")
    emit("  %w = call i32 @WaitForSingleObject(i8* %hp, i32 -1)")
    emit("  %g = call i32 @GetExitCodeProcess(i8* %hp, i32* %ec)")
    emit("  %c1 = call i32 @CloseHandle(i8* %hp)")
    emit("  %c2 = call i32 @CloseHandle(i8* %ht)")
    emit("  %ecv = load i32, i32* %ec")
    emit("  %ec64 = sext i32 %ecv to i64")
    emit("  ret i64 %ec64")
    emit("\}")
    emit("")
    emit("declare i32 @QueryPerformanceCounter(i64*)")
    emit("declare i32 @QueryPerformanceFrequency(i64*)")
    emit("define double @dnh_clock() \{")
    emit("entry:")
    emit("  %c = alloca i64")
    emit("  %f = alloca i64")
    emit("  %r1 = call i32 @QueryPerformanceCounter(i64* %c)")
    emit("  %r2 = call i32 @QueryPerformanceFrequency(i64* %f)")
    emit("  %cv = load i64, i64* %c")
    emit("  %fv = load i64, i64* %f")
    emit("  %cd = sitofp i64 %cv to double")
    emit("  %fd = sitofp i64 %fv to double")
    emit("  %s = fdiv double %cd, %fd")
    emit("  ret double %s")
    emit("\}")
    emit("")
    emit("define %DnhList* @dnh_get_args() \{")
    emit("entry:")
    emit("  %lst = call %DnhList* @dnh_new_list()")
    emit("  %cl = call i8* @GetCommandLineA()")
    emit("  %cur = alloca i8*")
    emit("  store i8* %cl, i8** %cur")
    emit("  %c0 = load i8, i8* %cl")
    emit("  %isq = icmp eq i8 %c0, 34")
    emit("  br i1 %isq, label %pq_init, label %pn_loop")
    emit("pq_init:")
    emit("  %pq0 = getelementptr i8, i8* %cl, i64 1")
    emit("  store i8* %pq0, i8** %cur")
    emit("  br label %pq_loop")
    emit("pq_loop:")
    emit("  %pqp = load i8*, i8** %cur")
    emit("  %pqc = load i8, i8* %pqp")
    emit("  %pq_end = icmp eq i8 %pqc, 0")
    emit("  %pq_q = icmp eq i8 %pqc, 34")
    emit("  %pq_stop = or i1 %pq_end, %pq_q")
    emit("  br i1 %pq_stop, label %pq_done, label %pq_adv")
    emit("pq_adv:")
    emit("  %pqn = getelementptr i8, i8* %pqp, i64 1")
    emit("  store i8* %pqn, i8** %cur")
    emit("  br label %pq_loop")
    emit("pq_done:")
    emit("  %pdp = load i8*, i8** %cur")
    emit("  %pdc = load i8, i8* %pdp")
    emit("  %pd_q = icmp eq i8 %pdc, 34")
    emit("  br i1 %pd_q, label %pd_skip, label %args_loop")
    emit("pd_skip:")
    emit("  %pdn = getelementptr i8, i8* %pdp, i64 1")
    emit("  store i8* %pdn, i8** %cur")
    emit("  br label %args_loop")
    emit("pn_loop:")
    emit("  %pnp = load i8*, i8** %cur")
    emit("  %pnc = load i8, i8* %pnp")
    emit("  %pn_end = icmp eq i8 %pnc, 0")
    emit("  %pn_sp = icmp eq i8 %pnc, 32")
    emit("  %pn_tab = icmp eq i8 %pnc, 9")
    emit("  %pn_stop0 = or i1 %pn_end, %pn_sp")
    emit("  %pn_stop = or i1 %pn_stop0, %pn_tab")
    emit("  br i1 %pn_stop, label %args_loop, label %pn_adv")
    emit("pn_adv:")
    emit("  %pnn = getelementptr i8, i8* %pnp, i64 1")
    emit("  store i8* %pnn, i8** %cur")
    emit("  br label %pn_loop")
    emit("args_loop:")
    emit("  %alp = load i8*, i8** %cur")
    emit("  %alc = load i8, i8* %alp")
    emit("  %al_sp = icmp eq i8 %alc, 32")
    emit("  %al_tab = icmp eq i8 %alc, 9")
    emit("  %al_ws = or i1 %al_sp, %al_tab")
    emit("  br i1 %al_ws, label %al_adv, label %al_check")
    emit("al_adv:")
    emit("  %aln = getelementptr i8, i8* %alp, i64 1")
    emit("  store i8* %aln, i8** %cur")
    emit("  br label %args_loop")
    emit("al_check:")
    emit("  %acp = load i8*, i8** %cur")
    emit("  %acc = load i8, i8* %acp")
    emit("  %ac_end = icmp eq i8 %acc, 0")
    emit("  br i1 %ac_end, label %ga_done, label %arg_start")
    emit("arg_start:")
    emit("  %asq = icmp eq i8 %acc, 34")
    emit("  br i1 %asq, label %tq_init, label %tb_loop")
    emit("tq_init:")
    emit("  %tqs = getelementptr i8, i8* %acp, i64 1")
    emit("  store i8* %tqs, i8** %cur")
    emit("  br label %tq_loop")
    emit("tq_loop:")
    emit("  %tqp = load i8*, i8** %cur")
    emit("  %tqc = load i8, i8* %tqp")
    emit("  %tq_end = icmp eq i8 %tqc, 0")
    emit("  %tq_q = icmp eq i8 %tqc, 34")
    emit("  %tq_stop = or i1 %tq_end, %tq_q")
    emit("  br i1 %tq_stop, label %tq_done2, label %tq_adv")
    emit("tq_adv:")
    emit("  %tqn = getelementptr i8, i8* %tqp, i64 1")
    emit("  store i8* %tqn, i8** %cur")
    emit("  br label %tq_loop")
    emit("tq_done2:")
    emit("  %tq_endp = load i8*, i8** %cur")
    emit("  call void @dnh_args_push(%DnhList* %lst, i8* %tqs, i8* %tq_endp)")
    emit("  %tqdc = load i8, i8* %tq_endp")
    emit("  %tqd_q = icmp eq i8 %tqdc, 34")
    emit("  br i1 %tqd_q, label %tqd_skip, label %args_loop")
    emit("tqd_skip:")
    emit("  %tqdn = getelementptr i8, i8* %tq_endp, i64 1")
    emit("  store i8* %tqdn, i8** %cur")
    emit("  br label %args_loop")
    emit("tb_loop:")
    emit("  %tbp = load i8*, i8** %cur")
    emit("  %tbc = load i8, i8* %tbp")
    emit("  %tb_end = icmp eq i8 %tbc, 0")
    emit("  %tb_sp = icmp eq i8 %tbc, 32")
    emit("  %tb_tab = icmp eq i8 %tbc, 9")
    emit("  %tb_stop0 = or i1 %tb_end, %tb_sp")
    emit("  %tb_stop = or i1 %tb_stop0, %tb_tab")
    emit("  br i1 %tb_stop, label %tb_done, label %tb_adv")
    emit("tb_adv:")
    emit("  %tbn = getelementptr i8, i8* %tbp, i64 1")
    emit("  store i8* %tbn, i8** %cur")
    emit("  br label %tb_loop")
    emit("tb_done:")
    emit("  %tb_endp = load i8*, i8** %cur")
    emit("  call void @dnh_args_push(%DnhList* %lst, i8* %acp, i8* %tb_endp)")
    emit("  br label %args_loop")
    emit("ga_done:")
    emit("  ret %DnhList* %lst")
    emit("\}")
    emit("")
}

// Linux x86_64 raw-syscall 런타임 — libc 없이 syscall 인라인 asm만 사용.
// emit_direct_os_rt(KERNEL32)와 같은 심볼 표면을 제공한다.
// 호출 규약: rax=번호, rdi/rsi/rdx/r10/r8/r9=인자, rcx/r11은 커널이 파괴.
fn emit_direct_linux_rt() {
    emit("@.rt_nl = private unnamed_addr constant [2 x i8] c\"\\0A\\00\", align 1")
    emit("@.rt_i64_buf = internal global [32 x i8] zeroinitializer, align 1")
    emit("@.rt_sh = private unnamed_addr constant [8 x i8] c\"/bin/sh\\00\", align 1")
    emit("@.rt_shc = private unnamed_addr constant [3 x i8] c\"-c\\00\", align 1")
    emit("@.rt_cmdline = private unnamed_addr constant [19 x i8] c\"/proc/self/cmdline\\00\", align 1")
    emit("")
    // syscall 헬퍼 — 3인자/6인자
    emit("define i64 @dnh_sys3(i64 %nr, i64 %a, i64 %b, i64 %c) \{")
    emit("entry:")
    emit("  %r = call i64 asm sideeffect \"syscall\", \"=\{rax\},\{rax\},\{rdi\},\{rsi\},\{rdx\},~\{rcx\},~\{r11\},~\{memory\}\"(i64 %nr, i64 %a, i64 %b, i64 %c)")
    emit("  ret i64 %r")
