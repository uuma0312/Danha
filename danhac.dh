            vn3 = vec_ty_n(vtyl)
            acc3 = ""
            li3 = 0
            while li3 < vn3 {
                ev3 = new_reg()
                emit("  " + ev3 + " = extractelement " + vtyl + " " + arg_rs[0] + ", i32 " + to_string(li3))
                sq3 = new_reg()
                emit("  " + sq3 + " = fmul double " + ev3 + ", " + ev3)
                if li3 == 0 { acc3 = sq3 }
                else {
                    na3 = new_reg()
                    emit("  " + na3 + " = fadd double " + acc3 + ", " + sq3)
                    acc3 = na3
                }
                li3 = li3 + 1
            }
            r3 = new_reg()
            emit("  " + r3 + " = call double @llvm.sqrt.f64(double " + acc3 + ")")
            g_expr_reg = r3; g_expr_ty = "double"; return
        }
        if fname_c == "normalize" and nargs == 1 and is_vec_ty(arg0t) {
            vtyn = arg_ts[0]
            vn4 = vec_ty_n(vtyn)
            acc4 = ""
            ni4 = 0
            while ni4 < vn4 {
                ev4 = new_reg()
                emit("  " + ev4 + " = extractelement " + vtyn + " " + arg_rs[0] + ", i32 " + to_string(ni4))
                sq4 = new_reg()
                emit("  " + sq4 + " = fmul double " + ev4 + ", " + ev4)
                if ni4 == 0 { acc4 = sq4 }
                else {
                    na4 = new_reg()
                    emit("  " + na4 + " = fadd double " + acc4 + ", " + sq4)
                    acc4 = na4
                }
                ni4 = ni4 + 1
            }
            ln4 = new_reg()
            emit("  " + ln4 + " = call double @llvm.sqrt.f64(double " + acc4 + ")")
            sp4 = vec_splat(ln4, "double", vtyn)
            nr4 = new_reg()
            emit("  " + nr4 + " = fdiv reassoc nsz contract arcp " + vtyn + " " + arg_rs[0] + ", " + sp4)
            g_expr_reg = nr4; g_expr_ty = vtyn; return
        }
        if fname_c == "cross" and nargs == 2 and arg0t == "<3 x double>" and arg1t == "<3 x double>" {
            ax = new_reg(); ay = new_reg(); az = new_reg()
            bx = new_reg(); by = new_reg(); bz = new_reg()
            emit("  " + ax + " = extractelement <3 x double> " + arg_rs[0] + ", i32 0")
            emit("  " + ay + " = extractelement <3 x double> " + arg_rs[0] + ", i32 1")
            emit("  " + az + " = extractelement <3 x double> " + arg_rs[0] + ", i32 2")
            emit("  " + bx + " = extractelement <3 x double> " + arg_rs[1] + ", i32 0")
            emit("  " + by + " = extractelement <3 x double> " + arg_rs[1] + ", i32 1")
            emit("  " + bz + " = extractelement <3 x double> " + arg_rs[1] + ", i32 2")
            t0 = new_reg(); t1 = new_reg(); cx = new_reg()
            emit("  " + t0 + " = fmul double " + ay + ", " + bz)
            emit("  " + t1 + " = fmul double " + az + ", " + by)
