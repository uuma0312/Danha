    emit("  br label %arg_loop")
    emit("arg_loop:")
    emit("  %pos = phi i64 [%p0, %args_start], [%posn, %arg_push]")
    emit("  %in = icmp slt i64 %pos, %tot")
    emit("  br i1 %in, label %scan, label %ga_done")
    emit("scan:")
    emit("  %e0 = phi i64 [%pos, %arg_loop], [%e1, %scan_cont]")
    emit("  %ein = icmp slt i64 %e0, %tot")
    emit("  br i1 %ein, label %scan_chk, label %arg_push")
    emit("scan_chk:")
    emit("  %ep = getelementptr i8, i8* %buf, i64 %e0")
    emit("  %ec = load i8, i8* %ep")
    emit("  %enul = icmp eq i8 %ec, 0")
    emit("  br i1 %enul, label %arg_push, label %scan_cont")
    emit("scan_cont:")
    emit("  %e1 = add i64 %e0, 1")
    emit("  br label %scan")
    emit("arg_push:")
    emit("  %aend = phi i64 [%e0, %scan], [%e0, %scan_chk]")
    emit("  %sp2 = getelementptr i8, i8* %buf, i64 %pos")
    emit("  %ep2 = getelementptr i8, i8* %buf, i64 %aend")
    emit("  call void @dnh_args_push(%DnhList* %lst, i8* %sp2, i8* %ep2)")
    emit("  %posn = add i64 %aend, 1")
    emit("  br label %arg_loop")
    emit("ga_done:")
    emit("  ret %DnhList* %lst")
    emit("\}")
    emit("")
    // ELF 엔트리 — 커널이 직접 점프하므로 스택 재정렬 필요 (stackrealign)
    emit("define void @_start() #0 \{")
    emit("entry:")
    emit("  %r = call i32 @main()")
    emit("  %r64 = sext i32 %r to i64")
    emit("  %x = call i64 @dnh_sys3(i64 231, i64 %r64, i64 0, i64 0)")
    emit("  unreachable")
    emit("\}")
    emit("")
    emit("attributes #0 = \{ \"stackrealign\" \}")
    emit("")
}

// p1*q1 - p2*q2 (2x2 소행렬식)
fn m4det2(nm: str, p1: str, q1: str, p2: str, q2: str) {
    emit("  " + nm + "a = fmul double " + p1 + ", " + q1)
    emit("  " + nm + "b = fmul double " + p2 + ", " + q2)
    emit("  " + nm + " = fsub double " + nm + "a, " + nm + "b")
}

// p1*q1 (s2) p2*q2 (s3) p3*q3 — 수반행렬 원소
fn m4adj(nm: str, p1: str, q1: str, s2: str, p2: str, q2: str, s3: str, p3: str, q3: str) {
    emit("  " + nm + "a = fmul double " + p1 + ", " + q1)
    emit("  " + nm + "b = fmul double " + p2 + ", " + q2)
    op2 = "fadd"
    if s2 == "-" { op2 = "fsub" }
    emit("  " + nm + "c = " + op2 + " double " + nm + "a, " + nm + "b")
    emit("  " + nm + "d = fmul double " + p3 + ", " + q3)
    op3 = "fadd"
    if s3 == "-" { op3 = "fsub" }
    emit("  " + nm + " = " + op3 + " double " + nm + "c, " + nm + "d")
}

// mat4 런타임 — internal이라 미사용이면 -O2가 제거. 열-우선(OpenGL) 레이아웃, py와 동일
fn emit_mat4_rt() {
    m4 = m4ty()
    idc = "[<4 x double> <double 1.0, double 0.0, double 0.0, double 0.0>, <4 x double> <double 0.0, double 1.0, double 0.0, double 0.0>, <4 x double> <double 0.0, double 0.0, double 1.0, double 0.0>, <4 x double> <double 0.0, double 0.0, double 0.0, double 1.0>]"
    emit("define internal " + m4 + " @dnh_m4_ident() \{")
    emit("entry:")
    emit("  ret " + m4 + " " + idc)
    emit("\}")
    emit("define internal " + m4 + " @dnh_m4_translate(double %x, double %y, double %z) \{")
    emit("entry:")
    emit("  %c0 = insertelement <4 x double> undef, double %x, i32 0")
    emit("  %c1 = insertelement <4 x double> %c0, double %y, i32 1")
    emit("  %c2 = insertelement <4 x double> %c1, double %z, i32 2")
    emit("  %c3 = insertelement <4 x double> %c2, double 1.0, i32 3")
    emit("  %m = insertvalue " + m4 + " " + idc + ", <4 x double> %c3, 3")
    emit("  ret " + m4 + " %m")
    emit("\}")
    emit("define internal " + m4 + " @dnh_m4_scale(double %x, double %y, double %z) \{")
    emit("entry:")
    emit("  %c0 = insertelement <4 x double> zeroinitializer, double %x, i32 0")
    emit("  %c1 = insertelement <4 x double> zeroinitializer, double %y, i32 1")
    emit("  %c2 = insertelement <4 x double> zeroinitializer, double %z, i32 2")
    emit("  %m0 = insertvalue " + m4 + " " + idc + ", <4 x double> %c0, 0")
    emit("  %m1 = insertvalue " + m4 + " %m0, <4 x double> %c1, 1")
    emit("  %m2 = insertvalue " + m4 + " %m1, <4 x double> %c2, 2")
    emit("  ret " + m4 + " %m2")
    emit("\}")
    // rotate_x: col1=<0,c,s,0>, col2=<0,-s,c,0>
    emit("define internal " + m4 + " @dnh_m4_rx(double %a) \{")
    emit("entry:")
    emit("  %c = call double @cos(double %a)")
    emit("  %s = call double @sin(double %a)")
    emit("  %ns = fneg double %s")
    emit("  %c1a = insertelement <4 x double> zeroinitializer, double %c, i32 1")
    emit("  %c1b = insertelement <4 x double> %c1a, double %s, i32 2")
    emit("  %c2a = insertelement <4 x double> zeroinitializer, double %ns, i32 1")
    emit("  %c2b = insertelement <4 x double> %c2a, double %c, i32 2")
    emit("  %m1 = insertvalue " + m4 + " " + idc + ", <4 x double> %c1b, 1")
    emit("  %m2 = insertvalue " + m4 + " %m1, <4 x double> %c2b, 2")
    emit("  ret " + m4 + " %m2")
    emit("\}")
    // rotate_y: col0=<c,0,-s,0>, col2=<s,0,c,0>
    emit("define internal " + m4 + " @dnh_m4_ry(double %a) \{")
    emit("entry:")
    emit("  %c = call double @cos(double %a)")
    emit("  %s = call double @sin(double %a)")
    emit("  %ns = fneg double %s")
    emit("  %c0a = insertelement <4 x double> zeroinitializer, double %c, i32 0")
    emit("  %c0b = insertelement <4 x double> %c0a, double %ns, i32 2")
    emit("  %c2a = insertelement <4 x double> zeroinitializer, double %s, i32 0")
    emit("  %c2b = insertelement <4 x double> %c2a, double %c, i32 2")
    emit("  %m0 = insertvalue " + m4 + " " + idc + ", <4 x double> %c0b, 0")
    emit("  %m2 = insertvalue " + m4 + " %m0, <4 x double> %c2b, 2")
    emit("  ret " + m4 + " %m2")
    emit("\}")
    // rotate_z: col0=<c,s,0,0>, col1=<-s,c,0,0>
    emit("define internal " + m4 + " @dnh_m4_rz(double %a) \{")
    emit("entry:")
    emit("  %c = call double @cos(double %a)")
    emit("  %s = call double @sin(double %a)")
    emit("  %ns = fneg double %s")
    emit("  %c0a = insertelement <4 x double> zeroinitializer, double %c, i32 0")
    emit("  %c0b = insertelement <4 x double> %c0a, double %s, i32 1")
    emit("  %c1a = insertelement <4 x double> zeroinitializer, double %ns, i32 0")
    emit("  %c1b = insertelement <4 x double> %c1a, double %c, i32 1")
    emit("  %m0 = insertvalue " + m4 + " " + idc + ", <4 x double> %c0b, 0")
    emit("  %m1 = insertvalue " + m4 + " %m0, <4 x double> %c1b, 1")
    emit("  ret " + m4 + " %m1")
    emit("\}")
    // m * v: r = c0*splat(v.x) + c1*splat(v.y) + c2*splat(v.z) + c3*splat(v.w)
    emit("define internal <4 x double> @dnh_m4_vec(" + m4 + " %m, <4 x double> %v) \{")
    emit("entry:")
    c = 0
    while c < 4 {
        cs = to_string(c)
        emit("  %cc" + cs + " = extractvalue " + m4 + " %m, " + cs)
        emit("  %e" + cs + " = extractelement <4 x double> %v, i32 " + cs)
        emit("  %t" + cs + " = insertelement <4 x double> undef, double %e" + cs + ", i32 0")
        emit("  %sp" + cs + " = shufflevector <4 x double> %t" + cs + ", <4 x double> undef, <4 x i32> zeroinitializer")
        emit("  %p" + cs + " = fmul <4 x double> %cc" + cs + ", %sp" + cs)
        c = c + 1
    }
    emit("  %a1 = fadd <4 x double> %p0, %p1")
    emit("  %a2 = fadd <4 x double> %a1, %p2")
    emit("  %a3 = fadd <4 x double> %a2, %p3")
    emit("  ret <4 x double> %a3")
    emit("\}")
    // m * m: 결과 col c = a * b.col[c]
    emit("define internal " + m4 + " @dnh_m4_mul(" + m4 + " %a, " + m4 + " %b) \{")
    emit("entry:")
    c = 0
    while c < 4 {
        cs = to_string(c)
        emit("  %bc" + cs + " = extractvalue " + m4 + " %b, " + cs)
        emit("  %rc" + cs + " = call <4 x double> @dnh_m4_vec(" + m4 + " %a, <4 x double> %bc" + cs + ")")
        base = "undef"
        if c > 0 { base = "%q" + to_string(c - 1) }
        emit("  %q" + cs + " = insertvalue " + m4 + " " + base + ", <4 x double> %rc" + cs + ", " + cs)
        c = c + 1
    }
    emit("  ret " + m4 + " %q3")
    emit("\}")
    // transpose: 결과 col r = (old[0][r], old[1][r], old[2][r], old[3][r])
    emit("define internal " + m4 + " @dnh_m4_transpose(" + m4 + " %m) \{")
    emit("entry:")
    c = 0
    while c < 4 {
        emit("  %cc" + to_string(c) + " = extractvalue " + m4 + " %m, " + to_string(c))
        c = c + 1
    }
    r = 0
    while r < 4 {
        c = 0
        while c < 4 {
            emit("  %e" + to_string(c) + "_" + to_string(r) + " = extractelement <4 x double> %cc" + to_string(c) + ", i32 " + to_string(r))
            c = c + 1
        }
        r = r + 1
    }
    r = 0
    while r < 4 {
        prev = "undef"
        c = 0
        while c < 4 {
            cur = "%t" + to_string(r) + "_" + to_string(c)
            emit("  " + cur + " = insertelement <4 x double> " + prev + ", double %e" + to_string(c) + "_" + to_string(r) + ", i32 " + to_string(c))
            prev = cur
            c = c + 1
        }
        base = "undef"
        if r > 0 { base = "%q" + to_string(r - 1) }
        emit("  %q" + to_string(r) + " = insertvalue " + m4 + " " + base + ", <4 x double> " + prev + ", " + to_string(r))
        r = r + 1
    }
    emit("  ret " + m4 + " %q3")
    emit("\}")
    // inverse: 여수인자(cofactor) 전개 — py mat4_inverse와 동일 공식
    emit("define internal " + m4 + " @dnh_m4_inverse(" + m4 + " %m) \{")
    emit("entry:")
    c = 0
    while c < 4 {
        emit("  %cc" + to_string(c) + " = extractvalue " + m4 + " %m, " + to_string(c))
        c = c + 1
    }
    r = 0
    while r < 4 {
        c = 0
        while c < 4 {
            emit("  %g" + to_string(r) + to_string(c) + " = extractelement <4 x double> %cc" + to_string(c) + ", i32 " + to_string(r))
            c = c + 1
        }
        r = r + 1
    }
    m4det2("%s0", "%g00", "%g11", "%g10", "%g01")
    m4det2("%s1", "%g00", "%g12", "%g10", "%g02")
    m4det2("%s2", "%g00", "%g13", "%g10", "%g03")
    m4det2("%s3", "%g01", "%g12", "%g11", "%g02")
    m4det2("%s4", "%g01", "%g13", "%g11", "%g03")
    m4det2("%s5", "%g02", "%g13", "%g12", "%g03")
    m4det2("%k5", "%g22", "%g33", "%g32", "%g23")
    m4det2("%k4", "%g21", "%g33", "%g31", "%g23")
    m4det2("%k3", "%g21", "%g32", "%g31", "%g22")
    m4det2("%k2", "%g20", "%g33", "%g30", "%g23")
    m4det2("%k1", "%g20", "%g32", "%g30", "%g22")
    m4det2("%k0", "%g20", "%g31", "%g30", "%g21")
    emit("  %d0 = fmul double %s0, %k5")
    emit("  %d1 = fmul double %s1, %k4")
    emit("  %d2 = fmul double %s2, %k3")
    emit("  %d3 = fmul double %s4, %k1")
    emit("  %d4 = fmul double %s3, %k2")
    emit("  %d5 = fmul double %s5, %k0")
    emit("  %d6 = fsub double %d0, %d1")
    emit("  %d7 = fadd double %d6, %d2")
    emit("  %d8 = fsub double %d7, %d3")
    emit("  %d9 = fadd double %d4, %d5")
    emit("  %det = fadd double %d8, %d9")
    emit("  %invd = fdiv double 1.0, %det")
    m4adj("%adj00", "%g11", "%k5", "+", "%g13", "%k3", "-", "%g12", "%k4")
    m4adj("%adj01", "%g02", "%k4", "-", "%g01", "%k5", "-", "%g03", "%k3")
    m4adj("%adj02", "%g31", "%s5", "+", "%g33", "%s3", "-", "%g32", "%s4")
    m4adj("%adj03", "%g22", "%s4", "-", "%g21", "%s5", "-", "%g23", "%s3")
    m4adj("%adj10", "%g12", "%k2", "-", "%g10", "%k5", "-", "%g13", "%k1")
    m4adj("%adj11", "%g00", "%k5", "+", "%g03", "%k1", "-", "%g02", "%k2")
    m4adj("%adj12", "%g32", "%s2", "-", "%g30", "%s5", "-", "%g33", "%s1")
    m4adj("%adj13", "%g20", "%s5", "+", "%g23", "%s1", "-", "%g22", "%s2")
    m4adj("%adj20", "%g10", "%k4", "+", "%g13", "%k0", "-", "%g11", "%k2")
    m4adj("%adj21", "%g01", "%k2", "-", "%g00", "%k4", "-", "%g03", "%k0")
    m4adj("%adj22", "%g30", "%s4", "+", "%g33", "%s0", "-", "%g31", "%s2")
    m4adj("%adj23", "%g21", "%s2", "-", "%g20", "%s4", "-", "%g23", "%s0")
    m4adj("%adj30", "%g11", "%k1", "-", "%g10", "%k3", "-", "%g12", "%k0")
    m4adj("%adj31", "%g00", "%k3", "+", "%g02", "%k0", "-", "%g01", "%k1")
    m4adj("%adj32", "%g31", "%s1", "-", "%g30", "%s3", "-", "%g32", "%s0")
    m4adj("%adj33", "%g20", "%s3", "+", "%g22", "%s0", "-", "%g21", "%s1")
    c = 0
    while c < 4 {
        prev = "undef"
        r = 0
        while r < 4 {
            sc = "%w" + to_string(c) + to_string(r)
            emit("  " + sc + " = fmul double %adj" + to_string(r) + to_string(c) + ", %invd")
            cur = "%n" + to_string(c) + to_string(r)
            emit("  " + cur + " = insertelement <4 x double> " + prev + ", double " + sc + ", i32 " + to_string(r))
            prev = cur
            r = r + 1
        }
        base = "undef"
        if c > 0 { base = "%mm" + to_string(c - 1) }
        emit("  %mm" + to_string(c) + " = insertvalue " + m4 + " " + base + ", <4 x double> " + prev + ", " + to_string(c))
        c = c + 1
    }
    emit("  ret " + m4 + " %mm3")
    emit("\}")
    emit("")
}

fn emit_rt() {
    emit("@.rt_fmt_lld = private unnamed_addr constant [5 x i8] c\"%lld\\00\", align 1")
    emit("@.rt_fmt_f   = private unnamed_addr constant [3 x i8] c\"%f\\00\", align 1")
    emit("@.rt_arena_overflow = private unnamed_addr constant [42 x i8] c\"danha arena: allocation exceeds capacity\\0A\\00\", align 1")
    emit("")
    emit("%DnhList = type \{ i64, i64, i64* \}")
    emit("%DnhEnum = type \{ i64, i64 \}")
    emit("%DnhArena = type \{ i8*, i64, i64 \}")
    emit("%DnhSB = type \{ i8*, i64, i64 \}")
    emit("%DnhHM = type \{ %DnhList*, %DnhList*, %DnhList* \}")
    emit("declare double @llvm.sqrt.f64(double)")
    emit("declare double @llvm.fabs.f64(double)")
    emit("declare double @llvm.floor.f64(double)")
    emit("declare double @llvm.ceil.f64(double)")
    emit("declare double @llvm.round.f64(double)")
    // libm 수학 함수 — direct 모드에선 선언만 (호출 시 링크 단계에서 거부됨)
    emit("declare double @sin(double)")
    emit("declare double @cos(double)")
    emit("declare double @tan(double)")
    emit("declare double @log(double)")
    emit("declare double @exp(double)")
    emit("declare double @pow(double, double)")
    emit("declare double @atan2(double, double)")
    emit("declare double @hypot(double, double)")
    // 리플렉션 영속화용 Ari 런타임 extern (사용 시에만 링크 필요)
    emit("declare i32 @ari_save_open(i8*)")
    emit("declare void @ari_save_int(i8*, i32)")
    emit("declare void @ari_save_float(i8*, double)")
    emit("declare void @ari_save_string(i8*, i8*)")
    emit("declare i32 @ari_save_close()")
    emit("declare i32 @ari_load_open(i8*)")
    emit("declare i32 @ari_load_int(i8*, i32)")
    emit("declare double @ari_load_float(i8*, double)")
    emit("declare void @ari_load_close()")
    emit("")
    emit_mat4_rt()
    if g_runtime_direct {
        if g_target_linux { emit_direct_linux_rt() }
        else { emit_direct_os_rt() }
    } else {
        emit("declare i8*  @malloc(i64)")
        emit("declare i8*  @realloc(i8*, i64)")
        emit("declare void @free(i8*)")
        emit("declare i32  @strlen(i8* noundef)")
        emit("declare i8*  @strcpy(i8* noundef, i8* noundef)")
        emit("declare i32  @snprintf(i8* noundef, i64, i8* noundef, ...)")
        emit("declare i32  @printf(i8* noundef, ...)")
        emit("declare i32  @puts(i8* noundef)")
        emit("declare i32  @strcmp(i8* noundef, i8* noundef)")
        emit("declare i32 @clock()")
        emit("define double @dnh_clock() \{")
        emit("entry:")
        emit("  %c = call i32 @clock()")
        emit("  %cf = sitofp i32 %c to double")
        emit("  %s = fdiv double %cf, 1000.0")
        emit("  ret double %s")
        emit("\}")
        emit("declare void @exit(i32)")
        emit("define void @dnh_exit(i32 %code) \{")
        emit("entry:")
        emit("  call void @exit(i32 %code)")
        emit("  ret void")
        emit("\}")
        emit("declare i8*  @fopen(i8* noundef, i8* noundef)")
        emit("declare i32  @fseek(i8* noundef, i32, i32)")
        emit("declare i32  @ftell(i8* noundef)")
        emit("declare i64  @fread(i8* noundef, i64, i64, i8* noundef)")
        emit("declare i64  @fwrite(i8* noundef, i64, i64, i8* noundef)")
        emit("declare i32  @fclose(i8* noundef)")
        emit("declare i32  @system(i8* noundef)")
        emit("")
        emit("@.rt_rb = private unnamed_addr constant [3 x i8] c\"rb\\00\"")
        emit("@.rt_wb = private unnamed_addr constant [3 x i8] c\"wb\\00\"")
        emit("@.rt_ab = private unnamed_addr constant [3 x i8] c\"ab\\00\"")
        emit("define i8* @dnh_file_read(i8* %path) \{")
        emit("entry:")
        emit("  %fr_f = call i8* @fopen(i8* %path, i8* getelementptr inbounds ([3 x i8], [3 x i8]* @.rt_rb, i32 0, i32 0))")
        emit("  %fr_null = icmp eq i8* %fr_f, null")
        emit("  br i1 %fr_null, label %fr_fail, label %fr_ok")
        emit("fr_fail:")
        emit("  %fr_e = call i8* @malloc(i64 1)")
        emit("  store i8 0, i8* %fr_e")
        emit("  ret i8* %fr_e")
        emit("fr_ok:")
        emit("  %fr_s1 = call i32 @fseek(i8* %fr_f, i32 0, i32 2)")
        emit("  %fr_sz = call i32 @ftell(i8* %fr_f)")
        emit("  %fr_s2 = call i32 @fseek(i8* %fr_f, i32 0, i32 0)")
        emit("  %fr_sz64 = sext i32 %fr_sz to i64")
        emit("  %fr_n1 = add i64 %fr_sz64, 1")
        emit("  %fr_buf = call i8* @malloc(i64 %fr_n1)")
        emit("  %fr_rd = call i64 @fread(i8* %fr_buf, i64 1, i64 %fr_sz64, i8* %fr_f)")
        emit("  %fr_end = getelementptr inbounds i8, i8* %fr_buf, i64 %fr_rd")
        emit("  store i8 0, i8* %fr_end")
        emit("  %fr_c = call i32 @fclose(i8* %fr_f)")
        emit("  ret i8* %fr_buf")
        emit("\}")
        emit("")
        emit("define void @dnh_file_write(i8* %path, i8* %text) \{")
        emit("entry:")
        emit("  %fw_f = call i8* @fopen(i8* %path, i8* getelementptr inbounds ([3 x i8], [3 x i8]* @.rt_wb, i32 0, i32 0))")
        emit("  %fw_null = icmp eq i8* %fw_f, null")
        emit("  br i1 %fw_null, label %fw_done, label %fw_ok")
        emit("fw_ok:")
        emit("  %fw_l32 = call i32 @strlen(i8* %text)")
        emit("  %fw_len = sext i32 %fw_l32 to i64")
        emit("  %fw_wr = call i64 @fwrite(i8* %text, i64 1, i64 %fw_len, i8* %fw_f)")
        emit("  %fw_c = call i32 @fclose(i8* %fw_f)")
        emit("  br label %fw_done")
        emit("fw_done:")
        emit("  ret void")
        emit("\}")
        emit("")
        emit("define void @dnh_file_append(i8* %path, i8* %text) \{")
        emit("entry:")
        emit("  %fa_f = call i8* @fopen(i8* %path, i8* getelementptr inbounds ([3 x i8], [3 x i8]* @.rt_ab, i32 0, i32 0))")
        emit("  %fa_null = icmp eq i8* %fa_f, null")
        emit("  br i1 %fa_null, label %fa_done, label %fa_ok")
        emit("fa_ok:")
        emit("  %fa_l32 = call i32 @strlen(i8* %text)")
        emit("  %fa_len = sext i32 %fa_l32 to i64")
        emit("  %fa_wr = call i64 @fwrite(i8* %text, i64 1, i64 %fa_len, i8* %fa_f)")
        emit("  %fa_c = call i32 @fclose(i8* %fa_f)")
        emit("  br label %fa_done")
        emit("fa_done:")
        emit("  ret void")
        emit("\}")
        emit("")
        emit("define i1 @dnh_file_exists(i8* %path) \{")
        emit("entry:")
        emit("  %fe_f = call i8* @fopen(i8* %path, i8* getelementptr inbounds ([3 x i8], [3 x i8]* @.rt_rb, i32 0, i32 0))")
        emit("  %fe_null = icmp eq i8* %fe_f, null")
        emit("  br i1 %fe_null, label %fe_no, label %fe_yes")
        emit("fe_yes:")
        emit("  %fe_c = call i32 @fclose(i8* %fe_f)")
        emit("  ret i1 1")
        emit("fe_no:")
        emit("  ret i1 0")
        emit("\}")
        emit("")
        emit("define i64 @dnh_os_exec(i8* %cmd) \{")
