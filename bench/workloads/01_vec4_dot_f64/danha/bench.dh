// vec4 dot product loop — runtime-varying b prevents constant folding
fn dot_sum(a: vec4, n: i32) -> f64 {
    acc = 0.0
    i = 0
    while i < n {
        x = i as f64
        b = vec4(x, x, x, x)
        acc = acc + dot(a, b)
        i = i + 1
    }
    return acc
}

a = vec4(1.0, 2.0, 3.0, 4.0)
print(dot_sum(a, 100000000))
