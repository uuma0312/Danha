// 10M iter with 4-way data-dependent branch — branch predictor stress
fn branchy(n: i32) -> i32 {
    acc = 0
    i = 0
    while i < n {
        x = i % 4
        if x == 0 { acc = acc + i }
        else if x == 1 { acc = acc + 2 * i }
        else if x == 2 { acc = acc - i }
        else { acc = acc + 3 }
        i = i + 1
    }
    return acc
}

print(branchy(10000000))
