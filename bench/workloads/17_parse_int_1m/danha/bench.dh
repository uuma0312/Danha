// 1M parse_int — pre-build 10K numeric strings, parse 100 times.

K = 10000
N_OUTER = 100

strs: [str] = []
i = 0
while i < K {
    push(strs, to_string(i))
    i = i + 1
}

acc = 0
outer = 0
while outer < N_OUTER {
    j = 0
    while j < K {
        acc = acc + parse_int(strs[j])
        j = j + 1
    }
    outer = outer + 1
}
print(acc)
